      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n  @import url('https://unpkg.com/lenis@1/dist/lenis.css');\n  @import url('https://cdn.jsdelivr.net/npm/locomotive-scroll@5/bundled/locomotive-scroll.css');\n\n  :root {\n    --sage: #7BA05B;\n    --snow: #FAFAF9;\n    --stone: #F5F5F4;\n    --pitch: #1C1917;\n  }\n\n  body {\n    background-color: var(--snow);\n    color: var(--pitch);\n    font-family: 'DM+Sans', sans-serif;\n    margin: 0;\n  }\n\n  .font-heading { font-family: 'Manrope', sans-serif; }\n\n  /* Locomotive Scroll Reveal Stagger */\n  [data-scroll] {\n    opacity: 0;\n    transform: translateY(30px);\n    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);\n  }\n\n  [data-scroll].is-inview {\n    opacity: 1;\n    transform: translateY(0);\n    transition-delay: calc(var(--i, 0) * 100ms);\n  }\n\n  .scrollbar-hide::-webkit-scrollbar { display: none; }\n  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }\n\n  /* Inset Track Shape */\n  .inset-track {\n    position: relative;\n    border: 1px solid rgba(28, 25, 23, 0.05);\n  }\n  .inset-track::before {\n    content: '';\n    position: absolute;\n    inset: 4px;\n    border: 1px solid rgba(28, 25, 23, 0.03);\n    border-radius: inherit;\n    pointer-events: none;\n  }\n\n  canvas#expenseChart {\n    width: 100% !important;\n    height: 300px !important;\n  }\n</style>\n\n<div id=\"scroll-container\" data-scroll-container class=\"min-h-screen flex\" data-kid=\"1\">\n  \n  <aside class=\"w-20 border-r border-[#1C1917]/5 flex flex-col items-center py-8 gap-10 bg-white/50 backdrop-blur-md sticky top-0 h-screen z-50 shrink-0\" data-kid=\"2\">\n    <div class=\"w-12 h-12 bg-[var(--sage)] rounded-2xl flex items-center justify-center text-white shadow-lg shadow-[#7BA05B]/20 cursor-pointer\" data-kid=\"3\">\n      <i class=\"ti ti-home-heart text-2xl\" data-kid=\"4\"></i>\n    </div>\n    <nav class=\"flex flex-col gap-6\" data-kid=\"5\">\n      <button class=\"w-12 h-12 rounded-xl flex items-center justify-center text-[var(--sage)] bg-[#7BA05B]/10 hover:bg-[#7BA05B]/20 transition-colors\" data-kid=\"6\">\n        <i class=\"ti ti-layout-dashboard text-2xl\" data-kid=\"7\"></i>\n      </button>\n      <button class=\"w-12 h-12 rounded-xl flex items-center justify-center text-[#1C1917]/40 hover:text-[var(--sage)] hover:bg-[#7BA05B]/10 transition-colors\" data-kid=\"8\">\n        <i class=\"ti ti-users text-2xl\" data-kid=\"9\"></i>\n      </button>\n      <button class=\"w-12 h-12 rounded-xl flex items-center justify-center text-[#1C1917]/40 hover:text-[var(--sage)] hover:bg-[#7BA05B]/10 transition-colors\" data-kid=\"10\">\n        <i class=\"ti ti-shopping-bag text-2xl\" data-kid=\"11\"></i>\n      </button>\n      <button class=\"w-12 h-12 rounded-xl flex items-center justify-center text-[#1C1917]/40 hover:text-[var(--sage)] hover:bg-[#7BA05B]/10 transition-colors\" data-kid=\"12\">\n        <i class=\"ti ti-credit-card text-2xl\" data-kid=\"13\"></i>\n      </button>\n      <button class=\"w-12 h-12 rounded-xl flex items-center justify-center text-[#1C1917]/40 hover:text-[var(--sage)] hover:bg-[#7BA05B]/10 transition-colors\" data-kid=\"14\">\n        <i class=\"ti ti-settings text-2xl\" data-kid=\"15\"></i>\n      </button>\n    </nav>\n    <div class=\"mt-auto\" data-kid=\"16\">\n      <img src=\"https://i.pravatar.cc/100?u=anjali\" class=\"w-12 h-12 rounded-2xl border-2 border-[var(--sage)] p-0.5\" alt=\"Profile\" decoding=\"async\" loading=\"lazy\" data-kid=\"17\">\n    </div>\n  </aside>\n\n  \n  <main class=\"flex-1 px-8 lg:px-16 py-10 overflow-x-clip\" data-kid=\"18\">\n    \n    \n    <section data-scroll style=\"--i: 0\" class=\"relative mb-12 rounded-[3rem] overflow-hidden min-h-[400px] flex flex-col justify-center p-12 text-white shadow-2xl shadow-[#1C1917]/10\" data-kid=\"19\">\n      <video class=\"absolute inset-0 w-full h-full object-cover scale-110\" src=\"https://videos.pexels.com/video-files/33198242/14148290_360_640_24fps.mp4\" poster=\"https://images.pexels.com/videos/33198242/pexels-photo-33198242.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" alt=\"Sunlight streaming through window\" data-kid=\"20\"></video>\n      <div class=\"absolute inset-0 bg-gradient-to-tr from-black/50 via-black/20 to-transparent\" data-kid=\"21\"></div>\n      \n      <div class=\"relative z-10\" data-kid=\"22\">\n        \n        <div class=\"inline-flex items-center gap-3 px-5 py-2.5 bg-white/10 backdrop-blur-2xl border border-white/20 rounded-full mb-8 shadow-xl\" data-kid=\"23\">\n          <i class=\"ti ti-cloud-rain text-[var(--sage)] text-xl animate-bounce\" data-kid=\"24\"></i>\n          <span class=\"text-base font-semibold tracking-wide\" data-kid=\"25\">28°C, Cloudy • New Delhi</span>\n        </div>\n        \n        <h1 class=\"text-6xl lg:text-8xl font-extrabold font-heading mb-6 tracking-tight leading-tight\" data-kid=\"26\">Good Morning,<br data-kid=\"27\">Anjali!</h1>\n        <p class=\"text-xl text-white/90 max-w-lg font-medium leading-relaxed\" data-kid=\"28\">Your home is at its optimal state. 3 family members are safely indoors.</p>\n      </div>\n\n      \n      <div class=\"absolute top-12 right-12 flex flex-col gap-4\" data-kid=\"29\">\n        <button class=\"w-14 h-14 bg-white/10 backdrop-blur-xl border border-white/20 rounded-2xl flex items-center justify-center text-white hover:bg-[var(--sage)] hover:border-[var(--sage)] transition-all duration-500 hover:scale-110 group cursor-pointer shadow-lg\" data-kid=\"30\">\n          <i class=\"ti ti-plus text-2xl group-hover:rotate-90 transition-transform\" data-kid=\"31\"></i>\n        </button>\n        <button class=\"w-14 h-14 bg-white/10 backdrop-blur-xl border border-white/20 rounded-2xl flex items-center justify-center text-white hover:bg-[var(--sage)] hover:border-[var(--sage)] transition-all duration-500 hover:scale-110 group cursor-pointer shadow-lg\" data-kid=\"32\">\n          <i class=\"ti ti-shopping-bag text-2xl\" data-kid=\"33\"></i>\n        </button>\n      </div>\n    </section>\n\n    \n    <section data-scroll style=\"--i: 1\" class=\"mb-12 bg-white rounded-[2.5rem] p-8 shadow-sm border border-[#1C1917]/5\" data-kid=\"34\">\n      <div class=\"flex items-center justify-between mb-8 px-2\" data-kid=\"35\">\n        <h3 class=\"text-2xl font-bold font-heading\" data-kid=\"36\">Family Hub</h3>\n        <button class=\"text-sm font-bold text-[var(--sage)] hover:underline\" data-kid=\"37\">View All Map</button>\n      </div>\n      <div class=\"flex flex-wrap gap-10 items-center justify-start px-2\" data-kid=\"38\">\n        \n        <div class=\"flex items-center gap-4 bg-[var(--stone)]/50 p-3 rounded-3xl border border-transparent hover:border-[var(--sage)]/20 transition-all cursor-pointer card-hover\" data-kid=\"39\">\n          <div class=\"relative\" data-kid=\"40\">\n            <div class=\"relative p-1 bg-white rounded-full border-[3px] border-[var(--sage)]\" data-kid=\"41\">\n               <img src=\"https://i.pravatar.cc/100?u=anjali\" class=\"w-14 h-14 rounded-full\" alt=\"Anjali\" decoding=\"async\" loading=\"lazy\" data-kid=\"42\">\n            </div>\n            <div class=\"absolute -bottom-1 -right-1 w-6 h-6 bg-[var(--sage)] border-2 border-white rounded-full flex items-center justify-center shadow-sm\" data-kid=\"43\">\n               <i class=\"ti ti-check text-[10px] text-white\" data-kid=\"44\"></i>\n            </div>\n          </div>\n          <div data-kid=\"45\">\n            <p class=\"font-bold text-lg leading-tight\" data-kid=\"46\">Anjali</p>\n            <p class=\"text-xs text-[var(--sage)] font-bold tracking-tight uppercase\" data-kid=\"47\">At Home</p>\n          </div>\n        </div>\n\n        \n        <div class=\"flex items-center gap-4 bg-[var(--stone)]/50 p-3 rounded-3xl border border-transparent hover:border-[var(--sage)]/20 transition-all cursor-pointer card-hover\" data-kid=\"48\">\n          <div class=\"relative\" data-kid=\"49\">\n            <div class=\"relative p-1 bg-white rounded-full border-[3px] border-[var(--sage)]\" data-kid=\"50\">\n               <img src=\"https://i.pravatar.cc/100?u=rohan\" class=\"w-14 h-14 rounded-full\" alt=\"Rohan\" decoding=\"async\" loading=\"lazy\" data-kid=\"51\">\n            </div>\n            <div class=\"absolute -bottom-1 -right-1 w-6 h-6 bg-[var(--sage)] border-2 border-white rounded-full flex items-center justify-center shadow-sm\" data-kid=\"52\">\n               <i class=\"ti ti-check text-[10px] text-white\" data-kid=\"53\"></i>\n            </div>\n          </div>\n          <div data-kid=\"54\">\n            <p class=\"font-bold text-lg leading-tight\" data-kid=\"55\">Rohan</p>\n            <p class=\"text-xs text-[var(--sage)] font-bold tracking-tight uppercase\" data-kid=\"56\">In Gym</p>\n          </div>\n        </div>\n\n        \n        <div class=\"flex items-center gap-4 bg-[var(--stone)]/50 p-3 rounded-3xl border border-transparent hover:border-[var(--sage)]/20 transition-all cursor-pointer opacity-70 hover:opacity-100 card-hover\" data-kid=\"57\">\n          <div class=\"relative\" data-kid=\"58\">\n            <div class=\"relative p-1 bg-white rounded-full border-[3px] border-gray-300\" data-kid=\"59\">\n               <img src=\"https://i.pravatar.cc/100?u=kavya\" class=\"w-14 h-14 rounded-full\" alt=\"Kavya\" decoding=\"async\" loading=\"lazy\" data-kid=\"60\">\n            </div>\n            <div class=\"absolute -bottom-1 -right-1 w-6 h-6 bg-gray-400 border-2 border-white rounded-full flex items-center justify-center shadow-sm\" data-kid=\"61\">\n               <i class=\"ti ti-map-pin text-[10px] text-white\" data-kid=\"62\"></i>\n            </div>\n          </div>\n          <div data-kid=\"63\">\n            <p class=\"font-bold text-lg leading-tight\" data-kid=\"64\">Kavya</p>\n            <p class=\"text-xs text-[#1C1917]/40 font-bold tracking-tight uppercase\" data-kid=\"65\">At School</p>\n          </div>\n        </div>\n\n        \n        <div class=\"flex items-center gap-4 bg-[var(--stone)]/50 p-3 rounded-3xl border border-transparent hover:border-[var(--sage)]/20 transition-all cursor-pointer card-hover\" data-kid=\"66\">\n          <div class=\"relative\" data-kid=\"67\">\n            <div class=\"relative p-1 bg-white rounded-full border-[3px] border-[var(--sage)]\" data-kid=\"68\">\n               <img src=\"https://i.pravatar.cc/100?u=aarav\" class=\"w-14 h-14 rounded-full\" alt=\"Aarav\" decoding=\"async\" loading=\"lazy\" data-kid=\"69\">\n            </div>\n            <div class=\"absolute -bottom-1 -right-1 w-6 h-6 bg-[var(--sage)] border-2 border-white rounded-full flex items-center justify-center shadow-sm\" data-kid=\"70\">\n               <i class=\"ti ti-check text-[10px] text-white\" data-kid=\"71\"></i>\n            </div>\n          </div>\n          <div data-kid=\"72\">\n            <p class=\"font-bold text-lg leading-tight\" data-kid=\"73\">Aarav</p>\n            <p class=\"text-xs text-[var(--sage)] font-bold tracking-tight uppercase\" data-kid=\"74\">At Home</p>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-8 mb-12\" data-kid=\"75\">\n      \n      <div data-scroll style=\"--i: 2\" class=\"lg:col-span-7 bg-white rounded-[3rem] p-10 shadow-sm border border-[#1C1917]/5 card-hover\" data-kid=\"76\">\n        <div class=\"flex items-center justify-between mb-10\" data-kid=\"77\">\n          <h3 class=\"text-2xl font-bold font-heading\" data-kid=\"78\">Today's Agenda</h3>\n          <span class=\"text-xs font-bold uppercase tracking-[0.2em] text-[var(--sage)] bg-[#7BA05B]/10 px-4 py-1.5 rounded-full\" data-kid=\"79\">4 Pending</span>\n        </div>\n        \n        <div class=\"space-y-6\" data-kid=\"80\">\n          <div class=\"flex items-center gap-5 p-5 rounded-[2rem] bg-[var(--sage)]/5 border border-[var(--sage)]/10 group cursor-pointer hover:bg-[var(--sage)]/10 transition-all duration-300\" data-kid=\"81\">\n            <div class=\"w-14 h-14 rounded-2xl bg-[var(--sage)] flex items-center justify-center text-white shrink-0 shadow-lg shadow-[#7BA05B]/20\" data-kid=\"82\">\n              <i class=\"ti ti-pill text-2xl\" data-kid=\"83\"></i>\n            </div>\n            <div class=\"flex-1\" data-kid=\"84\">\n              <h4 class=\"font-bold text-xl text-[var(--pitch)]\" data-kid=\"85\">Morning Vitamins</h4>\n              <p class=\"text-sm text-[var(--pitch)]/60\" data-kid=\"86\">Take with breakfast • 8:30 AM</p>\n            </div>\n            <button class=\"w-10 h-10 rounded-xl bg-white flex items-center justify-center text-[var(--sage)] shadow-sm border border-[var(--sage)]/10 hover:bg-[var(--sage)] hover:text-white transition-colors\" data-kid=\"87\">\n              <i class=\"ti ti-check\" data-kid=\"88\"></i>\n            </button>\n          </div>\n\n          <div class=\"flex items-center gap-5 p-5 rounded-[2rem] hover:bg-[var(--stone)] transition-all duration-300 border border-transparent hover:border-[#1C1917]/5 group cursor-pointer\" data-kid=\"89\">\n            <div class=\"w-14 h-14 rounded-2xl bg-blue-500/10 text-blue-500 flex items-center justify-center shrink-0\" data-kid=\"90\">\n              <i class=\"ti ti-school text-2xl\" data-kid=\"91\"></i>\n            </div>\n            <div class=\"flex-1\" data-kid=\"92\">\n              <h4 class=\"font-bold text-xl text-[var(--pitch)]\" data-kid=\"93\">Pick up kids</h4>\n              <p class=\"text-sm text-[var(--pitch)]/60\" data-kid=\"94\">Afternoon school run • 3:30 PM</p>\n            </div>\n            <i class=\"ti ti-chevron-right text-[#1C1917]/20 group-hover:translate-x-1 transition-transform\" data-kid=\"95\"></i>\n          </div>\n\n          <div class=\"flex items-center gap-5 p-5 rounded-[2rem] hover:bg-[var(--stone)] transition-all duration-300 border border-transparent hover:border-[#1C1917]/5 group cursor-pointer\" data-kid=\"96\">\n            <div class=\"w-14 h-14 rounded-2xl bg-orange-500/10 text-orange-500 flex items-center justify-center shrink-0\" data-kid=\"97\">\n              <i class=\"ti ti-tool text-2xl\" data-kid=\"98\"></i>\n            </div>\n            <div class=\"flex-1\" data-kid=\"99\">\n              <h4 class=\"font-bold text-xl text-[var(--pitch)]\" data-kid=\"100\">Plumber visit</h4>\n              <p class=\"text-sm text-[var(--pitch)]/60\" data-kid=\"101\">Kitchen sink repair • 11:00 AM</p>\n            </div>\n            <i class=\"ti ti-chevron-right text-[#1C1917]/20 group-hover:translate-x-1 transition-transform\" data-kid=\"102\"></i>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"lg:col-span-5 flex flex-col gap-8\" data-kid=\"103\">\n        \n        <div data-scroll style=\"--i: 3\" class=\"flex-1 bg-[var(--stone)] rounded-[3rem] p-10 flex flex-col card-hover border border-[#1C1917]/5 relative overflow-hidden\" data-kid=\"104\">\n          <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/gooey-molecule.svg\" class=\"absolute -right-8 -top-8 w-40 opacity-5 pointer-events-none\" style=\"filter: invert(53%) sepia(35%) saturate(543%) hue-rotate(50deg) brightness(92%) contrast(85%);\" data-kid=\"105\">\n          <div class=\"flex items-center justify-between mb-8 relative z-10\" data-kid=\"106\">\n            <h3 class=\"text-2xl font-bold font-heading\" data-kid=\"107\">Smart Grocery</h3>\n            <div class=\"w-10 h-10 bg-[var(--sage)]/10 rounded-full flex items-center justify-center text-[var(--sage)]\" data-kid=\"108\">\n              <i class=\"ti ti-shopping-bag text-xl\" data-kid=\"109\"></i>\n            </div>\n          </div>\n          <div class=\"flex gap-4 overflow-x-auto pb-4 scrollbar-hide relative z-10\" data-kid=\"110\">\n            <div class=\"min-w-[160px] bg-white p-5 rounded-[2rem] border border-[#1C1917]/5 shrink-0 shadow-sm inset-track\" data-kid=\"111\">\n              <p class=\"text-[10px] text-red-500 font-extrabold uppercase tracking-widest mb-3\" data-kid=\"112\">Critical</p>\n              <p class=\"font-bold text-[#1C1917] mb-2 text-lg\" data-kid=\"113\">Organic Milk</p>\n              <div class=\"w-full bg-[#1C1917]/5 h-2 rounded-full overflow-hidden\" data-kid=\"114\">\n                <div class=\"bg-red-400 h-full w-[15%]\" data-kid=\"115\"></div>\n              </div>\n            </div>\n            <div class=\"min-w-[160px] bg-white p-5 rounded-[2rem] border border-[#1C1917]/5 shrink-0 shadow-sm inset-track\" data-kid=\"116\">\n              <p class=\"text-[10px] text-orange-500 font-extrabold uppercase tracking-widest mb-3\" data-kid=\"117\">Running Low</p>\n              <p class=\"font-bold text-[#1C1917] mb-2 text-lg\" data-kid=\"118\">Avocados</p>\n              <div class=\"w-full bg-[#1C1917]/5 h-2 rounded-full overflow-hidden\" data-kid=\"119\">\n                <div class=\"bg-orange-400 h-full w-[35%]\" data-kid=\"120\"></div>\n              </div>\n            </div>\n            <div class=\"min-w-[160px] bg-white p-5 rounded-[2rem] border border-[#1C1917]/5 shrink-0 shadow-sm inset-track\" data-kid=\"121\">\n              <p class=\"text-[10px] text-[var(--sage)] font-extrabold uppercase tracking-widest mb-3\" data-kid=\"122\">Healthy</p>\n              <p class=\"font-bold text-[#1C1917] mb-2 text-lg\" data-kid=\"123\">Coffee</p>\n              <div class=\"w-full bg-[#1C1917]/5 h-2 rounded-full overflow-hidden\" data-kid=\"124\">\n                <div class=\"bg-[var(--sage)] h-full w-[80%]\" data-kid=\"125\"></div>\n              </div>\n            </div>\n          </div>\n          <button class=\"mt-4 w-full py-4 bg-white rounded-2xl font-bold text-[#1C1917]/80 hover:bg-[var(--sage)] hover:text-white transition-all duration-500 border border-[#1C1917]/5\" data-kid=\"126\">Open Pantry</button>\n        </div>\n\n        \n        <div data-scroll style=\"--i: 4\" class=\"bg-[var(--pitch)] text-white rounded-[3rem] p-10 card-hover relative overflow-hidden group\" data-kid=\"127\">\n          <div class=\"absolute inset-0 bg-gradient-to-br from-[var(--sage)]/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-1000\" data-kid=\"128\"></div>\n          <div class=\"flex items-center justify-between mb-8 relative z-10\" data-kid=\"129\">\n            <h3 class=\"text-2xl font-bold font-heading\" data-kid=\"130\">Upcoming Bills</h3>\n            <i class=\"ti ti-credit-card text-2xl text-[var(--sage)]\" data-kid=\"131\"></i>\n          </div>\n          <div class=\"space-y-6 relative z-10\" data-kid=\"132\">\n            <div class=\"flex items-center justify-between border-b border-white/10 pb-4\" data-kid=\"133\">\n              <div data-kid=\"134\">\n                <p class=\"font-bold text-lg text-white/90\" data-kid=\"135\">Electricity</p>\n                <p class=\"text-sm text-white/40\" data-kid=\"136\">Due in 3 days</p>\n              </div>\n              <p class=\"font-bold text-3xl font-heading text-[var(--sage)]\" data-counter=\"142.50\" data-kid=\"137\">$0.00</p>\n            </div>\n            <div class=\"flex items-center justify-between\" data-kid=\"138\">\n              <div data-kid=\"139\">\n                <p class=\"font-bold text-lg text-white/90\" data-kid=\"140\">Disney+ Sub</p>\n                <p class=\"text-sm text-white/40\" data-kid=\"141\">Auto-pay on Oct 15</p>\n              </div>\n              <p class=\"font-bold text-2xl font-heading text-white/70\" data-counter=\"12.99\" data-kid=\"142\">$0.00</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <section data-scroll style=\"--i: 5\" class=\"bg-white rounded-[3rem] p-10 shadow-sm border border-[#1C1917]/5 card-hover mb-12\" data-kid=\"143\">\n      <div class=\"flex flex-col lg:flex-row lg:items-center justify-between mb-10 gap-6\" data-kid=\"144\">\n         <div data-kid=\"145\">\n            <h3 class=\"text-2xl font-bold font-heading mb-1\" data-kid=\"146\">Monthly Analytics</h3>\n            <p class=\"text-[#1C1917]/50\" data-kid=\"147\">Household spending overview vs budget</p>\n         </div>\n         <div class=\"flex flex-wrap gap-8 bg-[var(--stone)]/50 p-6 rounded-[2rem] border border-[#1C1917]/5\" data-kid=\"148\">\n            <div class=\"flex flex-col\" data-kid=\"149\">\n               <span class=\"text-xs font-extrabold uppercase tracking-widest text-[#1C1917]/40 mb-1\" data-kid=\"150\">Total Spent</span>\n               <span class=\"text-2xl font-bold font-heading text-[var(--sage)]\" data-kid=\"151\">$2,840.00</span>\n            </div>\n            <div class=\"w-px h-10 bg-[#1C1917]/10\" data-kid=\"152\"></div>\n            <div class=\"flex flex-col\" data-kid=\"153\">\n               <span class=\"text-xs font-extrabold uppercase tracking-widest text-[#1C1917]/40 mb-1\" data-kid=\"154\">Budget</span>\n               <span class=\"text-2xl font-bold font-heading\" data-kid=\"155\">$3,200.00</span>\n            </div>\n            <div class=\"w-px h-10 bg-[#1C1917]/10\" data-kid=\"156\"></div>\n            <div class=\"flex flex-col\" data-kid=\"157\">\n               <span class=\"text-xs font-extrabold uppercase tracking-widest text-[#1C1917]/40 mb-1\" data-kid=\"158\">Saved</span>\n               <span class=\"text-2xl font-bold font-heading text-blue-500\" data-kid=\"159\">$360.00</span>\n            </div>\n         </div>\n      </div>\n      <div class=\"relative h-[300px] w-full\" data-kid=\"160\">\n        <canvas id=\"expenseChart\" data-kid=\"161\"></canvas>\n      </div>\n    </section>\n\n    \n    <footer data-scroll style=\"--i: 6\" class=\"mt-20 py-12 border-t border-[#1C1917]/5 flex flex-col lg:flex-row items-center justify-between gap-8 text-[#1C1917]/40\" data-kid=\"162\">\n      <div class=\"flex items-center gap-2\" data-kid=\"163\">\n        <div class=\"w-8 h-8 bg-[var(--sage)]/10 rounded-lg flex items-center justify-center text-[var(--sage)]\" data-kid=\"164\">\n          <i class=\"ti ti-home-heart\" data-kid=\"165\"></i>\n        </div>\n        <span class=\"font-bold text-[var(--pitch)] opacity-100\" data-kid=\"166\">HomeHero AI</span>\n        <span data-kid=\"167\">•</span>\n        <span data-kid=\"168\">Nordic Breeze v1.2</span>\n      </div>\n      <div class=\"flex gap-8 font-medium\" data-kid=\"169\">\n        <a href=\"#\" class=\"hover:text-[var(--sage)] transition-colors\" data-kid=\"170\">Support</a>\n        <a href=\"#\" class=\"hover:text-[var(--sage)] transition-colors\" data-kid=\"171\">Family Controls</a>\n        <a href=\"#\" class=\"hover:text-[var(--sage)] transition-colors\" data-kid=\"172\">Privacy</a>\n      </div>\n      <div class=\"flex gap-4\" data-kid=\"173\">\n        <button class=\"w-10 h-10 rounded-full border border-[#1C1917]/10 flex items-center justify-center hover:bg-[#1C1917] hover:text-white transition-all\" data-kid=\"174\">\n          <i class=\"ti ti-brand-apple\" data-kid=\"175\"></i>\n        </button>\n        <button class=\"w-10 h-10 rounded-full border border-[#1C1917]/10 flex items-center justify-center hover:bg-[#1C1917] hover:text-white transition-all\" data-kid=\"176\">\n          <i class=\"ti ti-brand-google-play\" data-kid=\"177\"></i>\n        </button>\n      </div>\n    </footer>\n\n  </main>\n</div>\n\n\n<div class=\"fixed bottom-8 right-8 z-[100] flex flex-col gap-4\" data-kid=\"178\">\n  <div id=\"fab-menu\" class=\"hidden flex flex-col gap-4 mb-4\" data-kid=\"179\">\n    <button class=\"w-12 h-12 bg-white rounded-full flex items-center justify-center text-[#1C1917] shadow-xl border border-[#1C1917]/5 hover:bg-[var(--sage)] hover:text-white transition-all\" data-kid=\"180\">\n      <i class=\"ti ti-shopping-cart text-xl\" data-kid=\"181\"></i>\n    </button>\n    <button class=\"w-12 h-12 bg-white rounded-full flex items-center justify-center text-[#1C1917] shadow-xl border border-[#1C1917]/5 hover:bg-[var(--sage)] hover:text-white transition-all\" data-kid=\"182\">\n      <i class=\"ti ti-plus text-xl\" data-kid=\"183\"></i>\n    </button>\n    <button class=\"w-12 h-12 bg-red-500 rounded-full flex items-center justify-center text-white shadow-xl hover:bg-red-600 transition-all\" data-kid=\"184\">\n      <i class=\"ti ti-alert-triangle text-xl\" data-kid=\"185\"></i>\n    </button>\n  </div>\n  <button id=\"main-fab\" class=\"w-16 h-16 bg-[var(--sage)] rounded-full flex items-center justify-center text-white shadow-2xl shadow-[#7BA05B]/40 hover:scale-110 active:scale-95 transition-all duration-300\" data-kid=\"186\">\n    <i class=\"ti ti-plus text-3xl\" data-kid=\"187\"></i>\n  </button>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"188\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"189\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/chart.js\" data-kid=\"190\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/locomotive-scroll@5/bundled/locomotive-scroll.min.js\" data-kid=\"191\"></script>\n<script type=\"module\" data-kid=\"192\">\n  import { animate, scroll, stagger, hover } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n  import { animate as animeAnimate } from 'https://esm.sh/animejs@4';\n\n  // Initialize Locomotive Scroll\n  const locomotiveScroll = new LocomotiveScroll({\n    el: document.querySelector('#scroll-container'),\n    smooth: true,\n    lerp: 0.05\n  });\n\n  // Motion Hover Lift for Cards\n  hover(\".card-hover\", (el) => {\n    animate(el, { y: -12, scale: 1.01 }, { type: \"spring\", stiffness: 400, damping: 25 });\n    return () => animate(el, { y: 0, scale: 1 }, { type: \"spring\", stiffness: 300, damping: 30 });\n  });\n\n  // Chart Implementation\n  const ctx = document.getElementById('expenseChart').getContext('2d');\n  const gradient = ctx.createLinearGradient(0, 0, 0, 300);\n  gradient.addColorStop(0, 'rgba(123, 160, 91, 0.4)');\n  gradient.addColorStop(1, 'rgba(123, 160, 91, 0)');\n\n  new Chart(ctx, {\n    type: 'line',\n    data: {\n      labels: ['Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov'],\n      datasets: [\n        {\n          label: 'Spent',\n          data: [2100, 2400, 1950, 2800, 2300, 2840],\n          borderColor: '#7BA05B',\n          borderWidth: 4,\n          tension: 0.4,\n          fill: true,\n          backgroundColor: gradient,\n          pointBackgroundColor: '#fff',\n          pointBorderColor: '#7BA05B',\n          pointBorderWidth: 2,\n          pointRadius: 6,\n          pointHoverRadius: 8\n        },\n        {\n          label: 'Budget',\n          data: [3200, 3200, 3200, 3200, 3200, 3200],\n          borderColor: 'rgba(28, 25, 23, 0.1)',\n          borderWidth: 2,\n          borderDash: [10, 5],\n          tension: 0,\n          fill: false,\n          pointRadius: 0\n        }\n      ]\n    },\n    options: {\n      responsive: true,\n      maintainAspectRatio: false,\n      plugins: {\n        legend: { display: false },\n        tooltip: {\n          backgroundColor: '#1C1917',\n          padding: 12,\n          titleFont: { size: 14, family: 'Manrope' },\n          bodyFont: { size: 14, family: 'DM Sans' },\n          cornerRadius: 12,\n          displayColors: false\n        }\n      },\n      scales: {\n        y: {\n          beginAtZero: true,\n          grid: { color: 'rgba(28, 25, 23, 0.03)', drawBorder: false },\n          ticks: { color: 'rgba(28, 25, 23, 0.4)', font: { family: 'DM Sans' } }\n        },\n        x: {\n          grid: { display: false },\n          ticks: { color: 'rgba(28, 25, 23, 0.4)', font: { family: 'DM Sans' } }\n        }\n      }\n    }\n  });\n\n  // FAB Toggle\n  const mainFab = document.getElementById('main-fab');\n  const fabMenu = document.getElementById('fab-menu');\n  let menuOpen = false;\n\n  mainFab.addEventListener('click', () => {\n    menuOpen = !menuOpen;\n    if (menuOpen) {\n      fabMenu.classList.remove('hidden');\n      animate(fabMenu, { opacity: [0, 1], y: [20, 0], scale: [0.8, 1] }, { duration: 0.4, easing: \"ease-out\" });\n      animate(mainFab.querySelector('i'), { rotate: 45 }, { duration: 0.3 });\n    } else {\n      animate(fabMenu, { opacity: 0, y: 20, scale: 0.8 }, { duration: 0.3 }).finished.then(() => fabMenu.classList.add('hidden'));\n      animate(mainFab.querySelector('i'), { rotate: 0 }, { duration: 0.3 });\n    }\n  });\n\n  // Counter Animation for Bills\n  document.querySelectorAll('[data-counter]').forEach(el => {\n    const target = parseFloat(el.getAttribute('data-counter'));\n    const state = { value: 0 };\n    animeAnimate(state, {\n      value: target,\n      duration: 1500,\n      ease: 'out(3)',\n      onUpdate: () => {\n        el.textContent = '$' + state.value.toFixed(2);\n      }\n    });\n  });\n\n</script>\n",
