-hover/grocery:text-[#00FFBF]/50 text-sm\" data-kid=\"147\"></i>\n                            </button>\n                            <div data-kid=\"148\">\n                                <p class=\"text-sm font-bold\" data-kid=\"149\">Organic Whole Milk (2L)</p>\n                                <p class=\"text-[10px] text-white/30 uppercase tracking-widest font-bold\" data-kid=\"150\">Dairy • Essential</p>\n                            </div>\n                        </div>\n                        <span class=\"text-xs font-bold text-white/20\" data-kid=\"151\">£2.40</span>\n                    </div>\n\n                    <div class=\"flex items-center justify-between p-5 rounded-2xl hover:bg-white/5 transition-all group/grocery border-b border-white/5\" data-kid=\"152\">\n                        <div class=\"flex items-center gap-5\" data-kid=\"153\">\n                            <button class=\"w-6 h-6 rounded-lg border-2 border-white/20 flex items-center justify-center group-hover/grocery:border-[#00FFBF] transition-colors\" data-kid=\"154\">\n                                <i class=\"ti ti-check text-transparent group-hover/grocery:text-[#00FFBF]/50 text-sm\" data-kid=\"155\"></i>\n                            </button>\n                            <div data-kid=\"156\">\n                                <p class=\"text-sm font-bold\" data-kid=\"157\">Hass Avocados</p>\n                                <p class=\"text-[10px] text-white/30 uppercase tracking-widest font-bold\" data-kid=\"158\">Produce • Low Stock</p>\n                            </div>\n                        </div>\n                        <span class=\"text-xs font-bold text-white/20\" data-kid=\"159\">£3.50</span>\n                    </div>\n\n                    <div class=\"flex items-center justify-between p-5 rounded-2xl hover:bg-white/5 transition-all group/grocery border-b border-white/5\" data-kid=\"160\">\n                        <div class=\"flex items-center gap-5\" data-kid=\"161\">\n                            <button class=\"w-6 h-6 rounded-lg border-2 border-white/20 flex items-center justify-center group-hover/grocery:border-[#00FFBF] transition-colors\" data-kid=\"162\">\n                                <i class=\"ti ti-check text-transparent group-hover/grocery:text-[#00FFBF]/50 text-sm\" data-kid=\"163\"></i>\n                            </button>\n                            <div data-kid=\"164\">\n                                <p class=\"text-sm font-bold\" data-kid=\"165\">Greek Yogurt (500g)</p>\n                                <p class=\"text-[10px] text-white/30 uppercase tracking-widest font-bold\" data-kid=\"166\">Dairy • Frequent</p>\n                            </div>\n                        </div>\n                        <span class=\"text-xs font-bold text-white/20\" data-kid=\"167\">£1.80</span>\n                    </div>\n                </div>\n\n                <div class=\"mt-8 relative group\" data-kid=\"168\">\n                    <div class=\"absolute inset-y-0 left-5 flex items-center pointer-events-none text-white/30 group-focus-within:text-[#8A2BE2] transition-colors\" data-kid=\"169\">\n                        <i class=\"ti ti-plus text-xl\" data-kid=\"170\"></i>\n                    </div>\n                    <input type=\"text\" placeholder=\"Type to add or use voice...\" class=\"w-full bg-white/5 border border-white/10 rounded-2xl py-5 pl-14 pr-14 focus:outline-none focus:border-[#8A2BE2] focus:ring-1 focus:ring-[#8A2BE2]/50 transition-all font-medium text-sm\" data-kid=\"171\">\n                    <button class=\"absolute inset-y-0 right-4 flex items-center px-2 text-white/30 hover:text-[#00FFBF] transition-colors\" data-kid=\"172\">\n                        <i class=\"ti ti-microphone text-2xl\" data-kid=\"173\"></i>\n                    </button>\n                </div>\n            </div>\n        </section>\n    </main>\n\n    \n    <div class=\"fixed bottom-8 left-1/2 -translate-x-1/2 z-50\" data-kid=\"174\">\n        <div id=\"dock\" class=\"flex items-end gap-3 px-4 py-3 bg-[#1A1A1A]/40 backdrop-blur-3xl border border-white/10 rounded-[2.2rem] shadow-[0_20px_50px_rgba(0,0,0,0.5)]\" data-kid=\"175\">\n            <div class=\"dock-item relative group\" data-label=\"Home\" data-kid=\"176\">\n                <div class=\"w-14 h-14 bg-[#8A2BE2] rounded-2xl flex items-center justify-center text-white shadow-[0_0_20px_rgba(138,43,226,0.5)] cursor-pointer hover:scale-110 active:scale-95 transition-all\" data-kid=\"177\">\n                    <i class=\"ti ti-smart-home text-2xl\" data-kid=\"178\"></i>\n                </div>\n            </div>\n            <div class=\"dock-item relative group\" data-label=\"Security\" data-kid=\"179\">\n                <div class=\"w-14 h-14 bg-white/5 hover:bg-white/10 border border-white/10 rounded-2xl flex items-center justify-center text-white/70 hover:text-white cursor-pointer hover:scale-110 active:scale-95 transition-all\" data-kid=\"180\">\n                    <i class=\"ti ti-shield-lock text-2xl\" data-kid=\"181\"></i>\n                </div>\n            </div>\n            <div class=\"dock-item relative group\" data-label=\"Appliances\" data-kid=\"182\">\n                <div class=\"w-14 h-14 bg-white/5 hover:bg-white/10 border border-white/10 rounded-2xl flex items-center justify-center text-white/70 hover:text-white cursor-pointer hover:scale-110 active:scale-95 transition-all\" data-kid=\"183\">\n                    <i class=\"ti ti-refrigerator text-2xl\" data-kid=\"184\"></i>\n                </div>\n            </div>\n            <div class=\"w-px h-10 bg-white/10 mx-1 mb-2\" data-kid=\"185\"></div>\n            <div class=\"dock-item relative group\" data-label=\"Family\" data-kid=\"186\">\n                <div class=\"w-14 h-14 bg-white/5 hover:bg-white/10 border border-white/10 rounded-2xl flex items-center justify-center text-white/70 hover:text-white cursor-pointer hover:scale-110 active:scale-95 transition-all\" data-kid=\"187\">\n                    <i class=\"ti ti-users text-2xl\" data-kid=\"188\"></i>\n                </div>\n            </div>\n            <div class=\"dock-item relative group\" data-label=\"Settings\" data-kid=\"189\">\n                <div class=\"w-14 h-14 bg-white/5 hover:bg-white/10 border border-white/10 rounded-2xl flex items-center justify-center text-white/70 hover:text-white cursor-pointer hover:scale-110 active:scale-95 transition-all\" data-kid=\"190\">\n                    <i class=\"ti ti-adjustments-horizontal text-2xl\" data-kid=\"191\"></i>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    \n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"192\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/Draggable.min.js\" data-kid=\"193\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"194\"></script>\n    <script data-kid=\"195\">gsap.registerPlugin(ScrollTrigger);</script>\n    <script type=\"module\" data-kid=\"196\">\n        import { animate as animeAnimate } from 'https://esm.sh/animejs@4';\n        import { animate, hover } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\";\n\n        // Background Animation (GSAP)\n        gsap.to(\"#blob-1\", {\n            x: \"30%\",\n            y: \"20%\",\n            duration: 15,\n            repeat: -1,\n            yoyo: true,\n            ease: \"sine.inOut\"\n        });\n        gsap.to(\"#blob-2\", {\n            x: \"-20%\",\n            y: \"-10%\",\n            duration: 20,\n            repeat: -1,\n            yoyo: true,\n            ease: \"sine.inOut\"\n        });\n\n        // Medicine Progress Ring (Anime.js v4)\n        const circumference = 2 * Math.PI * 70;\n        const progressValue = 75; // 75%\n        \n        animeAnimate('#medicine-ring', {\n            strokeDashoffset: [circumference, circumference * (1 - progressValue / 100)],\n            duration: 2000,\n            ease: 'outExpo',\n            delay: 500\n        });\n\n        animeAnimate('#med-percent', {\n            innerHTML: [0, progressValue],\n            round: 1,\n            duration: 2000,\n            ease: 'outExpo',\n            delay: 500\n        });\n\n        // Hover Glow Effect (Motion JS)\n        document.querySelectorAll('.glass-card').forEach(card => {\n            const glowColor = card.dataset.glowColor || 'rgba(255, 255, 255, 0.1)';\n            hover(card, (el) => {\n                animate(el, { \n                    boxShadow: `0 0 40px ${glowColor}`,\n                    borderColor: 'rgba(255, 255, 255, 0.25)',\n                    y: -4\n                }, { duration: 0.4 });\n                return () => animate(el, { \n                    boxShadow: '0 0 0px transparent',\n                    borderColor: 'rgba(255, 255, 255, 0.1)',\n                    y: 0\n                }, { duration: 0.3 });\n            });\n        });\n\n        // Draggable Kanban (GSAP)\n        gsap.registerPlugin(Draggable);\n        \n        Draggable.create(\".kanban-item\", {\n            type: \"x,y\",\n            edgeResistance: 0.65,\n            bounds: \".kanban-container\",\n            inertia: true,\n            onPress: function() {\n                gsap.to(this.target, { scale: 1.05, boxShadow: \"0 20px 40px rgba(0,0,0,0.4)\", zIndex: 100 });\n            },\n            onRelease: function() {\n                gsap.to(this.target, { scale: 1, boxShadow: \"none\", zIndex: 1, x: 0, y: 0, duration: 0.5, ease: \"back.out(1.7)\" });\n            }\n        });\n\n        // Dock Interaction (Simple magnification feeling)\n        document.querySelectorAll('.dock-item').forEach(item => {\n            item.addEventListener('mouseenter', () => {\n                const prev = item.previousElementSibling;\n                const next = item.nextElementSibling;\n                if(prev && prev.classList.contains('dock-item')) gsap.to(prev, { scale: 1.15, duration: 0.2 });\n                if(next && next.classList.contains('dock-item')) gsap.to(next, { scale: 1.15, duration: 0.2 });\n            });\n            item.addEventListener('mouseleave', () => {\n                document.querySelectorAll('.dock-item').forEach(i => gsap.to(i, { scale: 1, duration: 0.2 }));\n            });\n        });\n    </script>\n\n    <style data-kid=\"197\">\n        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Sora:wght@600;700;800&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n        .glass-card {\n            background: rgba(26, 26, 26, 0.4);\n            backdrop-filter: blur(40px);\n            border: 1px solid rgba(255, 255, 255, 0.08); /* #hairline */\n            border-radius: 2.5rem;\n            position: relative;\n            /* No transition because we use GSAP/Motion on these elements */\n        }\n\n        .glass-highlight::after {\n            content: '';\n            position: absolute;\n            top: 0; left: 0; right: 0; height: 1px;\n            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);\n            pointer-events: none;\n        }\n\n        /* Custom Scrollbar for list */\n        .custom-scrollbar::-webkit-scrollbar {\n            width: 4px;\n        }\n        .custom-scrollbar::-webkit-scrollbar-track {\n            background: transparent;\n        }\n        .custom-scrollbar::-webkit-scrollbar-thumb {\n            background: rgba(255, 255, 255, 0.1);\n            border-radius: 20px;\n        }\n        .custom-scrollbar::-webkit-scrollbar-thumb:hover {\n            background: rgba(138, 43, 226, 0.5);\n        }\n\n        /* Active Kanban state indicator */\n        .kanban-col {\n            min-height: 200px;\n            background: rgba(255, 255, 255, 0.02);\n            border-radius: 1.5rem;\n            padding: 0.5rem;\n        }\n    </style>\n</div>\n",
