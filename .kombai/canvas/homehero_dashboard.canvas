      "html": "\n<div id=\"app\" class=\"min-h-screen bg-[#0A0A0A] text-white font-['Plus_Jakarta_Sans'] relative overflow-x-clip selection:bg-[#8A2BE2]/30\" data-kid=\"0\">\n    \n    <div class=\"fixed inset-0 pointer-events-none z-0\" data-kid=\"1\">\n        <div id=\"blob-1\" class=\"absolute top-[10%] left-[5%] w-[600px] h-[600px] bg-[#8A2BE2]/15 rounded-full blur-[140px]\" data-kid=\"2\"></div>\n        <div id=\"blob-2\" class=\"absolute bottom-[10%] right-[5%] w-[700px] h-[700px] bg-[#00FFBF]/10 rounded-full blur-[160px]\" data-kid=\"3\"></div>\n        <div id=\"blob-3\" class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] bg-[#8A2BE2]/5 rounded-full blur-[120px]\" data-kid=\"4\"></div>\n    </div>\n\n    \n    <main class=\"relative z-10 max-w-[1440px] mx-auto p-8 lg:p-12 pb-32 space-y-10\" data-kid=\"5\">\n        \n        \n        <section id=\"hero\" class=\"relative\" data-kid=\"6\">\n            <div class=\"glass-card glass-highlight p-10 lg:p-14 flex flex-col md:flex-row justify-between items-center gap-8 shadow-2xl overflow-hidden\" data-kid=\"7\">\n                <div class=\"flex flex-col gap-2 relative z-10\" data-kid=\"8\">\n                    <h1 class=\"text-4xl lg:text-7xl font-['Sora'] font-extrabold tracking-tighter leading-none\" data-kid=\"9\">\n                        Good Evening, <span class=\"bg-gradient-to-r from-[#8A2BE2] via-[#8A2BE2] to-[#00FFBF] bg-clip-text text-transparent drop-shadow-[0_0_15px_rgba(138,43,226,0.3)]\" data-kid=\"10\">Family</span>\n                    </h1>\n                    <p class=\"text-white/60 text-lg lg:text-2xl font-medium tracking-tight\" data-kid=\"11\">System Status: <span class=\"text-[#00FFBF]\" data-kid=\"12\">Optimal</span> • 8:45 PM</p>\n                </div>\n\n                <div class=\"flex items-center gap-6 bg-white/5 backdrop-blur-3xl p-6 rounded-3xl border border-white/10 relative z-10 shadow-lg\" data-kid=\"13\">\n                    <div class=\"w-14 h-14 rounded-2xl bg-[#00FFBF]/20 flex items-center justify-center\" data-kid=\"14\">\n                        <i class=\"ti ti-cloud-storm text-3xl text-[#00FFBF]\" data-kid=\"15\"></i>\n                    </div>\n                    <div data-kid=\"16\">\n                        <div class=\"flex items-baseline gap-1\" data-kid=\"17\">\n                            <span class=\"text-4xl font-bold font-['Sora']\" data-kid=\"18\">18°</span>\n                            <span class=\"text-white/40 font-bold\" data-kid=\"19\">C</span>\n                        </div>\n                        <p class=\"text-[10px] font-bold uppercase tracking-[0.2em] text-white/30\" data-kid=\"20\">Stormy • London</p>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        \n        <section class=\"grid grid-cols-12 gap-6 lg:gap-8\" data-kid=\"21\">\n            \n            <div class=\"col-span-12 lg:col-span-4 glass-card glass-highlight p-8\" data-glow-color=\"rgba(138, 43, 226, 0.3)\" data-kid=\"22\">\n                <div class=\"flex items-center justify-between mb-8\" data-kid=\"23\">\n                    <div class=\"flex items-center gap-3\" data-kid=\"24\">\n                        <div class=\"p-2 rounded-lg bg-[#8A2BE2]/20\" data-kid=\"25\">\n                            <i class=\"ti ti-pill text-[#8A2BE2] text-xl\" data-kid=\"26\"></i>\n                        </div>\n                        <h3 class=\"font-bold text-sm uppercase tracking-widest text-white/60\" data-kid=\"27\">Health Tracker</h3>\n                    </div>\n                    <span class=\"text-[10px] font-bold text-[#00FFBF] bg-[#00FFBF]/10 px-2 py-1 rounded\" data-kid=\"28\">ON TRACK</span>\n                </div>\n                \n                <div class=\"flex flex-col items-center justify-center py-6\" data-kid=\"29\">\n                    <div class=\"relative w-40 h-40\" data-kid=\"30\">\n                        <svg class=\"w-full h-full -rotate-90 drop-shadow-[0_0_15px_rgba(0,255,191,0.2)]\" data-kid=\"31\">\n                            <circle cx=\"80\" cy=\"80\" r=\"70\" stroke=\"currentColor\" stroke-width=\"10\" fill=\"transparent\" class=\"text-white/5\" data-kid=\"32\"></circle>\n                            <circle id=\"medicine-ring\" cx=\"80\" cy=\"80\" r=\"70\" stroke=\"#00FFBF\" stroke-width=\"10\" fill=\"transparent\" stroke-dasharray=\"439.8\" stroke-dashoffset=\"439.8\" stroke-linecap=\"round\" data-kid=\"33\"></circle>\n                        </svg>\n                        <div class=\"absolute inset-0 flex flex-col items-center justify-center\" data-kid=\"34\">\n                            <span id=\"med-percent\" class=\"text-4xl font-extrabold font-['Sora'] text-white\" data-kid=\"35\">0</span>\n                            <span class=\"text-[10px] font-bold text-white/40 uppercase\" data-kid=\"36\">Complete</span>\n                        </div>\n                    </div>\n                    <div class=\"mt-8 text-center\" data-kid=\"37\">\n                        <p class=\"text-lg font-bold\" data-kid=\"38\">3 of 4 doses</p>\n                        <p class=\"text-sm text-white/40\" data-kid=\"39\">Next: Multi-Vit at 10 PM</p>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"col-span-12 lg:col-span-4 glass-card glass-highlight p-8\" data-glow-color=\"rgba(0, 255, 191, 0.2)\" data-kid=\"40\">\n                <div class=\"flex items-center justify-between mb-8\" data-kid=\"41\">\n                    <div class=\"flex items-center gap-3\" data-kid=\"42\">\n                        <div class=\"p-2 rounded-lg bg-orange-500/20\" data-kid=\"43\">\n                            <i class=\"ti ti-receipt-2 text-orange-400 text-xl\" data-kid=\"44\"></i>\n                        </div>\n                        <h3 class=\"font-bold text-sm uppercase tracking-widest text-white/60\" data-kid=\"45\">Upcoming Bills</h3>\n                    </div>\n                    <i class=\"ti ti-alert-circle text-orange-400\" data-kid=\"46\"></i>\n                </div>\n\n                <div class=\"space-y-8 py-4\" data-kid=\"47\">\n                    <div class=\"relative\" data-kid=\"48\">\n                        <div class=\"flex justify-between items-end mb-4\" data-kid=\"49\">\n                            <div data-kid=\"50\">\n                                <h4 class=\"text-4xl font-extrabold font-['Sora'] text-orange-400\" data-kid=\"51\">2 <span class=\"text-xl\" data-kid=\"52\">Days</span></h4>\n                                <p class=\"text-sm text-white/40 font-medium\" data-kid=\"53\">Electricity Bill Due</p>\n                            </div>\n                            <div class=\"text-right\" data-kid=\"54\">\n                                <p class=\"text-2xl font-bold font-['Sora']\" data-kid=\"55\">£142.00</p>\n                                <p class=\"text-[10px] text-white/30 font-bold uppercase tracking-widest\" data-kid=\"56\">Oct 26, 2023</p>\n                            </div>\n                        </div>\n                        <div class=\"w-full h-3 bg-white/5 rounded-full overflow-hidden\" data-kid=\"57\">\n                            <div class=\"h-full bg-gradient-to-r from-orange-400 to-red-500 w-[85%] rounded-full shadow-[0_0_15px_rgba(251,146,60,0.4)]\" data-kid=\"58\"></div>\n                        </div>\n                    </div>\n\n                    <button class=\"w-full group/btn relative overflow-hidden bg-white/[0.03] hover:bg-white/[0.08] border border-white/10 rounded-2xl py-4 font-bold tracking-widest uppercase text-xs transition-all flex items-center justify-center gap-2\" data-kid=\"59\">\n                        <span class=\"relative z-10\" data-kid=\"60\">Initialize Quick Pay</span>\n                        <i class=\"ti ti-arrow-right relative z-10 group-hover/btn:translate-x-1 transition-transform\" data-kid=\"61\"></i>\n                    </button>\n                </div>\n            </div>\n\n            \n            <div class=\"col-span-12 lg:col-span-4 glass-card glass-highlight overflow-hidden p-0 min-h-[400px]\" data-kid=\"62\">\n                \n                <div class=\"absolute inset-0 bg-[#0A0A0A] overflow-hidden opacity-60\" data-kid=\"63\">\n                    <div class=\"absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_0%,#0A0A0A_80%)] z-10\" data-kid=\"64\"></div>\n                    <svg class=\"w-full h-full text-white/5 opacity-50\" viewBox=\"0 0 800 600\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" data-kid=\"65\">\n                        <path d=\"M0 50H800M0 150H800M0 250H800M0 350H800M0 450H800M100 0V600M200 0V600M300 0V600M400 0V600M500 0V600M600 0V600M700 0V600\" stroke=\"currentColor\" stroke-width=\"0.5\" data-kid=\"66\"></path>\n                        <circle cx=\"300\" cy=\"200\" r=\"150\" stroke=\"currentColor\" stroke-width=\"0.5\" stroke-dasharray=\"4 4\" data-kid=\"67\"></circle>\n                        <circle cx=\"300\" cy=\"200\" r=\"10\" fill=\"#8A2BE2\" fill-opacity=\"0.3\" data-kid=\"68\"></circle>\n                        <circle cx=\"300\" cy=\"200\" r=\"4\" fill=\"#8A2BE2\" data-kid=\"69\"></circle>\n                        <circle cx=\"500\" cy=\"400\" r=\"10\" fill=\"#00FFBF\" fill-opacity=\"0.3\" data-kid=\"70\"></circle>\n                        <circle cx=\"500\" cy=\"400\" r=\"4\" fill=\"#00FFBF\" data-kid=\"71\"></circle>\n                    </svg>\n                </div>\n                \n                <div class=\"relative h-full flex flex-col p-8\" data-kid=\"72\">\n                    <div class=\"flex items-center justify-between mb-auto\" data-kid=\"73\">\n                        <div class=\"flex items-center gap-3\" data-kid=\"74\">\n                            <div class=\"p-2 rounded-lg bg-[#00FFBF]/20\" data-kid=\"75\">\n                                <i class=\"ti ti-map-pin text-[#00FFBF] text-xl\" data-kid=\"76\"></i>\n                            </div>\n                            <h3 class=\"font-bold text-sm uppercase tracking-widest text-white/60\" data-kid=\"77\">Family Locations</h3>\n                        </div>\n                        <span class=\"flex items-center gap-2 px-3 py-1 bg-white/5 rounded-full border border-white/10 text-[10px] font-bold uppercase tracking-widest text-white/50\" data-kid=\"78\">\n                            <span class=\"w-1.5 h-1.5 rounded-full bg-[#00FFBF] animate-ping\" data-kid=\"79\"></span>\n                            Live Now\n                        </span>\n                    </div>\n\n                    <div class=\"flex flex-col gap-4\" data-kid=\"80\">\n                        <div class=\"flex items-center justify-between p-4 bg-white/5 backdrop-blur-md rounded-2xl border border-white/10 hover:border-[#8A2BE2]/50 transition-colors\" data-kid=\"81\">\n                            <div class=\"flex items-center gap-4\" data-kid=\"82\">\n                                <div class=\"relative\" data-kid=\"83\">\n                                    <div class=\"w-12 h-12 rounded-2xl bg-gradient-to-br from-[#8A2BE2] to-[#4B0082] p-0.5\" data-kid=\"84\">\n                                        <img src=\"https://i.pravatar.cc/100?u=jane\" class=\"w-full h-full rounded-[14px] object-cover\" data-kid=\"85\">\n                                    </div>\n                                    <div class=\"absolute -bottom-1 -right-1 w-4 h-4 bg-[#00FFBF] border-2 border-[#0A0A0A] rounded-full\" data-kid=\"86\"></div>\n                                </div>\n                                <div data-kid=\"87\">\n                                    <p class=\"font-bold text-sm\" data-kid=\"88\">Jane (Mom)</p>\n                                    <p class=\"text-[10px] text-white/40 font-medium\" data-kid=\"89\">High St. Coffee Shop • 0.8 mi</p>\n                                </div>\n                            </div>\n                            <i class=\"ti ti-chevron-right text-white/20\" data-kid=\"90\"></i>\n                        </div>\n                        <div class=\"flex items-center justify-between p-4 bg-white/5 backdrop-blur-md rounded-2xl border border-white/10 hover:border-[#00FFBF]/50 transition-colors\" data-kid=\"91\">\n                            <div class=\"flex items-center gap-4\" data-kid=\"92\">\n                                <div class=\"relative\" data-kid=\"93\">\n                                    <div class=\"w-12 h-12 rounded-2xl bg-gradient-to-br from-[#00FFBF] to-[#008B8B] p-0.5\" data-kid=\"94\">\n                                        <img src=\"https://i.pravatar.cc/100?u=mark\" class=\"w-full h-full rounded-[14px] object-cover\" data-kid=\"95\">\n                                    </div>\n                                    <div class=\"absolute -bottom-1 -right-1 w-4 h-4 bg-[#00FFBF] border-2 border-[#0A0A0A] rounded-full\" data-kid=\"96\"></div>\n                                </div>\n                                <div data-kid=\"97\">\n                                    <p class=\"font-bold text-sm\" data-kid=\"98\">Mark (Dad)</p>\n                                    <p class=\"text-[10px] text-white/40 font-medium\" data-kid=\"99\">Home • <span class=\"text-[#00FFBF]\" data-kid=\"100\">Safe Zone</span></p>\n                                </div>\n                            </div>\n                            <i class=\"ti ti-chevron-right text-white/20\" data-kid=\"101\"></i>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        \n        <section class=\"grid grid-cols-1 lg:grid-cols-2 gap-8\" data-kid=\"102\">\n            \n            <div class=\"glass-card glass-highlight p-10 flex flex-col min-h-[500px]\" data-kid=\"103\">\n                <div class=\"flex items-center justify-between mb-10\" data-kid=\"104\">\n                    <div data-kid=\"105\">\n                        <h2 class=\"text-3xl font-['Sora'] font-extrabold\" data-kid=\"106\">Family Chores</h2>\n                        <p class=\"text-sm text-white/40 mt-1\" data-kid=\"107\">Drag and drop tasks to update status</p>\n                    </div>\n                    <button class=\"w-12 h-12 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center hover:bg-[#8A2BE2] hover:text-white transition-all duration-300\" data-kid=\"108\">\n                        <i class=\"ti ti-plus text-xl\" data-kid=\"109\"></i>\n                    </button>\n                </div>\n\n                <div class=\"kanban-container grid grid-cols-2 gap-6 flex-grow\" data-kid=\"110\">\n                    \n                    <div class=\"kanban-col space-y-4\" data-status=\"todo\" data-kid=\"111\">\n                        <div class=\"flex items-center gap-2 mb-2\" data-kid=\"112\">\n                            <div class=\"w-2 h-2 rounded-full bg-[#8A2BE2]\" data-kid=\"113\"></div>\n                            <span class=\"text-[10px] font-bold uppercase tracking-[0.2em] text-white/40\" data-kid=\"114\">Open Tasks</span>\n                        </div>\n                        \n                        <div class=\"kanban-item p-5 bg-white/5 border border-white/10 rounded-2xl cursor-grab active:cursor-grabbing hover:bg-white/10 transition-all group/item\" data-id=\"1\" data-kid=\"115\">\n                            <p class=\"text-sm font-bold mb-3 group-hover/item:text-[#8A2BE2] transition-colors\" data-kid=\"116\">Water the rooftop garden</p>\n                            <div class=\"flex items-center justify-between\" data-kid=\"117\">\n                                <span class=\"text-[9px] font-bold bg-[#8A2BE2]/10 text-[#8A2BE2] px-2 py-0.5 rounded border border-[#8A2BE2]/20 uppercase\" data-kid=\"118\">Outdoor</span>\n                                <div class=\"flex -space-x-2\" data-kid=\"119\">\n      