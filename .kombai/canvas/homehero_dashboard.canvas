      },
      "html": "\n<div class=\"min-h-screen bg-[#FAF0E6] text-[#3D2B1F] font-['Public_Sans'] selection:bg-[#E44D2E]/20 overflow-x-clip\" data-kid=\"0\">\n    <link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"1\">\n    <style data-kid=\"2\">\n        @import url('https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,700;1,400&family=Public+Sans:wght@300;400;600&display=swap');\n\n        :root {\n            --color-linen: #FAF0E6;\n            --color-terracotta: #E44D2E;\n            --color-coffee: #3D2B1F;\n        }\n\n        .font-serif { font-family: 'Lora', serif; }\n        .font-sans { font-family: 'Public_Sans', sans-serif; }\n\n        .blob-shape {\n            border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;\n        }\n\n        .ticket-notch {\n            position: relative;\n        }\n        .ticket-notch::before, .ticket-notch::after {\n            content: '';\n            position: absolute;\n            top: 50%;\n            width: 24px;\n            height: 24px;\n            background: var(--color-linen);\n            border-radius: 50%;\n            z-index: 20;\n            transform: translateY(-50%);\n        }\n        .ticket-notch::before { left: -12px; }\n        .ticket-notch::after { right: -12px; }\n\n        /* Custom scrollbar for premium feel */\n        ::-webkit-scrollbar { width: 6px; }\n        ::-webkit-scrollbar-track { background: var(--color-linen); }\n        ::-webkit-scrollbar-thumb { background: #d1c6bc; border-radius: 10px; }\n        \n        /* Animation specific - ensuring no flashes */\n        .chart-reveal-container { overflow: hidden; }\n    </style>\n\n    \n    <nav class=\"flex justify-between items-center px-8 md:px-16 py-10 max-w-7xl mx-auto\" data-kid=\"3\">\n        <div class=\"flex items-center gap-3\" data-kid=\"4\">\n            <div class=\"w-10 h-10 bg-[#E44D2E] rounded-xl flex items-center justify-center transform -rotate-12 shadow-lg\" data-kid=\"5\">\n                <i class=\"ti ti-home-bolt text-white text-2xl\" data-kid=\"6\"></i>\n            </div>\n            <span class=\"font-serif text-2xl font-bold tracking-tight\" data-kid=\"7\">HomeHero<span class=\"text-[#E44D2E]\" data-kid=\"8\">.ai</span></span>\n        </div>\n        <div class=\"flex items-center gap-8\" data-kid=\"9\">\n            <div class=\"hidden md:flex items-center gap-6 text-sm font-semibold tracking-wide uppercase opacity-60\" data-kid=\"10\">\n                <a href=\"#\" class=\"hover:text-[#E44D2E] transition-colors\" data-kid=\"11\">Journal</a>\n                <a href=\"#\" class=\"hover:text-[#E44D2E] transition-colors\" data-kid=\"12\">Expenses</a>\n                <a href=\"#\" class=\"hover:text-[#E44D2E] transition-colors\" data-kid=\"13\">Family</a>\n            </div>\n            <img src=\"https://i.pravatar.cc/100?u=homehero\" alt=\"User Profile\" class=\"w-12 h-12 rounded-full border-2 border-white shadow-sm ring-4 ring-[#E44D2E]/5\" decoding=\"async\" loading=\"lazy\" data-kid=\"14\">\n        </div>\n    </nav>\n\n    \n    <header class=\"max-w-7xl mx-auto px-8 md:px-16 pt-12 pb-24 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center\" data-kid=\"15\">\n        <div class=\"lg:col-span-8\" data-kid=\"16\">\n            <div id=\"hero-date-eyebrow\" class=\"text-sm font-bold tracking-[0.3em] uppercase opacity-40 mb-6\" data-kid=\"17\">\n                Thursday, October 24th\n            </div>\n            <h1 class=\"text-5xl md:text-8xl font-serif italic text-[#E44D2E] leading-[1.1] mb-8\" id=\"greeting-target\" data-kid=\"18\">\n                Good morning. It's a bit chilly today.\n            </h1>\n            <p class=\"text-xl md:text-2xl font-light leading-relaxed max-w-2xl opacity-80\" data-kid=\"19\">\n                The kettle is hot, and your first meeting starts in an hour. We've updated your daily timeline with a few new reminders.\n            </p>\n        </div>\n        <div class=\"lg:col-span-4 flex justify-center lg:justify-end\" data-kid=\"20\">\n            <div class=\"relative w-72 h-72 flex items-center justify-center\" data-kid=\"21\">\n                <div class=\"weather-blob blob-shape absolute inset-0 bg-white/40 backdrop-blur-md border border-white/50 shadow-inner\" data-kid=\"22\"></div>\n                <div class=\"relative text-center z-10 flex flex-col items-center\" data-kid=\"23\">\n                    <div class=\"mb-4 text-[#E44D2E]\" data-kid=\"24\">\n                        <i class=\"ti ti-cloud-storm text-7xl animate-pulse\" data-kid=\"25\"></i>\n                    </div>\n                    <div class=\"text-6xl font-serif leading-none\" data-kid=\"26\">58°</div>\n                    <div class=\"mt-2 text-xs font-bold tracking-widest uppercase opacity-50\" data-kid=\"27\">Mostly Cloudy</div>\n                </div>\n            </div>\n        </div>\n    </header>\n\n    <main class=\"max-w-7xl mx-auto px-8 md:px-16 pb-40\" data-kid=\"28\">\n        <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-16\" data-kid=\"29\">\n            \n            \n            <aside class=\"lg:col-span-4\" data-kid=\"30\">\n                <div class=\"sticky top-12\" data-kid=\"31\">\n                    <h2 class=\"font-serif text-3xl italic mb-12\" data-kid=\"32\">Family Timeline</h2>\n                    <div class=\"space-y-0 relative\" data-kid=\"33\">\n                        <div class=\"absolute left-[7px] top-2 bottom-8 w-px bg-[#3D2B1F]/10\" data-kid=\"34\"></div>\n                        \n                        \n                        <div class=\"timeline-item relative pl-10 pb-12 group\" data-kid=\"35\">\n                            <div class=\"absolute left-0 top-1.5 w-[15px] h-[15px] rounded-full bg-[#E44D2E] border-4 border-[#FAF0E6] z-10 transition-transform group-hover:scale-125\" data-kid=\"36\"></div>\n                            <div class=\"space-y-1\" data-kid=\"37\">\n                                <p class=\"text-[10px] font-bold tracking-widest uppercase opacity-40\" data-kid=\"38\">08:30 AM</p>\n                                <h4 class=\"font-serif text-xl\" data-kid=\"39\">Medicine Reminder</h4>\n                                <p class=\"text-sm font-light leading-relaxed opacity-60\" data-kid=\"40\">Dad's Heart Support & Vitamin D. Located in the side cabinet.</p>\n                            </div>\n                        </div>\n\n                        <div class=\"timeline-item relative pl-10 pb-12 group\" data-kid=\"41\">\n                            <div class=\"absolute left-0 top-1.5 w-[15px] h-[15px] rounded-full bg-[#3D2B1F]/20 border-4 border-[#FAF0E6] z-10 transition-transform group-hover:scale-125\" data-kid=\"42\"></div>\n                            <div class=\"space-y-1\" data-kid=\"43\">\n                                <p class=\"text-[10px] font-bold tracking-widest uppercase opacity-40\" data-kid=\"44\">11:00 AM</p>\n                                <h4 class=\"font-serif text-xl\" data-kid=\"45\">Electrician Scheduled</h4>\n                                <p class=\"text-sm font-light leading-relaxed opacity-60\" data-kid=\"46\">Checking the hall AC unit. Contact: David (+91 98XXX XXX01).</p>\n                            </div>\n                        </div>\n\n                        <div class=\"timeline-item relative pl-10 pb-12 group\" data-kid=\"47\">\n                            <div class=\"absolute left-0 top-1.5 w-[15px] h-[15px] rounded-full bg-[#E44D2E] border-4 border-[#FAF0E6] z-10 transition-transform group-hover:scale-125\" data-kid=\"48\"></div>\n                            <div class=\"space-y-1\" data-kid=\"49\">\n                                <p class=\"text-[10px] font-bold tracking-widest uppercase opacity-40\" data-kid=\"50\">03:15 PM</p>\n                                <h4 class=\"font-serif text-xl\" data-kid=\"51\">Grocery Run</h4>\n                                <p class=\"text-sm font-light leading-relaxed opacity-60\" data-kid=\"52\">Pick up Almond Milk, Fresh Sourdough, and Organic Apples.</p>\n                            </div>\n                        </div>\n\n                        <div class=\"timeline-item relative pl-10 group\" data-kid=\"53\">\n                            <div class=\"absolute left-0 top-1.5 w-[15px] h-[15px] rounded-full bg-[#3D2B1F]/10 border-4 border-[#FAF0E6] z-10 transition-transform group-hover:scale-125\" data-kid=\"54\"></div>\n                            <div class=\"space-y-1\" data-kid=\"55\">\n                                <p class=\"text-[10px] font-bold tracking-widest uppercase opacity-40\" data-kid=\"56\">07:00 PM</p>\n                                <h4 class=\"font-serif text-xl\" data-kid=\"57\">Dinner with Sarah</h4>\n                                <p class=\"text-sm font-light leading-relaxed opacity-60\" data-kid=\"58\">Reservation at \"The Hearth\". It's a 15-minute drive.</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </aside>\n\n            \n            <section class=\"lg:col-span-8 space-y-20\" data-kid=\"59\">\n                \n                \n                <div data-kid=\"60\">\n                    <div class=\"flex items-baseline justify-between mb-10\" data-kid=\"61\">\n                        <h2 class=\"font-serif text-3xl italic\" data-kid=\"62\">Household Hub</h2>\n                        <a href=\"#\" class=\"text-sm font-bold tracking-widest uppercase opacity-40 hover:opacity-100 transition-opacity\" data-kid=\"63\">View All</a>\n                    </div>\n                    \n                    <div class=\"grid grid-cols-1 md:grid-cols-2 gap-8 items-start\" data-kid=\"64\">\n                        \n                        \n                        <div class=\"hub-card bg-white rounded-[2.5rem] p-8 shadow-sm space-y-6 flex flex-col h-full border border-white\" data-kid=\"65\">\n                            <div class=\"flex justify-between items-center\" data-kid=\"66\">\n                                <h3 class=\"font-serif text-2xl\" data-kid=\"67\">Market List</h3>\n                                <span class=\"bg-[#FAF0E6] text-[#E44D2E] px-4 py-1.5 rounded-full text-[10px] font-bold tracking-widest uppercase\" data-kid=\"68\">8 Items</span>\n                            </div>\n                            <div class=\"relative flex-1 min-h-[320px] bg-[#FAF0E6] rounded-3xl overflow-hidden mt-2\" data-kid=\"69\">\n                                \n                                <img src=\"https://images.unsplash.com/photo-1672586420444-1a1a492e7bd6?auto=format&w=600&q=80&fit=crop\" class=\"absolute top-8 left-8 w-44 h-44 object-cover rounded-2xl shadow-2xl -rotate-6 border-4 border-white z-20\" decoding=\"async\" loading=\"lazy\" alt=\"Fresh Produce\" data-kid=\"70\">\n                                <img src=\"https://images.unsplash.com/photo-1718081003379-e879dcbbe438?auto=format&w=600&q=80&fit=crop\" class=\"absolute bottom-12 right-8 w-52 h-52 object-cover rounded-2xl shadow-2xl rotate-6 border-4 border-white z-10\" decoding=\"async\" loading=\"lazy\" alt=\"Dining Decor\" data-kid=\"71\">\n                                <img src=\"https://images.unsplash.com/photo-1631510390389-c1e4fb20ff31?auto=format&w=600&q=80&fit=crop\" class=\"absolute top-1/3 right-1/4 w-36 h-36 object-cover rounded-2xl shadow-xl rotate-12 border-4 border-white z-30\" decoding=\"async\" loading=\"lazy\" alt=\"Cozy Living Space\" data-kid=\"72\">\n                                \n                                <div class=\"absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent\" data-kid=\"73\"></div>\n                                <div class=\"absolute bottom-6 left-8 text-white z-40\" data-kid=\"74\">\n                                    <p class=\"text-xs font-bold tracking-widest uppercase opacity-80\" data-kid=\"75\">Last update</p>\n                                    <p class=\"font-serif italic\" data-kid=\"76\">10 minutes ago</p>\n                                </div>\n                            </div>\n                            <button class=\"w-full py-4 bg-[#E44D2E] text-white rounded-2xl font-bold tracking-widest uppercase hover:bg-[#c93d22] transition-colors shadow-lg shadow-[#E44D2E]/20\" data-kid=\"77\">Go Shopping</button>\n                        </div>\n\n                        \n                        <div class=\"hub-card ticket-notch group relative bg-white p-10 flex flex-col items-center text-center space-y-8 shadow-sm border border-[#3D2B1F]/5 overflow-hidden rounded-sm\" data-kid=\"78\">\n                            \n                            <div class=\"absolute -top-1 left-1/3 w-28 h-6 bg-[#dcc864]/40 -rotate-3 z-10 shadow-sm\" data-kid=\"79\"></div>\n                            <div class=\"absolute -top-1 right-1/4 w-12 h-6 bg-[#E44D2E]/10 rotate-2 z-10\" data-kid=\"80\"></div>\n                            \n                            <div class=\"space-y-2 mt-4\" data-kid=\"81\">\n                                <p class=\"text-[10px] font-bold tracking-[0.3em] uppercase text-[#E44D2E]\" data-kid=\"82\">Overdue Alert</p>\n                                <h3 class=\"font-serif text-3xl italic\" data-kid=\"83\">Electricity Bill</h3>\n                                <p class=\"text-sm font-light opacity-50\" data-kid=\"84\">September Billing Cycle</p>\n                            </div>\n\n                            <div class=\"flex flex-col items-center\" data-kid=\"85\">\n                                <div class=\"text-5xl font-serif text-[#3D2B1F] mb-1\" data-kid=\"86\">₹4,250</div>\n                                <div class=\"w-full h-px border-t border-dashed border-[#3D2B1F]/20 my-6\" data-kid=\"87\"></div>\n                                <p class=\"text-sm italic font-light leading-relaxed max-w-[200px] opacity-70\" data-kid=\"88\">\n                                    \"Looks like this one slipped through the cracks. Shall I pay it for you?\"\n                                </p>\n                            </div>\n\n                            <button class=\"group-hover:scale-105 transition-transform px-10 py-3 border-2 border-[#E44D2E] text-[#E44D2E] rounded-full text-xs font-bold tracking-widest uppercase hover:bg-[#E44D2E] hover:text-white\" data-kid=\"89\">Pay Instantly</button>\n                        </div>\n\n                    </div>\n                </div>\n\n                \n                <div class=\"bg-white p-12 rounded-[3.5rem] shadow-sm relative overflow-hidden border border-white\" data-kid=\"90\">\n                    <div class=\"relative z-20 flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16\" data-kid=\"91\">\n                        <div class=\"max-w-md space-y-4\" data-kid=\"92\">\n                            <h2 class=\"font-serif text-4xl italic\" data-kid=\"93\">Expense Story</h2>\n                            <p class=\"text-lg font-light leading-relaxed opacity-70\" data-kid=\"94\">\n                                \"You're writing a great financial chapter this month. Spending is <span class=\"font-serif italic font-normal text-[#E44D2E]\" data-kid=\"95\">₹42,800</span>, trending <span class=\"text-[#E44D2E]\" data-kid=\"96\">15% lower</span> than your usual autumn baseline.\"\n                            </p>\n                        </div>\n                        <div class=\"flex items-center gap-2 px-6 py-3 bg-[#FAF0E6] rounded-2xl\" data-kid=\"97\">\n                             <i class=\"ti ti-trending-down text-[#E44D2E] text-2xl\" data-kid=\"98\"></i>\n                             <span class=\"font-bold text-sm tracking-widest uppercase opacity-60\" data-kid=\"99\">Savings ↑</span>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"relative h-[280px] mt-12 mb-16 px-4\" data-kid=\"100\">\n                        <svg id=\"expense-chart-svg\" viewBox=\"0 0 800 200\" class=\"w-full h-full preserve-3d\" preserveAspectRatio=\"none\" data-kid=\"101\">\n                            <defs data-kid=\"102\">\n                                <linearGradient id=\"chartGradientMain\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\" data-kid=\"103\">\n                                    <stop offset=\"0%\" stop-color=\"#E44D2E\" stop-opacity=\"0.25\" data-kid=\"104\"></stop>\n                                    <stop offset=\"100%\" stop-color=\"#E44D2E\" stop-opacity=\"0\" data-kid=\"105\"></stop>\n                                </linearGradient>\n                            </defs>\n                            <path d=\"M0,180 Q100,140 200,160 T400,90 T600,120 T800,40 L800,200 L0,200 Z\" fill=\"url(#chartGradientMain)\" data-kid=\"106\"></path>\n                            <path d=\"M0,180 Q100,140 200,160 T400,90 T600,120 T800,40\" fill=\"none\" stroke=\"#E44D2E\" stroke-width=\"4\" stroke-linecap=\"round\" data-kid=\"107\"></path>\n                        </svg>\n                        \n                        <div id=\"chart-reveal-mask\" class=\"absolute inset-0 bg-white z-10 origin-right\" data-kid=\"108\"></div>\n                    </div>\n\n                    <div class=\"grid grid-cols-1 md:grid-cols-3 gap-12 border-t border-[#FAF0E6] pt-12\" data-kid=\"109\">\n                        <div class=\"space-y-2\" data-kid=\"110\">\n                            <div class=\"flex items-center gap-2 mb-1\" data-kid=\"111\">\n                                <div class=\"w-2 h-2 rounded-full bg-[#E44D2E]\" data-kid=\"112\"></div>\n                                <p class=\"text-[10px] font-bold tracking-[0.2em] uppercase opacity-40\" data-kid=\"113\">Groceries</p>\n                            </div>\n                            <p class=\"font-serif text-2xl italic\" data-kid=\"114\">₹12,400</p>\n                        </div>\n                        <div class=\"space-y-2\" data-kid=\"115\">\n                            <div class=\"flex items-center gap-2 mb-1\" data-kid=\"116\">\n                                <div class=\"w-2 h-2 rounded-full bg-[#3D2B1F]/20\" data-kid=\"117\"></div>\n                                <p class=\"text-[10px] font-bold tracking-[0.2em] uppercase opacity-40\" data-kid=\"118\">Utilities</p>\n                            </div>\n                            <p class=\"font-serif text-2xl italic\" data-kid=\"119\">₹8,200</p>\n                        </div>\n                        <div class=\"space-y-2\" data-kid=\"120\">\n                            <div class=\"flex items-center gap-2 mb-1\" data-kid=\"121\">\n                                <div class=\"w-2 h-2 rounded-full bg-[#3D2B1F]/20\" data-kid=\"122\"></div>\n                                <p class=\"text-[10px] font-bold tracking-[0.2em] uppercase opacity-40\" data-kid=\"123\">Dining & Leisure</p>\n                            </div>\n                            <p class=\"font-serif text-2xl italic\" data-kid=\"124\">₹5,100</p>\n                        </div>\n                    </div>\n                </div>\n\n            </section>\n        </div>\n    </main>\n\n\n    \n    <div class=\"fixed top-0 left-0 w-full h-full pointer-events-none -z-10 overflow-hidden\" data-kid=\"125\">\n        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/solid-leaf.svg\" class=\"absolute top-20 -left-12 w-64 h-64 opacity-[0.03] rotate-45 text-[#3D2B1F]\" data-kid=\"126\">\n        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/falling-leaf.svg\" class=\"absolute bottom-20 -right-12 w-80 h-80 opacity-[0.03] -rotate-12 text-[#3D2B1F]\" data-kid=\"127\">\n    </div>\n\n    \n    <div class=\"fixed bottom-8 left-1/2 -translate-x-1/2 w-[90%] max-w-2xl z-[999] group pointer-events-none\" data-kid=\"128\">\n        <div class=\"bg-[#E44D2E] text-white p-4 rounded-[2.5rem] shadow-[0_25px_50px_-12px_rgba(228,77,46,0.5)] flex items-center justify-between px-8 border-b-4 border-black/20 pointer-events-auto\" data-kid=\"129\">\n            <div class=\"flex items-center gap-5\" data-kid=\"130\">\n                <div class=\"sos-icon w-12 h-12 bg-white/20 rounded-full flex items-center justify-center\" data-kid=\"131\">\n                    <i class=\"ti ti-alert-triangle text-2xl\" data-kid=\"132\"></i>\n                </div>\n                <div data-kid=\"133\">\n                    <p class=\"font-serif italic text-lg tracking-wide leading-none\" data-kid=\"134\">Emergency SOS</p>\n                    <p class=\"text-[10px] font-bold tracking-[0.2em] uppercase opacity-60 mt-1\" data-kid=\"135\">Quick Assist Active</p>\n                </div>\n            </div>\n            <div class=\"flex items-center gap-6\" data-kid=\"136\">\n                 <button class=\"hover:rotate-12 transition-transform opacity-70 hover:opacity-100 cursor-pointer\" data-kid=\"137\">\n                    <i class=\"ti ti-message-2-code text-2xl\" data-kid=\"138\"></i>\n                 </button>\n                 <button class=\"bg-white text-[#E44D2E] w-12 h-12 rounded-full flex items-center justify-center font-bold text-2xl shadow-xl hover:bg-[#FAF0E6] transition-colors cursor-pointer\" data-kid=\"139\">\n                    <i class=\"ti ti-plus\" data-kid=\"140\"></i>\n                 </button>\n            </div>\n        </div>\n    </div>\n\n</div>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"141\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"142\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/TextPlugin.min.js\" data-kid=\"143\"></script>\n\n<script type=\"module\" data-kid=\"144\">\n    import Lenis from \"https://esm.sh/lenis@1\"\n    import { animate } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n\n    // Initialize Lenis\n    const lenis = new Lenis()\n    function raf(time) {\n        lenis.raf(time)\n        requestAnimationFrame(raf)\n    }\n    requestAnimationFrame(raf)\n\n    // Register GSAP Plugins\n    gsap.registerPlugin(ScrollTrigger, TextPlugin);\n\n    // 1. Text Typing Animation (GSAP TextPlugin)\n    const greetingOriginal = \"Good morning. It's a bit chilly today.\";\n    \n    gsap.to(\"#greeting-target\", {\n        duration: 2.5,\n        text: {\n            value: greetingOriginal,\n            delimiter: \"\"\n        },\n        ease: \"power1.inOut\",\n        delay: 0.5\n    });\n\n    // 2. Weather Blob Ambient Pulse (Motion.js)\n    animate(\".weather-blob\", \n        { \n            scale: [1, 1.05, 1],\n            borderRadius: [\n                \"60% 40% 30% 70% / 60% 30% 70% 40%\", \n                \"50% 50% 50% 50% / 50% 50% 50% 50%\",\n                \"40% 60% 70% 30% / 30% 70% 40% 60%\",\n                \"60% 40% 30% 70% / 60% 30% 70% 40%\"\n            ] \n        }, \n        { \n            duration: 12, \n            repeat: Infinity, \n            ease: \"linear\" \n        }\n    );\n\n    // 3. SOS Icon Pulse\n    animate(\".sos-icon\", { scale: [1, 1.1, 1], opacity: [0.8, 1, 0.8] }, { duration: 2, repeat: Infinity, ease: \"easeInOut\" });\n\n    // 4. Expense Chart Reveal (GSAP Mask Wipe)\n    gsap.to(\"#chart-reveal-mask\", {\n        scaleX: 0,\n        duration: 2.5,\n        ease: \"power3.inOut\",\n        scrollTrigger: {\n            trigger: \"#expense-chart-svg\",\n            start: \"top 80%\",\n            once: true\n        }\n    });\n\n    // 5. Timeline Stagger Reveal\n    gsap.from(\".timeline-item\", {\n        x: -30,\n        opacity: 0,\n        duration: 1,\n        stagger: 0.2,\n        ease: \"power2.out\",\n        scrollTrigger: {\n            trigger: \".timeline-item\",\n            start: \"top 85%\"\n        }\n    });\n\n    // 6. Hub Cards Reveal\n    gsap.from(\".hub-card\", {\n        y: 60,\n        opacity: 0,\n        duration: 1.2,\n        stagger: 0.3,\n        ease: \"power4.out\",\n        scrollTrigger: {\n            trigger: \".hub-card\",\n            start: \"top 90%\"\n        }\n    });\n\n</script>\n",
