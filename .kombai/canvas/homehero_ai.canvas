      "html": "<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"0\">\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"1\">\n\n<style data-kid=\"2\">\n    @import url('https://fonts.googleapis.com/css2?family=Quicksand:wght@400;600;700&family=Nunito+Sans:wght@400;600;700&display=swap');\n\n    :root {\n        --white: #FFFFFF;\n        --soft-blossom: #F2BDCD;\n        --jade-green: #03C03C;\n        --slate-blue: #6A5ACD;\n        --clay-shadow: rgba(163, 177, 198, 0.4);\n        --clay-highlight: rgba(255, 255, 255, 1);\n    }\n\n    .main-container {\n        font-family: 'Nunito Sans', sans-serif;\n        background-color: #f4f7fa;\n        color: var(--slate-blue);\n        min-height: 100vh;\n        overflow-x: clip;\n    }\n\n    h1, h2, h3, h4, .font-heading {\n        font-family: 'Quicksand', sans-serif;\n    }\n\n    /* Enhanced Claymorphism Utilities */\n    .clay-card {\n        background: white;\n        border-radius: 2.5rem;\n        box-shadow: \n            20px 20px 40px var(--clay-shadow), \n            -15px -15px 30px var(--clay-highlight),\n            inset -8px -8px 12px rgba(0,0,0,0.02),\n            inset 8px 8px 12px rgba(255,255,255,0.6);\n        border: 1px solid rgba(255, 255, 255, 0.5);\n    }\n\n    .clay-pink {\n        background: var(--soft-blossom);\n        box-shadow: \n            16px 16px 32px rgba(242, 189, 205, 0.5), \n            inset -10px -10px 15px rgba(0, 0, 0, 0.1),\n            inset 10px 10px 15px rgba(255, 255, 255, 0.5);\n        border: none;\n    }\n\n    .clay-green {\n        background: var(--jade-green);\n        box-shadow: \n            16px 16px 32px rgba(3, 192, 60, 0.35), \n            inset -10px -10px 15px rgba(0, 0, 0, 0.15),\n            inset 10px 10px 15px rgba(255, 255, 255, 0.4);\n        border: none;\n        color: white;\n    }\n\n    .clay-blue {\n        background: var(--slate-blue);\n        box-shadow: \n            16px 16px 32px rgba(106, 90, 205, 0.45), \n            inset -10px -10px 15px rgba(0, 0, 0, 0.2),\n            inset 10px 10px 15px rgba(255, 255, 255, 0.2);\n        border: none;\n        color: white;\n    }\n\n    .clay-inset {\n        background: #f0f4f8;\n        box-shadow: \n            inset 8px 8px 16px rgba(0,0,0,0.08),\n            inset -8px -8px 16px rgba(255,255,255,1);\n        border-radius: 1.5rem;\n    }\n\n    .floating-ai-btn {\n        position: fixed;\n        bottom: 2rem;\n        right: 2rem;\n        width: 4.5rem;\n        height: 4.5rem;\n        z-index: 1000;\n        cursor: pointer;\n    }\n\n    .clay-button {\n        border-radius: 1.5rem;\n        /* Removed CSS transition to avoid conflict with GSAP */\n        display: inline-flex;\n        align-items: center;\n        justify-content: center;\n        cursor: pointer;\n        user-select: none;\n    }\n\n    .clay-button:hover {\n        box-shadow: 20px 20px 40px var(--clay-shadow);\n    }\n\n    .clay-button:active {\n        box-shadow: inset 5px 5px 10px rgba(0,0,0,0.1);\n    }\n\n    .no-scrollbar::-webkit-scrollbar { display: none; }\n    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n\n    .story-ring {\n        padding: 5px;\n        border: 4px solid var(--soft-blossom);\n        border-radius: 50%;\n        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n    }\n    .story-ring:hover {\n        transform: scale(1.15) rotate(8deg);\n        border-color: var(--slate-blue);\n    }\n\n    /* Podium Heights */\n    .podium-1 { height: 240px; }\n    .podium-2 { height: 180px; }\n    .podium-3 { height: 120px; }\n\n    /* Animated background blobs for welcome screen */\n    .blob {\n        position: absolute;\n        filter: blur(80px);\n        z-index: -1;\n        opacity: 0.6;\n        animation: blob-move 20s infinite alternate;\n    }\n    @keyframes blob-move {\n        from { transform: translate(0, 0) scale(1); }\n        to { transform: translate(50px, 50px) scale(1.2); }\n    }\n\n    #dashboard-view {\n        display: block;\n    }\n</style>\n\n<div class=\"main-container relative overflow-hidden bg-[#eff3f8]\" data-kid=\"3\">\n    \n    <div class=\"blob w-[40rem] h-[40rem] bg-pink-100/50 top-[-20%] left-[-10%] rounded-full\" data-kid=\"4\"></div>\n    <div class=\"blob w-[35rem] h-[35rem] bg-green-50/50 bottom-[20%] right-[-5%] rounded-full\" style=\"animation-delay: -5s;\" data-kid=\"5\"></div>\n    <div class=\"blob w-[30rem] h-[30rem] bg-indigo-100/40 top-[40%] right-[15%] rounded-full\" style=\"animation-delay: -10s;\" data-kid=\"6\"></div>\n\n    \n    <div id=\"dashboard-view\" class=\"py-12 px-6 md:px-12 space-y-16 max-w-[1440px] mx-auto relative z-10\" data-kid=\"7\">\n        \n        <section id=\"centered-welcome\" class=\"text-center space-y-8 py-12 pop-in\" data-kid=\"8\">\n            <div class=\"welcome-icon w-32 h-32 bg-[var(--soft-blossom)] rounded-[2.8rem] mx-auto flex items-center justify-center clay-pink mb-8\" data-kid=\"9\">\n                <i class=\"ti ti-home text-6xl text-[var(--slate-blue)]\" data-kid=\"10\"></i>\n            </div>\n            <div class=\"welcome-text space-y-4\" data-kid=\"11\">\n                <h1 class=\"text-6xl font-bold text-[var(--slate-blue)] leading-tight\" data-kid=\"12\">Good morning, Miller Family!</h1>\n                <p class=\"text-2xl text-[var(--slate-blue)] font-medium opacity-90 max-w-2xl mx-auto\" data-kid=\"13\">Your Tuesday is looking productive. AI has 4 updates for you.</p>\n            </div>\n            <div class=\"flex justify-center gap-4\" data-kid=\"14\">\n                <button class=\"px-8 py-4 clay-blue clay-button font-bold text-lg rounded-[1.5rem] group\" data-kid=\"15\">\n                    <i class=\"ti ti-circle-plus mr-2 text-xl group-hover:rotate-90 transition-transform\" data-kid=\"16\"></i> New Task\n                </button>\n                <button class=\"px-8 py-4 bg-white clay-card clay-button font-bold text-lg rounded-[1.5rem] text-[var(--slate-blue)]\" data-kid=\"17\">\n                    Family View\n                </button>\n            </div>\n        </section>\n\n        \n        <header class=\"flex flex-col md:flex-row justify-between items-center gap-8 pop-in bg-white/30 backdrop-blur-xl p-8 rounded-[3rem] clay-card border-white/50\" data-kid=\"18\">\n            <div class=\"flex items-center gap-6\" data-kid=\"19\">\n                <div class=\"w-16 h-16 clay-pink rounded-[1.8rem] flex items-center justify-center\" data-kid=\"20\">\n                    <i class=\"ti ti-home text-3xl\" data-kid=\"21\"></i>\n                </div>\n                <div data-kid=\"22\">\n                    <h2 class=\"text-3xl font-bold\" data-kid=\"23\">HomeHero AI</h2>\n                    <p class=\"text-base font-bold text-gray-400\" data-kid=\"24\">Miller Residence • Tuesday, 22 May</p>\n                </div>\n            </div>\n            <div class=\"flex items-center gap-8\" data-kid=\"25\">\n                <div class=\"flex -space-x-4\" data-kid=\"26\">\n                    <img src=\"https://i.pravatar.cc/150?u=dad\" class=\"w-14 h-14 rounded-full border-4 border-white clay-card p-0.5\" alt=\"Dad\" data-kid=\"27\">\n                    <img src=\"https://i.pravatar.cc/150?u=mom\" class=\"w-14 h-14 rounded-full border-4 border-white clay-card p-0.5\" alt=\"Mom\" data-kid=\"28\">\n                    <img src=\"https://i.pravatar.cc/150?u=kid1\" class=\"w-14 h-14 rounded-full border-4 border-white clay-card p-0.5\" alt=\"Kid 1\" data-kid=\"29\">\n                    <div class=\"w-14 h-14 rounded-full border-4 border-white bg-gray-50 flex items-center justify-center text-gray-400 font-bold clay-inset\" data-kid=\"30\">\n                        <i class=\"ti ti-plus\" data-kid=\"31\"></i>\n                    </div>\n                </div>\n                <button class=\"w-16 h-16 clay-card flex items-center justify-center relative clay-button\" data-kid=\"32\">\n                    <i class=\"ti ti-bell text-2xl\" data-kid=\"33\"></i>\n                    <span class=\"absolute top-4 right-4 w-4 h-4 bg-pink-500 rounded-full border-2 border-white\" data-kid=\"34\"></span>\n                </button>\n            </div>\n        </header>\n\n        \n        <div id=\"modular-tiles\" class=\"grid grid-cols-2 lg:grid-cols-4 gap-8\" data-kid=\"35\">\n            <div class=\"clay-card p-8 flex flex-col items-center justify-center text-center space-y-3 pop-in\" data-kid=\"36\">\n                <div class=\"w-16 h-16 clay-inset flex items-center justify-center mb-2\" data-kid=\"37\">\n                    <i class=\"ti ti-shopping-bag text-[var(--soft-blossom)] text-3xl\" data-kid=\"38\"></i>\n                </div>\n                <span class=\"text-5xl font-bold text-[var(--slate-blue)]\" data-kid=\"39\">8</span>\n                <span class=\"text-sm text-gray-400 font-bold uppercase tracking-widest\" data-kid=\"40\">Grocery Low</span>\n            </div>\n            <div class=\"clay-card p-8 flex flex-col items-center justify-center text-center space-y-3 pop-in\" data-kid=\"41\">\n                <div class=\"w-16 h-16 clay-inset flex items-center justify-center mb-2\" data-kid=\"42\">\n                    <i class=\"ti ti-activity text-[var(--jade-green)] text-3xl\" data-kid=\"43\"></i>\n                </div>\n                <span class=\"text-5xl font-bold text-[var(--slate-blue)]\" data-kid=\"44\">94%</span>\n                <span class=\"text-sm text-gray-400 font-bold uppercase tracking-widest\" data-kid=\"45\">Health Score</span>\n            </div>\n            <div class=\"clay-card p-8 flex flex-col items-center justify-center text-center space-y-3 pop-in\" data-kid=\"46\">\n                <div class=\"w-16 h-16 clay-inset flex items-center justify-center mb-2\" data-kid=\"47\">\n                    <i class=\"ti ti-cpu text-[var(--slate-blue)] text-3xl\" data-kid=\"48\"></i>\n                </div>\n                <span class=\"text-3xl font-bold text-[var(--slate-blue)] uppercase\" data-kid=\"49\">Optimized</span>\n                <span class=\"text-sm text-gray-400 font-bold uppercase tracking-widest\" data-kid=\"50\">AI Status</span>\n            </div>\n            <div class=\"clay-card p-8 flex flex-col items-center justify-center text-center space-y-3 pop-in\" data-kid=\"51\">\n                <div class=\"w-16 h-16 clay-inset flex items-center justify-center mb-2\" data-kid=\"52\">\n                    <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/star.svg\" class=\"w-10 h-10\" data-kid=\"53\">\n                </div>\n                <span class=\"text-5xl font-bold text-[var(--slate-blue)]\" data-kid=\"54\">240</span>\n                <span class=\"text-sm text-gray-400 font-bold uppercase tracking-widest\" data-kid=\"55\">Reward Pts</span>\n            </div>\n        </div>\n\n        \n        <section id=\"story-reel-bar\" class=\"space-y-6 pop-in\" data-kid=\"56\">\n            <div class=\"flex justify-between items-center px-4\" data-kid=\"57\">\n                <h3 class=\"text-2xl font-bold\" data-kid=\"58\">AI Grocery Suggestions</h3>\n                <span class=\"text-sm font-bold text-[var(--soft-blossom)] cursor-pointer hover:underline\" data-kid=\"59\">Manage List</span>\n            </div>\n            <div class=\"flex gap-10 overflow-x-auto no-scrollbar py-8 px-6 clay-inset rounded-[3rem]\" data-kid=\"60\">\n                <div class=\"flex flex-col items-center gap-4 shrink-0 group cursor-pointer\" data-kid=\"61\">\n                    <div class=\"story-ring border-4 border-white ring-4 ring-[var(--soft-blossom)]\" data-kid=\"62\">\n                        <div class=\"w-24 h-24 rounded-full overflow-hidden clay-inset p-1 bg-white\" data-kid=\"63\">\n                            <img src=\"https://images.unsplash.com/photo-1550583724-1277f313410c?auto=format&w=250&q=80&fit=crop\" class=\"w-full h-full object-cover rounded-full\" data-kid=\"64\">\n                        </div>\n                    </div>\n                    <span class=\"text-sm font-bold\" data-kid=\"65\">Milk Refill</span>\n                </div>\n                <div class=\"flex flex-col items-center gap-4 shrink-0 group cursor-pointer\" data-kid=\"66\">\n                    <div class=\"story-ring\" style=\"border-color: var(--jade-green);\" data-kid=\"67\">\n                        <div class=\"w-24 h-24 rounded-full overflow-hidden clay-inset p-1 bg-white\" data-kid=\"68\">\n                            <img src=\"https://images.unsplash.com/photo-1557844352-761f2565b576?auto=format&w=250&q=80&fit=crop\" class=\"w-full h-full object-cover rounded-full\" data-kid=\"69\">\n                        </div>\n                    </div>\n                    <span class=\"text-sm font-bold\" data-kid=\"70\">Fresh Kale</span>\n                </div>\n                <div class=\"flex flex-col items-center gap-4 shrink-0 group cursor-pointer\" data-kid=\"71\">\n                    <div class=\"story-ring\" style=\"border-color: #60a5fa;\" data-kid=\"72\">\n                        <div class=\"w-24 h-24 rounded-full overflow-hidden clay-inset p-1 bg-white\" data-kid=\"73\">\n                            <img src=\"https://images.unsplash.com/photo-1509440159596-0249088772ff?auto=format&w=250&q=80&fit=crop\" class=\"w-full h-full object-cover rounded-full\" data-kid=\"74\">\n                        </div>\n                    </div>\n                    <span class=\"text-sm font-bold\" data-kid=\"75\">Sourdough</span>\n                </div>\n                <div class=\"flex flex-col items-center gap-4 shrink-0 group cursor-pointer\" data-kid=\"76\">\n                    <div class=\"story-ring\" style=\"border-color: #facc15;\" data-kid=\"77\">\n                        <div class=\"w-24 h-24 rounded-full overflow-hidden clay-inset p-1 bg-white\" data-kid=\"78\">\n                            <img src=\"https://images.unsplash.com/photo-1610832958506-aa56368176cf?auto=format&w=250&q=80&fit=crop\" class=\"w-full h-full object-cover rounded-full\" data-kid=\"79\">\n                        </div>\n                    </div>\n                    <span class=\"text-sm font-bold\" data-kid=\"80\">Avocados</span>\n                </div>\n                <div class=\"flex flex-col items-center gap-4 shrink-0 group cursor-pointer\" data-kid=\"81\">\n                    <div class=\"story-ring\" style=\"border-color: #c084fc;\" data-kid=\"82\">\n                        <div class=\"w-24 h-24 rounded-full overflow-hidden clay-inset p-1 bg-white\" data-kid=\"83\">\n                            <img src=\"https://images.unsplash.com/photo-1596003906949-67221c37965c?auto=format&w=250&q=80&fit=crop\" class=\"w-full h-full object-cover rounded-full\" data-kid=\"84\">\n                        </div>\n                    </div>\n                    <span class=\"text-sm font-bold\" data-kid=\"85\">Juice Box</span>\n                </div>\n            </div>\n        </section>\n\n        \n        <div class=\"grid grid-cols-1 lg:grid-cols-3 gap-10\" data-kid=\"86\">\n            <div class=\"lg:col-span-2 space-y-8 pop-in\" data-kid=\"87\">\n                <div class=\"flex justify-between items-center px-4\" data-kid=\"88\">\n                    <h3 class=\"text-2xl font-bold\" data-kid=\"89\">Smart Inventory</h3>\n                    <div class=\"flex gap-4\" data-kid=\"90\">\n                        <button class=\"px-6 py-3 clay-inset text-sm font-bold clay-button\" data-kid=\"91\">All Items</button>\n                        <button class=\"px-6 py-3 bg-white rounded-2xl text-sm font-bold text-gray-400\" data-kid=\"92\">Low Stock Only</button>\n                    </div>\n                </div>\n                <div id=\"ecommerce-product-grid\" class=\"grid grid-cols-1 sm:grid-cols-2 gap-8\" data-kid=\"93\">\n                    <div class=\"clay-card p-6 space-y-6 group cursor-pointer\" data-kid=\"94\">\n                        <div class=\"aspect-video bg-[#f8fafc] rounded-[2.5rem] overflow-hidden clay-inset p-1\" data-kid=\"95\">\n                            <img src=\"https://images.unsplash.com/photo-1550583724-1277f313410c?auto=format&w=600&q=80&fit=crop\" class=\"w-full h-full object-cover rounded-[2.2rem] group-hover:scale-110 transition-transform duration-700\" data-kid=\"96\">\n                        </div>\n                        <div class=\"flex justify-between items-end\" data-kid=\"97\">\n                            <div data-kid=\"98\">\n                                <h4 class=\"text-2xl font-bold\" data-kid=\"99\">Milk (2.5L)</h4>\n                                <p class=\"text-base font-bold text-pink-500\" data-kid=\"100\">Predicted to finish in 2 days</p>\n                            </div>\n                            <button class=\"w-14 h-14 clay-pink clay-button text-2xl\" data-kid=\"101\">\n                                <i class=\"ti ti-plus\" data-kid=\"102\"></i>\n                            </button>\n                        </div>\n                    </div>\n                    <div class=\"clay-card p-6 space-y-6 group cursor-pointer\" data-kid=\"103\">\n                        <div class=\"aspect-video bg-[#f8fafc] rounded-[2.5rem] overflow-hidden clay-inset p-1\" data-kid=\"104\">\n                            <img src=\"https://images.unsplash.com/photo-1596003906949-67221c37965c?auto=format&w=600&q=80&fit=crop\" class=\"w-full h-full object-cover rounded-[2.2rem] group-hover:scale-110 transition-transform duration-700\" data-kid=\"105\">\n                        </div>\n                        <div class=\"flex justify-between items-end\" data-kid=\"106\">\n                            <div data-kid=\"107\">\n                                <h4 class=\"text-2xl font-bold\" data-kid=\"108\">Fruit Juice</h4>\n                                <p class=\"text-base font-bold text-green-500\" data-kid=\"109\">Fully Stocked • 6 Packs</p>\n                            </div>\n                            <button class=\"w-14 h-14 clay-card clay-button text-gray-300\" data-kid=\"110\">\n                                <i class=\"ti ti-check text-2xl\" data-kid=\"111\"></i>\n                            </button>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <div id=\"dashboard-analytics\" class=\"clay-card p-10 space-y-10 pop-in\" data-kid=\"112\">\n                <div class=\"flex justify-between items-center\" data-kid=\"113\">\n                    <h3 class=\"text-2xl font-bold\" data-kid=\"114\">Health Track</h3>\n                    <div class=\"w-12 h-12 clay-inset flex items-center justify-center\" data-kid=\"115\">\n                        <i class=\"ti ti-heart text-pink-500 text-2xl\" data-kid=\"116\"></i>\n                    </div>\n                </div>\n                \n                <div class=\"space-y-8\" data-kid=\"117\">\n                    <div class=\"clay-inset p-8 flex items-center justify-between\" data-kid=\"118\">\n                        <div class=\"flex items-center gap-5\" data-kid=\"119\">\n                            <div class=\"w-16 h-16 clay-blue clay-button rounded-[1.5rem] text-white\" data-kid=\"120\">\n                                <i class=\"ti ti-droplet text-3xl\" data-kid=\"121\"></i>\n                            </div>\n                            <div data-kid=\"122\">\n                                <h4 class=\"text-lg font-bold\" data-kid=\"123\">Water</h4>\n                                <p class=\"text-sm font-bold text-gray-400\" data-kid=\"124\">1.8 / 3.0 Liters</p>\n                            </div>\n                        </div>\n                        <div class=\"relative w-20 h-20\" data-kid=\"125\">\n                            <svg class=\"w-full h-full -rotate-90\" viewBox=\"0 0 80 80\" data-kid=\"126\">\n                                <circle cx=\"40\" cy=\"40\" r=\"32\" stroke=\"#e2e8f0\" stroke-width=\"8\" fill=\"transparent\" data-kid=\"127\"></circle>\n                                <circle cx=\"40\" cy=\"40\" r=\"32\" stroke=\"var(--slate-blue)\" stroke-width=\"8\" fill=\"transparent\" stroke-dasharray=\"201\" stroke-dashoffset=\"80\" stroke-linecap=\"round\" data-kid=\"128\"></circle>\n                            </svg>\n                        </div>\n                    </div>\n                    <div class=\"clay-inset p-8 flex items-center justify-between\" data-kid=\"129\">\n                        <div class=\"flex items-center gap-5\" data-kid=\"130\">\n                            <div class=\"w-16 h-16 clay-pink clay-button rounded-[1.5rem]\" data-kid=\"131\">\n                                <i class=\"ti ti-moon text-3xl\" data-kid=\"132\"></i>\n                            </div>\n                            <div data-kid=\"133\">\n                                <h4 class=\"text-lg font-bold\" data-kid=\"134\">Sleep</h4>\n                                <p class=\"text-sm font-bold text-gray-400\" data-kid=\"135\">7h 12m Quality</p>\n                            </div>\n                        </div>\n                        <div class=\"relative w-20 h-20\" data-kid=\"136\">\n                            <svg class=\"w-full h-full -rotate-90\" viewBox=\"0 0 80 80\" data-kid=\"137\">\n                                <circle cx=\"40\" cy=\"40\" r=\"32\" stroke=\"#FCE4EC\" stroke-width=\"8\" fill=\"transparent\" data-kid=\"138\"></circle>\n                                <circle cx=\"40\" cy=\"40\" r=\"32\" stroke=\"#F48FB1\" stroke-width=\"8\" fill=\"transparent\" stroke-dasharray=\"201\" stroke-dashoffset=\"50\" stroke-linecap=\"round\" data-kid=\"139\"></circle>\n                            </svg>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        \n        <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-10\" data-kid=\"140\">\n            <div id=\"leaderboard-podium\" class=\"clay-card p-12 space-y-12 pop-in\" data-kid=\"141\">\n                <div class=\"flex justify-between items-center\" data-kid=\"142\">\n                    <h3 class=\"text-3xl font-bold flex items-center gap-4\" data-kid=\"143\">\n                        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/trophy.svg\" class=\"w-10 h-10\" data-kid=\"144\">\n                        Family Podium\n                    </h3>\n                </div>\n\n                <div class=\"flex justify-center items-end gap-6 sm:gap-14 pt-12\" data-kid=\"145\">\n                    <div class=\"flex flex-col items-center\" data-kid=\"146\">\n                        <div class=\"w-24 h-24 rounded-full border-4 border-white clay-card overflow-hidden mb-6\" data-kid=\"147\">\n                            <img src=\"https://i.pravatar.cc/150?u=sarah\" class=\"w-full h-full object-cover\" data-kid=\"148\">\n                        </div>\n                        <div class=\"clay-card w-32 podium-2 flex flex-col items-center justify-center bg-blue-50/60 border-none\" data-kid=\"149\">\n                            <span class=\"text-blue-300 font-bold text-2xl\" data-kid=\"150\">2nd</span>\n                            <span class=\"text-base font-bold text-blue-500\" data-kid=\"151\">Sarah</span>\n                        </div>\n                    </div>\n                    <div class=\"flex flex-col items-center\" data-kid=\"152\">\n                        <div class=\"w-28 h-28 rounded-full border-4 border-yellow-400 clay-card overflow-hidden mb-6 relative\" data-kid=\"153\">\n                            <img src=\"https://i.pravatar.cc/150?u=david\" class=\"w-full h-full object-cover\" data-kid=\"154\">\n                            <div class=\"absolute -top-3 -right-3\" data-kid=\"155\">\n                                <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/star.svg\" class=\"w-10 h-10\" data-kid=\"156\">\n                            </div>\n                        </div>\n                        <div class=\"clay-pink w-40 podium-1 flex flex-col items-center justify-center border-none\" data-kid=\"157\">\n                            <span class=\"text-5xl font-bold text-[var(--slate-blue)] drop-shadow-sm\" data-kid=\"158\">1st</span>\n                            <span class=\"text-xl font-bold text-[var(--slate-blue)]\" data-kid=\"159\">David</span>\n                        </div>\n                    </div>\n                    <div class=\"flex flex-col items-center\" data-kid=\"160\">\n                        <div class=\"w-24 h-24 rounded-full border-4 border-white clay-card overflow-hidden mb-6\" data-kid=\"161\">\n                            <img src=\"https://i.pravatar.cc/150?u=kid1\" class=\"w-full h-full object-cover\" data-kid=\"162\">\n                        </div>\n                        <div class=\"clay-card w-32 podium-3 flex flex-col items-center justify-center bg-green-50/60 border-none\" data-kid=\"163\">\n                            <span class=\"text-green-300 font-bold text-2xl\" data-kid=\"164\">3rd</span>\n                            <span class=\"text-base font-bold text-green-600\" data-kid=\"165\">Leo</span>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <div id=\"chat-bubbles-section\" class=\"clay-card p-10 flex flex-col min-h-[500px] pop-in\" data-kid=\"166\">\n                <div class=\"flex items-center justify-between mb-10\" data-kid=\"167\">\n                    <div class=\"flex items-center gap-5\" data-kid=\"168\">\n                        <div class=\"w-14 h-14 clay-blue rounded-2xl flex items-center justify-center\" data-kid=\"169\">\n                            <i class=\"ti ti-cpu text-white text-2xl\" data-kid=\"170\"></i>\n                        </div>\n                        <div data-kid=\"171\">\n                            <h4 class=\"text-xl font-bold\" data-kid=\"172\">HomeHero AI</h4>\n                            <span class=\"text-sm text-green-500 font-bold flex items-center gap-2\" data-kid=\"173\">\n                                <span class=\"w-2.5 h-2.5 bg-green-500 rounded-full animate-ping\" data-kid=\"174\"></span> Active Now\n                            </span>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"flex-1 space-y-8 overflow-y-auto no-scrollbar pr-2\" data-kid=\"175\">\n                    <div class=\"flex gap-5\" data-kid=\"176\">\n                        <div class=\"w-12 h-12 clay-blue shrink-0 rounded-full flex items-center justify-center text-white\" data-kid=\"177\">\n                            <i class=\"ti ti-cpu text-lg\" data-kid=\"178\"></i>\n                        </div>\n                        <div class=\"clay-inset p-6 rounded-[2rem] rounded-tl-none max-w-[85%]\" data-kid=\"179\">\n                            <p class=\"text-base font-bold text-[var(--slate-blue)] leading-relaxed\" data-kid=\"180\">Good morning! I've noticed your milk stock is very low. I've added a 2.5L pack to your shared grocery list. 🥛 Also, don't forget it's Leo's practice session today at 5 PM!</p>\n                        </div>\n                    </div>\n                    <div class=\"flex justify-end gap-5\" data-kid=\"181\">\n                        <div class=\"clay-pink p-6 rounded-[2rem] rounded-tr-none max-w-[85%]\" data-kid=\"182\">\n                            <p class=\"text-base font-bold text-[var(--slate-blue)] leading-relaxed\" data-kid=\"183\">Perfect, thank you! Can you also suggest a quick 15-minute dinner for after the practice?</p>\n                        </div>\n                        <div class=\"w-12 h-12 rounded-full overflow-hidden shrink-0 clay-card border-none p-1 bg-white\" data-kid=\"184\">\n                            <img src=\"https://i.pravatar.cc/150?u=mom\" class=\"w-full h-full rounded-full object-cover\" data-kid=\"185\">\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"mt-10 flex gap-4\" data-kid=\"186\">\n                    <div class=\"flex-1 clay-inset p-1 flex items-center\" data-kid=\"187\">\n                        <input type=\"text\" placeholder=\"Ask HomeHero anything...\" class=\"w-full bg-transparent border-none px-8 py-4 font-bold text-base outline-none placeholder:text-gray-300\" data-kid=\"188\">\n                    </div>\n                    <button class=\"w-16 h-16 clay-blue clay-button\" data-kid=\"189\">\n                        <i class=\"ti ti-send text-2xl\" data-kid=\"190\"></i>\n                    </button>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    \n    <div class=\"floating-ai-btn clay-blue clay-button rounded-full flex items-center justify-center pop-in\" data-kid=\"191\">\n        <i class=\"ti ti-cpu text-3xl\" data-kid=\"192\"></i>\n        <span class=\"absolute -top-1 -right-1 w-5 h-5 bg-red-500 rounded-full border-2 border-white animate-pulse\" data-kid=\"193\"></span>\n    </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"194\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"195\"></script>\n<script type=\"module\" data-kid=\"196\">\n    import Lenis from \"https://esm.sh/lenis@1\"\n    import Snap from \"https://esm.sh/lenis@1/snap\"\n    import { animate, spring } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n\n    // GSAP ScrollTrigger registration\n    gsap.registerPlugin(ScrollTrigger);\n\n    // Initialize Lenis\n    const lenis = new Lenis();\n    function raf(time) {\n        lenis.raf(time);\n        requestAnimationFrame(raf);\n    }\n    requestAnimationFrame(raf);\n\n    const dashboardView = document.getElementById('dashboard-view');\n\n    // Initial Dashboard Entrance\n    gsap.set(dashboardView, { opacity: 1 });\n    \n    gsap.from(\".pop-in\", {\n        scale: 0.85,\n        opacity: 0,\n        y: 60,\n        duration: 1.2,\n        stagger: 0.1,\n        ease: \"back.out(1.2)\",\n        clearProps: \"all\"\n    });\n\n    // Floating button wiggle\n    gsap.to(\".floating-ai-btn\", {\n        y: -10,\n        repeat: -1,\n        yoyo: true,\n        duration: 2,\n        ease: \"sine.inOut\"\n    });\n\n    // Specific puffy effect for the modular tiles using Motion.js\n    animate(\"#modular-tiles > div\", \n        { scale: [0.6, 1], opacity: [0, 1] }, \n        { \n            type: spring, \n            visualDuration: 0.8, \n            bounce: 0.6, \n            delay: (i) => 0.5 + (i * 0.15) \n        }\n    );\n\n    // Button interactions using GSAP for conflict-free animation\n    document.querySelectorAll('.clay-button').forEach(btn => {\n        btn.addEventListener('mouseenter', () => {\n            gsap.to(btn, { y: -8, scale: 1.05, duration: 0.4, ease: \"back.out(2)\" });\n        });\n        btn.addEventListener('mouseleave', () => {\n            gsap.to(btn, { y: 0, scale: 1, duration: 0.4, ease: \"power2.out\" });\n        });\n        btn.addEventListener('mousedown', () => {\n            gsap.to(btn, { scale: 0.95, duration: 0.1 });\n        });\n        btn.addEventListener('mouseup', () => {\n            gsap.to(btn, { scale: 1.05, duration: 0.2 });\n        });\n    });\n\n    // Simple micro-interactions for cards\n    document.querySelectorAll('.clay-card').forEach(card => {\n        card.addEventListener('mouseenter', () => {\n            if (window.getComputedStyle(dashboardView).opacity !== \"0\") {\n                gsap.to(card, { y: -12, scale: 1.01, duration: 0.4, ease: \"power2.out\" });\n            }\n        });\n        card.addEventListener('mouseleave', () => {\n            if (window.getComputedStyle(dashboardView).opacity !== \"0\") {\n                gsap.to(card, { y: 0, scale: 1, duration: 0.4, ease: \"power2.out\" });\n            }\n        });\n    });\n</script>",
      "comments": [],
      "created": "2026-07-04T07:30:55.462944+00:00",
