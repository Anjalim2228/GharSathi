      "themeId": null,
      "rect": {
        "x": 6160,
        "y": 0,
        "w": 1440,
        "h": 800
      },
      "html": "\n<div class=\"min-h-screen bg-[#F8FAFB] font-['DM_Sans'] text-[#1E293B] selection:bg-teal-500/30 relative pb-20\" data-kid=\"0\">\n    \n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=DM+Sans:wght@400;500;700&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n        @import url('https://unpkg.com/lenis@1/dist/lenis.css');\n\n        /* Grounded Premium Cards */\n        .card-premium {\n            background: #FFFFFF;\n            border: 1px solid rgba(226, 232, 240, 0.8);\n            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02), 0 2px 4px -1px rgba(0, 0, 0, 0.01);\n            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n        }\n        .card-premium:hover {\n            border-color: rgba(45, 212, 191, 0.3);\n            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05), 0 10px 10px -5px rgba(0, 0, 0, 0.02);\n        }\n\n        /* Fluid Fill Animation */\n        .wave-container {\n            position: relative;\n            width: 100%;\n            height: 100%;\n            overflow: hidden;\n            background: #E0F2F1;\n        }\n        .wave {\n            position: absolute;\n            bottom: 0;\n            left: 0;\n            width: 200%;\n            height: 100%;\n            background: #2DD4BF;\n            opacity: 0.6;\n            border-radius: 40%;\n            animation: wave-animation 10s linear infinite;\n        }\n        .wave-2 {\n            bottom: 5px;\n            opacity: 0.3;\n            animation: wave-animation 7s linear infinite reverse;\n        }\n        @keyframes wave-animation {\n            0% { transform: translateX(0) rotate(0deg); }\n            100% { transform: translateX(-50%) rotate(360deg); }\n        }\n\n        /* Custom Scrollbar */\n        .custom-scroll::-webkit-scrollbar { width: 4px; }\n        .custom-scroll::-webkit-scrollbar-track { background: transparent; }\n        .custom-scroll::-webkit-scrollbar-thumb { background: #CBD5E1; border-radius: 10px; }\n\n        /* Remove transition from GSAP targets */\n        #voice-assistant-orb, .progress-circle-path {\n            transition: none !important;\n        }\n    </style>\n\n    \n    <nav class=\"sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-100 px-8 py-4 flex items-center justify-between\" data-kid=\"2\">\n        <div class=\"flex items-center gap-8\" data-kid=\"3\">\n            <div class=\"flex items-center gap-2\" data-kid=\"4\">\n                <div class=\"w-8 h-8 bg-teal-500 rounded-lg flex items-center justify-center text-white\" data-kid=\"5\">\n                    <i class=\"ti ti-activity-heartbeat text-lg\" data-kid=\"6\"></i>\n                </div>\n                <h1 class=\"text-xl font-bold font-['Inter'] tracking-tight\" data-kid=\"7\">HomeHero <span class=\"text-slate-400 font-medium\" data-kid=\"8\">Health</span></h1>\n            </div>\n            <div class=\"hidden lg:flex items-center gap-6\" data-kid=\"9\">\n                <a href=\"#\" class=\"text-sm font-semibold text-slate-500 hover:text-teal-600 transition-colors\" data-kid=\"10\">Dashboard</a>\n                <a href=\"#\" class=\"text-sm font-bold text-teal-600 border-b-2 border-teal-500 pb-1\" data-kid=\"11\">Wellness</a>\n                <a href=\"#\" class=\"text-sm font-semibold text-slate-500 hover:text-teal-600 transition-colors\" data-kid=\"12\">Emergency Hub</a>\n            </div>\n        </div>\n        \n        <div class=\"flex items-center gap-6\" data-kid=\"13\">\n            <button class=\"text-slate-400 hover:text-slate-600 transition-colors relative\" data-kid=\"14\">\n                <i class=\"ti ti-bell text-xl\" data-kid=\"15\"></i>\n                <span class=\"absolute top-0 right-0 w-2 h-2 bg-red-500 rounded-full border-2 border-white\" data-kid=\"16\"></span>\n            </button>\n            <div class=\"h-8 w-[1px] bg-slate-100\" data-kid=\"17\"></div>\n            <div class=\"flex items-center gap-3 cursor-pointer group\" data-kid=\"18\">\n                <div class=\"text-right hidden sm:block\" data-kid=\"19\">\n                    <p class=\"text-sm font-bold text-slate-800\" data-kid=\"20\">Anjali Sharma</p>\n                    <p class=\"text-xs text-slate-400\" data-kid=\"21\">Head of Household</p>\n                </div>\n                <img src=\"https://i.pravatar.cc/150?u=Anjali\" class=\"w-9 h-9 rounded-full ring-2 ring-slate-50 group-hover:ring-teal-100 transition-all\" alt=\"Profile\" data-kid=\"22\">\n            </div>\n        </div>\n    </nav>\n\n    <main class=\"max-w-[1440px] mx-auto px-10 py-10 space-y-10\" data-kid=\"23\">\n        \n        \n        <header class=\"flex flex-col md:flex-row justify-between items-start md:items-end gap-6 stagger-item\" data-kid=\"24\">\n            <div data-kid=\"25\">\n                <p class=\"text-teal-600 font-bold text-sm tracking-wide uppercase mb-2\" data-kid=\"26\">Family Wellness Score</p>\n                <div class=\"flex items-center gap-4\" data-kid=\"27\">\n                    <h2 class=\"text-4xl font-bold font-['Inter'] text-slate-900\" data-kid=\"28\">Preventive Care Active</h2>\n                    <span class=\"px-3 py-1 bg-teal-50 text-teal-700 text-xs font-bold rounded-full border border-teal-100\" data-kid=\"29\">Excellent Status</span>\n                </div>\n            </div>\n            \n            <div class=\"flex items-center gap-3\" data-kid=\"30\">\n                <button class=\"px-5 py-2.5 bg-white border border-slate-200 rounded-xl text-sm font-bold text-slate-600 hover:bg-slate-50 transition-all flex items-center gap-2\" data-kid=\"31\">\n                    <i class=\"ti ti-download text-lg\" data-kid=\"32\"></i> Health Summary\n                </button>\n                <button class=\"px-5 py-2.5 bg-white border border-red-100 rounded-xl text-sm font-bold text-red-500 hover:bg-red-50 transition-all flex items-center gap-2 shadow-sm\" data-kid=\"33\">\n                    <i class=\"ti ti-alert-circle text-lg\" data-kid=\"34\"></i> SOS Emergency\n                </button>\n            </div>\n        </header>\n\n        \n        <section class=\"grid grid-cols-1 lg:grid-cols-12 gap-8 stagger-item\" data-kid=\"35\">\n            \n            <div class=\"lg:col-span-3 card-premium rounded-3xl overflow-hidden flex flex-col h-[400px]\" data-kid=\"36\">\n                <div class=\"p-6 pb-0 flex justify-between items-start\" data-kid=\"37\">\n                    <div data-kid=\"38\">\n                        <h3 class=\"text-sm font-bold text-slate-400 uppercase tracking-wider\" data-kid=\"39\">Hydration</h3>\n                        <p class=\"text-3xl font-black text-slate-800 mt-1\" data-kid=\"40\">1.8 <span class=\"text-lg text-slate-400 font-bold\" data-kid=\"41\">L</span></p>\n                    </div>\n                    <div class=\"w-10 h-10 bg-teal-50 text-teal-600 rounded-xl flex items-center justify-center\" data-kid=\"42\">\n                        <i class=\"ti ti-droplet-filled text-xl\" data-kid=\"43\"></i>\n                    </div>\n                </div>\n                <div class=\"flex-1 mt-6 relative group\" data-kid=\"44\">\n                    <div class=\"wave-container h-full\" data-kid=\"45\">\n                        <div class=\"wave\" style=\"top: 25%;\" data-kid=\"46\"></div>\n                        <div class=\"wave wave-2\" style=\"top: 28%;\" data-kid=\"47\"></div>\n                        <div class=\"absolute inset-0 flex flex-col items-center justify-center text-teal-900/60 font-bold z-10\" data-kid=\"48\">\n                            <span class=\"text-4xl\" data-kid=\"49\">72%</span>\n                            <span class=\"text-xs\" data-kid=\"50\">of daily goal</span>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"p-4 bg-slate-50 border-t border-slate-100 flex items-center justify-between text-xs font-bold text-slate-500\" data-kid=\"51\">\n                    <span data-kid=\"52\">Goal: 2.5L</span>\n                    <span class=\"text-teal-600\" data-kid=\"53\">Drink 2 glasses soon</span>\n                </div>\n            </div>\n\n            \n            <div class=\"lg:col-span-6 card-premium rounded-3xl p-8 flex flex-col justify-between bg-[url('https://images.unsplash.com/photo-1541781774459-bb2af2f05b55?auto=format&w=800&q=80&fit=crop')] bg-cover bg-center h-[400px] relative overflow-hidden group/sleep\" data-kid=\"54\">\n                <div class=\"absolute inset-0 bg-slate-900/50 rounded-3xl backdrop-blur-[1px] transition-all group-hover/sleep:bg-slate-900/60\" data-kid=\"55\"></div>\n                <div class=\"relative z-10\" data-kid=\"56\">\n                    <div class=\"flex justify-between items-start text-white\" data-kid=\"57\">\n                        <div data-kid=\"58\">\n                            <h3 class=\"text-sm font-bold uppercase tracking-wider opacity-70\" data-kid=\"59\">Sleep Quality</h3>\n                            <p class=\"text-5xl font-black mt-2\" data-kid=\"60\">6.5<span class=\"text-2xl font-bold opacity-50\" data-kid=\"61\">h</span></p>\n                        </div>\n                        <div class=\"w-12 h-12 bg-white/20 backdrop-blur-md rounded-2xl flex items-center justify-center border border-white/20\" data-kid=\"62\">\n                            <i class=\"ti ti-moon-stars text-2xl\" data-kid=\"63\"></i>\n                        </div>\n                    </div>\n                    <div class=\"mt-8 flex gap-4\" data-kid=\"64\">\n                        <div class=\"bg-white/10 backdrop-blur-md border border-white/10 px-4 py-2 rounded-xl\" data-kid=\"65\">\n                            <p class=\"text-[10px] font-bold uppercase opacity-60 text-white\" data-kid=\"66\">Deep Sleep</p>\n                            <p class=\"text-lg font-bold text-white\" data-kid=\"67\">2h 15m</p>\n                        </div>\n                        <div class=\"bg-white/10 backdrop-blur-md border border-white/10 px-4 py-2 rounded-xl\" data-kid=\"68\">\n                            <p class=\"text-[10px] font-bold uppercase opacity-60 text-white\" data-kid=\"69\">REM</p>\n                            <p class=\"text-lg font-bold text-white\" data-kid=\"70\">1h 45m</p>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"relative z-10 flex items-center justify-between p-4 bg-white/10 backdrop-blur-md border border-white/10 rounded-2xl\" data-kid=\"71\">\n                    <p class=\"text-sm text-white font-medium italic\" data-kid=\"72\">\"Anjali, your sleep efficiency was 82% last night. Try turning off screens by 10 PM.\"</p>\n                    <i class=\"ti ti-sparkles text-teal-300\" data-kid=\"73\"></i>\n                </div>\n            </div>\n\n            \n            <div class=\"lg:col-span-3 card-premium rounded-3xl p-8 h-[400px] flex flex-col\" data-kid=\"74\">\n                <div class=\"flex justify-between items-start mb-8\" data-kid=\"75\">\n                    <div data-kid=\"76\">\n                        <h3 class=\"text-sm font-bold text-slate-400 uppercase tracking-wider\" data-kid=\"77\">Active Steps</h3>\n                        <p class=\"text-3xl font-black text-slate-800 mt-1\" data-kid=\"78\">8,421</p>\n                    </div>\n                    <div class=\"w-10 h-10 bg-emerald-50 text-emerald-600 rounded-xl flex items-center justify-center\" data-kid=\"79\">\n                        <i class=\"ti ti-shoe text-xl\" data-kid=\"80\"></i>\n                    </div>\n                </div>\n                <div class=\"flex-1 flex gap-6 px-4\" data-kid=\"81\">\n                    <div class=\"w-6 h-full bg-slate-100 rounded-full relative overflow-hidden\" data-kid=\"82\">\n                        <div class=\"absolute bottom-0 left-0 w-full bg-emerald-500 rounded-full\" style=\"height: 84%;\" data-kid=\"83\"></div>\n                    </div>\n                    <div class=\"flex-1 flex flex-col justify-between py-2 text-xs font-bold text-slate-400\" data-kid=\"84\">\n                        <div class=\"flex justify-between items-center\" data-kid=\"85\">\n                            <span data-kid=\"86\">10,000</span>\n                            <span class=\"w-4 h-[1px] bg-slate-200\" data-kid=\"87\"></span>\n                        </div>\n                        <div class=\"flex justify-between items-center text-emerald-600\" data-kid=\"88\">\n                            <span data-kid=\"89\">8,000</span>\n                            <span class=\"w-8 h-[2px] bg-emerald-400\" data-kid=\"90\"></span>\n                        </div>\n                        <div class=\"flex justify-between items-center\" data-kid=\"91\">\n                            <span data-kid=\"92\">6,000</span>\n                            <span class=\"w-4 h-[1px] bg-slate-200\" data-kid=\"93\"></span>\n                        </div>\n                        <div class=\"flex justify-between items-center\" data-kid=\"94\">\n                            <span data-kid=\"95\">4,000</span>\n                            <span class=\"w-4 h-[1px] bg-slate-200\" data-kid=\"96\"></span>\n                        </div>\n                        <div class=\"flex justify-between items-center\" data-kid=\"97\">\n                            <span data-kid=\"98\">2,000</span>\n                            <span class=\"w-4 h-[1px] bg-slate-200\" data-kid=\"99\"></span>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"mt-8 text-center\" data-kid=\"100\">\n                    <p class=\"text-sm font-bold text-slate-800\" data-kid=\"101\">1,579 steps to go</p>\n                    <p class=\"text-xs text-slate-400 mt-1\" data-kid=\"102\">You're more active than 85% of peers</p>\n                </div>\n            </div>\n        </section>\n\n        \n        <section class=\"grid grid-cols-1 lg:grid-cols-12 gap-8 stagger-item\" data-kid=\"103\">\n            \n            <div class=\"lg:col-span-8 space-y-8\" data-kid=\"104\">\n                <div class=\"card-premium rounded-3xl p-8\" data-kid=\"105\">\n                    <div class=\"flex justify-between items-center mb-8\" data-kid=\"106\">\n                        <h3 class=\"text-xl font-bold font-['Inter']\" data-kid=\"107\">Family Healthy Leaderboard</h3>\n                        <div class=\"flex items-center gap-2 px-3 py-1.5 bg-slate-50 rounded-lg text-xs font-bold text-slate-500\" data-kid=\"108\">\n                            <i class=\"ti ti-calendar\" data-kid=\"109\"></i> This Week\n                        </div>\n                    </div>\n                    <div class=\"space-y-3\" data-kid=\"110\">\n                        <div class=\"flex items-center justify-between p-4 bg-slate-50 rounded-2xl border border-slate-100 transition-all hover:translate-x-1 cursor-pointer\" data-kid=\"111\">\n                            <div class=\"flex items-center gap-4\" data-kid=\"112\">\n                                <div class=\"w-6 h-6 rounded-full bg-teal-500 text-white flex items-center justify-center text-[10px] font-black\" data-kid=\"113\">1</div>\n                                <img src=\"https://i.pravatar.cc/150?u=Anjali\" class=\"w-10 h-10 rounded-full border-2 border-white\" alt data-kid=\"114\">\n                                <div data-kid=\"115\">\n                                    <p class=\"text-sm font-bold text-slate-800\" data-kid=\"116\">Anjali (You)</p>\n                                    <p class=\"text-[11px] text-teal-600 font-bold\" data-kid=\"117\">12 day active streak</p>\n                                </div>\n                            </div>\n                            <div class=\"text-right\" data-kid=\"118\">\n                                <p class=\"text-lg font-black text-slate-800\" data-kid=\"119\">2,450</p>\n                                <p class=\"text-[10px] font-bold text-slate-400 uppercase tracking-widest\" data-kid=\"120\">Points</p>\n                            </div>\n                        </div>\n                        <div class=\"flex items-center justify-between p-4 bg-white rounded-2xl border border-slate-50 hover:border-slate-200 transition-all hover:translate-x-1 cursor-pointer\" data-kid=\"121\">\n                            <div class=\"flex items-center gap-4\" data-kid=\"122\">\n                                <div class=\"w-6 h-6 rounded-full bg-slate-100 text-slate-400 flex items-center justify-center text-[10px] font-black\" data-kid=\"123\">2</div>\n                                <img src=\"https://i.pravatar.cc/150?u=Karan\" class=\"w-10 h-10 rounded-full border-2 border-slate-50\" alt data-kid=\"124\">\n                                <div data-kid=\"125\">\n                                    <p class=\"text-sm font-bold text-slate-800\" data-kid=\"126\">Karan</p>\n                                    <p class=\"text-[11px] text-slate-400 font-medium\" data-kid=\"127\">Step goal reached today</p>\n                                </div>\n                            </div>\n                            <div class=\"text-right\" data-kid=\"128\">\n                                <p class=\"text-lg font-black text-slate-800\" data-kid=\"129\">2,100</p>\n                                <p class=\"text-[10px] font-bold text-slate-400 uppercase tracking-widest\" data-kid=\"130\">Points</p>\n                            </div>\n                        </div>\n                        <div class=\"flex items-center justify-between p-4 bg-white rounded-2xl border border-slate-50 hover:border-slate-200 transition-all hover:translate-x-1 cursor-pointer\" data-kid=\"131\">\n                            <div class=\"flex items-center gap-4\" data-kid=\"132\">\n                                <div class=\"w-6 h-6 rounded-full bg-slate-100 text-slate-400 flex items-center justify-center text-[10px] font-black\" data-kid=\"133\">3</div>\n                                <img src=\"https://i.pravatar.cc/150?u=Mom\" class=\"w-10 h-10 rounded-full border-2 border-slate-50\" alt data-kid=\"134\">\n                                <div data-kid=\"135\">\n                                    <p class=\"text-sm font-bold text-slate-800\" data-kid=\"136\">Mom</p>\n                                    <p class=\"text-[11px] text-slate-400 font-medium\" data-kid=\"137\">Hydration champion</p>\n                                </div>\n                            </div>\n                            <div class=\"text-right\" data-kid=\"138\">\n                                <p class=\"text-lg font-black text-slate-800\" data-kid=\"139\">1,850</p>\n                                <p class=\"text-[10px] font-bold text-slate-400 uppercase tracking-widest\" data-kid=\"140\">Points</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"space-y-6\" data-kid=\"141\">\n                    <h3 class=\"text-xl font-bold font-['Inter'] flex items-center gap-2\" data-kid=\"142\">\n                        <i class=\"ti ti-stethoscope text-teal-600\" data-kid=\"143\"></i> Upcoming Checkups\n                    </h3>\n                    <div class=\"grid grid-cols-1 md:grid-cols-2 gap-4\" data-kid=\"144\">\n                        <div class=\"card-premium rounded-2xl p-6 flex gap-4 group cursor-pointer hover:border-teal-200 hover:bg-teal-50/20 transition-all\" data-kid=\"145\">\n                            <div class=\"w-14 h-14 bg-teal-50 rounded-xl flex flex-col items-center justify-center text-teal-600 shrink-0\" data-kid=\"146\">\n                                <span class=\"text-[10px] font-bold uppercase opacity-60\" data-kid=\"147\">Jul</span>\n                                <span class=\"text-2xl font-black\" data-kid=\"148\">18</span>\n                            </div>\n                            <div data-kid=\"149\">\n                                <p class=\"text-sm font-bold text-slate-800 group-hover:text-teal-600 transition-colors\" data-kid=\"150\">General Consultation</p>\n                                <p class=\"text-xs text-slate-400 mt-1\" data-kid=\"151\">Dr. Sarah Thompson • Mom</p>\n                                <div class=\"flex gap-3 mt-3 text-[10px] font-bold text-slate-400 uppercase tracking-tighter\" data-kid=\"152\">\n                                    <span class=\"flex items-center gap-1\" data-kid=\"153\"><i class=\"ti ti-clock\" data-kid=\"154\"></i> 10:30 AM</span>\n                                    <span class=\"flex items-center gap-1\" data-kid=\"155\"><i class=\"ti ti-map-pin\" data-kid=\"156\"></i> 2.4 Mi</span>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"card-premium rounded-2xl p-6 flex gap-4 group cursor-pointer opacity-70 hover:opacity-100 hover:border-blue-200 hover:bg-blue-50/20 transition-all\" data-kid=\"157\">\n                            <div class=\"w-14 h-14 bg-blue-50 rounded-xl flex flex-col items-center justify-center text-blue-600 shrink-0\" data-kid=\"158\">\n                                <span class=\"text-[10px] font-bold uppercase opacity-60\" data-kid=\"159\">Aug</span>\n                                <span class=\"text-2xl font-black\" data-kid=\"160\">02</span>\n                            </div>\n                            <div data-kid=\"161\">\n                                <p class=\"text-sm font-bold text-slate-800 group-hover:text-blue-600 transition-colors\" data-kid=\"162\">Dental Cleaning</p>\n                                <p class=\"text-xs text-slate-400 mt-1\" data-kid=\"163\">Dr. Marcus Lee • Karan</p>\n                                <div class=\"flex gap-3 mt-3 text-[10px] font-bold text-slate-400 uppercase tracking-tighter\" data-kid=\"164\">\n                                    <span class=\"flex items-center gap-1\" data-kid=\"165\"><i class=\"ti ti-clock\" data-kid=\"166\"></i> 02:00 PM</span>\n                                    <span class=\"flex items-center gap-1\" data-kid=\"167\"><i class=\"ti ti-map-pin\" data-kid=\"168\"></i> 4.1 Mi</span>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"lg:col-span-4 space-y-8\" data-kid=\"169\">\n                <div class=\"bg-slate-900 rounded-3xl p-8 text-white relative overflow-hidden h-full min-h-[400px] flex flex-col\" data-kid=\"170\">\n                    <div class=\"absolute -top-10 -right-10 w-32 h-32 bg-teal-500/20 rounded-full blur-3xl\" data-kid=\"171\"></div>\n                    <div class=\"relative z-10 flex-1\" data-kid=\"172\">\n                        <div class=\"w-12 h-12 bg-teal-500 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-teal-500/20\" data-kid=\"173\">\n                            <i class=\"ti ti-heart-rate-monitor text-2xl\" data-kid=\"174\"></i>\n                        </div>\n                        <p class=\"text-sm font-bold text-teal-400 uppercase tracking-widest mb-4\" data-kid=\"175\">Daily Insight</p>\n                        <h4 class=\"text-2xl font-bold font-['Inter'] mb-8 leading-tight italic\" data-kid=\"176\">\"Your resting heart rate has trended 4 BPM lower this week. This suggests improved cardiovascular recovery.\"</h4>\n                        <div class=\"space-y-4\" data-kid=\"177\">\n                            <button class=\"w-full bg-white text-slate-900 py-4 rounded-xl font-bold text-sm hover:bg-teal-50 transition-all flex items-center justify-center gap-2\" data-kid=\"178\">\n                                <i class=\"ti ti-chart-line\" data-kid=\"179\"></i> View HRV Trends\n                            </button>\n                            <button class=\"w-full bg-slate-800 text-white/60 py-4 rounded-xl font-bold text-sm hover:bg-slate-700 hover:text-white transition-all\" data-kid=\"180\">\n                                Dismiss Insight\n                            </button>\n                        </div>\n                    </div>\n                    <div class=\"mt-12 pt-6 border-t border-slate-800 flex justify-between items-center text-[10px] font-bold text-slate-500 uppercase tracking-widest\" data-kid=\"181\">\n                        <span data-kid=\"182\">AI Monitoring Active</span>\n                        <div class=\"flex items-center gap-1.5\" data-kid=\"183\">\n                            <div class=\"w-2 h-2 bg-teal-500 rounded-full\" data-kid=\"184\"></div>\n                            <span data-kid=\"185\">Normal</span>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"card-premium rounded-3xl p-8 space-y-6\" data-kid=\"186\">\n                    <h4 class=\"text-xs font-bold text-slate-400 uppercase tracking-widest\" data-kid=\"187\">Wellness Score Factors</h4>\n                    <div class=\"space-y-4\" data-kid=\"188\">\n                        <div class=\"flex items-center justify-between\" data-kid=\"189\">\n                            <span class=\"text-sm font-bold text-slate-700\" data-kid=\"190\">Physical Health</span>\n                            <span class=\"text-sm font-black text-teal-600\" data-kid=\"191\">92%</span>\n                        </div>\n                        <div class=\"w-full h-1.5 bg-slate-100 rounded-full overflow-hidden\" data-kid=\"192\">\n                            <div class=\"h-full bg-teal-500 w-[92%] rounded-full\" data-kid=\"193\"></div>\n                        </div>\n                        <div class=\"flex items-center justify-between\" data-kid=\"194\">\n                            <span class=\"text-sm font-bold text-slate-700\" data-kid=\"195\">Sleep Score</span>\n                            <span class=\"text-sm font-black text-blue-500\" data-kid=\"196\">78%</span>\n                        </div>\n                        <div class=\"w-full h-1.5 bg-slate-100 rounded-full overflow-hidden\" data-kid=\"197\">\n                            <div class=\"h-full bg-blue-500 w-[78%] rounded-full\" data-kid=\"198\"></div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </section>\n    </main>\n\n    \n    <div class=\"fixed bottom-10 right-10 z-[60] flex flex-col items-end gap-6 pointer-events-none\" data-kid=\"199\">\n        <div id=\"health-tip-bubble\" class=\"opacity-0 translate-y-8 pointer-events-auto bg-white shadow-[0_24px_64px_-16px_rgba(0,0,0,0.12)] p-6 rounded-[2rem] mb-2 max-w-[300px] border border-slate-100 relative overflow-hidden group\" data-kid=\"200\">\n            <div class=\"absolute -top-4 -right-4 w-12 h-12 bg-teal-100/40 rounded-full blur-2xl pointer-events-none\" data-kid=\"201\"></div>\n            <div class=\"flex items-center gap-2 mb-3\" data-kid=\"202\">\n                <div class=\"w-6 h-6 rounded-md bg-teal-500 flex items-center justify-center text-white\" data-kid=\"203\">\n                    <i class=\"ti ti-bulb text-xs\" data-kid=\"204\"></i>\n                </div>\n                <p class=\"text-sm font-bold text-slate-800\" data-kid=\"205\">Health Tip</p>\n            </div>\n            <p class=\"text-xs text-slate-600 leading-relaxed font-medium\" data-kid=\"206\">Standing up for 5 minutes can improve your focus and blood flow. You've been stationary for a while.</p>\n            <div class=\"mt-4 flex gap-2\" data-kid=\"207\">\n                <button class=\"flex-1 bg-teal-600 text-white text-[10px] font-bold py-2 rounded-lg hover:bg-teal-700 transition-all\" data-kid=\"208\">Doing it now</button>\n                <button class=\"px-3 bg-slate-50 text-slate-400 text-[10px] font-bold py-2 rounded-lg\" data-kid=\"209\">Later</button>\n            </div>\n        </div>\n        \n        <div class=\"relative pointer-events-auto cursor-pointer group\" id=\"voice-assistant-orb\" data-kid=\"210\">\n            <div class=\"w-14 h-14 rounded-2xl bg-slate-900 flex items-center justify-center text-white relative z-10 border border-slate-800 shadow-xl hover:scale-105 hover:bg-teal-600 transition-all duration-300\" data-kid=\"211\">\n                <i class=\"ti ti-microphone text-xl\" data-kid=\"212\"></i>\n            </div>\n        </div>\n    </div>\n\n    \n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"213\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"214\"></script>\n    <script type=\"module\" data-kid=\"215\">\n        import Lenis from \"https://esm.sh/lenis@1\"\n        const lenis = new Lenis();\n        function raf(time) {\n            lenis.raf(time);\n            requestAnimationFrame(raf);\n        }\n        requestAnimationFrame(raf);\n    </script>\n\n    <script data-kid=\"216\">\n        gsap.registerPlugin(ScrollTrigger);\n\n        window.addEventListener('load', () => {\n            // Entrance Animations\n            gsap.from(\".stagger-item\", {\n                duration: 1.2,\n                y: 40,\n                opacity: 0,\n                stagger: 0.2,\n                ease: \"power3.out\"\n            });\n\n            // Delayed Tip Bubble\n            gsap.to(\"#health-tip-bubble\", {\n                delay: 4,\n                duration: 0.8,\n                opacity: 1,\n                y: 0,\n                ease: \"back.out(1.4)\"\n            });\n        });\n\n        // Simple toggle for tip bubble\n        const orb = document.getElementById('voice-assistant-orb');\n        const bubble = document.getElementById('health-tip-bubble');\n        \n        orb.addEventListener('click', () => {\n            const isVisible = bubble.style.opacity === \"1\";\n            if(!isVisible) {\n                gsap.to(bubble, { opacity: 1, y: 0, duration: 0.6, ease: \"power3.out\" });\n            } else {\n                gsap.to(bubble, { opacity: 0, y: 30, duration: 0.4, ease: \"power3.in\" });\n            }\n        });\n    </script>\n</div>\n",
