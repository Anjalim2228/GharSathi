ass rounded-[2.5rem] p-8 bg-[#011F5B] text-white overflow-hidden relative group\" data-kid=\"205\">\n                        <div class=\"absolute -right-10 -bottom-10 w-32 h-32 bg-white/5 rounded-full blur-2xl group-hover:bg-white/10 transition-all\" data-kid=\"206\"></div>\n                        <h4 class=\"text-lg font-['Outfit'] font-bold mb-4 flex items-center gap-2\" data-kid=\"207\">\n                            <i class=\"ti ti-activity-heartbeat\" data-kid=\"208\"></i> Pantry Health\n                        </h4>\n                        <div class=\"space-y-4\" data-kid=\"209\">\n                            <div class=\"flex justify-between text-xs font-bold\" data-kid=\"210\">\n                                <span class=\"opacity-60\" data-kid=\"211\">Inventory Health</span>\n                                <span class=\"text-[#E5AA70]\" data-kid=\"212\">Good</span>\n                            </div>\n                            <div class=\"w-full h-1.5 bg-white/10 rounded-full overflow-hidden\" data-kid=\"213\">\n                                <div class=\"h-full bg-[#E5AA70] w-[78%] rounded-full\" data-kid=\"214\"></div>\n                            </div>\n                            <p class=\"text-[11px] opacity-60 leading-relaxed\" data-kid=\"215\">78% of your staples are currently at optimal levels. 2 items require attention.</p>\n                        </div>\n                    </div>\n                </div>\n            </section>\n        </div>\n    </main>\n\n    \n    <div class=\"fixed bottom-10 right-10 z-[100] flex flex-col items-end gap-6\" data-kid=\"216\">\n        \n        <div id=\"voice-response\" class=\"opacity-0 translate-y-10 scale-95 pointer-events-none glass shadow-[0_40px_100px_-20px_rgba(1,31,91,0.3)] p-10 rounded-[3.5rem] max-w-[420px] border-2 border-white relative overflow-hidden group\" data-kid=\"217\">\n            <div class=\"absolute -top-10 -right-10 w-32 h-32 bg-[#E5AA70]/15 rounded-full blur-3xl\" data-kid=\"218\"></div>\n            <div class=\"flex items-center gap-4 mb-6\" data-kid=\"219\">\n                <div class=\"w-12 h-12 rounded-2xl bg-[#011F5B] flex items-center justify-center text-white shadow-xl shadow-[#011F5B]/20\" data-kid=\"220\">\n                    <i class=\"ti ti-sparkles text-xl\" data-kid=\"221\"></i>\n                </div>\n                <div data-kid=\"222\">\n                    <p class=\"text-xl font-['Outfit'] font-bold text-[#011F5B]\" data-kid=\"223\">HomeHero Assistant</p>\n                    <span class=\"text-[10px] font-bold text-green-500 uppercase tracking-widest flex items-center gap-1.5\" data-kid=\"224\">\n                        <span class=\"w-2 h-2 bg-green-500 rounded-full animate-ping\" data-kid=\"225\"></span> Listening...\n                    </span>\n                </div>\n            </div>\n            <p class=\"text-xl font-medium leading-relaxed text-[#011F5B]/90 italic font-['DM_Sans']\" data-kid=\"226\">\"I've added 3 organic avocados and oat milk to your Produce list. Shall I set a reminder for the eggs as well?\"</p>\n            <div class=\"mt-8 flex gap-3\" data-kid=\"227\">\n                <button class=\"bg-[#011F5B] text-white text-xs font-bold px-8 py-4 rounded-2xl hover:scale-105 transition-transform shadow-lg shadow-[#011F5B]/20\" data-kid=\"228\">Yes, please</button>\n                <button class=\"bg-white/50 text-black/60 text-xs font-bold px-8 py-4 rounded-2xl hover:bg-white/80 transition-colors border border-black/5\" data-kid=\"229\">No, I'm good</button>\n            </div>\n        </div>\n        \n        \n        <div class=\"relative cursor-pointer group mb-6 mr-2\" id=\"main-voice-orb\" data-kid=\"230\">\n            \n            <div class=\"wave-ring w-20 h-20 top-0 left-0\" data-kid=\"231\"></div>\n            <div class=\"wave-ring w-20 h-20 top-0 left-0\" style=\"animation-delay: 1.3s;\" data-kid=\"232\"></div>\n            <div class=\"wave-ring w-20 h-20 top-0 left-0\" style=\"animation-delay: 2.6s;\" data-kid=\"233\"></div>\n            \n            <div class=\"w-20 h-20 rounded-full bg-[#011F5B] orb-pulse flex items-center justify-center text-white relative z-10 border-4 border-white shadow-2xl group-hover:scale-105\" id=\"orb-visual\" data-kid=\"234\">\n                <i class=\"ti ti-microphone text-3xl group-hover:scale-110\" id=\"orb-icon\" data-kid=\"235\"></i>\n            </div>\n        </div>\n    </div>\n\n    \n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"236\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"237\"></script>\n    <script data-kid=\"238\">gsap.registerPlugin(ScrollTrigger);</script>\n\n    <script data-kid=\"239\">\n        // Entrance Animations\n        window.addEventListener('DOMContentLoaded', () => {\n            gsap.from(\".stagger-item\", {\n                duration: 1.4,\n                y: 60,\n                opacity: 0,\n                stagger: 0.3,\n                ease: \"power4.out\",\n                clearProps: \"all\"\n            });\n        });\n\n        // Voice Orb Interaction\n        const orb = document.getElementById('main-voice-orb');\n        const orbVisual = document.getElementById('orb-visual');\n        const orbIcon = document.getElementById('orb-icon');\n        const responseBubble = document.getElementById('voice-response');\n        let isListening = false;\n\n        orb.addEventListener('click', () => {\n            isListening = !isListening;\n            \n            if(isListening) {\n                // Activate state\n                orbVisual.classList.add('voice-orb-active');\n                orbIcon.classList.replace('ti-microphone', 'ti-waveform');\n                \n                gsap.to(responseBubble, {\n                    opacity: 1,\n                    y: 0,\n                    scale: 1,\n                    pointerEvents: 'auto',\n                    duration: 0.6,\n                    ease: \"back.out(1.7)\"\n                });\n\n                // Pulse effect enhancement\n                gsap.to(orbVisual, {\n                    scale: 1.15,\n                    duration: 0.4,\n                    repeat: -1,\n                    yoyo: true,\n                    ease: \"sine.inOut\"\n                });\n            } else {\n                // Deactivate state\n                orbVisual.classList.remove('voice-orb-active');\n                orbIcon.classList.replace('ti-waveform', 'ti-microphone');\n                \n                gsap.to(responseBubble, {\n                    opacity: 0,\n                    y: 40,\n                    scale: 0.95,\n                    pointerEvents: 'none',\n                    duration: 0.4,\n                    ease: \"power4.in\"\n                });\n\n                gsap.killTweensOf(orbVisual);\n                gsap.to(orbVisual, { scale: 1, duration: 0.3 });\n            }\n        });\n\n        // Small interaction for check-boxes\n        document.querySelectorAll('input[type=\"checkbox\"]').forEach(box => {\n            box.addEventListener('change', function() {\n                const parent = this.closest('.glass-dark');\n                if(this.checked) {\n                    gsap.to(parent, { opacity: 0.5, x: 10, duration: 0.3, ease: \"power2.out\" });\n                } else {\n                    gsap.to(parent, { opacity: 1, x: 0, duration: 0.3, ease: \"power2.out\" });\n                }\n            });\n        });\n\n        // Hover animations for staples cards\n        document.querySelectorAll('.card-hover').forEach(card => {\n            card.addEventListener('mouseenter', () => {\n                gsap.to(card, { y: -10, duration: 0.5, ease: \"power3.out\" });\n            });\n            card.addEventListener('mouseleave', () => {\n                gsap.to(card, { y: 0, duration: 0.5, ease: \"power3.out\" });\n            });\n        });\n    </script>\n</div>\n",
