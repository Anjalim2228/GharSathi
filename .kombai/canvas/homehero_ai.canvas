      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n  @import url('https://unpkg.com/lenis@1/dist/lenis.css');\n\n  :root {\n    --navy-dark: #020617;\n    --navy-light: #0f172a;\n    --accent-primary: #6366f1;\n    --accent-secondary: #a855f7;\n    --glass: rgba(255, 255, 255, 0.03);\n    --glass-border: rgba(255, 255, 255, 0.08);\n  }\n\n  body {\n    background-color: var(--navy-dark);\n    color: #f8fafc;\n    font-family: 'DM Sans', sans-serif;\n    margin: 0;\n    overflow-x: clip;\n  }\n\n  .font-heading { font-family: 'Manrope', sans-serif; }\n\n  .glass-effect {\n    background: var(--glass);\n    backdrop-filter: blur(16px);\n    border: 1px solid var(--glass-border);\n  }\n\n  .timeline-line {\n    position: absolute;\n    left: 20px;\n    top: 20px;\n    bottom: 20px;\n    width: 2px;\n    background: linear-gradient(to bottom, transparent, rgba(99, 102, 241, 0.2), rgba(99, 102, 241, 0.2), transparent);\n  }\n\n  .glow-dot {\n    box-shadow: 0 0 10px currentColor;\n  }\n\n  /* Custom Scrollbar */\n  .scrollbar-hide::-webkit-scrollbar { display: none; }\n  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }\n\n  /* Smooth chart container */\n  #historyChart {\n    width: 100% !important;\n    height: 280px !important;\n  }\n\n  .stagger-reveal {\n    /* GSAP will handle the initial state. Removing CSS defaults to prevent 0->0 opacity issues */\n  }\n</style>\n\n<div id=\"scroll-wrapper\" class=\"flex min-h-screen\" data-kid=\"1\">\n  \n  \n  <aside class=\"w-24 border-r border-white/5 flex flex-col items-center py-10 gap-10 bg-black/20 backdrop-blur-xl sticky top-0 h-screen z-50 shrink-0\" data-kid=\"2\">\n    <div class=\"w-14 h-14 bg-indigo-600 rounded-2xl flex items-center justify-center text-white shadow-xl shadow-indigo-600/20 cursor-pointer hover:scale-105 transition-transform\" data-kid=\"3\">\n      <i class=\"ti ti-home-heart text-3xl\" data-kid=\"4\"></i>\n    </div>\n    <nav class=\"flex flex-col gap-8\" data-kid=\"5\">\n      <button class=\"w-14 h-14 rounded-2xl flex items-center justify-center text-white/40 hover:text-indigo-400 hover:bg-indigo-500/10 transition-all group\" data-kid=\"6\">\n        <i class=\"ti ti-layout-dashboard text-2xl group-hover:scale-110\" data-kid=\"7\"></i>\n      </button>\n      <button class=\"w-14 h-14 rounded-2xl flex items-center justify-center text-indigo-400 bg-indigo-500/10 border border-indigo-500/20 relative group\" data-kid=\"8\">\n        <i class=\"ti ti-credit-card text-2xl\" data-kid=\"9\"></i>\n        <div class=\"absolute left-0 top-1/2 -translate-y-1/2 w-1 h-6 bg-indigo-500 rounded-r-full\" data-kid=\"10\"></div>\n      </button>\n      <button class=\"w-14 h-14 rounded-2xl flex items-center justify-center text-white/40 hover:text-indigo-400 hover:bg-indigo-500/10 transition-all group\" data-kid=\"11\">\n        <i class=\"ti ti-calendar-clock text-2xl group-hover:scale-110\" data-kid=\"12\"></i>\n      </button>\n      <button class=\"w-14 h-14 rounded-2xl flex items-center justify-center text-white/40 hover:text-indigo-400 hover:bg-indigo-500/10 transition-all group\" data-kid=\"13\">\n        <i class=\"ti ti-history text-2xl group-hover:scale-110\" data-kid=\"14\"></i>\n      </button>\n      <button class=\"w-14 h-14 rounded-2xl flex items-center justify-center text-white/40 hover:text-indigo-400 hover:bg-indigo-500/10 transition-all group\" data-kid=\"15\">\n        <i class=\"ti ti-settings text-2xl group-hover:scale-110\" data-kid=\"16\"></i>\n      </button>\n    </nav>\n    <div class=\"mt-auto\" data-kid=\"17\">\n      <img src=\"https://i.pravatar.cc/150?u=anjali\" class=\"w-12 h-12 rounded-2xl border-2 border-indigo-500/50 p-0.5\" alt=\"User\" decoding=\"async\" loading=\"lazy\" data-kid=\"18\">\n    </div>\n  </aside>\n\n  \n  <main class=\"flex-1 px-12 py-10 overflow-x-clip\" data-kid=\"19\">\n    \n    \n    <header class=\"flex items-center justify-between mb-12 stagger-reveal\" data-kid=\"20\">\n      <div data-kid=\"21\">\n        <h1 class=\"text-4xl lg:text-5xl font-extrabold font-heading tracking-tight mb-2\" data-kid=\"22\">Financial Control</h1>\n        <p class=\"text-slate-400 text-lg flex flex-wrap items-center gap-2 lg:gap-3\" data-kid=\"23\">\n          Manage your monthly overheads and smart reminders. \n          <span class=\"inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-emerald-500/5 text-emerald-400 text-xs font-bold border border-emerald-500/10\" data-kid=\"24\">\n            <span class=\"w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse\" data-kid=\"25\"></span>\n            All systems optimal\n          </span>\n        </p>\n      </div>\n      <div class=\"flex gap-4\" data-kid=\"26\">\n        <div class=\"glass-effect rounded-2xl px-6 py-3.5 flex items-center gap-4\" data-kid=\"27\">\n          <div class=\"w-10 h-10 rounded-full bg-indigo-500/10 flex items-center justify-center text-indigo-400 shrink-0\" data-kid=\"28\">\n            <i class=\"ti ti-receipt text-xl\" data-kid=\"29\"></i>\n          </div>\n          <div class=\"whitespace-nowrap\" data-kid=\"30\">\n            <p class=\"text-[10px] font-bold text-slate-500 uppercase tracking-widest leading-none mb-1.5\" data-kid=\"31\">Next Due</p>\n            <p class=\"text-xl font-bold font-heading text-white leading-none\" data-kid=\"32\">$142.50 <span class=\"text-xs font-normal text-slate-400 ml-1\" data-kid=\"33\">in 2d</span></p>\n          </div>\n        </div>\n        <button class=\"px-8 py-3.5 rounded-2xl bg-white text-indigo-950 font-bold hover:bg-slate-100 transition-all shadow-xl shadow-white/5 flex items-center gap-2 active:scale-95\" data-kid=\"34\">\n          <i class=\"ti ti-plus font-bold\" data-kid=\"35\"></i> Add Bill\n        </button>\n      </div>\n    </header>\n\n    <div class=\"grid grid-cols-12 gap-10\" data-kid=\"36\">\n      \n      \n      <section class=\"col-span-12 lg:col-span-7 space-y-8\" data-kid=\"37\">\n        <div class=\"flex items-center justify-between mb-4 stagger-reveal\" data-kid=\"38\">\n          <h3 class=\"text-2xl font-bold font-heading\" data-kid=\"39\">Upcoming Schedule</h3>\n          <div class=\"flex items-center gap-2\" data-kid=\"40\">\n            <span class=\"w-2 h-2 rounded-full bg-yellow-400 glow-dot\" data-kid=\"41\"></span>\n            <span class=\"text-sm text-slate-400\" data-kid=\"42\">Attention Required</span>\n          </div>\n        </div>\n\n        <div class=\"relative pl-12 space-y-6\" data-kid=\"43\">\n          <div class=\"timeline-line\" data-kid=\"44\"></div>\n\n          \n          <div class=\"relative bill-card group stagger-reveal\" data-kid=\"45\">\n            <div class=\"absolute -left-[36px] top-1/2 -translate-y-1/2 w-4 h-4 rounded-full bg-yellow-400 glow-dot z-10 border-4 border-navy-dark\" data-kid=\"46\"></div>\n            <div class=\"glass-effect-child glass-effect rounded-[2rem] p-6 flex items-center justify-between hover:border-indigo-500/60 transition-all duration-300\" data-kid=\"47\">\n              <div class=\"flex items-center gap-6\" data-kid=\"48\">\n                <div class=\"w-16 h-16 rounded-[1.25rem] bg-yellow-400/10 flex items-center justify-center text-yellow-400\" data-kid=\"49\">\n                  <i class=\"ti ti-bolt text-3xl\" data-kid=\"50\"></i>\n                </div>\n                <div data-kid=\"51\">\n                  <div class=\"flex items-center gap-2 mb-1\" data-kid=\"52\">\n                    <h4 class=\"text-white font-bold text-xl\" data-kid=\"53\">Electricity Bill</h4>\n                    <span class=\"text-[10px] font-bold text-indigo-400 bg-indigo-500/10 px-2 py-0.5 rounded border border-indigo-500/20 uppercase\" data-kid=\"54\">Overdue</span>\n                  </div>\n                  <p class=\"text-slate-400 text-sm\" data-kid=\"55\">North Grid Energy • Oct 24, 2024</p>\n                </div>\n              </div>\n              <div class=\"flex items-center gap-8\" data-kid=\"56\">\n                <div class=\"text-right\" data-kid=\"57\">\n                  <p class=\"text-2xl font-bold font-heading text-white\" data-val=\"142.50\" data-kid=\"58\">$0.00</p>\n                  <p class=\"text-xs font-bold text-yellow-400/80 uppercase\" data-kid=\"59\">Action Required</p>\n                </div>\n                <button class=\"px-8 py-3.5 rounded-2xl bg-indigo-600 text-white font-bold shadow-lg shadow-indigo-600/20 hover:bg-indigo-500 transition-all active:scale-95\" data-kid=\"60\">\n                  Pay Now\n                </button>\n              </div>\n            </div>\n          </div>\n\n          \n          <div class=\"relative space-y-3\" data-kid=\"61\">\n            \n            <div class=\"relative bill-card group stagger-reveal\" data-kid=\"62\">\n              <div class=\"absolute -left-[36px] top-1/2 -translate-y-1/2 w-4 h-4 rounded-full bg-indigo-500/40 z-10 border-4 border-navy-dark\" data-kid=\"63\"></div>\n              <div class=\"glass-effect-child glass-effect rounded-2xl p-5 flex items-center justify-between hover:bg-white/[0.04] transition-all duration-300 border-white/5\" data-kid=\"64\">\n                <div class=\"flex items-center gap-4\" data-kid=\"65\">\n                  <div class=\"w-12 h-12 rounded-xl bg-white/5 flex items-center justify-center text-slate-400 group-hover:text-indigo-400 transition-colors\" data-kid=\"66\">\n                    <i class=\"ti ti-home text-2xl\" data-kid=\"67\"></i>\n                  </div>\n                  <div data-kid=\"68\">\n                    <h4 class=\"text-white font-bold\" data-kid=\"69\">Monthly Rent</h4>\n                    <p class=\"text-slate-500 text-xs\" data-kid=\"70\">Downtown Residences • Nov 01</p>\n                  </div>\n                </div>\n                <div class=\"flex items-center gap-6\" data-kid=\"71\">\n                   <div class=\"text-right\" data-kid=\"72\">\n                     <p class=\"text-lg font-bold font-heading text-white/90\" data-val=\"2400.00\" data-kid=\"73\">$0.00</p>\n                     <p class=\"text-[10px] font-bold text-indigo-400/60 uppercase\" data-kid=\"74\">Scheduled</p>\n                   </div>\n                   <button class=\"w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center text-slate-400 hover:bg-white/10 hover:text-white transition-all\" data-kid=\"75\">\n                      <i class=\"ti ti-dots\" data-kid=\"76\"></i>\n                   </button>\n                </div>\n              </div>\n            </div>\n\n            \n            <div class=\"relative bill-card group stagger-reveal\" data-kid=\"77\">\n              <div class=\"absolute -left-[36px] top-1/2 -translate-y-1/2 w-4 h-4 rounded-full bg-blue-500/40 z-10 border-4 border-navy-dark\" data-kid=\"78\"></div>\n              <div class=\"glass-effect-child glass-effect rounded-2xl p-5 flex items-center justify-between hover:bg-white/[0.04] transition-all duration-300 border-white/5\" data-kid=\"79\">\n                <div class=\"flex items-center gap-4\" data-kid=\"80\">\n                  <div class=\"w-12 h-12 rounded-xl bg-white/5 flex items-center justify-center text-slate-400 group-hover:text-blue-400 transition-colors\" data-kid=\"81\">\n                    <i class=\"ti ti-world text-2xl\" data-kid=\"82\"></i>\n                  </div>\n                  <div data-kid=\"83\">\n                    <h4 class=\"text-white font-bold\" data-kid=\"84\">Internet & Fiber</h4>\n                    <p class=\"text-slate-500 text-xs\" data-kid=\"85\">Starlink Home • Nov 05</p>\n                  </div>\n                </div>\n                <div class=\"flex items-center gap-6\" data-kid=\"86\">\n                   <div class=\"text-right\" data-kid=\"87\">\n                     <p class=\"text-lg font-bold font-heading text-white/90\" data-val=\"89.99\" data-kid=\"88\">$0.00</p>\n                     <p class=\"text-[10px] font-bold text-blue-400/60 uppercase\" data-kid=\"89\">Processing</p>\n                   </div>\n                   <button class=\"w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center text-slate-400 hover:bg-white/10 hover:text-white transition-all\" data-kid=\"90\">\n                      <i class=\"ti ti-dots\" data-kid=\"91\"></i>\n                   </button>\n                </div>\n              </div>\n            </div>\n\n            \n            <div class=\"relative bill-card group stagger-reveal\" data-kid=\"92\">\n              <div class=\"absolute -left-[36px] top-1/2 -translate-y-1/2 w-4 h-4 rounded-full bg-emerald-500/40 z-10 border-4 border-navy-dark\" data-kid=\"93\"></div>\n              <div class=\"glass-effect-child glass-effect rounded-2xl p-5 flex items-center justify-between hover:bg-white/[0.04] transition-all duration-300 border-white/5\" data-kid=\"94\">\n                <div class=\"flex items-center gap-4\" data-kid=\"95\">\n                  <div class=\"w-12 h-12 rounded-xl bg-white/5 flex items-center justify-center text-slate-400 group-hover:text-emerald-400 transition-colors\" data-kid=\"96\">\n                    <i class=\"ti ti-shield-check text-2xl\" data-kid=\"97\"></i>\n                  </div>\n                  <div data-kid=\"98\">\n                    <h4 class=\"text-white font-bold\" data-kid=\"99\">Life Insurance</h4>\n                    <p class=\"text-slate-500 text-xs\" data-kid=\"100\">Global Protection • Oct 12</p>\n                  </div>\n                </div>\n                <div class=\"flex items-center gap-6\" data-kid=\"101\">\n                   <div class=\"text-right\" data-kid=\"102\">\n                     <p class=\"text-lg font-bold font-heading text-white/90\" data-val=\"215.00\" data-kid=\"103\">$0.00</p>\n                     <p class=\"text-[10px] font-bold text-emerald-400/60 uppercase\" data-kid=\"104\">Paid</p>\n                   </div>\n                   <button class=\"w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center text-slate-400 hover:bg-white/10 hover:text-white transition-all\" data-kid=\"105\">\n                      <i class=\"ti ti-receipt\" data-kid=\"106\"></i>\n                   </button>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      \n      <aside class=\"col-span-12 lg:col-span-5 space-y-10\" data-kid=\"107\">\n        \n        \n        <section class=\"glass-effect rounded-[2.5rem] p-8 stagger-reveal\" data-kid=\"108\">\n          <div class=\"flex items-center justify-between mb-8\" data-kid=\"109\">\n            <div data-kid=\"110\">\n              <h3 class=\"text-xl font-bold font-heading\" data-kid=\"111\">Spending Trends</h3>\n              <p class=\"text-slate-500 text-sm\" data-kid=\"112\">Last 6 months breakdown</p>\n            </div>\n            <div class=\"flex bg-white/5 p-1 rounded-xl\" data-kid=\"113\">\n              <button class=\"px-4 py-1.5 rounded-lg bg-indigo-600 text-white text-xs font-bold shadow-lg\" data-kid=\"114\">6M</button>\n              <button class=\"px-4 py-1.5 rounded-lg text-slate-400 text-xs font-bold hover:text-white transition-colors\" data-kid=\"115\">1Y</button>\n            </div>\n          </div>\n          \n          <div class=\"h-[280px] w-full relative\" data-kid=\"116\">\n            <canvas id=\"historyChart\" data-kid=\"117\"></canvas>\n          </div>\n\n          <div class=\"grid grid-cols-2 gap-4 mt-8\" data-kid=\"118\">\n            <div class=\"p-4 rounded-2xl bg-white/5 border border-white/5\" data-kid=\"119\">\n              <p class=\"text-slate-500 text-[10px] font-bold uppercase mb-1\" data-kid=\"120\">Average Monthly</p>\n              <p class=\"text-xl font-bold font-heading text-white\" data-kid=\"121\">$2,142</p>\n            </div>\n            <div class=\"p-4 rounded-2xl bg-white/5 border border-white/5\" data-kid=\"122\">\n              <p class=\"text-slate-500 text-[10px] font-bold uppercase mb-1\" data-kid=\"123\">Yearly Forecast</p>\n              <p class=\"text-xl font-bold font-heading text-white\" data-kid=\"124\">$25.7k</p>\n            </div>\n          </div>\n        </section>\n\n        \n        <section class=\"space-y-6 stagger-reveal\" data-kid=\"125\">\n          <h3 class=\"text-xl font-bold font-heading\" data-kid=\"126\">Quick Insights</h3>\n          \n          \n          <div class=\"p-6 rounded-[2rem] glass-effect flex items-center justify-between group cursor-pointer hover:border-indigo-500/40 transition-all\" data-kid=\"127\">\n            <div class=\"flex items-center gap-4\" data-kid=\"128\">\n              <div class=\"w-12 h-12 rounded-xl bg-cyan-500/10 flex items-center justify-center text-cyan-400\" data-kid=\"129\">\n                <i class=\"ti ti-droplet-filled text-xl\" data-kid=\"130\"></i>\n              </div>\n              <div data-kid=\"131\">\n                <p class=\"text-white font-bold\" data-kid=\"132\">Water Utilities</p>\n                <p class=\"text-slate-500 text-xs font-medium\" data-kid=\"133\">Billed quarterly • Oct 30</p>\n              </div>\n            </div>\n            <p class=\"text-lg font-bold font-heading text-white\" data-kid=\"134\">$45.20</p>\n          </div>\n\n          \n          <div class=\"relative p-8 rounded-[2.5rem] bg-indigo-950/40 border border-indigo-500/20 overflow-hidden group\" data-kid=\"135\">\n             <div class=\"flex items-start justify-between mb-8\" data-kid=\"136\">\n                <div class=\"w-12 h-12 rounded-2xl bg-indigo-500/10 flex items-center justify-center text-indigo-400\" data-kid=\"137\">\n                   <i class=\"ti ti-chart-arrows text-2xl\" data-kid=\"138\"></i>\n                </div>\n                <span class=\"px-3 py-1 rounded-full bg-amber-500/10 text-amber-500 text-[10px] font-bold uppercase tracking-widest border border-amber-500/20\" data-kid=\"139\">Anomaly Detected</span>\n             </div>\n             <h4 class=\"text-xl font-bold font-heading text-white mb-3 leading-tight\" data-kid=\"140\">Monthly Variance Alert</h4>\n             <p class=\"text-indigo-100/60 text-sm mb-8 leading-relaxed\" data-kid=\"141\">\n                Electricity usage is <span class=\"text-amber-400 font-bold\" data-kid=\"142\">14% higher</span> than Oct 2023. This typically correlates with thermostat settings.\n             </p>\n             <div class=\"flex items-center gap-3 p-4 rounded-2xl bg-white/5 border border-white/5 mb-6\" data-kid=\"143\">\n                <div class=\"w-1 bg-amber-500 h-8 rounded-full\" data-kid=\"144\"></div>\n                <div data-kid=\"145\">\n                   <p class=\"text-slate-500 text-[10px] font-bold uppercase\" data-kid=\"146\">Estimated Impact</p>\n                   <p class=\"text-white font-bold\" data-kid=\"147\">+$18.40 / mo</p>\n                </div>\n             </div>\n             <button class=\"w-full py-4 rounded-2xl bg-white text-indigo-950 font-bold hover:bg-indigo-50 transition-all shadow-xl active:scale-95\" data-kid=\"148\">\n                Review Smart Thermostat\n             </button>\n          </div>\n        </section>\n\n      </aside>\n    </div>\n  </main>\n</div>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"149\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"150\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/chart.js\" data-kid=\"151\"></script>\n<script type=\"module\" data-kid=\"152\">\n  import { animate, scroll, hover } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n  import { animate as animeAnimate } from 'https://esm.sh/animejs@4';\n  import Lenis from \"https://esm.sh/lenis@1\"\n\n  // Smooth Scroll\n  const lenis = new Lenis();\n  function raf(time) {\n    lenis.raf(time);\n    requestAnimationFrame(raf);\n  }\n  requestAnimationFrame(raf);\n\n  // Stagger Reveal GSAP\n  gsap.set(\".stagger-reveal\", { opacity: 0, y: 30 });\n  gsap.to(\".stagger-reveal\", {\n    y: 0,\n    opacity: 1,\n    duration: 1.2,\n    stagger: 0.1,\n    ease: \"expo.out\",\n    scrollTrigger: {\n      trigger: \"main\",\n      start: \"top 80%\",\n    }\n  });\n\n  // MotionJS Hovers - Applied to child to avoid GSAP conflict\n  hover(\".glass-effect-child\", (el) => {\n    animate(el, { scale: 1.01, backgroundColor: \"rgba(255, 255, 255, 0.06)\" }, { duration: 0.3 });\n    return () => animate(el, { scale: 1, backgroundColor: \"rgba(255, 255, 255, 0.03)\" }, { duration: 0.3 });\n  });\n\n  // Counter Animation - Fixed hook for v4\n  document.querySelectorAll('[data-val]').forEach(el => {\n    const target = parseFloat(el.getAttribute('data-val'));\n    const state = { value: 0 };\n    animeAnimate(state, {\n      value: target,\n      duration: 2000,\n      easing: 'easeOutExpo',\n      onUpdate: () => {\n        el.textContent = '$' + state.value.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });\n      }\n    });\n  });\n\n  // Chart Implementation\n  const ctx = document.getElementById('historyChart').getContext('2d');\n  const gradient = ctx.createLinearGradient(0, 0, 0, 280);\n  gradient.addColorStop(0, 'rgba(99, 102, 241, 0.4)');\n  gradient.addColorStop(1, 'rgba(99, 102, 241, 0)');\n\n  new Chart(ctx, {\n    type: 'line',\n    data: {\n      labels: ['May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct'],\n      datasets: [{\n        label: 'Bill Spending',\n        data: [1850, 2100, 1950, 2400, 2200, 2840],\n        borderColor: '#6366f1',\n        borderWidth: 3,\n        tension: 0.4,\n        fill: true,\n        backgroundColor: gradient,\n        pointBackgroundColor: '#6366f1',\n        pointBorderColor: 'rgba(2, 6, 23, 1)',\n        pointBorderWidth: 3,\n        pointRadius: 0,\n        pointHoverRadius: 6,\n        pointHoverBackgroundColor: '#fff',\n      }]\n    },\n    options: {\n      responsive: true,\n      maintainAspectRatio: false,\n      interaction: {\n        intersect: false,\n        mode: 'index',\n      },\n      plugins: {\n        legend: { display: false },\n        tooltip: {\n          backgroundColor: '#0f172a',\n          titleFont: { family: 'Manrope', size: 14 },\n          bodyFont: { family: 'DM Sans', size: 13 },\n          padding: 12,\n          cornerRadius: 12,\n          displayColors: false\n        }\n      },\n      scales: {\n        y: {\n          beginAtZero: false,\n          grid: { color: 'rgba(255, 255, 255, 0.05)', drawBorder: false },\n          ticks: { color: 'rgba(255, 255, 255, 0.2)', font: { size: 10, family: 'DM Sans' }, padding: 10 }\n        },\n        x: {\n          grid: { display: false },\n          ticks: { color: 'rgba(255, 255, 255, 0.2)', font: { size: 10, family: 'DM Sans' }, padding: 10 }\n        }\n      }\n    }\n  });\n</script>\n",
