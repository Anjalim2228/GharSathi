 border-white/60 hover:bg-white transition-all cursor-pointer\" data-kid=\"215\">\n                        <img src=\"https://i.pravatar.cc/150?u=doc1\" class=\"w-10 h-10 rounded-full border-2 border-white\" alt=\"Doctor\" data-kid=\"216\">\n                        <div class=\"flex-1\" data-kid=\"217\">\n                            <h4 class=\"text-xs font-bold\" data-kid=\"218\">Dr. Sarah Chen</h4>\n                            <p class=\"text-[9px] text-[#011F5B]/40 font-semibold uppercase\" data-kid=\"219\">Family Physician</p>\n                        </div>\n                        <button class=\"w-8 h-8 rounded-full bg-blue-500/10 text-blue-600 flex items-center justify-center hover:bg-blue-500 hover:text-white transition-all\" data-kid=\"220\">\n                            <i class=\"ti ti-phone text-sm\" data-kid=\"221\"></i>\n                        </button>\n                    </div>\n                    <div class=\"flex items-center gap-4 bg-red-500/5 p-3 rounded-2xl border border-red-500/10 hover:bg-red-500/10 transition-all cursor-pointer\" data-kid=\"222\">\n                        <div class=\"w-10 h-10 rounded-full bg-red-500 text-white flex items-center justify-center\" data-kid=\"223\">\n                            <i class=\"ti ti-phone-calling text-lg\" data-kid=\"224\"></i>\n                        </div>\n                        <div class=\"flex-1\" data-kid=\"225\">\n                            <h4 class=\"text-xs font-bold text-red-600\" data-kid=\"226\">Emergency Dispatch</h4>\n                            <p class=\"text-[9px] text-red-500/60 font-semibold uppercase\" data-kid=\"227\">Quick Call (911)</p>\n                        </div>\n                    </div>\n                </div>\n            </section>\n        </div>\n    </main>\n\n    \n    <div class=\"fixed bottom-8 right-8 z-[60] flex flex-col items-end gap-4 pointer-events-none\" data-kid=\"228\">\n        <div class=\"relative pointer-events-auto cursor-pointer group\" id=\"assistantOrb\" data-kid=\"229\">\n            <div class=\"absolute inset-0 bg-blue-500/10 rounded-full blur-2xl group-hover:bg-blue-500/20 transition-all\" data-kid=\"230\"></div>\n            <div class=\"w-14 h-14 rounded-full bg-[#011F5B] flex items-center justify-center text-white relative z-10 border-2 border-white/50 shadow-2xl\" data-kid=\"231\">\n                <i class=\"ti ti-microphone text-xl\" data-kid=\"232\"></i>\n            </div>\n        </div>\n    </div>\n\n    \n    <div id=\"sosModal\" class=\"fixed inset-0 z-[100] hidden items-center justify-center px-4 bg-red-600/20 backdrop-blur-xl\" data-kid=\"233\">\n        <div class=\"glass p-10 rounded-[3.5rem] max-w-md w-full text-center space-y-8 border-4 border-red-500/50 shadow-[0_0_100px_rgba(239,68,68,0.5)]\" data-kid=\"234\">\n            <div class=\"w-24 h-24 bg-red-600 rounded-full mx-auto flex items-center justify-center text-white sos-pulse\" data-kid=\"235\">\n                <i class=\"ti ti-urgent text-5xl\" data-kid=\"236\"></i>\n            </div>\n            <div data-kid=\"237\">\n                <h2 class=\"text-3xl font-black text-red-600 uppercase tracking-tighter\" data-kid=\"238\">Emergency Alert</h2>\n                <p class=\"text-lg font-bold text-[#011F5B] mt-2\" data-kid=\"239\">Alerting Emergency Services in 5s...</p>\n            </div>\n            <div class=\"space-y-4\" data-kid=\"240\">\n                <div class=\"w-full h-3 bg-red-100 rounded-full overflow-hidden\" data-kid=\"241\">\n                    <div id=\"sosProgress\" class=\"h-full bg-red-600 w-full transition-all duration-[5000ms] ease-linear\" data-kid=\"242\"></div>\n                </div>\n                <button id=\"cancelSos\" class=\"w-full py-4 rounded-2xl bg-[#011F5B] text-white font-bold hover:bg-black transition-colors\" data-kid=\"243\">CANCEL (Tap anywhere)</button>\n            </div>\n        </div>\n    </div>\n\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"244\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/chart.js\" data-kid=\"245\"></script>\n\n    <script data-kid=\"246\">\n        // Entrance Animations\n        window.addEventListener('load', () => {\n            gsap.from(\".stagger-item\", {\n                duration: 1.2,\n                y: 60,\n                opacity: 0,\n                stagger: 0.2,\n                ease: \"power4.out\"\n            });\n        });\n\n        // Initialize Vitals Chart\n        const ctx = document.getElementById('vitalsChart').getContext('2d');\n        const gradient = ctx.createLinearGradient(0, 0, 0, 400);\n        gradient.addColorStop(0, 'rgba(239, 68, 68, 0.25)');\n        gradient.addColorStop(1, 'rgba(239, 68, 68, 0)');\n\n        const blueGradient = ctx.createLinearGradient(0, 0, 0, 400);\n        blueGradient.addColorStop(0, 'rgba(1, 31, 91, 0.15)');\n        blueGradient.addColorStop(1, 'rgba(1, 31, 91, 0)');\n\n        new Chart(ctx, {\n            type: 'line',\n            data: {\n                labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],\n                datasets: [\n                    {\n                        label: 'Physical Activity',\n                        data: [65, 59, 105, 81, 56, 120, 75],\n                        borderColor: '#011F5B',\n                        backgroundColor: blueGradient,\n                        fill: true,\n                        tension: 0.4,\n                        borderWidth: 4,\n                        pointRadius: 6,\n                        pointBackgroundColor: '#fff',\n                        pointBorderColor: '#011F5B',\n                        pointBorderWidth: 2\n                    },\n                    {\n                        label: 'Vital Stability',\n                        data: [70, 78, 71, 85, 70, 88, 71],\n                        borderColor: '#EF4444',\n                        backgroundColor: gradient,\n                        fill: true,\n                        tension: 0.4,\n                        borderWidth: 4,\n                        pointRadius: 0\n                    }\n                ]\n            },\n            options: {\n                responsive: true,\n                maintainAspectRatio: false,\n                plugins: {\n                    legend: { display: false }\n                },\n                scales: {\n                    x: {\n                        grid: { display: false },\n                        ticks: { font: { weight: '600' }, color: '#011F5B66' }\n                    },\n                    y: {\n                        display: false,\n                        beginAtZero: true\n                    }\n                }\n            }\n        });\n\n        // SOS Button Interaction (Long Press)\n        const sosBtn = document.getElementById('sosButton');\n        const sosModal = document.getElementById('sosModal');\n        const cancelSos = document.getElementById('cancelSos');\n        const sosProgress = document.getElementById('sosProgress');\n        let sosTimer;\n\n        sosBtn.addEventListener('mousedown', startSos);\n        sosBtn.addEventListener('touchstart', startSos);\n        \n        window.addEventListener('mouseup', endSos);\n        window.addEventListener('touchend', endSos);\n\n        function startSos() {\n            gsap.to(sosBtn, { scale: 1.1, duration: 0.3 });\n            sosTimer = setTimeout(() => {\n                sosModal.style.display = 'flex';\n                sosProgress.style.width = '0%';\n            }, 800);\n        }\n\n        function endSos() {\n            clearTimeout(sosTimer);\n            gsap.to(sosBtn, { scale: 1, duration: 0.3 });\n        }\n\n        cancelSos.addEventListener('click', () => {\n            sosModal.style.display = 'none';\n        });\n\n        sosModal.addEventListener('click', (e) => {\n            if(e.target === sosModal) sosModal.style.display = 'none';\n        });\n\n        // Assistant Orb Interaction\n        document.getElementById('assistantOrb').addEventListener('click', () => {\n            gsap.to(\"#assistantOrb\", { scale: 0.9, duration: 0.1, yoyo: true, repeat: 1 });\n        });\n    </script>\n</div>\n",
