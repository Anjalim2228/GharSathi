lass=\"flex-1 min-w-0\" data-kid=\"152\">\n                <div class=\"flex items-center gap-2 mb-1\" data-kid=\"153\">\n                  <span class=\"text-[10px] font-black uppercase tracking-tighter text-rose-500\" data-kid=\"154\">Expiring Soon</span>\n                  <span class=\"w-1 h-1 bg-rose-500 rounded-full animate-pulse\" data-kid=\"155\"></span>\n                </div>\n                <h4 class=\"font-bold text-sm truncate\" data-kid=\"156\">Passport (Anjali Sharma)</h4>\n                <p class=\"text-xs text-white/50 mt-1\" data-kid=\"157\">28 days remaining for renewal.</p>\n                <div class=\"mt-4 flex gap-2\" data-kid=\"158\">\n                  <button class=\"bg-rose-500 text-black text-[10px] font-black uppercase px-4 py-2 rounded-lg hover:bg-rose-400 transition-colors\" data-kid=\"159\">Renew Now</button>\n                  <button class=\"bg-white/5 text-white/60 text-[10px] font-black uppercase px-4 py-2 rounded-lg hover:bg-white/10 transition-colors\" data-kid=\"160\">Dismiss</button>\n                </div>\n              </div>\n            </div>\n\n            \n            <div class=\"relative overflow-hidden p-5 rounded-3xl bg-teal-500/5 border border-teal-500/20 flex items-start gap-4 alert-item\" data-kid=\"161\">\n              <div class=\"w-10 h-10 rounded-xl bg-teal-500/20 text-teal-400 flex items-center justify-center flex-shrink-0\" data-kid=\"162\">\n                <i class=\"ti ti-key text-xl\" data-kid=\"163\"></i>\n              </div>\n              <div class=\"flex-1 min-w-0\" data-kid=\"164\">\n                <div class=\"flex items-center gap-2 mb-1\" data-kid=\"165\">\n                  <span class=\"text-[10px] font-black uppercase tracking-tighter text-teal-400\" data-kid=\"166\">Security Check</span>\n                </div>\n                <h4 class=\"font-bold text-sm truncate\" data-kid=\"167\">Update Vault Recovery</h4>\n                <p class=\"text-xs text-white/50 mt-1\" data-kid=\"168\"