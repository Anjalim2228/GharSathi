      "html": "\n<div class=\"min-h-screen bg-[#F8F9FA] font-['DM_Sans'] text-[#011F5B] overflow-x-clip selection:bg-blue-500/30 relative\" data-kid=\"0\">\n    \n    \n    <div class=\"fixed top-[-10%] left-[-10%] w-[40%] h-[40%] bg-blue-500/[0.03] rounded-full blur-[120px] pointer-events-none\" data-kid=\"1\"></div>\n    <div class=\"fixed bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-blue-900/[0.03] rounded-full blur-[150px] pointer-events-none\" data-kid=\"2\"></div>\n\n    <style data-kid=\"3\">\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=DM+Sans:wght@400;500;700&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n        .glass {\n            background: rgba(255, 255, 255, 0.45);\n            backdrop-filter: blur(40px);\n            -webkit-backdrop-filter: blur(40px);\n            border: 1px solid rgba(255, 255, 255, 0.6);\n            box-shadow: 0 10px 40px -10px rgba(1, 31, 91, 0.04);\n        }\n        .no-scrollbar::-webkit-scrollbar { display: none; }\n        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n\n        .scanning-line {\n            animation: scan 3s infinite ease-in-out;\n        }\n        @keyframes scan {\n            0% { top: 0; opacity: 0; }\n            10% { opacity: 1; }\n            90% { opacity: 1; }\n            100% { top: 100%; opacity: 0; }\n        }\n\n        .pill-active {\n            box-shadow: 0 10px 25px -5px rgba(1, 31, 91, 0.2);\n        }\n\n        .sidebar-transition {\n            transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);\n        }\n    </style>\n\n    \n    <nav class=\"sticky top-0 z-40 px-8 py-4 flex items-center justify-between glass border-b border-white/50 mb-6\" data-kid=\"4\">\n        <div class=\"flex items-center gap-3\" data-kid=\"5\">\n            <div class=\"w-10 h-10 bg-[#011F5B] rounded-xl flex items-center justify-center text-white shadow-lg shadow-[#011F5B]/20\" data-kid=\"6\">\n                <i class=\"ti ti-pill text-xl\" data-kid=\"7\"></i>\n            </div>\n            <h1 class=\"text-2xl font-bold font-['Inter'] tracking-tight\" data-kid=\"8\">HomeHero <span class=\"text-blue-600\" data-kid=\"9\">Meds</span></h1>\n        </div>\n        \n        <div class=\"hidden lg:flex items-center gap-8\" data-kid=\"10\">\n            <a href=\"#\" class=\"text-sm font-bold opacity-100 text-blue-600 flex items-center gap-2\" data-kid=\"11\">\n                <span class=\"w-1.5 h-1.5 rounded-full bg-blue-600\" data-kid=\"12\"></span> Medication Manager\n            </a>\n            <a href=\"#\" class=\"text-sm font-bold opacity-50 hover:opacity-100 transition-opacity\" data-kid=\"13\">Schedule</a>\n            <a href=\"#\" class=\"text-sm font-bold opacity-50 hover:opacity-100 transition-opacity\" data-kid=\"14\">Pharmacy Connect</a>\n            <a href=\"#\" class=\"text-sm font-bold opacity-50 hover:opacity-100 transition-opacity\" data-kid=\"15\">History</a>\n        </div>\n\n        <div class=\"flex items-center gap-4\" data-kid=\"16\">\n            <div class=\"w-10 h-10 rounded-full border border-black/5 flex items-center justify-center text-[#011F5B]/60 hover:text-blue-600 transition-colors cursor-pointer\" data-kid=\"17\">\n                <i class=\"ti ti-bell text-xl\" data-kid=\"18\"></i>\n            </div>\n            <img src=\"https://i.pravatar.cc/150?u=Anjali\" class=\"w-10 h-10 rounded-full border-2 border-blue-500/20 p-0.5\" alt=\"User\" data-kid=\"19\">\n        </div>\n    </nav>\n\n    <main class=\"max-w-[1440px] mx-auto px-8 pb-20\" data-kid=\"20\">\n        \n        \n        <div class=\"flex items-center gap-4 mb-10 overflow-x-auto pb-4 no-scrollbar\" data-kid=\"21\">\n            <button class=\"flex items-center gap-3 px-6 py-3 rounded-full bg-[#011F5B] text-white pill-active shrink-0 cursor-pointer\" data-kid=\"22\">\n                <img src=\"https://i.pravatar.cc/150?u=Anjali\" class=\"w-8 h-8 rounded-full border border-white/20\" alt=\"Anjali\" data-kid=\"23\">\n                <span class=\"font-bold text-sm\" data-kid=\"24\">Anjali (Self)</span>\n            </button>\n            <button class=\"flex items-center gap-3 px-6 py-3 rounded-full bg-white text-[#011F5B] border border-black/5 hover:border-blue-500/30 transition-all shrink-0 cursor-pointer group\" data-kid=\"25\">\n                <img src=\"https://i.pravatar.cc/150?u=Rahul\" class=\"w-8 h-8 rounded-full border border-black/5 group-hover:scale-105 transition-transform\" alt=\"Rahul\" data-kid=\"26\">\n                <span class=\"font-bold text-sm\" data-kid=\"27\">Rahul</span>\n            </button>\n            <button class=\"flex items-center gap-3 px-6 py-3 rounded-full bg-white text-[#011F5B] border border-black/5 hover:border-blue-500/30 transition-all shrink-0 cursor-pointer group\" data-kid=\"28\">\n                <img src=\"https://i.pravatar.cc/150?u=Aarav\" class=\"w-8 h-8 rounded-full border border-black/5 group-hover:scale-105 transition-transform\" alt=\"Aarav\" data-kid=\"29\">\n                <span class=\"font-bold text-sm\" data-kid=\"30\">Aarav</span>\n            </button>\n            <button class=\"w-12 h-12 rounded-full border-2 border-dashed border-black/10 flex items-center justify-center text-black/30 hover:text-blue-500 hover:border-blue-500/30 transition-all shrink-0 cursor-pointer\" data-kid=\"31\">\n                <i class=\"ti ti-plus\" data-kid=\"32\"></i>\n            </button>\n        </div>\n\n        <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-10 items-start\" data-kid=\"33\">\n            \n            \n            <div class=\"lg:col-span-8 space-y-12\" data-kid=\"34\">\n                \n                \n                <section class=\"stagger-item\" data-kid=\"35\">\n                    <div class=\"flex items-center justify-between mb-8\" data-kid=\"36\">\n                        <div data-kid=\"37\">\n                            <div class=\"flex items-center gap-3\" data-kid=\"38\">\n                                <i class=\"ti ti-clock-play text-2xl text-blue-600\" data-kid=\"39\"></i>\n                                <h2 class=\"text-2xl font-bold font-['Inter']\" data-kid=\"40\">Daily Pill Box</h2>\n                            </div>\n                            <p class=\"text-[10px] font-bold text-blue-900/40 uppercase tracking-[0.2em] mt-1 ml-9\" data-kid=\"41\">3 Meds Scheduled • 33% Done</p>\n                        </div>\n                        <div class=\"flex gap-2 p-1 bg-black/5 rounded-xl\" data-kid=\"42\">\n                            <button class=\"px-4 py-1.5 bg-white rounded-lg text-xs font-bold shadow-sm\" data-kid=\"43\">Today</button>\n                            <button class=\"px-4 py-1.5 rounded-lg text-xs font-bold opacity-40\" data-kid=\"44\">Week</button>\n                        </div>\n                    </div>\n                    \n                    <div class=\"grid grid-cols-1 md:grid-cols-4 gap-6 items-stretch\" data-kid=\"45\">\n                        \n                        <div class=\"flex flex-col gap-4\" data-kid=\"46\">\n                            <div class=\"flex items-center gap-2 px-1 shrink-0\" data-kid=\"47\">\n                                <div class=\"w-8 h-8 rounded-lg bg-yellow-400/20 text-yellow-600 flex items-center justify-center\" data-kid=\"48\"><i class=\"ti ti-sun\" data-kid=\"49\"></i></div>\n                                <span class=\"text-xs font-bold text-[#011F5B] uppercase tracking-wider\" data-kid=\"50\">Morning</span>\n                            </div>\n                            <div class=\"flex-1 bg-white p-5 rounded-[2rem] border border-blue-50/50 shadow-sm border-l-4 border-l-yellow-400 hover:shadow-md transition-shadow cursor-pointer flex flex-col justify-between\" data-kid=\"51\">\n                                <div data-kid=\"52\">\n                                    <div class=\"flex justify-between items-start mb-2\" data-kid=\"53\">\n                                        <p class=\"text-sm font-bold text-[#011F5B]\" data-kid=\"54\">Metformin</p>\n                                        <i class=\"ti ti-circle-check text-green-500 text-lg\" data-kid=\"55\"></i>\n                                    </div>\n                                    <p class=\"text-xs text-blue-900/40 font-medium\" data-kid=\"56\">500mg • After Breakfast</p>\n                                </div>\n                                <div class=\"mt-4 text-[10px] font-bold text-green-600 flex items-center gap-1\" data-kid=\"57\">\n                                    <i class=\"ti ti-check\" data-kid=\"58\"></i> Taken at 08:30 AM\n                                </div>\n                            </div>\n                        </div>\n\n                        \n                        <div class=\"flex flex-col gap-4\" data-kid=\"59\">\n                            <div class=\"flex items-center gap-2 px-1 shrink-0\" data-kid=\"60\">\n                                <div class=\"w-8 h-8 rounded-lg bg-blue-400/20 text-blue-600 flex items-center justify-center\" data-kid=\"61\"><i class=\"ti ti-cloud\" data-kid=\"62\"></i></div>\n                                <span class=\"text-xs font-bold text-[#011F5B] uppercase tracking-wider\" data-kid=\"63\">Noon</span>\n                            </div>\n                            <div class=\"flex-1 min-h-[140px] bg-white/40 backdrop-blur-sm rounded-[2rem] border border-dashed border-black/10 flex flex-col items-center justify-center text-center p-4\" data-kid=\"64\">\n                                <i class=\"ti ti-zzz text-black/10 text-2xl mb-1\" data-kid=\"65\"></i>\n                                <span class=\"text-[10px] font-bold text-black/20\" data-kid=\"66\">No Meds Scheduled</span>\n                            </div>\n                        </div>\n\n                        \n                        <div class=\"flex flex-col gap-4\" data-kid=\"67\">\n                            <div class=\"flex items-center gap-2 px-1 shrink-0\" data-kid=\"68\">\n                                <div class=\"w-8 h-8 rounded-lg bg-orange-400/20 text-orange-600 flex items-center justify-center\" data-kid=\"69\"><i class=\"ti ti-sunset\" data-kid=\"70\"></i></div>\n                                <span class=\"text-xs font-bold text-[#011F5B] uppercase tracking-wider\" data-kid=\"71\">Evening</span>\n                            </div>\n                            <div class=\"flex-1 bg-white p-5 rounded-[2rem] border border-blue-50/50 shadow-sm border-l-4 border-l-orange-400 hover:shadow-md transition-shadow cursor-pointer flex flex-col justify-between group\" data-kid=\"72\">\n                                <div data-kid=\"73\">\n                                    <div class=\"flex justify-between items-start mb-2\" data-kid=\"74\">\n                                        <p class=\"text-sm font-bold text-[#011F5B]\" data-kid=\"75\">Vitamin D3</p>\n                                        <i class=\"ti ti-clock text-blue-400 text-lg\" data-kid=\"76\"></i>\n                                    </div>\n                                    <p class=\"text-xs text-blue-900/40 font-medium\" data-kid=\"77\">2000 IU • 06:00 PM</p>\n                                </div>\n                                <button class=\"mt-4 w-full py-2 bg-blue-50 text-blue-600 rounded-xl text-[10px] font-bold hover:bg-blue-600 hover:text-white transition-all\" data-kid=\"78\">Mark as Taken</button>\n                            </div>\n                        </div>\n\n                        \n                        <div class=\"flex flex-col gap-4\" data-kid=\"79\">\n                            <div class=\"flex items-center gap-2 px-1 shrink-0\" data-kid=\"80\">\n                                <div class=\"w-8 h-8 rounded-lg bg-indigo-400/20 text-indigo-600 flex items-center justify-center\" data-kid=\"81\"><i class=\"ti ti-moon\" data-kid=\"82\"></i></div>\n                                <span class=\"text-xs font-bold text-[#011F5B] uppercase tracking-wider\" data-kid=\"83\">Night</span>\n                            </div>\n                            <div class=\"flex-1 bg-white p-5 rounded-[2rem] border border-blue-50/50 shadow-sm border-l-4 border-l-indigo-400 hover:shadow-md transition-shadow cursor-pointer flex flex-col justify-between\" data-kid=\"84\">\n                                <div data-kid=\"85\">\n                                    <div class=\"flex justify-between items-start mb-2\" data-kid=\"86\">\n                                        <p class=\"text-sm font-bold text-[#011F5B]\" data-kid=\"87\">Atorvastatin</p>\n                                        <i class=\"ti ti-clock text-blue-400 text-lg\" data-kid=\"88\"></i>\n                                    </div>\n                                    <p class=\"text-xs text-blue-900/40 font-medium\" data-kid=\"89\">10mg • 09:30 PM</p>\n                                </div>\n                                <button class=\"mt-4 w-full py-2 bg-blue-50 text-blue-600 rounded-xl text-[10px] font-bold hover:bg-blue-600 hover:text-white transition-all\" data-kid=\"90\">Mark as Taken</button>\n                            </div>\n                        </div>\n                    </div>\n                </section>\n\n                \n                <section class=\"stagger-item\" data-kid=\"91\">\n                    <div class=\"flex items-center justify-between mb-8\" data-kid=\"92\">\n                        <div class=\"flex items-center gap-3\" data-kid=\"93\">\n                            <i class=\"ti ti-clipboard-list text-2xl text-blue-600\" data-kid=\"94\"></i>\n                            <h2 class=\"text-2xl font-bold font-['Inter']\" data-kid=\"95\">All Medications</h2>\n                        </div>\n                        <button class=\"flex items-center gap-2 text-sm font-bold text-blue-600 hover:bg-blue-50 px-4 py-2 rounded-xl transition-colors\" data-kid=\"96\">\n                            <i class=\"ti ti-adjustments-horizontal\" data-kid=\"97\"></i> Filter\n                        </button>\n                    </div>\n\n                    <div class=\"grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8\" data-kid=\"98\">\n                        \n                        <div class=\"bg-white/60 backdrop-blur-xl rounded-[2.5rem] border border-white p-6 shadow-sm hover:shadow-xl transition-all group flex flex-col h-full\" data-kid=\"99\">\n                            <div class=\"relative mb-5 overflow-hidden rounded-3xl h-44 bg-blue-50\" data-kid=\"100\">\n                                <img src=\"https://images.unsplash.com/photo-1584308666744-24d5c474f2ae?auto=format&w=600&q=80\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-700\" alt=\"Atorvastatin\" decoding=\"async\" loading=\"lazy\" data-kid=\"101\">\n                                <div class=\"absolute top-4 right-4 flex items-center gap-1.5 px-3 py-1 bg-red-500 text-white text-[10px] font-bold rounded-full uppercase tracking-wider shadow-lg animate-pulse\" data-kid=\"102\">\n                                    <i class=\"ti ti-pill\" data-kid=\"103\"></i> Low Stock\n                                </div>\n                            </div>\n                            <div class=\"flex-1 space-y-4\" data-kid=\"104\">\n                                <div class=\"flex justify-between items-start\" data-kid=\"105\">\n                                    <div data-kid=\"106\">\n                                        <h4 class=\"text-lg font-bold text-[#011F5B]\" data-kid=\"107\">Atorvastatin</h4>\n                                        <p class=\"text-xs text-blue-600 font-medium\" data-kid=\"108\">Cholesterol • 10mg</p>\n                                    </div>\n                                    <button onclick=\"toggleSidebar()\" class=\"w-9 h-9 rounded-full bg-blue-50 flex items-center justify-center text-blue-600 hover:bg-blue-600 hover:text-white transition-all shadow-sm cursor-pointer\" title=\"AI Med-Explain\" data-kid=\"109\">\n                                        <i class=\"ti ti-sparkles\" data-kid=\"110\"></i>\n                                    </button>\n                                </div>\n                                <div class=\"grid grid-cols-2 gap-4 pt-2\" data-kid=\"111\">\n                                    <div class=\"bg-blue-50/40 p-3 rounded-2xl border border-blue-100/50\" data-kid=\"112\">\n                                        <p class=\"text-[9px] text-blue-900/40 font-bold uppercase tracking-wider mb-1\" data-kid=\"113\">Inventory</p>\n                                        <p class=\"text-sm font-bold text-red-600\" data-kid=\"114\">4 Pills Left</p>\n                                    </div>\n                                    <div class=\"bg-blue-50/40 p-3 rounded-2xl border border-blue-100/50\" data-kid=\"115\">\n                                        <p class=\"text-[9px] text-blue-900/40 font-bold uppercase tracking-wider mb-1\" data-kid=\"116\">Expiry</p>\n                                        <p class=\"text-sm font-bold text-[#011F5B]\" data-kid=\"117\">Oct 2024</p>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n\n                        \n                        <div class=\"bg-white/60 backdrop-blur-xl rounded-[2.5rem] border border-white p-6 shadow-sm hover:shadow-xl transition-all group flex flex-col h-full\" data-kid=\"118\">\n                            <div class=\"relative mb-5 overflow-hidden rounded-3xl h-44 bg-blue-50\" data-kid=\"119\">\n                                <img src=\"https://images.unsplash.com/photo-1583459529363-23136202df35?auto=format&w=600&q=80\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-700\" alt=\"Metformin\" decoding=\"async\" loading=\"lazy\" data-kid=\"120\">\n                                <div class=\"absolute top-4 right-4 px-3 py-1 bg-green-500 text-white text-[10px] font-bold rounded-full uppercase tracking-wider shadow-lg\" data-kid=\"121\">In Stock</div>\n                            </div>\n                            <div class=\"flex-1 space-y-4\" data-kid=\"122\">\n                                <div class=\"flex justify-between items-start\" data-kid=\"123\">\n                                    <div data-kid=\"124\">\n                                        <h4 class=\"text-lg font-bold text-[#011F5B]\" data-kid=\"125\">Metformin</h4>\n                                        <p class=\"text-xs text-blue-600 font-medium\" data-kid=\"126\">Diabetes • 500mg</p>\n                                    </div>\n                                    <button onclick=\"toggleSidebar()\" class=\"w-9 h-9 rounded-full bg-blue-50 flex items-center justify-center text-blue-600 hover:bg-blue-600 hover:text-white transition-all shadow-sm cursor-pointer relative\" title=\"AI Med-Explain\" data-kid=\"127\">\n                                        <span class=\"absolute inset-0 rounded-full bg-blue-400/20 animate-ping\" data-kid=\"128\"></span>\n                                        <i class=\"ti ti-sparkles relative z-10\" data-kid=\"129\"></i>\n                                    </button>\n                                </div>\n                                <div class=\"grid grid-cols-2 gap-4 pt-2\" data-kid=\"130\">\n                                    <div class=\"bg-blue-50/40 p-3 rounded-2xl border border-blue-100/50\" data-kid=\"131\">\n                                        <p class=\"text-[9px] text-blue-900/40 font-bold uppercase tracking-wider mb-1\" data-kid=\"132\">Inventory</p>\n                                        <p class=\"text-sm font-bold text-green-600\" data-kid=\"133\">28 Pills Left</p>\n                                    </div>\n                                    <div class=\"bg-blue-50/40 p-3 rounded-2xl border border-blue-100/50\" data-kid=\"134\">\n                                        <p class=\"text-[9px] text-blue-900/40 font-bold uppercase tracking-wider mb-1\" data-kid=\"135\">Expiry</p>\n                                        <p class=\"text-sm font-bold text-[#011F5B]\" data-kid=\"136\">Jan 2026</p>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n\n                        \n                        <div class=\"rounded-[2.5rem] border-4 border-dashed border-blue-100/50 p-6 flex flex-col items-center justify-center text-center group cursor-pointer hover:border-blue-300 hover:bg-blue-50/30 transition-all h-full min-h-[360px]\" data-kid=\"137\">\n                            <div class=\"w-16 h-16 rounded-3xl bg-blue-50 text-blue-600 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform\" data-kid=\"138\">\n                                <i class=\"ti ti-plus text-3xl\" data-kid=\"139\"></i>\n                            </div>\n                            <h4 class=\"text-lg font-bold text-[#011F5B]\" data-kid=\"140\">Add New Medicine</h4>\n                            <p class=\"text-xs text-blue-900/40 mt-2 font-medium max-w-[200px]\" data-kid=\"141\">Manually enter drug details and set reminders</p>\n                        </div>\n                    </div>\n                </section>\n            </div>\n\n            \n            <div class=\"lg:col-span-4 h-full stagger-item\" data-kid=\"142\">\n                <div class=\"glass rounded-[3rem] overflow-hidden border border-white/80 shadow-2xl flex flex-col\" data-kid=\"143\">\n                    \n                    \n                    <div class=\"relative bg-[#011F5B] p-8 overflow-hidden group\" data-kid=\"144\">\n                        \n                        <div class=\"absolute inset-0 opacity-10 bg-[linear-gradient(rgba(255,255,255,0.1)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.1)_1px,transparent_1px)] [background-size:20px_20px]\" data-kid=\"145\"></div>\n                        \n                        <div class=\"relative z-10 text-center\" data-kid=\"146\">\n                            <div class=\"relative w-full aspect-video rounded-2xl border-2 border-blue-400/30 bg-black/20 mb-6 flex items-center justify-center overflow-hidden\" data-kid=\"147\">\n                                \n                                <div class=\"absolute top-4 left-4 w-6 h-6 border-t-2 border-l-2 border-white/60\" data-kid=\"148\"></div>\n                                <div class=\"absolute top-4 right-4 w-6 h-6 border-t-2 border-r-2 border-white/60\" data-kid=\"149\"></div>\n                                <div class=\"absolute bottom-4 left-4 w-6 h-6 border-b-2 border-l-2 border-white/60\" data-kid=\"150\"></div>\n                                <div class=\"absolute bottom-4 right-4 w-6 h-6 border-b-2 border-r-2 border-white/60\" data-kid=\"151\"></div>\n                                \n                                <div id=\"scanLine\" class=\"hidden absolute inset-x-0 top-0 h-0.5 bg-blue-400 shadow-[0_0_15px_rgba(96,165,250,1)] z-20 scanning-line\" data-kid=\"152\"></div>\n                                \n                                <div class=\"flex flex-col items-center\" data-kid=\"153\">\n                                    <div class=\"w-14 h-14 rounded-full bg-white/10 backdrop-blur-md flex items-center justify-center text-white mb-2 group-hover:scale-110 transition-transform\" data-kid=\"154\">\n                                        <i class=\"ti ti-camera-plus text-2xl\" data-kid=\"155\"></i>\n                                    </div>\n                                    <span class=\"text-[10px] font-bold text-white/40 uppercase tracking-widest\" data-kid=\"156\">Awaiting Capture</span>\n                                </div>\n                            </div>\n                            <h3 class=\"text-lg font-bold text-white mb-1\" data-kid=\"157\">Prescription AI-Scan</h3>\n                            <p class=\"text-xs text-white/50 font-medium mb-6\" data-kid=\"158\">Automated medicine detection</p>\n                            <button onclick=\"startScan()\" class=\"w-full py-4 bg-blue-600 text-white rounded-2xl font-bold text-sm hover:bg-white hover:text-[#011F5B] transition-all shadow-xl shadow-blue-900/20 active:scale-[0.98]\" data-kid=\"159\">\n                                Start Scanning\n                            </button>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"p-8 space-y-10 bg-white/40 backdrop-blur-xl\" data-kid=\"160\">\n                        \n                        \n                        <div data-kid=\"161\">\n                            <div class=\"flex items-center gap-3 mb-6\" data-kid=\"162\">\n                                <div class=\"w-10 h-10 rounded-2xl bg-blue-50 text-blue-600 flex items-center justify-center shadow-sm\" data-kid=\"163\">\n                                    <i class=\"ti ti-activity-heartbeat text-xl\" data-kid=\"164\"></i>\n                                </div>\n                                <h4 class=\"text-sm font-bold text-[#011F5B]\" data-kid=\"165\">Health Insights</h4>\n                            </div>\n                            \n                            <div class=\"space-y-6\" data-kid=\"166\">\n                                <div class=\"bg-white/60 p-5 rounded-2xl border border-white/80 shadow-sm\" data-kid=\"167\">\n                                    <div class=\"flex items-center justify-between mb-3\" data-kid=\"168\">\n                                        <span class=\"text-xs font-bold text-[#011F5B]/60\" data-kid=\"169\">Weekly Adherence</span>\n                                        <span class=\"text-sm font-bold text-green-600\" data-kid=\"170\">94%</span>\n                                    </div>\n                                    <div class=\"w-full h-2 bg-black/5 rounded-full overflow-hidden\" data-kid=\"171\">\n                                        <div class=\"h-full bg-green-500 w-[94%] rounded-full shadow-[0_0_8px_rgba(34,197,94,0.4)]\" data-kid=\"172\"></div>\n                                    </div>\n                                </div>\n\n                                <p class=\"text-sm text-blue-900/70 font-medium leading-relaxed italic border-l-2 border-blue-200 pl-4 py-1\" data-kid=\"173\">\n                                    \"Excellent work, Anjali! You've taken all your doses on time this week. Your cholesterol levels are likely stabilizing as expected.\"\n                                </p>\n                            </div>\n                        </div>\n\n                        \n                        <div data-kid=\"174\">\n                            <div class=\"flex items-center gap-3 mb-6\" data-kid=\"175\">\n                                <div class=\"w-10 h-10 rounded-2xl bg-blue-50 text-blue-600 flex items-center justify-center shadow-sm\" data-kid=\"176\">\n                                    <i class=\"ti ti-building-hospital text-xl\" data-kid=\"177\"></i>\n                                </div>\n                                <h4 class=\"text-sm font-bold text-[#011F5B]\" data-kid=\"178\">Pharmacy Support</h4>\n                            </div>\n                            <div class=\"grid grid-cols-1 gap-3\" data-kid=\"179\">\n                                <button class=\"w-full flex items-center justify-between p-4 bg-white/60 rounded-2xl border border-white/80 hover:border-blue-500/30 hover:bg-white transition-all text-left shadow-xs\" data-kid=\"180\">\n                                    <div class=\"flex items-center gap-3\" data-kid=\"181\">\n                                        <div class=\"w-9 h-9 bg-blue-50/50 rounded-xl flex items-center justify-center text-blue-600\" data-kid=\"182\">\n                                            <i class=\"ti ti-truck\" data-kid=\"183\"></i>\n                                        </div>\n                                        <span class=\"text-sm font-bold text-[#011F5B]\" data-kid=\"184\">Request Refills</span>\n                                    </div>\n                                    <i class=\"ti ti-chevron-right text-gray-300\" data-kid=\"185\"></i>\n                                </button>\n                                <button class=\"w-full flex items-center justify-between p-4 bg-white/60 rounded-2xl border border-white/80 hover:border-blue-500/30 hover:bg-white transition-all text-left shadow-xs\" data-kid=\"186\">\n                                    <div class=\"flex items-center gap-3\" data-kid=\"187\">\n                                        <div class=\"w-9 h-9 bg-blue-50/50 rounded-xl flex items-center justify-center text-blue-600\" data-kid=\"188\">\n                                            <i class=\"ti ti-message-2\" data-kid=\"189\"></i>\n                                        </div>\n                                        <span class=\"text-sm font-bold text-[#011F5B]\" data-kid=\"190\">Consult Pharmacist</span>\n                                    </div>\n                                    <i class=\"ti ti-chevron-right text-gray-300\" data-kid=\"191\"></i>\n                                </button>\n                            </div>\n                        </div>\n\n                    </div>\n                </div>\n            </div>\n        </div>\n    </main>\n\n    \n    <div id=\"sidebar\" class=\"fixed top-0 right-0 h-full w-[450px] bg-white z-[100] sidebar-transition translate-x-full shadow-[-20px_0_60px_rgba(1,31,91,0.1)] flex flex-col\" data-kid=\"192\">\n        <div class=\"absolute inset-0 bg-blue-500/[0.02] pointer-events-none\" data-kid=\"193\"></div>\n        \n        <div class=\"p-8 flex items-center justify-between border-b border-gray-100 relative bg-white/80 backdrop-blur-md\" data-kid=\"194\">\n            <div class=\"flex items-center gap-4\" data-kid=\"195\">\n                <div class=\"w-12 h-12 bg-blue-600 rounded-2xl flex items-center justify-center text-white shadow-xl shadow-blue-600/20\" data-kid=\"196\">\n                    <i class=\"ti ti-sparkles text-2xl\" data-kid=\"197\"></i>\n                </div>\n                <div data-kid=\"198\">\n                    <h3 class=\"text-xl font-bold text-[#011F5B]\" data-kid=\"199\">AI Med-Explain</h3>\n                    <p class=\"text-[10px] text-blue-600 font-bold uppercase tracking-widest\" data-kid=\"200\">Medical Insight Assistant</p>\n                </div>\n            </div>\n            <button onclick=\"toggleSidebar()\" class=\"w-10 h-10 rounded-full bg-gray-50 text-gray-400 hover:bg-red-50 hover:text-red-500 transition-all flex items-center justify-center cursor-pointer\" data-kid=\"201\">\n                <i class=\"ti ti-x text-xl\" data-kid=\"202\"></i>\n            </button>\n        </div>\n\n        <div class=\"flex-1 overflow-y-auto p-10 space-y-10 custom-scrollbar relative\" data-kid=\"203\">\n            \n            \n            <div data-kid=\"204\">\n                <h4 class=\"text-[10px] font-bold text-blue-600 uppercase tracking-widest mb-3\" data-kid=\"205\">Understanding the medicine</h4>\n                <h2 class=\"text-3xl font-bold text-[#011F5B] mb-4 tracking-tight\" data-kid=\"206\">What is Atorvastatin?</h2>\n                <div class=\"inline-flex items-center gap-2 px-3 py-1 bg-blue-50 text-blue-600 rounded-full text-[10px] font-bold border border-blue-100 mb-6\" data-kid=\"207\">\n                    <i class=\"ti ti-pill\" data-kid=\"208\"></i> Drug Class: Statins\n                </div>\n                <p class=\"text-base text-blue-900/60 leading-relaxed font-medium\" data-kid=\"209\">\n                    Atorvastatin is a medication used to lower \"bad\" cholesterol (LDL) and fats (triglycerides) and raise \"good\" cholesterol (HDL) in the blood. It works by reducing the amount of cholesterol made by the liver.\n                </p>\n            </div>\n\n            \n            <div class=\"bg-blue-50/50 p-6 rounded-[2rem] border border-blue-100\" data-kid=\"210\">\n                <h4 class=\"text-sm font-bold text-[#011F5B] mb-3 flex items-center gap-2\" data-kid=\"211\">\n                    <i class=\"ti ti-info-circle text-blue-600\" data-kid=\"212\"></i> Clinical Context\n                </h4>\n                <p class=\"text-sm text-blue-900/60 leading-relaxed font-medium\" data-kid=\"213\">\n                    This was prescribed by <span class=\"text-[#011F5B] font-bold\" data-kid=\"214\">Dr. Sarah Chen</span> to manage your cardiovascular risk. Regular use helps prevent heart attacks and strokes.\n                </p>\n            </div>\n\n            \n            <div class=\"space-y-6\" data-kid=\"215\">\n                <h4 class=\"text-[10px] font-bold text-red-500 uppercase tracking-widest flex items-center gap-2\" data-kid=\"216\">\n                    <span class=\"w-4 h-[1px] bg-red-500\" data-kid=\"217\"></span> Crucial Warnings\n                </h4>\n                <div class=\"space-y-4\" data-kid=\"218\">\n                    <div class=\"flex gap-4 items-start bg-red-50/50 p-5 rounded-2xl border border-red-100/50\" data-kid=\"219\">\n                        <div class=\"w-10 h-10 rounded-full bg-red-100 flex items-center justify-center text-red-600 shrink-0\" data-kid=\"220\">\n                            <i class=\"ti ti-glass-full text-xl\" data-kid=\"221\"></i>\n                        </div>\n                        <div data-kid=\"222\">\n                            <p class=\"text-sm font-bold text-[#011F5B] mb-1\" data-kid=\"223\">Avoid Grapefruit</p>\n                            <p class=\"text-xs text-blue-900/70 font-medium leading-relaxed\" data-kid=\"224\">Grapefruit juice can significantly increase the concentration of this medicine in your blood, increasing side effect risks.</p>\n                        </div>\n                    </div>\n                    <div class=\"flex gap-4 items-start bg-amber-50/50 p-5 rounded-2xl border border-amber-100/50\" data-kid=\"225\">\n                        <div class=\"w-10 h-10 rounded-full bg-amber-100 flex items-center justify-center text-amber-600 shrink-0\" data-kid=\"226\">\n                            <i class=\"ti ti-stretching text-xl\" data-kid=\"227\"></i>\n                        </div>\n                        <div data-kid=\"228\">\n                            <p class=\"text-sm font-bold text-[#011F5B] mb-1\" data-kid=\"229\">Muscle Soreness</p>\n                            <p class=\"text-xs text-blue-900/70 font-medium leading-relaxed\" data-kid=\"230\">If you experience unexplained muscle pain or weakness, contact your doctor immediately as this could be a rare side effect.</p>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"space-y-4\" data-kid=\"231\">\n                <h4 class=\"text-[10px] font-bold text-blue-600 uppercase tracking-widest\" data-kid=\"232\">Common Questions</h4>\n                <div class=\"p-5 rounded-2xl border border-gray-100 hover:border-blue-200 transition-colors cursor-pointer group\" data-kid=\"233\">\n                    <div class=\"flex items-center justify-between\" data-kid=\"234\">\n                        <span class=\"text-sm font-bold text-[#011F5B]\" data-kid=\"235\">Can I skip a dose?</span>\n                        <i class=\"ti ti-chevron-down text-gray-300 group-hover:text-blue-500 transition-colors\" data-kid=\"236\"></i>\n                    </div>\n                </div>\n                <div class=\"p-5 rounded-2xl border border-gray-100 hover:border-blue-200 transition-colors cursor-pointer group\" data-kid=\"237\">\n                    <div class=\"flex items-center justify-between\" data-kid=\"238\">\n                        <span class=\"text-sm font-bold text-[#011F5B]\" data-kid=\"239\">When is the best time to take it?</span>\n                        <i class=\"ti ti-chevron-down text-gray-300 group-hover:text-blue-500 transition-colors\" data-kid=\"240\"></i>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <div class=\"p-8 bg-gray-50/80 backdrop-blur-md border-t border-gray-100\" data-kid=\"241\">\n            <button onclick=\"toggleSidebar()\" class=\"w-full py-4 bg-[#011F5B] text-white rounded-2xl font-bold text-sm shadow-xl shadow-blue-900/20 hover:bg-black transition-all active:scale-95\" data-kid=\"242\">\n                Understood, Thank You\n            </button>\n            <p class=\"text-[9px] text-center text-gray-400 mt-4 font-medium px-4\" data-kid=\"243\">This information is generated by AI for educational purposes. Always consult your doctor for medical advice.</p>\n        </div>\n    </div>\n\n    \n    <div id=\"sidebarBackdrop\" onclick=\"toggleSidebar()\" class=\"fixed inset-0 bg-[#011F5B]/20 backdrop-blur-sm z-[90] opacity-0 pointer-events-none transition-opacity duration-300\" data-kid=\"244\"></div>\n\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"245\"></script>\n    <script data-kid=\"246\">\n        // Entrance Animations\n        window.addEventListener('load', () => {\n            gsap.from(\".stagger-item\", {\n                duration: 1,\n                y: 30,\n                opacity: 0,\n                stagger: 0.15,\n                ease: \"power3.out\"\n            });\n        });\n\n        // Sidebar Control\n        let sidebarOpen = false;\n        function toggleSidebar() {\n            const sidebar = document.getElementById('sidebar');\n            const backdrop = document.getElementById('sidebarBackdrop');\n            sidebarOpen = !sidebarOpen;\n\n            if (sidebarOpen) {\n                sidebar.classList.remove('translate-x-full');\n                backdrop.classList.remove('opacity-0', 'pointer-events-none');\n            } else {\n                sidebar.classList.add('translate-x-full');\n                backdrop.classList.add('opacity-0', 'pointer-events-none');\n            }\n        }\n\n        // Scan Simulation\n        function startScan() {\n            const scanLine = document.getElementById('scanLine');\n            scanLine.classList.remove('hidden');\n            \n            // Simulate processing\n            setTimeout(() => {\n                alert(\"HomeHero AI: Prescription scanned successfully! Atorvastatin 10mg detected. Would you like to add it to Anjali's profile?\");\n                scanLine.classList.add('hidden');\n            }, 3000);\n        }\n    </script>\n</div>\n",
