      "themeId": null,
      "rect": {
        "x": 1540,
        "y": 0,
        "w": 1440,
        "h": 800
      },
      "html": "\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Red+Hat+Display:wght@400;500;600;700;800&family=Source+Sans+3:wght@300;400;500;600;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n    @import url('https://unpkg.com/lenis@1/dist/lenis.css');\n\n    :root {\n        --linen: #FAF0E6;\n        --terracotta: #A45A52;\n        --pacific-blue: #3AA8C1;\n        --card-border: rgba(164, 90, 82, 0.15);\n    }\n\n    body {\n        margin: 0;\n        background-color: var(--linen);\n        color: var(--terracotta);\n        font-family: 'Source Sans 3', sans-serif;\n    }\n\n    .font-display { font-family: 'Red Hat Display', sans-serif; }\n\n    /* Hide scrollbars for clean look but keep functionality */\n    .no-scrollbar::-webkit-scrollbar { display: none; }\n    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n\n    /* Custom borders */\n    .bento-border { border: 2px solid var(--card-border); }\n    .card-hover-focus:hover { border-color: var(--pacific-blue); }\n\n    /* Hover effects - GSAP handled mostly but simple ones here */\n    .nav-item:hover { background-color: rgba(164, 90, 82, 0.05); }\n    \n    .kanban-column {\n        min-width: 320px;\n        flex: 1;\n    }\n\n    .glass-header {\n        background: rgba(255, 255, 255, 0.7);\n        backdrop-filter: blur(10px);\n    }\n\n    .proportional-block {\n        /* CSS transitions removed to prevent conflict with GSAP */\n        position: relative;\n    }\n</style>\n\n<div class=\"flex h-screen overflow-hidden\" data-kid=\"1\">\n    \n    <aside class=\"w-16 bg-[#3D2522] flex flex-col items-center py-6 gap-8 z-20 shrink-0\" data-kid=\"2\">\n        <div class=\"w-10 h-10 bg-[var(--terracotta)] rounded-xl flex items-center justify-center text-white shadow-lg\" data-kid=\"3\">\n            <i class=\"ti ti-home-2 text-xl\" data-kid=\"4\"></i>\n        </div>\n        <nav class=\"flex flex-col gap-6 text-white/40\" data-kid=\"5\">\n            <i class=\"ti ti-layout-grid text-xl hover:text-[var(--pacific-blue)] cursor-pointer\" data-kid=\"6\"></i>\n            <i class=\"ti ti-calendar-event text-xl hover:text-[var(--pacific-blue)] cursor-pointer\" data-kid=\"7\"></i>\n            <i class=\"ti ti-shopping-cart text-xl hover:text-[var(--pacific-blue)] cursor-pointer\" data-kid=\"8\"></i>\n            <i class=\"ti ti-pill text-xl hover:text-[var(--pacific-blue)] cursor-pointer\" data-kid=\"9\"></i>\n            <i class=\"ti ti-settings text-xl hover:text-[var(--pacific-blue)] cursor-pointer\" data-kid=\"10\"></i>\n        </nav>\n        <div class=\"mt-auto\" data-kid=\"11\">\n            <img src=\"https://i.pravatar.cc/100?u=father\" alt=\"Profile\" class=\"w-8 h-8 rounded-full border-2 border-[var(--terracotta)]\" decoding=\"async\" loading=\"lazy\" data-kid=\"12\">\n        </div>\n    </aside>\n\n    \n    <aside class=\"w-64 bg-white border-r bento-border flex flex-col shrink-0\" data-kid=\"13\">\n        <div class=\"p-6 border-b bento-border\" data-kid=\"14\">\n            <h1 class=\"font-display font-extrabold text-xl tracking-tight text-[var(--terracotta)]\" data-kid=\"15\">HomeHero<span class=\"text-[var(--pacific-blue)]\" data-kid=\"16\">AI</span></h1>\n        </div>\n        <div class=\"flex-1 overflow-y-auto p-4 space-y-8 no-scrollbar\" data-kid=\"17\">\n            <section data-kid=\"18\">\n                <p class=\"text-[10px] font-bold uppercase tracking-widest text-[var(--terracotta)]/70 mb-3 ml-2\" data-kid=\"19\">Main Menu</p>\n                <div class=\"space-y-1\" data-kid=\"20\">\n                    <a href=\"#\" class=\"nav-item flex items-center gap-3 px-3 py-2 rounded-lg bg-[var(--terracotta)] text-white font-medium\" data-kid=\"21\">\n                        <i class=\"ti ti-smart-home\" data-kid=\"22\"></i> Dashboard\n                    </a>\n                    <a href=\"#\" class=\"nav-item flex items-center gap-3 px-3 py-2 rounded-lg text-[var(--terracotta)]/70 hover:text-[var(--terracotta)] font-medium\" data-kid=\"23\">\n                        <i class=\"ti ti-chef-hat\" data-kid=\"24\"></i> AI Recipe Chef\n                    </a>\n                    <a href=\"#\" class=\"nav-item flex items-center gap-3 px-3 py-2 rounded-lg text-[var(--terracotta)]/70 hover:text-[var(--terracotta)] font-medium\" data-kid=\"25\">\n                        <i class=\"ti ti-receipt-2\" data-kid=\"26\"></i> Monthly Expenses\n                    </a>\n                    <a href=\"#\" class=\"nav-item flex items-center gap-3 px-3 py-2 rounded-lg text-[var(--terracotta)]/70 hover:text-[var(--terracotta)] font-medium\" data-kid=\"27\">\n                        <i class=\"ti ti-building-warehouse\" data-kid=\"28\"></i> Home Inventory\n                    </a>\n                </div>\n            </section>\n            \n            <section data-kid=\"29\">\n                <p class=\"text-[10px] font-bold uppercase tracking-widest text-[var(--terracotta)]/70 mb-3 ml-2\" data-kid=\"30\">Family Groups</p>\n                <div class=\"space-y-1\" data-kid=\"31\">\n                    <div class=\"flex items-center gap-3 px-3 py-2 text-[var(--terracotta)]/70 cursor-pointer\" data-kid=\"32\">\n                        <span class=\"w-2 h-2 rounded-full bg-[var(--pacific-blue)]\" data-kid=\"33\"></span> The Malhotras\n                    </div>\n                    <div class=\"flex items-center gap-3 px-3 py-2 text-[var(--terracotta)]/70 cursor-pointer\" data-kid=\"34\">\n                        <span class=\"w-2 h-2 rounded-full bg-orange-400\" data-kid=\"35\"></span> Weekend Trips\n                    </div>\n                </div>\n            </section>\n        </div>\n        <div class=\"p-5 bg-[var(--terracotta)]/5 rounded-3xl border bento-border m-4 mt-auto\" data-kid=\"36\">\n            <div class=\"flex items-start gap-3\" data-kid=\"37\">\n                <div class=\"p-2 bg-[var(--terracotta)] text-white rounded-xl shadow-sm\" data-kid=\"38\">\n                    <i class=\"ti ti-bulb\" data-kid=\"39\"></i>\n                </div>\n                <div class=\"flex-1\" data-kid=\"40\">\n                    <p class=\"text-xs font-bold text-[var(--terracotta)]\" data-kid=\"41\">Smart Assistant</p>\n                    <p class=\"text-[11px] text-[var(--terracotta)]/70 mt-1 leading-snug font-medium\" data-kid=\"42\">Rice is running low. Should I add it to your 1-tap grocery cart?</p>\n                    <button class=\"mt-2 text-[10px] font-bold text-[var(--pacific-blue)] flex items-center gap-1\" data-kid=\"43\">Add now <i class=\"ti ti-arrow-right\" data-kid=\"44\"></i></button>\n                </div>\n            </div>\n        </div>\n    </aside>\n\n    \n    <main class=\"flex-1 overflow-y-auto no-scrollbar relative p-8\" data-kid=\"45\">\n        \n        <header class=\"flex justify-between items-center mb-10\" data-kid=\"46\">\n            <div data-kid=\"47\">\n                <h2 class=\"font-display text-4xl font-black text-[var(--terracotta)] tracking-tight\" data-kid=\"48\">Smart Family Insights</h2>\n                <p class=\"text-[var(--terracotta)]/70 font-semibold mt-1 flex items-center gap-2\" data-kid=\"49\">\n                    <i class=\"ti ti-calendar-time text-[var(--pacific-blue)]\" data-kid=\"50\"></i> Wednesday, 24 October 2026 • 🌤 24°C\n                </p>\n            </div>\n            <div class=\"flex items-center gap-4\" data-kid=\"51\">\n                <div class=\"relative\" data-kid=\"52\">\n                    <i class=\"ti ti-search absolute left-3 top-1/2 -translate-y-1/2 text-[var(--terracotta)]/40\" data-kid=\"53\"></i>\n                    <input type=\"text\" placeholder=\"Ask AI anything...\" class=\"bg-white border-2 border-[var(--card-border)] rounded-xl py-2 pl-10 pr-4 w-64 focus:outline-hidden focus:border-[var(--pacific-blue)] transition-colors\" data-kid=\"54\">\n