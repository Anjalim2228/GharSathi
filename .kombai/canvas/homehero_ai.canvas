      "html": "\n<div class=\"min-h-screen bg-[#0A0D14] text-slate-300 font-['Inter'] selection:bg-orange-500/30 selection:text-white overflow-x-clip\" data-kid=\"0\">\n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;600;700&family=JetBrains+Mono:wght@400;500&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n        .font-outfit { font-family: 'Outfit', sans-serif; }\n        .font-mono { font-family: 'JetBrains Mono', monospace; }\n\n        .industrial-glass {\n            background: rgba(17, 24, 39, 0.7);\n            backdrop-filter: blur(12px);\n            border: 1px solid rgba(255, 255, 255, 0.05);\n        }\n\n        .corner-accent::before {\n            content: '';\n            position: absolute;\n            top: -1px; left: -1px;\n            width: 12px; height: 12px;\n            border-top: 2px solid #F97316;\n            border-left: 2px solid #F97316;\n            pointer-events: none;\n        }\n\n        .service-card-hover {\n            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n        }\n        .service-card-hover:hover {\n            border-color: rgba(249, 115, 22, 0.4);\n            background: rgba(30, 41, 59, 0.4);\n            transform: translateY(-4px);\n        }\n\n        .gauge-svg { transform: rotate(-90deg); }\n        .gauge-track { fill: none; stroke: rgba(255, 255, 255, 0.05); stroke-width: 10; }\n        .gauge-progress { \n            fill: none; \n            stroke: #F97316; \n            stroke-width: 10; \n            stroke-linecap: round;\n            stroke-dasharray: 440; \n            stroke-dashoffset: 440;\n        }\n\n        .timeline-line {\n            position: absolute;\n            left: 7px; top: 0; bottom: 0;\n            width: 1px;\n            background: linear-gradient(to bottom, transparent, rgba(255, 255, 255, 0.1) 15%, rgba(255, 255, 255, 0.1) 85%, transparent);\n        }\n\n        .scrollbar-hide::-webkit-scrollbar { display: none; }\n        .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }\n\n        @keyframes orange-glow {\n            0%, 100% { opacity: 0.5; }\n            50% { opacity: 1; box-shadow: 0 0 20px rgba(249, 115, 22, 0.4); }\n        }\n        .alert-glow { animation: orange-glow 2s infinite; }\n    </style>\n\n    \n    <nav class=\"sticky top-0 z-50 industrial-glass border-b border-white/5 px-8 py-4 flex items-center justify-between\" data-kid=\"2\">\n        <div class=\"flex items-center gap-10\" data-kid=\"3\">\n            <div class=\"flex items-center gap-3 group cursor-pointer\" data-kid=\"4\">\n                <div class=\"w-10 h-10 bg-orange-500 rounded-lg flex items-center justify-center text-black shadow-lg shadow-orange-500/20 group-hover:scale-105 transition-transform\" data-kid=\"5\">\n                    <i class=\"ti ti-tool text-2xl\" data-kid=\"6\"></i>\n                </div>\n                <h1 class=\"text-xl font-bold tracking-tight text-white font-outfit\" data-kid=\"7\">HomeHero <span class=\"text-orange-500\" data-kid=\"8\">AI</span></h1>\n            </div>\n            <div class=\"hidden lg:flex items-center gap-8\" data-kid=\"9\">\n                <a href=\"#\" class=\"text-sm font-medium text-slate-500 hover:text-white transition-colors\" data-kid=\"10\">Overview</a>\n                <a href=\"#\" class=\"text-sm font-bold text-white relative after:absolute after:-bottom-[1.6rem] after:left-0 after:right-0 after:h-0.5 after:bg-orange-500\" data-kid=\"11\">Maintenance</a>\n                <a href=\"#\" class=\"text-sm font-medium text-slate-500 hover:text-white transition-colors\" data-kid=\"12\">Inventory</a>\n                <a href=\"#\" class=\"text-sm font-medium text-slate-500 hover:text-white transition-colors\" data-kid=\"13\">Analytics</a>\n            </div>\n        </div>\n        <div class=\"flex items-center gap-6\" data-kid=\"14\">\n            <div class=\"hidden md:flex flex-col text-right\" data-kid=\"15\">\n                <span class=\"text-xs font-mono text-slate-500\" data-kid=\"16\">SYSTEM STATUS</span>\n                <span class=\"text-[10px] font-bold text-green-500 flex items-center gap-1.5 justify-end\" data-kid=\"17\">\n                    <span class=\"w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse\" data-kid=\"18\"></span> ALL SYSTEMS NOMINAL\n                </span>\n            </div>\n            <div class=\"w-10 h-10 rounded-full border border-white/10 flex items-center justify-center relative cursor-pointer hover:bg-white/5 transition-colors\" data-kid=\"19\">\n                <i class=\"ti ti-bell text-lg\" data-kid=\"20\"></i>\n                <span class=\"absolute top-2.5 right-2.5 w-2 h-2 bg-orange-500 rounded-full border-2 border-[#0A0D14]\" data-kid=\"21\"></span>\n            </div>\n            <img src=\"https://i.pravatar.cc/150?u=maintenance_admin\" class=\"w-10 h-10 rounded-lg border border-white/10 shadow-sm hover:border-orange-500/50 transition-colors cursor-pointer\" alt=\"User\" decoding=\"async\" loading=\"lazy\" data-kid=\"22\">\n        </div>\n    </nav>\n\n    <main class=\"max-w-[1440px] mx-auto px-8 py-10 grid grid-cols-1 lg:grid-cols-12 gap-8\" data-kid=\"23\">\n        \n        \n        <div class=\"lg:col-span-8 space-y-8\" data-kid=\"24\">\n            \n            \n            <header class=\"grid grid-cols-1 md:grid-cols-3 gap-6\" data-kid=\"25\">\n                <div class=\"md:col-span-2 bg-[#111827] industrial-border corner-accent p-8 rounded-lg relative overflow-hidden\" data-kid=\"26\">\n                    <div class=\"flex flex-col md:flex-row items-center gap-10\" data-kid=\"27\">\n                        <div class=\"relative w-44 h-44 shrink-0\" data-kid=\"28\">\n                            <svg class=\"gauge-svg w-full h-full\" viewBox=\"0 0 160 160\" data-kid=\"29\">\n                                <circle class=\"gauge-track\" cx=\"80\" cy=\"80\" r=\"70\" data-kid=\"30\"></circle>\n                                <circle class=\"gauge-progress\" id=\"main-gauge\" cx=\"80\" cy=\"80\" r=\"70\" data-kid=\"31\"></circle>\n                            </svg>\n                            <div class=\"absolute inset-0 flex flex-col items-center justify-center\" data-kid=\"32\">\n                                <span class=\"text-5xl font-outfit font-bold text-white leading-none\" data-kid=\"33\">84</span>\n                                <span class=\"text-[10px] font-mono text-orange-500 mt-1 uppercase tracking-widest\" data-kid=\"34\">Score</span>\n                            </div>\n                        </div>\n                        <div class=\"flex-1 text-center md:text-left\" data-kid=\"35\">\n                            <h2 class=\"text-2xl font-outfit font-bold text-white mb-2\" data-kid=\"36\">Home Health Index</h2>\n                            <p class=\"text-sm text-slate-400 mb-6 leading-relaxed\" data-kid=\"37\">Overall asset longevity is <span class=\"text-orange-500 font-bold\" data-kid=\"38\">Excellent</span>. Two maintenance tasks require your attention within the next 48 hours to maintain peak efficiency.</p>\n                            <div class=\"flex flex-wrap gap-3 justify-center md:justify-start\" data-kid=\"39\">\n                                <button class=\"bg-orange-500 text-black px-6 py-2.5 rounded font-bold text-sm hover:bg-orange-400 transition-all flex items-center gap-2\" data-kid=\"40\">\n                                    <i class=\"ti ti-bolt\" data-kid=\"41\"></i> RUN DIAGNOSTICS\n                                </button>\n                                <button class=\"border border-white/10 text-white px-6 py-2.5 rounded font-bold text-sm hover:bg-white/5 transition-all\" data-kid=\"42\">\n                                    VIEW REPORT\n                                </button>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"grid grid-rows-2 gap-4\" data-kid=\"43\">\n                    <div class=\"bg-[#111827] border border-white/5 p-5 rounded-lg flex flex-col justify-between\" data-kid=\"44\">\n                        <p class=\"text-[10px] font-mono text-slate-500 uppercase\" data-kid=\"45\">Active Warranties</p>\n                        <div class=\"flex items-end justify-between\" data-kid=\"46\">\n                            <h3 class=\"text-3xl font-outfit font-bold text-white\" data-kid=\"47\">08</h3>\n                            <span class=\"text-xs text-green-500 font-bold\" data-kid=\"48\">+1 New</span>\n                        </div>\n                    </div>\n                    <div class=\"bg-[#111827] border border-white/5 p-5 rounded-lg flex flex-col justify-between\" data-kid=\"49\">\n                        <p class=\"text-[10px] font-mono text-slate-500 uppercase\" data-kid=\"50\">Est. Replacement Cost</p>\n                        <div class=\"flex items-end justify-between\" data-kid=\"51\">\n                            <h3 class=\"text-3xl font-outfit font-bold text-white\" data-kid=\"52\">$14.2k</h3>\n                            <i class=\"ti ti-trending-up text-orange-500 text-xl\" data-kid=\"53\"></i>\n                        </div>\n                    </div>\n                </div>\n            </header>\n\n            \n            <section class=\"space-y-6\" data-kid=\"54\">\n                <div class=\"flex items-center justify-between\" data-kid=\"55\">\n                    <h3 class=\"text-lg font-outfit font-bold text-white flex items-center gap-3\" data-kid=\"56\">\n                        <span class=\"w-8 h-px bg-orange-500/30\" data-kid=\"57\"></span> ASSET MONITORING\n                    </h3>\n                    <div class=\"flex gap-2\" data-kid=\"58\">\n                        <button class=\"p-2 hover:bg-white/5 rounded transition-colors text-slate-500 hover:text-white\" data-kid=\"59\">\n                            <i class=\"ti ti-layout-grid\" data-kid=\"60\"></i>\n                        </button>\n                        <button class=\"p-2 hover:bg-white/5 rounded transition-colors text-slate-500 hover:text-white\" data-kid=\"61\">\n                            <i class=\"ti ti-list\" data-kid=\"62\"></i>\n                        </button>\n                    </div>\n                </div>\n\n                <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\" data-kid=\"63\">\n                    \n                    <div class=\"bg-[#111827] border border-white/5 p-6 rounded-xl service-card-hover relative group stagger-card\" data-kid=\"64\">\n                        <div class=\"absolute top-4 right-4 opacity-5 group-hover:opacity-10 transition-opacity\" data-kid=\"65\">\n                            <i class=\"ti ti-wind text-7xl\" data-kid=\"66\"></i>\n                        </div>\n                        <div class=\"flex items-start gap-4 mb-8\" data-kid=\"67\">\n                            <div class=\"w-12 h-12 rounded-lg bg-slate-800 flex items-center justify-center text-orange-500 border border-white/5\" data-kid=\"68\">\n                                <i class=\"ti ti-wind text-2xl\" data-kid=\"69\"></i>\n                            </div>\n                            <div data-kid=\"70\">\n                                <h4 class=\"text-lg font-outfit font-bold text-white\" data-kid=\"71\">HVAC System</h4>\n                                <p class=\"text-[10px] font-mono text-slate-500 uppercase tracking-wider\" data-kid=\"72\">SN: MSZ-AP35VG-2023</p>\n                            </div>\n                        </div>\n                        <div class=\"grid grid-cols-2 gap-4 mb-6\" data-kid=\"73\">\n                            <div data-kid=\"74\">\n                                <p class=\"text-[10px] font-mono text-slate-500 uppercase mb-1\" data-kid=\"75\">Last Service</p>\n                                <p class=\"text-sm font-medium text-slate-300\" data-kid=\"76\">Mar 12, 2024</p>\n                            </div>\n                            <div class=\"text-right\" data-kid=\"77\">\n                                <p class=\"text-[10px] font-mono text-slate-500 uppercase mb-1\" data-kid=\"78\">Condition</p>\n                                <p class=\"text-sm font-bold text-green-500\" data-kid=\"79\">OPTIMAL</p>\n                            </div>\n                        </div>\n                        <div class=\"space-y-2\" data-kid=\"80\">\n                            <div class=\"flex justify-between text-[10px] font-mono uppercase text-slate-500\" data-kid=\"81\">\n                                <span data-kid=\"82\">Filter Life</span>\n                                <span class=\"text-orange-500\" data-kid=\"83\">65%</span>\n                            </div>\n                            <div class=\"h-1.5 bg-slate-800 rounded-full overflow-hidden\" data-kid=\"84\">\n                                <div class=\"h-full bg-orange-500 w-[65%] rounded-full\" data-kid=\"85\"></div>\n                            </div>\n                        </div>\n                        <div class=\"mt-8 flex items-center justify-between pt-4 border-t border-white/5\" data-kid=\"86\">\n                            <span class=\"text-[10px] font-mono text-slate-400 bg-white/5 px-2 py-1 rounded\" data-kid=\"87\">DUE IN 14 DAYS</span>\n                            <button class=\"text-xs font-bold text-white group-hover:text-orange-500 transition-colors flex items-center gap-1\" data-kid=\"88\">\n                                MANAGE <i class=\"ti ti-chevron-right text-[10px]\" data-kid=\"89\"></i>\n                            </button>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"bg-[#111827] border border-orange-500/20 p-6 rounded-xl service-card-hover relative group stagger-card\" data-kid=\"90\">\n                        <div class=\"absolute top-4 right-4 opacity-5 group-hover:opacity-10 transition-opacity\" data-kid=\"91\">\n                            <i class=\"ti ti-car text-7xl\" data-kid=\"92\"></i>\n                        </div>\n                        <div class=\"flex items-start gap-4 mb-8\" data-kid=\"93\">\n                            <div class=\"w-12 h-12 rounded-lg bg-slate-800 flex items-center justify-center text-orange-500 border border-white/5\" data-kid=\"94\">\n                                <i class=\"ti ti-car text-2xl\" data-kid=\"95\"></i>\n                            </div>\n                            <div data-kid=\"96\">\n                                <h4 class=\"text-lg font-outfit font-bold text-white\" data-kid=\"97\">Tesla Model 3</h4>\n                                <p class=\"text-[10px] font-mono text-slate-500 uppercase tracking-wider\" data-kid=\"98\">SN: 5YJ3E1EAX-2022</p>\n                            </div>\n                            <div class=\"ml-auto w-2 h-2 rounded-full bg-orange-500 alert-glow\" data-kid=\"99\"></div>\n                        </div>\n                        <div class=\"grid grid-cols-2 gap-4 mb-6\" data-kid=\"100\">\n                            <div data-kid=\"101\">\n                                <p class=\"text-[10px] font-mono text-slate-500 uppercase mb-1\" data-kid=\"102\">Tire Pressure</p>\n                                <p class=\"text-sm font-bold text-orange-500\" data-kid=\"103\">28 PSI (LOW)</p>\n                            </div>\n                            <div class=\"text-right\" data-kid=\"104\">\n                                <p class=\"text-[10px] font-mono text-slate-500 uppercase mb-1\" data-kid=\"105\">Status</p>\n                                <p class=\"text-sm font-bold text-orange-500\" data-kid=\"106\">URGENT</p>\n                            </div>\n                        </div>\n                        <div class=\"space-y-2\" data-kid=\"107\">\n                            <div class=\"flex justify-between text-[10px] font-mono uppercase text-slate-500\" data-kid=\"108\">\n                                <span data-kid=\"109\">Battery Health</span>\n                                <span class=\"text-green-500\" data-kid=\"110\">92%</span>\n                            </div>\n                            <div class=\"h-1.5 bg-slate-800 rounded-full overflow-hidden\" data-kid=\"111\">\n                                <div class=\"h-full bg-green-500 w-[92%] rounded-full\" data-kid=\"112\"></div>\n                            </div>\n                        </div>\n                        <div class=\"mt-8 flex items-center justify-between pt-4 border-t border-white/5\" data-kid=\"113\">\n                            <span class=\"text-[10px] font-mono text-orange-500 bg-orange-500/10 px-2 py-1 rounded\" data-kid=\"114\">ACTION REQUIRED</span>\n                            <button class=\"bg-orange-500 text-black text-[10px] font-bold px-4 py-2 rounded hover:bg-orange-400 transition-colors\" data-kid=\"115\">\n                                BOOK SERVICE\n                            </button>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"bg-[#111827] border border-white/5 p-6 rounded-xl service-card-hover relative group stagger-card\" data-kid=\"116\">\n                        <div class=\"absolute top-4 right-4 opacity-5 group-hover:opacity-10 transition-opacity\" data-kid=\"117\">\n                            <i class=\"ti ti-droplet text-7xl\" data-kid=\"118\"></i>\n                        </div>\n                        <div class=\"flex items-start gap-4 mb-8\" data-kid=\"119\">\n                            <div class=\"w-12 h-12 rounded-lg bg-slate-800 flex items-center justify-center text-orange-500 border border-white/5\" data-kid=\"120\">\n                                <i class=\"ti ti-droplet text-2xl\" data-kid=\"121\"></i>\n                            </div>\n                            <div data-kid=\"122\">\n                                <h4 class=\"text-lg font-outfit font-bold text-white\" data-kid=\"123\">Water Purifier</h4>\n                                <p class=\"text-[10px] font-mono text-slate-500 uppercase tracking-wider\" data-kid=\"124\">SN: RO-7STG-PRO</p>\n                            </div>\n                        </div>\n                        <div class=\"grid grid-cols-2 gap-4 mb-6\" data-kid=\"125\">\n                            <div data-kid=\"126\">\n                                <p class=\"text-[10px] font-mono text-slate-500 uppercase mb-1\" data-kid=\"127\">Current TDS</p>\n                                <p class=\"text-sm font-medium text-slate-300\" data-kid=\"128\">42 PPM</p>\n                            </div>\n                            <div class=\"text-right\" data-kid=\"129\">\n                                <p class=\"text-[10px] font-mono text-slate-500 uppercase mb-1\" data-kid=\"130\">Flow Rate</p>\n                                <p class=\"text-sm font-bold text-green-500\" data-kid=\"131\">NORMAL</p>\n                            </div>\n                        </div>\n                        <div class=\"space-y-2\" data-kid=\"132\">\n                            <div class=\"flex justify-between text-[10px] font-mono uppercase text-slate-500\" data-kid=\"133\">\n                                <span data-kid=\"134\">Filter Saturation</span>\n                                <span class=\"text-slate-300\" data-kid=\"135\">12%</span>\n                            </div>\n                            <div class=\"h-1.5 bg-slate-800 rounded-full overflow-hidden\" data-kid=\"136\">\n                                <div class=\"h-full bg-blue-500 w-[12%] rounded-full\" data-kid=\"137\"></div>\n                            </div>\n                        </div>\n                        <div class=\"mt-8 flex items-center justify-between pt-4 border-t border-white/5\" data-kid=\"138\">\n                            <span class=\"text-[10px] font-mono text-slate-400 bg-white/5 px-2 py-1 rounded\" data-kid=\"139\">STABLE</span>\n                            <button class=\"text-xs font-bold text-white group-hover:text-orange-500 transition-colors flex items-center gap-1\" data-kid=\"140\">\n                                MANAGE <i class=\"ti ti-chevron-right text-[10px]\" data-kid=\"141\"></i>\n                            </button>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"bg-[#111827] border border-white/5 p-6 rounded-xl service-card-hover relative group stagger-card\" data-kid=\"142\">\n                        <div class=\"absolute top-4 right-4 opacity-5 group-hover:opacity-10 transition-opacity\" data-kid=\"143\">\n                            <i class=\"ti ti-bug text-7xl\" data-kid=\"144\"></i>\n                        </div>\n                        <div class=\"flex items-start gap-4 mb-8\" data-kid=\"145\">\n                            <div class=\"w-12 h-12 rounded-lg bg-slate-800 flex items-center justify-center text-orange-500 border border-white/5\" data-kid=\"146\">\n                                <i class=\"ti ti-bug text-2xl\" data-kid=\"147\"></i>\n                            </div>\n                            <div data-kid=\"148\">\n                                <h4 class=\"text-lg font-outfit font-bold text-white\" data-kid=\"149\">Pest Control</h4>\n                                <p class=\"text-[10px] font-mono text-slate-500 uppercase tracking-wider\" data-kid=\"150\">Plan: Quarterly Shield</p>\n                            </div>\n                        </div>\n                        <div class=\"grid grid-cols-2 gap-4 mb-6\" data-kid=\"151\">\n                            <div data-kid=\"152\">\n                                <p class=\"text-[10px] font-mono text-slate-500 uppercase mb-1\" data-kid=\"153\">Next Treatment</p>\n                                <p class=\"text-sm font-medium text-slate-300\" data-kid=\"154\">Jun 18, 2024</p>\n                            </div>\n                            <div class=\"text-right\" data-kid=\"155\">\n                                <p class=\"text-[10px] font-mono text-slate-500 uppercase mb-1\" data-kid=\"156\">Status</p>\n                                <p class=\"text-sm font-bold text-green-500\" data-kid=\"157\">PROTECTED</p>\n                            </div>\n                        </div>\n                        <div class=\"space-y-2\" data-kid=\"158\">\n                            <div class=\"flex justify-between text-[10px] font-mono uppercase text-slate-500\" data-kid=\"159\">\n                                <span data-kid=\"160\">Protection Level</span>\n                                <span class=\"text-green-500\" data-kid=\"161\">HIGH</span>\n                            </div>\n                            <div class=\"h-1.5 bg-slate-800 rounded-full overflow-hidden\" data-kid=\"162\">\n                                <div class=\"h-full bg-green-500 w-[100%] rounded-full\" data-kid=\"163\"></div>\n                            </div>\n                        </div>\n                        <div class=\"mt-8 flex items-center justify-between pt-4 border-t border-white/5\" data-kid=\"164\">\n                            <span class=\"text-[10px] font-mono text-slate-400 bg-white/5 px-2 py-1 rounded\" data-kid=\"165\">RECURRING TASK</span>\n                            <button class=\"text-xs font-bold text-white group-hover:text-orange-500 transition-colors flex items-center gap-1\" data-kid=\"166\">\n                                MANAGE <i class=\"ti ti-chevron-right text-[10px]\" data-kid=\"167\"></i>\n                            </button>\n                        </div>\n                    </div>\n                </div>\n            </section>\n        </div>\n\n        \n        <div class=\"lg:col-span-4 space-y-8\" data-kid=\"168\">\n            \n            \n            <section class=\"bg-[#111827]/50 rounded-xl p-6 border border-white/5\" data-kid=\"169\">\n                <h3 class=\"text-xs font-mono uppercase text-orange-500 tracking-[0.2em] mb-6 flex items-center gap-2\" data-kid=\"170\">\n                    <i class=\"ti ti-alarm\" data-kid=\"171\"></i> Upcoming Maintenance\n                </h3>\n                <div class=\"space-y-4\" data-kid=\"172\">\n                    <div class=\"flex items-center justify-between group p-3 rounded-lg hover:bg-white/5 transition-colors cursor-pointer border border-transparent hover:border-white/5\" data-kid=\"173\">\n                        <div class=\"flex items-center gap-4\" data-kid=\"174\">\n                            <div class=\"w-10 h-10 rounded bg-orange-500/10 flex items-center justify-center text-orange-500\" data-kid=\"175\">\n                                <i class=\"ti ti-calendar-event\" data-kid=\"176\"></i>\n                            </div>\n                            <div data-kid=\"177\">\n                                <p class=\"text-sm font-bold text-white\" data-kid=\"178\">Car Tire Rotation</p>\n                                <p class=\"text-[10px] text-slate-500 font-mono\" data-kid=\"179\">TOMORROW • 10:00 AM</p>\n                            </div>\n                        </div>\n                        <i class=\"ti ti-external-link text-slate-600 group-hover:text-orange-500 transition-colors\" data-kid=\"180\"></i>\n                    </div>\n                    <div class=\"flex items-center justify-between group p-3 rounded-lg hover:bg-white/5 transition-colors cursor-pointer border border-transparent hover:border-white/5\" data-kid=\"181\">\n                        <div class=\"flex items-center gap-4\" data-kid=\"182\">\n                            <div class=\"w-10 h-10 rounded bg-slate-800 flex items-center justify-center text-slate-400\" data-kid=\"183\">\n                                <i class=\"ti ti-wash\" data-kid=\"184\"></i>\n                            </div>\n                            <div data-kid=\"185\">\n                                <p class=\"text-sm font-bold text-white\" data-kid=\"186\">Dishwasher Deep Clean</p>\n                                <p class=\"text-[10px] text-slate-500 font-mono\" data-kid=\"187\">JUNE 12 • 09:30 AM</p>\n                            </div>\n                        </div>\n                        <i class=\"ti ti-external-link text-slate-600 group-hover:text-slate-400 transition-colors\" data-kid=\"188\"></i>\n                    </div>\n                    <button class=\"w-full mt-4 py-3 rounded border border-orange-500/30 text-orange-500 text-xs font-bold hover:bg-orange-500 hover:text-black transition-all\" data-kid=\"189\">\n                        BOOK NEW SERVICE\n                    </button>\n                </div>\n            </section>\n\n            \n            <section class=\"bg-[#111827] rounded-xl p-6 border border-white/5 overflow-hidden\" data-kid=\"190\">\n                <h3 class=\"text-xs font-mono uppercase text-slate-500 tracking-[0.2em] mb-8 flex items-center gap-2\" data-kid=\"191\">\n                    <i class=\"ti ti-history\" data-kid=\"192\"></i> Service History\n                </h3>\n                <div class=\"relative pl-8 space-y-10 scrollbar-hide\" data-kid=\"193\">\n                    <div class=\"timeline-line\" data-kid=\"194\"></div>\n                    \n                    \n                    <div class=\"relative stagger-history\" data-kid=\"195\">\n                        <div class=\"absolute -left-[1.85rem] top-1.5 w-4 h-4 rounded-full bg-[#0A0D14] border-2 border-orange-500 z-10\" data-kid=\"196\"></div>\n                        <div data-kid=\"197\">\n                            <div class=\"flex items-center justify-between mb-2\" data-kid=\"198\">\n                                <span class=\"text-[10px] font-mono text-slate-500\" data-kid=\"199\">MAY 24, 2024</span>\n                                <span class=\"text-[9px] font-bold bg-green-500/10 text-green-500 px-1.5 py-0.5 rounded\" data-kid=\"200\">COMPLETED</span>\n                            </div>\n                            <h4 class=\"text-sm font-bold text-white mb-2\" data-kid=\"201\">Water Purifier Filter Change</h4>\n                            <div class=\"bg-slate-900/50 rounded-lg p-3 border border-white/5\" data-kid=\"202\">\n                                <p class=\"text-xs text-slate-400 italic leading-relaxed\" data-kid=\"203\">\"Sediment and pre-carbon filters replaced. TDS levels calibrated to 45ppm. System leak-tested.\"</p>\n                                <div class=\"mt-3 flex items-center gap-2\" data-kid=\"204\">\n                                    <img src=\"https://i.pravatar.cc/150?u=tech_robert\" class=\"w-5 h-5 rounded-full border border-white/10\" alt=\"Tech\" decoding=\"async\" loading=\"lazy\" data-kid=\"205\">\n                                    <span class=\"text-[10px] text-slate-500 font-medium\" data-kid=\"206\">Technician: Robert M.</span>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"relative stagger-history\" data-kid=\"207\">\n                        <div class=\"absolute -left-[1.85rem] top-1.5 w-4 h-4 rounded-full bg-[#0A0D14] border-2 border-slate-700 z-10\" data-kid=\"208\"></div>\n                        <div data-kid=\"209\">\n                            <div class=\"flex items-center justify-between mb-2\" data-kid=\"210\">\n                                <span class=\"text-[10px] font-mono text-slate-500\" data-kid=\"211\">APR 12, 2024</span>\n                                <span class=\"text-[9px] font-bold bg-slate-800 text-slate-400 px-1.5 py-0.5 rounded\" data-kid=\"212\">ROUTINE</span>\n                            </div>\n                            <h4 class=\"text-sm font-bold text-white mb-2\" data-kid=\"213\">Pest Control - Quarterly Spray</h4>\n                            <div class=\"bg-slate-900/50 rounded-lg p-3 border border-white/5\" data-kid=\"214\">\n                                <p class=\"text-xs text-slate-400 italic leading-relaxed\" data-kid=\"215\">\"Barrier treatment applied to all entry points. No active infestations detected. Recommended sealing kitchen pipe gaps.\"</p>\n                                <div class=\"mt-3 flex items-center gap-2\" data-kid=\"216\">\n                                    <img src=\"https://i.pravatar.cc/150?u=tech_sarah\" class=\"w-5 h-5 rounded-full border border-white/10\" alt=\"Tech\" decoding=\"async\" loading=\"lazy\" data-kid=\"217\">\n                                    <span class=\"text-[10px] text-slate-500 font-medium\" data-kid=\"218\">Technician: Sarah J.</span>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"relative stagger-history\" data-kid=\"219\">\n                        <div class=\"absolute -left-[1.85rem] top-1.5 w-4 h-4 rounded-full bg-[#0A0D14] border-2 border-slate-700 z-10\" data-kid=\"220\"></div>\n                        <div data-kid=\"221\">\n                            <div class=\"flex items-center justify-between mb-2\" data-kid=\"222\">\n                                <span class=\"text-[10px] font-mono text-slate-500\" data-kid=\"223\">MAR 02, 2024</span>\n                                <span class=\"text-[9px] font-bold bg-slate-800 text-slate-400 px-1.5 py-0.5 rounded\" data-kid=\"224\">REPAIR</span>\n                            </div>\n                            <h4 class=\"text-sm font-bold text-white mb-2\" data-kid=\"225\">HVAC Condenser Cleaning</h4>\n                            <div class=\"bg-slate-900/50 rounded-lg p-3 border border-white/5\" data-kid=\"226\">\n                                <p class=\"text-xs text-slate-400 italic leading-relaxed\" data-kid=\"227\">\"Outdoor unit debris cleared. Refrigerant levels topped up (0.5kg R32). Current draw stabilized.\"</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n                <button class=\"w-full mt-10 text-[10px] font-bold text-slate-500 hover:text-white transition-colors uppercase tracking-widest\" data-kid=\"228\">\n                    Load Older Records <i class=\"ti ti-chevron-down ml-1\" data-kid=\"229\"></i>\n                </button>\n            </section>\n        </div>\n    </main>\n\n    \n    <footer class=\"fixed bottom-0 left-0 right-0 bg-[#0B0F17]/90 backdrop-blur-md border-t border-white/5 px-8 py-3 flex items-center justify-between z-40\" data-kid=\"230\">\n        <div class=\"flex items-center gap-6\" data-kid=\"231\">\n            <div class=\"flex items-center gap-2\" data-kid=\"232\">\n                <span class=\"w-2 h-2 rounded-full bg-orange-500 alert-glow\" data-kid=\"233\"></span>\n                <span class=\"text-[10px] font-mono text-orange-500\" data-kid=\"234\">2 URGENT TASKS</span>\n            </div>\n            <div class=\"h-4 w-px bg-white/10\" data-kid=\"235\"></div>\n            <div class=\"flex items-center gap-2\" data-kid=\"236\">\n                <span class=\"text-[10px] font-mono text-slate-500\" data-kid=\"237\">NEXT SYNC:</span>\n                <span class=\"text-[10px] font-mono text-white\" data-kid=\"238\">04:12:55</span>\n            </div>\n        </div>\n        <div class=\"flex items-center gap-4\" data-kid=\"239\">\n            <button class=\"text-[10px] font-mono text-slate-500 hover:text-white transition-colors\" data-kid=\"240\">API DOCS</button>\n            <button class=\"text-[10px] font-mono text-slate-500 hover:text-white transition-colors\" data-kid=\"241\">SUPPORT</button>\n        </div>\n    </footer>\n\n    \n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"242\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"243\"></script>\n    <script data-kid=\"244\">\n        gsap.registerPlugin(ScrollTrigger);\n\n        document.addEventListener('DOMContentLoaded', () => {\n            // Gauge Animation\n            gsap.to(\"#main-gauge\", {\n                strokeDashoffset: 440 - (440 * 0.84),\n                duration: 2,\n                ease: \"power2.out\"\n            });\n\n            // Entrance Animations\n            gsap.from(\".stagger-card\", {\n                y: 30,\n                opacity: 0,\n                duration: 0.8,\n                stagger: 0.15,\n                ease: \"power3.out\"\n            });\n\n            gsap.from(\".stagger-history\", {\n                x: 20,\n                opacity: 0,\n                duration: 0.8,\n                stagger: 0.1,\n                scrollTrigger: {\n                    trigger: \".stagger-history\",\n                    start: \"top 90%\"\n                }\n            });\n\n            // Smooth Scroll for Timeline (optional enhancement)\n            const timeline = document.querySelector('.scrollbar-hide');\n            if (timeline) {\n                // Potential scroll interactions can go here\n            }\n        });\n    </script>\n</div>\n",
