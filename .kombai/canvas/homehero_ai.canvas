           <div class=\"w-full h-2 bg-deep-navy/5 rounded-full overflow-hidden\" data-kid=\"80\">\n              <div class=\"h-full bg-accent w-[92%]\" data-kid=\"81\"></div>\n            </div>\n            <p class=\"text-[9px] font-black opacity-40 text-right uppercase tracking-widest\" data-kid=\"82\">92% of budget</p>\n          </div>\n        </div>\n\n        \n        <div class=\"glass-card p-8 rounded-[2rem] space-y-6\" data-kid=\"83\">\n          <div class=\"flex justify-between items-start\" data-kid=\"84\">\n            <div class=\"w-12 h-12 rounded-2xl bg-blue-500/10 flex items-center justify-center text-blue-500\" data-kid=\"85\">\n              <i class=\"ti ti-home text-2xl\" data-kid=\"86\"></i>\n            </div>\n            <span class=\"text-[10px] font-black text-blue-600 bg-blue-600/10 px-2.5 py-1 rounded-lg uppercase tracking-tighter\" data-kid=\"87\">Paid</span>\n          </div>\n          <div data-kid=\"88\">\n            <h4 class=\"text-lg font-black text-deep-navy leading-none\" data-kid=\"89\">Rent & Utilities</h4>\n            <p class=\"text-xs opacity-50 font-bold mt-1\" data-kid=\"90\">₹25,000 spent</p>\n          </div>\n          <div class=\"space-y-2\" data-kid=\"91\">\n            <div class=\"w-full h-2 bg-deep-navy/5 rounded-full overflow-hidden\" data-kid=\"92\">\n              <div class=\"h-full bg-blue-500 w-[100%]\" data-kid=\"93\"></div>\n            </div>\n            <p class=\"text-[9px] font-black opacity-40 text-right uppercase tracking-widest\" data-kid=\"94\">100% of budget</p>\n          </div>\n        </div>\n\n        \n        <div class=\"glass-card p-8 rounded-[2rem] space-y-6\" data-kid=\"95\">\n          <div class=\"flex justify-between items-start\" data-kid=\"96\">\n            <div class=\"w-12 h-12 rounded-2xl bg-emerald/10 flex items-center justify-center text-emerald\" data-kid=\"97\">\n              <i class=\"ti ti-shopping-bag text-2xl\" data-kid=\"98\"></i>\n            </div>\n            <span class=\"text-[10px] font-black text-emerald bg-emerald/10 px-2.5 py-1 rounded-lg uppercase tracking-tighter\" data-kid=\"99\">Healthy</span>\n          </div>\n          <div data-kid=\"100\">\n            <h4 class=\"text-lg font-black text-deep-navy leading-none\" data-kid=\"101\">Shopping</h4>\n            <p class=\"text-xs opacity-50 font-bold mt-1\" data-kid=\"102\">₹4,200 spent</p>\n          </div>\n          <div class=\"space-y-2\" data-kid=\"103\">\n            <div class=\"w-full h-2 bg-deep-navy/5 rounded-full overflow-hidden\" data-kid=\"104\">\n              <div class=\"h-full bg-emerald w-[28%]\" data-kid=\"105\"></div>\n            </div>\n            <p class=\"text-[9px] font-black opacity-40 text-right uppercase tracking-widest\" data-kid=\"106\">28% of budget</p>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"lg:col-span-4 space-y-10\" data-kid=\"107\">\n      \n      <div class=\"glass-card p-8 rounded-[2.5rem] bg-deep-navy text-white border-none shadow-[0_20px_60px_-15px_rgba(1,31,91,0.4)] relative overflow-hidden group\" data-kid=\"108\">\n        <div class=\"absolute -top-20 -right-20 w-64 h-64 bg-accent/20 rounded-full blur-[80px]\" data-kid=\"109\"></div>\n        \n        <div class=\"relative z-10 space-y-8\" data-kid=\"110\">\n          <div class=\"flex items-center gap-3\" data-kid=\"111\">\n            <div class=\"w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-accent animate-pulse\" data-kid=\"112\">\n              <i class=\"ti ti-sparkles text-xl\" data-kid=\"113\"></i>\n            </div>\n            <h3 class=\"text-lg font-black uppercase tracking-widest text-accent font-inter\" data-kid=\"114\">AI Smart Advisor</h3>\n          </div>\n\n          <div class=\"space-y-6\" data-kid=\"115\">\n            <div class=\"bg-white/10 p-6 rounded-3xl border border-white/10 space-y-3\" data-kid=\"116\">\n              <div class=\"flex items-center gap-2 text-accent\" data-kid=\"117\">\n                <i class=\"ti ti-alert-triangle\" data-kid=\"118\"></i>\n                <span class=\"text-[10px] font-black uppercase tracking-widest\" data-kid=\"119\">Risk Alert</span>\n              </div>\n              <p class=\"text-sm font-medium leading-relaxed\" data-kid=\"120\">Your food delivery spending is <span class=\"text-accent font-bold\" data-kid=\"121\">40% higher</span> than last month. Consider cooking at home this weekend.</p>\n            </div>\n\n            <div class=\"bg-white/10 p-6 rounded-3xl border border-white/10 space-y-3\" data-kid=\"122\">\n              <div class=\"flex items-center gap-2 text-emerald\" data-kid=\"123\">\n                <i class=\"ti ti-gift\" data-kid=\"124\"></i>\n                <span class=\"text-[10px] font-black uppercase tracking-widest\" data-kid=\"125\">Savings Tip</span>\n              </div>\n              <p class=\"text-sm font-medium leading-relaxed\" data-kid=\"126\">You have a surplus of <span class=\"text-emerald font-bold\" data-kid=\"127\">₹2,800</span> in your shopping budget. Move this to your Emergency Fund?</p>\n            </div>\n          </div>\n\n          <button class=\"w-full bg-accent text-deep-navy py-5 rounded-[1.5rem] font-black text-sm uppercase tracking-[0.2em] shadow-lg shadow-accent/20 hover:scale-[1.02] transition-transform\" data-kid=\"128\">\n            Optimize Strategy\n          </button>\n        </div>\n      </div>\n\n      \n      <div class=\"space-y-6\" data-kid=\"129\">\n        <div class=\"flex justify-between items-center px-2\" data-kid=\"130\">\n          <h3 class=\"text-xl font-black text-deep-navy font-inter uppercase tracking-widest\" data-kid=\"131\">Recent Activity</h3>\n          <button class=\"text-accent font-black text-xs uppercase tracking-widest hover:opacity-70 transition-opacity\" data-kid=\"132\">View All</button>\n        </div>\n\n        <div class=\"space-y-4\" data-kid=\"133\">\n          \n          <div class=\"glass-card p-5 rounded-3xl flex items-center gap-4 group cursor-pointer\" data-kid=\"134\">\n            <div class=\"w-12 h-12 rounded-2xl bg-white flex items-center justify-center shadow-sm group-hover:scale-110 transition-transform\" data-kid=\"135\">\n              <i class=\"ti ti-coffee text-xl text-deep-navy\" data-kid=\"136\"></i>\n            </div>\n            <div class=\"flex-1\" data-kid=\"137\">\n              <p class=\"text-sm font-bold text-deep-navy leading-none\" data-kid=\"138\">Blue Tokai Coffee</p>\n              <p class=\"text-[10px] font-bold opacity-40 uppercase mt-1\" data-kid=\"139\">Today • 09:42 AM</p>\n            </div>\n            <div class=\"text-right\" data-kid=\"140\">\n              <p class=\"text-sm font-black text-deep-navy leading-none\" data-kid=\"141\">- ₹380</p>\n              <p class=\"text-[9px] font-black text-orange-500 uppercase mt-1\" data-kid=\"142\">Dining</p>\n            </div>\n          </div>\n\n          \n          <div class=\"glass-card p-5 rounded-3xl flex items-center gap-4 group cursor-pointer\" data-kid=\"143\">\n            <div class=\"w-12 h-12 rounded-2xl bg-white flex items-center justify-center shadow-sm group-hover:scale-110 transition-transform\" data-kid=\"144\">\n              <i class=\"ti ti-shopping-bag text-xl text-deep-navy\" data-kid=\"145\"></i>\n            </div>\n            <div class=\"flex-1\" data-kid=\"146\">\n              <p class=\"text-sm font-bold text-deep-navy leading-none\" data-kid=\"147\">Amazon India</p>\n              <p class=\"text-[10px] font-bold opacity-40 uppercase mt-1\" data-kid=\"148\">Yesterday • 04:15 PM</p>\n            </div>\n            <div class=\"text-right\" data-kid=\"149\">\n              <p class=\"text-sm font-black text-deep-navy leading-none\" data-kid=\"150\">- ₹2,450</p>\n              <p class=\"text-[9px] font-black text-emerald uppercase mt-1\" data-kid=\"151\">Shopping</p>\n            </div>\n          </div>\n\n          \n          <div class=\"glass-card p-5 rounded-3xl flex items-center gap-4 group cursor-pointer\" data-kid=\"152\">\n            <div class=\"w-12 h-12 rounded-2xl bg-white flex items-center justify-center shadow-sm group-hover:scale-110 transition-transform\" data-kid=\"153\">\n              <i class=\"ti ti-arrow-down-left text-xl text-emerald\" data-kid=\"154\"></i>\n            </div>\n            <div class=\"flex-1\" data-kid=\"155\">\n              <p class=\"text-sm font-bold text-deep-navy leading-none\" data-kid=\"156\">Salary Credit</p>\n              <p class=\"text-[10px] font-bold opacity-40 uppercase mt-1\" data-kid=\"157\">01 July • 10:00 AM</p>\n            </div>\n            <div class=\"text-right\" data-kid=\"158\">\n              <p class=\"text-sm font-black text-emerald leading-none\" data-kid=\"159\">+ ₹85,000</p>\n              <p class=\"text-[9px] font-black text-deep-navy opacity-40 uppercase mt-1\" data-kid=\"160\">Income</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </main>\n</div>",
