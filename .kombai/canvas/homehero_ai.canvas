>\n                        <h4 class=\"text-xl font-bold mb-1\" data-kid=\"177\">Basmati Rice</h4>\n                        <p class=\"text-[11px] text-black/30 font-bold uppercase tracking-widest mb-6\" data-kid=\"178\">Pantry • 10kg Bag</p>\n                        <div class=\"w-full h-2 bg-black/5 rounded-full overflow-hidden\" data-kid=\"179\">\n                            <div class=\"h-full bg-orange-400 w-[22%] rounded-full shadow-[0_0_12px_rgba(251,146,60,0.3)]\" data-kid=\"180\"></div>\n                        </div>\n                        <p class=\"mt-4 text-[13px] font-bold text-orange-500\" data-kid=\"181\">Auto-restock scheduled for Tue.</p>\n                    </div>\n\n                    \n                    <div class=\"glass rounded-[2.5rem] p-8 card-hover transition-all duration-300 relative group\" data-kid=\"182\">\n                        <div class=\"flex justify-between items-start mb-6\" data-kid=\"183\">\n                            <div class=\"w-14 h-14 rounded-2xl bg-[#011F5B]/5 flex items-center justify-center text-[#011F5B]/60 group-hover:bg-[#011F5B] group-hover:text-white transition-colors duration-500\" data-kid=\"184\">\n                                <i class=\"ti ti-cube text-3xl\" data-kid=\"185\"></i>\n                            </div>\n                            <div class=\"text-right\" data-kid=\"186\">\n                                <span class=\"text-[11px] font-bold px-3 py-1 bg-blue-100 text-blue-600 rounded-full\" data-kid=\"187\">Sufficient</span>\n                                <p class=\"text-2xl font-bold mt-1\" data-kid=\"188\">62%</p>\n                            </div>\n                        </div>\n                        <h4 class=\"text-xl font-bold mb-1\" data-kid=\"189\">Refined Sugar</h4>\n                        <p class=\"text-[11px] text-black/30 font-bold uppercase tracking-widest mb-6\" data-kid=\"190\">Baking • 2kg Jar</p>\n                        <div class=\"w-full h-2 bg-black/5 round