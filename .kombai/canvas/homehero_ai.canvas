      "html": "\n<div class=\"min-h-screen bg-[#F8F9FA] font-['Inter'] text-[#1A1A1A] overflow-x-clip selection:bg-[#E5AA70]/30 selection:text-white pb-20\" data-kid=\"0\">\n\n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;600;700&family=JetBrains+Mono:wght@400;500&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n        .font-outfit { font-family: 'Outfit', sans-serif; }\n        .font-mono { font-family: 'JetBrains Mono', monospace; }\n\n        .glass {\n            background: rgba(255, 255, 255, 0.7);\n            backdrop-filter: blur(20px);\n            border: 1px solid rgba(255, 255, 255, 0.8);\n            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.03);\n        }\n\n        .card-shadow {\n            box-shadow: 0 4px 20px -5px rgba(0, 0, 0, 0.05);\n        }\n\n        .accent-gradient {\n            background: linear-gradient(135deg, #E5AA70 0%, #d4955b 100%);\n        }\n\n        .custom-toggle input:checked ~ .dot {\n            transform: translateX(100%);\n            background-color: white;\n        }\n        .custom-toggle input:checked ~ .bg {\n            background-color: #E5AA70;\n        }\n\n        .scanner-ring {\n            border: 2px solid #E5AA70;\n            box-shadow: 0 0 20px rgba(229, 170, 112, 0.4);\n            animation: scanner-pulse 2s infinite;\n        }\n        @keyframes scanner-pulse {\n            0% { transform: scale(1); opacity: 1; }\n            100% { transform: scale(1.5); opacity: 0; }\n        }\n\n        .scrollbar-hide::-webkit-scrollbar { display: none; }\n        .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }\n\n        .item-card-inner {\n            transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;\n        }\n        .item-card-inner:hover {\n            border-color: #E5AA70;\n            transform: translateY(-2px);\n            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.04);\n        }\n\n        .alert-pulse {\n            animation: alert-pulse-soft 2s infinite;\n        }\n        @keyframes alert-pulse-soft {\n            0% { border-color: rgba(239, 68, 68, 0.2); }\n            50% { border-color: rgba(239, 68, 68, 0.5); }\n            100% { border-color: rgba(239, 68, 68, 0.2); }\n        }\n\n        .low-stock-pulse {\n            animation: low-stock-pulse 2s infinite;\n        }\n        @keyframes low-stock-pulse {\n            0% { box-shadow: 0 0 0 0 rgba(229, 170, 112, 0.4); }\n            70% { box-shadow: 0 0 0 10px rgba(229, 170, 112, 0); }\n            100% { box-shadow: 0 0 0 0 rgba(229, 170, 112, 0); }\n        }\n    </style>\n\n    <link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"2\">\n\n    \n    <nav class=\"sticky top-0 z-50 glass border-b border-gray-100 px-8 py-5 flex items-center justify-between\" data-kid=\"3\">\n        <div class=\"flex items-center gap-8\" data-kid=\"4\">\n            <div class=\"flex items-center gap-2\" data-kid=\"5\">\n                <div class=\"w-10 h-10 bg-black rounded-xl flex items-center justify-center text-white shadow-lg\" data-kid=\"6\">\n                    <i class=\"ti ti-box-seam text-xl\" data-kid=\"7\"></i>\n                </div>\n                <h1 class=\"text-xl font-bold tracking-tight\" data-kid=\"8\">HomeHero <span class=\"text-[#E5AA70]\" data-kid=\"9\">AI</span></h1>\n            </div>\n            <div class=\"h-6 w-px bg-gray-200 hidden md:block\" data-kid=\"10\"></div>\n            <div class=\"hidden md:flex items-center gap-6\" data-kid=\"11\">\n                <a href=\"#\" class=\"text-sm font-medium text-gray-400 hover:text-black transition-colors\" data-kid=\"12\">Dashboard</a>\n                <a href=\"#\" class=\"text-sm font-bold text-black border-b-2 border-[#E5AA70] pb-1\" data-kid=\"13\">Inventory</a>\n         