      "html": "\n<div class=\"min-h-screen bg-[#F5F5F5] font-['DM_Sans'] text-[#011F5B] overflow-x-clip selection:bg-[#E5AA70]/30 relative pb-20\" data-kid=\"0\">\n    \n    <div class=\"fixed top-[-10%] left-[-10%] w-[40%] h-[40%] bg-[#E5AA70]/5 rounded-full blur-[120px] pointer-events-none\" data-kid=\"1\"></div>\n    <div class=\"fixed bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-[#011F5B]/5 rounded-full blur-[150px] pointer-events-none\" data-kid=\"2\"></div>\n\n    <style data-kid=\"3\">\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=DM+Sans:wght@400;500;700&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n        .glass {\n            background: rgba(255, 255, 255, 0.55);\n            backdrop-filter: blur(28px);\n            -webkit-backdrop-filter: blur(28px);\n            border: 1px solid rgba(255, 255, 255, 0.6);\n            box-shadow: 0 12px 48px -10px rgba(1, 31, 91, 0.05);\n        }\n        .card-hover:hover {\n            transform: translateY(-8px);\n            box-shadow: 0 32px 80px -20px rgba(1, 31, 91, 0.15);\n        }\n        .shimmer {\n            position: relative;\n            overflow: hidden;\n        }\n        .shimmer::after {\n            content: '';\n            position: absolute;\n            top: -50%;\n            left: -50%;\n            width: 200%;\n            height: 200%;\n            background: linear-gradient(\n                45deg,\n                transparent,\n                rgba(255, 255, 255, 0.1),\n                transparent\n            );\n            transform: rotate(45deg);\n            transition: 0.5s;\n        }\n        .shimmer:hover::after {\n            left: 100%;\n        }\n        \n        .glass-dark {\n            background: rgba(1, 31, 91, 0.03);\n            backdrop-filter: blur(8px);\n            border: 1px solid rgba(1, 31, 91, 0.05);\n        }\n\n        .orb-pulse {\n            animation: orb-pulse 4s infinite cubic-bezier(0.4, 0, 0.6, 1);\n        }\n        @keyframes orb-pulse {\n            0%, 100% { transform: scale(1); box-shadow: 0 0 20px rgba(1, 31, 91, 0.2); }\n            50% { transform: scale(1.1); box-shadow: 0 0 40px rgba(1, 31, 91, 0.4); }\n        }\n\n        .wave-ring {\n            position: absolute;\n            border-radius: 50%;\n            border: 1px solid rgba(229, 170, 112, 0.4);\n            animation: ring-ripple 4s infinite ease-out;\n        }\n        @keyframes ring-ripple {\n            0% { transform: scale(0.8); opacity: 0.8; }\n            100% { transform: scale(3); opacity: 0; }\n        }\n\n        .custom-scrollbar::-webkit-scrollbar { width: 6px; }\n        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }\n        .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(1, 31, 91, 0.1); border-radius: 10px; }\n    </style>\n\n    \n    <nav class=\"sticky top-0 z-50 px-8 py-6 flex items-center justify-between glass mb-8 border-b border-white/40\" data-kid=\"4\">\n        <div class=\"flex items-center gap-3\" data-kid=\"5\">\n            <div class=\"w-10 h-10 bg-[#011F5B] rounded-xl flex items-center justify-center text-white shadow-lg shadow-[#011F5B]/20\" data-kid=\"6\">\n                <i class=\"ti ti-home-heart text-xl\" data-kid=\"7\"></i>\n            </div>\n            <h1 class=\"text-2xl font-bold font-['Inter'] tracking-tight\" data-kid=\"8\">HomeHero <span class=\"text-[#E5AA70]\" data-kid=\"9\">AI</span></h1>\n        </div>\n        \n        <div class=\"hidden md:flex items-center gap-10\" data-kid=\"10\">\n            <a href=\"#\" class=\"text-sm font-bold opacity-100 hover:text-[#E5AA70] transition-colors\" data-kid=\"11\">Dashboard</a>\n            <a href=\"#\" class=\"text-sm font-bold opacity-50 hover:opacity-100 transition-opacity\" data-kid=\"12\">Grocery</a>\n            <a href=\"#\" class=\"text-sm font-bold opacity-50 hover:opacity-100 transition-opacity\" data-kid=\"13\">Expenses</a>\n            <a href=\"#\" class=\"text-sm font-bold opacity-50 hover:opacity-100 transition-opacity\" data-kid=\"14\">Health</a>\n        </div>\n\n        <div class=\"flex items-center gap-6\" data-kid=\"15\">\n            <div class=\"relative hidden sm:block\" data-kid=\"16\">\n                <i class=\"ti ti-bell text-xl opacity-60 hover:opacity-100 cursor-pointer transition-opacity\" data-kid=\"17\"></i>\n                <div class=\"absolute -top-1 -right-1 w-2 h-2 bg-red-500 rounded-full border-2 border-white\" data-kid=\"18\"></div>\n            </div>\n            <div class=\"flex items-center gap-3 pl-6 border-l border-black/5\" data-kid=\"19\">\n                <div class=\"text-right hidden sm:block\" data-kid=\"20\">\n                    <p class=\"text-xs font-bold opacity-40 uppercase tracking-widest\" data-kid=\"21\">Premium User</p>\n                    <p class=\"text-sm font-bold\" data-kid=\"22\">Anjali Sharma</p>\n                </div>\n                <img src=\"https://i.pravatar.cc/150?u=Anjali\" class=\"w-10 h-10 rounded-full border-2 border-[#E5AA70] p-0.5\" alt=\"Anjali\" data-kid=\"23\">\n            </div>\n        </div>\n    </nav>\n\n    <main class=\"max-w-7xl mx-auto px-8 space-y-16 pb-40\" data-kid=\"24\">\n        \n        <section class=\"grid grid-cols-1 md:grid-cols-12 gap-6 stagger-item\" data-kid=\"25\">\n            \n            <div class=\"md:col-span-8 glass card-hover rounded-[2.5rem] p-10 flex flex-col justify-between min-h-[460px] relative overflow-hidden group transition-all duration-300\" data-kid=\"26\">\n                <div class=\"absolute -top-10 -right-10 p-8 opacity-5 group-hover:opacity-10 transition-opacity pointer-events-none rotate-12\" data-kid=\"27\">\n                    <i class=\"ti ti-sun text-[18rem]\" data-kid=\"28\"></i>\n                </div>\n                \n                <div class=\"relative z-10\" data-kid=\"29\">\n                    <div class=\"flex items-center gap-3 mb-8\" data-kid=\"30\">\n                        <div class=\"w-8 h-8 rounded-full bg-[#E5AA70]/10 flex items-center justify-center text-[#E5AA70]\" data-kid=\"31\">\n                            <i class=\"ti ti-brightness-up text-lg\" data-kid=\"32\"></i>\n                        </div>\n                        <span class=\"text-black/40 text-sm font-semibold tracking-tight\" data-kid=\"33\">Today is Monday, July 14, 2026</span>\n                    </div>\n                    <h2 class=\"text-5xl md:text-[5rem] font-bold font-['Inter'] leading-[0.95] mb-6 tracking-tight text-[#011F5B]\" data-kid=\"34\">Good Morning,<br data-kid=\"35\">Anjali!</h2>\n                    <p class=\"text-2xl text-black/50 max-w-lg font-medium leading-tight\" data-kid=\"36\">It's 28°C and clear in Paris. You've got a busy morning with 2 important alerts requiring your attention.</p>\n                </div>\n\n                <div class=\"relative z-10 flex flex-col sm:flex-row items-end sm:items-center justify-between gap-8 mt-12 bg-white/30 backdrop-blur-md p-6 rounded-[2rem] border border-white/40\" data-kid=\"37\">\n                    <div class=\"space-y-4 flex-1\" data-kid=\"38\">\n                        <div class=\"flex flex-col gap-3\" data-kid=\"39\">\n                            <div class=\"flex items-center gap-3\" data-kid=\"40\">\n                                <div class=\"w-2.5 h-2.5 rounded-full bg-red-500 shadow-[0_0_10px_rgba(239,68,68,0.5)]\" data-kid=\"41\"></div>\n                                <span class=\"text-sm font-bold text-[#011F5B]/80\" data-kid=\"42\">Electricity bill due today ($142)</span>\n                            </div>\n                            <div class=\"flex items-center gap-3\" data-kid=\"43\">\n                                <div class=\"w-2.5 h-2.5 rounded-full bg-[#E5AA70] shadow-[0_0_10px_rgba(229,170,112,0.5)]\" data-kid=\"44\"></div>\n                                <span class=\"text-sm font-bold text-[#011F5B]/80\" data-kid=\"45\">Mom's medicine reminder at 9:00 AM</span>\n                            </div>\n                        </div>\n                    </div>\n                    <button class=\"bg-[#011F5B] text-white px-8 py-4 rounded-2xl font-bold flex items-center gap-3 hover:bg-[#011F5B]/90 transition-all shadow-xl shadow-[#011F5B]/15 group whitespace-nowrap shimmer\" data-kid=\"46\">\n                        Schedule Overview\n                        <i class=\"ti ti-calendar-event group-hover:scale-110 transition-transform\" data-kid=\"47\"></i>\n                    </button>\n                </div>\n            </div>\n\n            \n            <div class=\"md:col-span-4 flex flex-col gap-6\" data-kid=\"48\">\n                \n                <div class=\"glass card-hover rounded-[2.5rem] p-8 flex flex-col items-center justify-center text-center flex-1 border-[#E5AA70]/10 border relative overflow-hidden group transition-all duration-300\" data-kid=\"49\">\n                    <div class=\"absolute inset-0 bg-gradient-to-br from-[#E5AA70]/10 to-transparent pointer-events-none\" data-kid=\"50\"></div>\n                    <div class=\"relative z-10 mb-6 group-hover:scale-110 transition-transform duration-500\" data-kid=\"51\">\n                        <i class=\"ti ti-cloud-sun text-7xl text-[#011F5B]/80 drop-shadow-md\" data-kid=\"52\"></i>\n                    </div>\n                    <div class=\"relative z-10\" data-kid=\"53\">\n                        <h3 class=\"text-5xl font-bold font-['Inter'] mb-2\" data-kid=\"54\">28°C</h3>\n                        <p class=\"text-[#011F5B]/60 font-bold text-lg tracking-tight\" data-kid=\"55\">Mostly Sunny • Paris</p>\n                        <div class=\"mt-4 flex items-center gap-2 justify-center opacity-40\" data-kid=\"56\">\n                            <i class=\"ti ti-wind text-sm\" data-kid=\"57\"></i>\n                            <span class=\"text-xs font-bold\" data-kid=\"58\">12 km/h NE</span>\n                        </div>\n                    </div>\n                </div>\n                \n                <div class=\"glass card-hover rounded-[2.5rem] p-8 flex items-center justify-between group cursor-pointer transition-all duration-300\" data-kid=\"59\">\n                    <div data-kid=\"60\">\n                        <h3 class=\"text-xl font-bold flex items-center gap-2 text-[#011F5B]\" data-kid=\"61\">\n                            All Safe <span class=\"w-2.5 h-2.5 rounded-full bg-green-500 animate-pulse\" data-kid=\"62\"></span>\n                        </h3>\n                        <p class=\"text-xs font-semibold text-black/40 mt-1\" data-kid=\"63\">4 family members detected</p>\n                    </div>\n                    <div class=\"flex -space-x-3\" data-kid=\"64\">\n                        <img src=\"https://i.pravatar.cc/150?u=1\" class=\"w-10 h-10 rounded-full border-2 border-white shadow-lg\" alt=\"Family\" data-kid=\"65\">\n                        <img src=\"https://i.pravatar.cc/150?u=2\" class=\"w-10 h-10 rounded-full border-2 border-white shadow-lg\" alt=\"Family\" data-kid=\"66\">\n                        <div class=\"w-10 h-10 rounded-full bg-[#E5AA70] flex items-center justify-center text-white text-xs font-bold border-2 border-white shadow-lg\" data-kid=\"67\">+2</div>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        \n        <section class=\"grid grid-cols-1 lg:grid-cols-12 gap-12 items-center stagger-item\" data-kid=\"68\">\n            \n            <div class=\"lg:col-span-4 space-y-10\" data-kid=\"69\">\n                <div class=\"relative\" data-kid=\"70\">\n                    <div class=\"absolute -left-4 -top-4 w-16 h-16 bg-[#E5AA70]/5 rounded-full blur-2xl\" data-kid=\"71\"></div>\n                    <div class=\"flex items-center gap-4 mb-6 relative\" data-kid=\"72\">\n                        <i class=\"ti ti-shopping-cart text-4xl text-[#E5AA70]\" data-kid=\"73\"></i>\n                        <h4 class=\"text-sm font-bold uppercase tracking-widest text-[#E5AA70]/60\" data-kid=\"74\">Pantry Intelligence</h4>\n                    </div>\n                    <h2 class=\"text-4xl md:text-5xl font-bold font-['Inter'] mb-6 leading-[1.1] tracking-tight\" data-kid=\"75\">Seamless Kitchen Management</h2>\n                    <p class=\"text-black/50 leading-relaxed text-xl font-medium\" data-kid=\"76\">Predictive restocking and AI-curated recipes tailored to what you already have in stock.</p>\n                </div>\n                \n                <div class=\"glass card-hover rounded-[2rem] p-6 border-l-4 border-red-500 shadow-xl shadow-red-500/5 transition-all duration-300\" data-kid=\"77\">\n                    <div class=\"flex items-start gap-4\" data-kid=\"78\">\n                        <div class=\"w-10 h-10 rounded-xl bg-red-50 flex items-center justify-center text-red-500 shrink-0\" data-kid=\"79\">\n                            <i class=\"ti ti-alert-triangle-filled\" data-kid=\"80\"></i>\n                        </div>\n                        <div data-kid=\"81\">\n                            <p class=\"font-bold text-[#011F5B]\" data-kid=\"82\">Rice Inventory Low</p>\n                            <p class=\"text-sm text-black/50 mt-1 font-medium\" data-kid=\"83\">Only 400g left. Auto-replenishment order scheduled for tomorrow.</p>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"flex gap-4\" data-kid=\"84\">\n                    <button class=\"bg-[#011F5B] text-white px-8 py-4 rounded-2xl font-bold shadow-lg shadow-[#011F5B]/15 hover:scale-105 transition-transform\" data-kid=\"85\">\n                        Grocery List\n                    </button>\n                    <button class=\"bg-white border border-black/5 px-8 py-4 rounded-2xl font-bold hover:bg-black/5 transition-colors\" data-kid=\"86\">\n                        Inventory\n                    </button>\n                </div>\n            </div>\n\n            \n            <div class=\"lg:col-span-8 grid grid-cols-1 sm:grid-cols-2 gap-6 h-full min-h-[500px]\" data-kid=\"87\">\n                <div class=\"sm:row-span-2 relative rounded-[3rem] overflow-hidden group shadow-2xl\" data-kid=\"88\">\n                    <img src=\"https://images.unsplash.com/photo-1766596737206-214abffe65bf?auto=format&w=800&q=80&fit=crop\" alt=\"James Kern on Unsplash\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-[2s]\" data-kid=\"89\">\n                    <div class=\"absolute inset-0 bg-gradient-to-t from-[#011F5B]/90 via-[#011F5B]/20 to-transparent p-10 flex flex-col justify-end\" data-kid=\"90\">\n                        <span class=\"px-3 py-1 bg-[#E5AA70] rounded-full text-white text-[10px] font-bold uppercase w-fit mb-4\" data-kid=\"91\">Chef's Choice</span>\n                        <h3 class=\"text-3xl font-bold text-white font-['Inter'] leading-tight mb-2\" data-kid=\"92\">Summer Harvest Vegetable Stew</h3>\n                        <p class=\"text-white/70 mb-6\" data-kid=\"93\">Uses 90% of current pantry stock. High in Fiber & Vitamin C.</p>\n                        <div class=\"flex gap-3 items-center\" data-kid=\"94\">\n                            <div class=\"flex items-center gap-1.5 px-3 py-1.5 bg-white/20 backdrop-blur-xl rounded-lg text-white text-xs font-bold\" data-kid=\"95\">\n                                <i class=\"ti ti-clock\" data-kid=\"96\"></i> 25 MIN\n                            </div>\n                            <div class=\"flex items-center gap-1.5 px-3 py-1.5 bg-white/20 backdrop-blur-xl rounded-lg text-white text-xs font-bold\" data-kid=\"97\">\n                                <i class=\"ti ti-flame\" data-kid=\"98\"></i> 320 CAL\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"glass card-hover rounded-[2.5rem] p-8 flex flex-col justify-between transition-all duration-300\" data-kid=\"99\">\n                    <div class=\"flex justify-between items-center mb-4\" data-kid=\"100\">\n                        <div class=\"flex items-center gap-3\" data-kid=\"101\">\n                            <i class=\"ti ti-tools-kitchen-2 text-2xl text-[#011F5B]/40\" data-kid=\"102\"></i>\n                            <span class=\"text-xs font-bold text-[#011F5B]/40 uppercase tracking-widest\" data-kid=\"103\">Daily Recipe</span>\n                        </div>\n                        <i class=\"ti ti-heart text-xl text-[#011F5B]/20 cursor-pointer hover:text-red-400 transition-colors\" data-kid=\"104\"></i>\n                    </div>\n                    <div data-kid=\"105\">\n                        <h4 class=\"text-2xl font-bold font-['Inter'] mb-2 tracking-tight\" data-kid=\"106\">Wild Mushroom Risotto</h4>\n                        <p class=\"text-sm text-black/50 font-medium leading-relaxed\" data-kid=\"107\">Deliciously creamy and rich. Perfect for tonight's dinner based on your preferences.</p>\n                    </div>\n                    <a href=\"#\" class=\"text-[#E5AA70] font-bold text-sm flex items-center gap-2 group/link mt-6\" data-kid=\"108\">\n                        Explore Full Recipe <i class=\"ti ti-arrow-right group-hover/link:translate-x-1 transition-transform\" data-kid=\"109\"></i>\n                    </a>\n                </div>\n\n                <div class=\"glass card-hover rounded-[2.5rem] p-8 flex flex-col justify-between border-2 border-[#E5AA70]/20 relative overflow-hidden transition-all duration-300\" data-kid=\"110\">\n                    <div class=\"absolute -right-4 -top-4 w-24 h-24 bg-[#E5AA70]/10 rounded-full blur-2xl\" data-kid=\"111\"></div>\n                    <div class=\"flex justify-between items-center relative z-10 mb-4\" data-kid=\"112\">\n                        <div class=\"flex items-center gap-3\" data-kid=\"113\">\n                            <i class=\"ti ti-sparkles text-2xl text-[#E5AA70]\" data-kid=\"114\"></i>\n                            <span class=\"text-xs font-bold text-[#E5AA70] uppercase tracking-widest\" data-kid=\"115\">Stock Alert</span>\n                        </div>\n                    </div>\n                    <div class=\"relative z-10\" data-kid=\"116\">\n                        <h4 class=\"text-2xl font-bold font-['Inter'] mb-2 tracking-tight\" data-kid=\"117\">Milk Stock Prediction</h4>\n                        <p class=\"text-sm text-[#011F5B]/60 font-medium\" data-kid=\"118\">Estimated finish by 9:00 PM tomorrow. Added to cart for one-tap checkout.</p>\n                    </div>\n                    <button class=\"bg-[#011F5B] text-white text-xs font-bold px-6 py-3 rounded-xl w-fit relative z-10 hover:bg-[#011F5B]/90 transition-colors shadow-lg shadow-[#011F5B]/10 mt-6 shimmer\" data-kid=\"119\">\n                        Confirm Purchase\n                    </button>\n                </div>\n            </div>\n        </section>\n\n        \n        <section class=\"grid grid-cols-1 lg:grid-cols-12 gap-6 stagger-item\" data-kid=\"120\">\n            \n            <div class=\"lg:col-span-8 glass rounded-[3rem] p-10 relative overflow-hidden group\" data-kid=\"121\">\n                <div class=\"flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-10\" data-kid=\"122\">\n                    <div data-kid=\"123\">\n                        <h2 class=\"text-3xl font-bold font-['Inter']\" data-kid=\"124\">Monthly Financial Health</h2>\n                        <p class=\"text-black/50 text-sm\" data-kid=\"125\">Tracking expenses vs your $5,000 budget target</p>\n                    </div>\n                    <div class=\"flex items-center gap-6 glass-dark px-6 py-3 rounded-2xl\" data-kid=\"126\">\n                        <div class=\"flex items-center gap-2\" data-kid=\"127\">\n                            <div class=\"w-3 h-3 rounded-full bg-[#011F5B]\" data-kid=\"128\"></div>\n                            <span class=\"text-xs font-bold opacity-70\" data-kid=\"129\">Actual</span>\n                        </div>\n                        <div class=\"flex items-center gap-2\" data-kid=\"130\">\n                            <div class=\"w-3 h-3 rounded-full bg-[#E5AA70]\" data-kid=\"131\"></div>\n                            <span class=\"text-xs font-bold opacity-40\" data-kid=\"132\">Budget</span>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"h-72 w-full relative mb-10 px-4\" data-kid=\"133\">\n                    <canvas id=\"expensesTimeline\" data-kid=\"134\"></canvas>\n                </div>\n\n                <div class=\"grid grid-cols-1 sm:grid-cols-3 gap-6\" data-kid=\"135\">\n                    <div class=\"glass-dark p-6 rounded-[2rem] border-b-2 border-[#011F5B]/10\" data-kid=\"136\">\n                        <p class=\"text-[10px] font-bold text-black/30 uppercase tracking-widest mb-2\" data-kid=\"137\">Total Spent</p>\n                        <p class=\"text-2xl font-bold\" data-kid=\"138\">$3,842.10</p>\n                    </div>\n                    <div class=\"glass-dark p-6 rounded-[2rem] border-b-2 border-[#E5AA70]/10\" data-kid=\"139\">\n                        <p class=\"text-[10px] font-bold text-black/30 uppercase tracking-widest mb-2\" data-kid=\"140\">Savings</p>\n                        <p class=\"text-2xl font-bold\" data-kid=\"141\">$1,157.90</p>\n                    </div>\n                    <div class=\"bg-green-500/10 p-6 rounded-[2rem] border-b-2 border-green-500/20\" data-kid=\"142\">\n                        <p class=\"text-[10px] font-bold text-green-600/60 uppercase tracking-widest mb-2\" data-kid=\"143\">AI Forecast</p>\n                        <p class=\"text-2xl font-bold text-green-600\" data-kid=\"144\">On Track</p>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"lg:col-span-4 glass rounded-[3rem] p-10 flex flex-col\" data-kid=\"145\">\n                <h3 class=\"text-xl font-bold font-['Inter'] mb-10\" data-kid=\"146\">Spending Breakdown</h3>\n                \n                <div class=\"flex-1 space-y-8\" data-kid=\"147\">\n                    <div class=\"space-y-3\" data-kid=\"148\">\n                        <div class=\"flex justify-between text-[11px] font-bold uppercase tracking-widest\" data-kid=\"149\">\n                            <span class=\"text-black/50\" data-kid=\"150\">Home & Rent</span>\n                            <span class=\"text-[#011F5B]\" data-kid=\"151\">$1,400</span>\n                        </div>\n                        <div class=\"w-full h-2 bg-black/5 rounded-full overflow-hidden\" data-kid=\"152\">\n                            <div class=\"h-full bg-[#011F5B] w-[90%] rounded-full\" data-kid=\"153\"></div>\n                        </div>\n                    </div>\n                    <div class=\"space-y-3\" data-kid=\"154\">\n                        <div class=\"flex justify-between text-[11px] font-bold uppercase tracking-widest\" data-kid=\"155\">\n                            <span class=\"text-black/50\" data-kid=\"156\">Grocery</span>\n                            <span class=\"text-[#011F5B]\" data-kid=\"157\">$840</span>\n                        </div>\n                        <div class=\"w-full h-2 bg-black/5 rounded-full overflow-hidden\" data-kid=\"158\">\n                            <div class=\"h-full bg-[#E5AA70] w-[60%] rounded-full\" data-kid=\"159\"></div>\n                        </div>\n                    </div>\n                    <div class=\"space-y-3\" data-kid=\"160\">\n                        <div class=\"flex justify-between text-[11px] font-bold uppercase tracking-widest\" data-kid=\"161\">\n                            <span class=\"text-black/50\" data-kid=\"162\">Health</span>\n                            <span class=\"text-[#011F5B]\" data-kid=\"163\">$420</span>\n                        </div>\n                        <div class=\"w-full h-1.5 bg-black/5 rounded-full overflow-hidden\" data-kid=\"164\">\n                            <div class=\"h-full bg-[#011F5B] w-[35%] rounded-full\" data-kid=\"165\"></div>\n                        </div>\n                    </div>\n                    <div class=\"space-y-3\" data-kid=\"166\">\n                        <div class=\"flex justify-between text-[11px] font-bold uppercase tracking-widest\" data-kid=\"167\">\n                            <span class=\"text-black/50\" data-kid=\"168\">Education</span>\n                            <span class=\"text-[#011F5B]\" data-kid=\"169\">$600</span>\n                        </div>\n                        <div class=\"w-full h-1.5 bg-black/5 rounded-full overflow-hidden\" data-kid=\"170\">\n                            <div class=\"h-full bg-[#E5AA70] w-[50%] rounded-full\" data-kid=\"171\"></div>\n                        </div>\n                    </div>\n                </div>\n\n                <button class=\"mt-12 w-full border-2 border-[#011F5B]/10 py-4 rounded-2xl font-bold flex items-center justify-center gap-2 hover:bg-[#011F5B] hover:text-white transition-all group\" data-kid=\"172\">\n                    <i class=\"ti ti-chart-pie\" data-kid=\"173\"></i> Detailed Breakdown\n                </button>\n            </div>\n        </section>\n    </main>\n\n    \n    <div class=\"fixed bottom-8 right-8 z-[60] flex flex-col items-end gap-4 pointer-events-none\" data-kid=\"174\">\n        <div id=\"ai-chat-bubble\" class=\"opacity-0 translate-y-4 pointer-events-auto glass shadow-2xl p-8 rounded-[3rem] mb-4 max-w-[340px] border-2 border-white/60 relative overflow-hidden group\" data-kid=\"175\">\n            <div class=\"absolute -top-4 -right-4 w-20 h-20 bg-[#E5AA70]/10 rounded-full blur-2xl pointer-events-none\" data-kid=\"176\"></div>\n            <div class=\"flex items-center gap-3 mb-4\" data-kid=\"177\">\n                <div class=\"w-8 h-8 rounded-full bg-[#011F5B] flex items-center justify-center text-white\" data-kid=\"178\">\n                    <i class=\"ti ti-sparkles text-sm\" data-kid=\"179\"></i>\n                </div>\n                <p class=\"text-lg font-bold text-[#011F5B] tracking-tight\" data-kid=\"180\">Smart Analysis</p>\n            </div>\n            <p class=\"text-base font-medium leading-relaxed text-[#011F5B]/70 italic\" data-kid=\"181\">\"Hello Anjali, I've noticed a 15% increase in food delivery this week. Shall I suggest some quick 15-minute home-cooked meals instead?\"</p>\n            <div class=\"mt-6 flex gap-2\" data-kid=\"182\">\n                <button class=\"bg-[#011F5B] text-white text-[10px] font-bold px-4 py-2 rounded-full pointer-events-auto\" data-kid=\"183\">Yes, show me</button>\n                <button class=\"bg-black/5 text-black/40 text-[10px] font-bold px-4 py-2 rounded-full pointer-events-auto\" data-kid=\"184\">Maybe later</button>\n            </div>\n        </div>\n        \n        <div class=\"relative pointer-events-auto cursor-pointer group\" id=\"voice-assistant-orb\" data-kid=\"185\">\n            \n            <div class=\"wave-ring w-20 h-20 top-0 left-0\" data-kid=\"186\"></div>\n            <div class=\"wave-ring w-20 h-20 top-0 left-0\" style=\"animation-delay: 1s;\" data-kid=\"187\"></div>\n            <div class=\"wave-ring w-20 h-20 top-0 left-0\" style=\"animation-delay: 2s;\" data-kid=\"188\"></div>\n            \n            <div class=\"w-20 h-20 rounded-full bg-[#011F5B] orb-pulse flex items-center justify-center text-white relative z-10 border-4 border-white shadow-2xl\" data-kid=\"189\">\n                <i class=\"ti ti-mic text-3xl\" data-kid=\"190\"></i>\n            </div>\n        </div>\n    </div>\n\n    \n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"191\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/chart.js\" data-kid=\"192\"></script>\n\n    <script data-kid=\"193\">\n        // Entrance Animations\n        window.addEventListener('load', () => {\n            gsap.from(\".stagger-item\", {\n                duration: 1.2,\n                y: 50,\n                opacity: 0,\n                stagger: 0.3,\n                ease: \"power4.out\"\n            });\n\n            gsap.to(\"#ai-chat-bubble\", {\n                delay: 2,\n                duration: 0.8,\n                opacity: 1,\n                y: 0,\n                ease: \"back.out(1.7)\"\n            });\n        });\n\n        // Initialize ROI Timeline Chart\n        const ctx = document.getElementById('expensesTimeline').getContext('2d');\n        const gradient = ctx.createLinearGradient(0, 0, 0, 300);\n        gradient.addColorStop(0, 'rgba(1, 31, 91, 0.15)');\n        gradient.addColorStop(1, 'rgba(1, 31, 91, 0)');\n\n        new Chart(ctx, {\n            type: 'line',\n            data: {\n                labels: ['Week 1', 'Week 2', 'Week 3', 'Week 4', 'Week 5'],\n                datasets: [\n                    {\n                        label: 'Actual Expenses',\n                        data: [800, 1500, 1200, 2400, 1900],\n                        borderColor: '#011F5B',\n                        backgroundColor: gradient,\n                        fill: true,\n                        tension: 0.4,\n                        borderWidth: 4,\n                        pointRadius: 6,\n                        pointBackgroundColor: '#011F5B',\n                        pointBorderColor: '#fff',\n                        pointBorderWidth: 2\n                    },\n                    {\n                        label: 'Budget Path',\n                        data: [1000, 2000, 3000, 4000, 5000],\n                        borderColor: '#E5AA70',\n                        borderWidth: 2,\n                        borderDash: [10, 5],\n                        fill: false,\n                        pointRadius: 0\n                    }\n                ]\n            },\n            options: {\n                responsive: true,\n                maintainAspectRatio: false,\n                plugins: {\n                    legend: { display: false }\n                },\n                scales: {\n                    x: {\n                        grid: { display: false },\n                        ticks: { font: { weight: '600' }, color: '#011F5B66' }\n                    },\n                    y: {\n                        display: false\n                    }\n                }\n            }\n        });\n\n        // Interactive Orb\n        document.getElementById('voice-assistant-orb').addEventListener('click', () => {\n            gsap.to(\"#voice-assistant-orb\", { scale: 0.9, duration: 0.1, yoyo: true, repeat: 1 });\n            const bubble = document.getElementById('ai-chat-bubble');\n            const isVisible = bubble.dataset.visible === \"true\";\n            \n            if(!isVisible) {\n                 gsap.to(bubble, { opacity: 1, y: 0, duration: 0.6, ease: \"power4.out\" });\n                 bubble.dataset.visible = \"true\";\n            } else {\n                 gsap.to(bubble, { opacity: 0, y: 30, duration: 0.5, ease: \"power4.in\" });\n                 bubble.dataset.visible = \"false\";\n            }\n        });\n    </script>\n</div>\n",
