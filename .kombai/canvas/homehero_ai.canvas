    "var_d1d734875068": {
      "type": "variant",
      "label": "HomeHero - Glassmorphic Premium",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 3080,
        "y": 0,
        "w": 1440,
        "h": 800
