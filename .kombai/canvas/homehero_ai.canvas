      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap');\n\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --color-accent: #E5AA70; /* Terracotta */\n    --color-deep-navy: #011F5B;\n    --color-navy-light: #1A3A7A;\n    --color-glass-bg: rgba(255, 255, 255, 0.45);\n    --color-glass-border: rgba(255, 255, 255, 0.5);\n    --color-surface: #F5F5F5;\n    --color-emerald: #10B981;\n  }\n\n  @layer base {\n    body {\n      background-color: var(--color-surface);\n      color: var(--color-deep-navy);\n      font-family: 'DM Sans', sans-serif;\n      margin: 0;\n      overflow-x: hidden;\n    }\n  }\n\n  @layer components {\n    .glass-card {\n      background: var(--color-glass-bg);\n      backdrop-filter: blur(24px);\n      -webkit-backdrop-filter: blur(24px);\n      border: 1px solid var(--color-glass-border);\n      box-shadow: 0 12px 48px -10px rgba(1, 31, 91, 0.1);\n      transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);\n    }\n\n    .glass-card:hover {\n      transform: translateY(-4px);\n      box-shadow: 0 20px 60px -15px rgba(1, 31, 91, 0.15);\n    }\n\n    .premium-button {\n      position: relative;\n      overflow: hidden;\n      padding: 0.75rem 1.5rem;\n      border-radius: 1rem;\n      font-weight: 700;\n      transition: all 0.3s ease;\n      background: var(--color-deep-navy);\n      color: white;\n      border: none;\n      cursor: pointer;\n    }\n\n    .premium-button:hover {\n      opacity: 0.9;\n      transform: scale(1.02);\n    }\n\n    .orb-pulse {\n      animation: orb-pulse 4s infinite cubic-bezier(0.4, 0, 0.6, 1);\n    }\n\n    @keyframes orb-pulse {\n      0%, 100% { transform: scale(1); box-shadow: 0 0 20px rgba(1, 31, 91, 0.1); }\n      50% { transform: scale(1.05); box-shadow: 0 0 40px rgba(1, 31, 91, 0.2); }\n    }\n\n    .silk-mesh {\n      position: fixed;\n      inset: 0;\n      z-index: -1;\n      background: \n        radial-gradient(at 0% 0%, rgba(229, 170, 112, 0.15) 0px, transparent 50%),\n        radial-gradient(at 100% 100%, rgba(26, 58, 122, 0.15) 0px, transparent 50%),\n        radial-gradient(at 50% 50%, rgba(16, 185, 129, 0.05) 0px, transparent 50%);\n      filter: blur(100px);\n    }\n  }\n</style>\n\n<div class=\"silk-mesh\" data-kid=\"1\"></div>\n\n<div class=\"min-h-screen flex flex-col\" data-kid=\"2\">\n  \n  <header class=\"w-full px-10 py-6 flex items-center justify-between sticky top-0 z-50 backdrop-blur-md border-b border-white/20\" data-kid=\"3\">\n    <div class=\"flex items-center gap-2\" data-kid=\"4\">\n      <div class=\"w-10 h-10 bg-deep-navy rounded-xl flex items-center justify-center text-white\" data-kid=\"5\">\n        <i class=\"ti ti-home-hero text-2xl\" data-kid=\"6\"></i>\n      </div>\n      <span class=\"font-black text-xl tracking-tighter text-deep-navy font-inter\" data-kid=\"7\">HomeHero <span class=\"text-accent italic\" data-kid=\"8\">AI</span></span>\n    </div>\n    \n    <nav class=\"hidden md:flex items-center gap-10\" data-kid=\"9\">\n      <a href=\"#\" class=\"text-sm font-black opacity-40 hover:opacity-100 transition-opacity uppercase tracking-widest\" data-kid=\"10\">Dashboard</a>\n      <a href=\"#\" class=\"text-sm font-black opacity-40 hover:opacity-100 transition-opacity uppercase tracking-widest\" data-kid=\"11\">Grocery</a>\n      <a href=\"#\" class=\"text-sm font-black text-deep-navy uppercase tracking-widest border-b-2 border-accent pb-1\" data-kid=\"12\">Expenses</a>\n      <a href=\"#\" class=\"text-sm font-black opacity-40 hover:opacity-100 transition-opacity uppercase tracking-widest\" data-kid=\"13\">Health</a>\n    </nav>\n\n    <div class=\"flex items-center gap-6\" data-kid=\"14\">\n      <button class=\"relative w-10 h-10 rounded-full bg-white/40 border border-white/60 flex items-center justify-center hover:bg-white transition-colors\" data-kid=\"15\">\n        <i class=\"ti ti-bell text-xl\" data-kid=\"16\"></i>\n        <span class=\"absolute top-2 right-2 w-2 h-2 bg-accent rounded-full border-2 border-white\" data-kid=\"17\"></span>\n      </button>\n      <div class=\"flex items-center gap-3 pl-4 border-l border-deep-navy/10\" data-kid=\"18\">\n        <div class=\"text-right hidden sm:block\" data-kid=\"19\">\n          <p class=\"text-[10px] font-black opacity-40 uppercase tracking-widest leading-none\" data-kid=\"20\">Premium User</p>\n          <p class=\"text-sm font-bold text-deep-navy leading-tight\" data-kid=\"21\">Anjali Sharma</p>\n        </div>\n        <img src=\"https://images.pexels.com/photos/31725618/pexels-photo-31725618.jpeg?auto=compress&cs=tinysrgb&w=100&q=80\" alt=\"Anjali Sharma by Dr. Haror's Wellness on Pexels\" class=\"w-12 h-12 rounded-2xl object-cover shadow-lg\" decoding=\"async\" loading=\"lazy\" data-kid=\"22\">\n      </div>\n    </div>\n  </header>\n\n  <main class=\"flex-1 p-10 grid grid-cols-1 lg:grid-cols-12 gap-10 max-w-[1600px] mx-auto w-full\" data-kid=\"23\">\n    \n    <div class=\"lg:col-span-8 space-y-10\" data-kid=\"24\">\n      <div class=\"flex justify-between items-end\" data-kid=\"25\">\n        <div data-kid=\"26\">\n          <h1 class=\"text-5xl font-black text-deep-navy font-inter leading-none\" data-kid=\"27\">Smart Wealth</h1>\n          <p class=\"text-lg text-deep-navy/60 mt-3 font-medium\" data-kid=\"28\">Your financial health is currently <span class=\"text-emerald font-bold\" data-kid=\"29\">Optimal</span>.</p>\n        </div>\n        <div class=\"flex gap-2 bg-white/40 p-1.5 rounded-2xl border border-white/60\" data-kid=\"30\">\n          <button class=\"px-6 py-2.5 rounded-xl text-xs font-black bg-white shadow-sm text-deep-navy uppercase tracking-widest\" data-kid=\"31\">Monthly</button>\n          <button class=\"px-6 py-2.5 rounded-xl text-xs font-black text-deep-navy/40 hover:text-deep-navy transition-all uppercase tracking-widest\" data-kid=\"32\">Yearly</button>\n        </div>\n      </div>\n\n      \n      <div class=\"glass-card rounded-[3rem] p-12 relative overflow-hidden group\" data-kid=\"33\">\n        \n        <div class=\"absolute inset-0 z-0 opacity-20 group-hover:opacity-30 transition-opacity\" data-kid=\"34\">\n          <img src=\"https://images.unsplash.com/photo-1601662528567-526cd06f6582?auto=format&w=1000&q=80&fit=crop\" alt=\"Textured paper by Olga Thelavart on Unsplash\" class=\"w-full h-full object-cover mix-blend-multiply\" decoding=\"async\" loading=\"lazy\" data-kid=\"35\">\n        </div>\n\n        <div class=\"relative z-10 grid grid-cols-1 xl:grid-cols-2 gap-16 items-center\" data-kid=\"36\">\n          \n          <div class=\"relative flex items-center justify-center\" data-kid=\"37\">\n            <svg viewBox=\"0 0 400 400\" class=\"w-full max-w-[400px] transform transition-transform duration-[2s] group-hover:rotate-12\" data-kid=\"38\">\n              \n              <circle cx=\"200\" cy=\"200\" r=\"180\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"0.5\" class=\"text-deep-navy/10\" data-kid=\"39\"></circle>\n              <circle cx=\"200\" cy=\"200\" r=\"140\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"0.5\" class=\"text-deep-navy/10\" data-kid=\"40\"></circle>\n              <circle cx=\"200\" cy=\"200\" r=\"100\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"0.5\" class=\"text-deep-navy/10\" data-kid=\"41\"></circle>\n              \n              \n              <path d=\"M 200,20 A 180,180 0 1,1 200,380\" fill=\"none\" stroke=\"var(--color-emerald)\" stroke-width=\"12\" stroke-linecap=\"round\" stroke-dasharray=\"600 1000\" data-kid=\"42\"></path>\n              \n              \n              <circle cx=\"200\" cy=\"20\" r=\"8\" fill=\"var(--color-emerald)\" class=\"animate-pulse\" data-kid=\"43\"></circle>\n              <circle cx=\"380\" cy=\"200\" r=\"6\" fill=\"var(--color-accent)\" data-kid=\"44\"></circle>\n              <circle cx=\"100\" cy=\"200\" r=\"5\" fill=\"var(--color-navy-light)\" data-kid=\"45\"></circle>\n            </svg>\n            \n            <div class=\"absolute inset-0 flex flex-col items-center justify-center text-center\" data-kid=\"46\">\n              <div class=\"w-48 h-48 rounded-full border border-white/60 bg-white/20 backdrop-blur-3xl orb-pulse flex flex-col items-center justify-center\" data-kid=\"47\">\n                <span class=\"text-[10px] font-black opacity-40 uppercase tracking-[0.2em] mb-1\" data-kid=\"48\">Net Savings</span>\n                <h2 class=\"text-4xl font-black text-deep-navy font-inter tracking-tighter\" data-kid=\"49\">₹91,040</h2>\n                <div class=\"flex items-center gap-1 text-emerald font-black text-[10px] mt-2 bg-emerald/10 px-2 py-0.5 rounded-lg\" data-kid=\"50\">\n                  <i class=\"ti ti-trending-up\" data-kid=\"51\"></i> +12.4%\n                </div>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"space-y-8\" data-kid=\"52\">\n            <div class=\"space-y-2\" data-kid=\"53\">\n              <h3 class=\"text-3xl font-black text-deep-navy font-inter leading-none\" data-kid=\"54\">July Prosperity</h3>\n              <p class=\"text-deep-navy/60 font-medium\" data-kid=\"55\">You've reached <span class=\"text-deep-navy font-bold\" data-kid=\"56\">82%</span> of your savings goal this month.</p>\n            </div>\n\n            <div class=\"grid grid-cols-2 gap-6\" data-kid=\"57\">\n              <div class=\"bg-white/40 p-6 rounded-3xl border border-white/60\" data-kid=\"58\">\n                <p class=\"text-[10px] font-black opacity-40 uppercase tracking-widest mb-2\" data-kid=\"59\">Income</p>\n                <p class=\"text-xl font-black text-deep-navy\" data-kid=\"60\">₹1,42,000</p>\n              </div>\n              <div class=\"bg-white/40 p-6 rounded-3xl border border-white/60\" data-kid=\"61\">