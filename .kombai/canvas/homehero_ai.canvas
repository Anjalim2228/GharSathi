 <div class=\"fixed bottom-8 right-8 z-[100] flex flex-col items-end gap-4\" id=\"scanner-container\" data-kid=\"235\">\n        \n        <div id=\"scanner-popover\" class=\"w-72 bg-white rounded-[2.5rem] shadow-2xl border border-gray-100 p-5 mb-2 hidden opacity-0 translate-y-10\" data-kid=\"236\">\n            <div class=\"h-44 bg-gray-950 rounded-[2rem] relative overflow-hidden flex items-center justify-center group/scan\" data-kid=\"237\">\n                \n                <div class=\"absolute inset-0 opacity-40 bg-[url('https://images.unsplash.com/photo-1542838132-92c53300491e?auto=format&w=400&q=80&fit=crop')] bg-cover bg-center\" data-kid=\"238\"></div>\n                \n                <div class=\"absolute inset-8 border border-white/20 rounded-2xl\" data-kid=\"239\">\n                    <div class=\"absolute top-0 left-0 w-4 h-4 border-t-2 border-l-2 border-[#E5AA70]\" data-kid=\"240\"></div>\n                    <div class=\"absolute top-0 right-0 w-4 h-4 border-t-2 border-r-2 border-[#E5AA70]\" data-kid=\"241\"></div>\n                    <div class=\"absolute bottom-0 left-0 w-4 h-4 border-b-2 border-l-2 border-[#E5AA70]\" data-kid=\"242\"></div>\n                    <div class=\"absolute bottom-0 right-0 w-4 h-4 border-b-2 border-r-2 border-[#E5AA70]\" data-kid=\"243\"></div>\n                </div>\n                \n                <div class=\"w-full h-0.5 bg-[#E5AA70] absolute top-1/2 left-0 shadow-[0_0_15px_#E5AA70] animate-[bounce_3s_infinite] opacity-80\" data-kid=\"244\"></div>\n                <i class=\"ti ti-scan text-white/20 text-5xl relative z-10 group-hover/scan:scale-110 transition-transform\" data-kid=\"245\"></i>\n            </div>\n            <div class=\"mt-4 px-2 flex items-center justify-between\" data-kid=\"246\">\n                <div data-kid=\"247\">\n                    <p class=\"text-sm font-bold text-gray-800\" data-kid=\"248\">Scanner Active</p>\n                    <p class=\"text-[10px] text-gray-400 mt-0.5\" data-kid=\"249\">Align barcode within frame</p>\n                </div>\n                <div class=\"flex items-center gap-1.5\" data-kid=\"250\">\n                    <span class=\"w-2 h-2 bg-green-500 rounded-full animate-pulse\" data-kid=\"251\"></span>\n                    <span class=\"text-[10px] font-bold text-green-600\" data-kid=\"252\">LIVE</span>\n                </div>\n            </div>\n        </div>\n\n        <button id=\"scanner-toggle\" class=\"w-20 h-20 bg-black text-white rounded-full flex items-center justify-center shadow-2xl hover:scale-105 active:scale-95 transition-all duration-300 relative group overflow-hidden\" data-kid=\"253\">\n            <div class=\"absolute inset-0 bg-[#E5AA70] opacity-0 group-hover:opacity-10 transition-opacity\" data-kid=\"254\"></div>\n            <i class=\"ti ti-barcode text-4xl group-hover:scale-110 transition-transform duration-500\" id=\"scanner-icon\" data-kid=\"255\"></i>\n            \n            <div class=\"absolute inset-0 rounded-full scanner-ring hidden\" id=\"scanner-feedback\" data-kid=\"256\"></div>\n        </button>\n    </div>\n\n    \n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"257\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"258\"></script>\n    <script type=\"module\" data-kid=\"259\">\n        import Lenis from \"https://esm.sh/lenis@1\"\n        const lenis = new Lenis()\n        function raf(time) {\n            lenis.raf(time)\n            requestAnimationFrame(raf)\n        }\n        requestAnimationFrame(raf)\n    </script>\n    \n    <script data-kid=\"260\">\n        document.addEventListener('DOMContentLoaded', () => {\n            gsap.registerPlugin(ScrollTrigger);\n\n            // Staggered Entrance\n            gsap.from(\".stagger-item\", {\n                y: 30,\n                opacity: 0,\n                duration: 0.8,\n                stagger: 0.1,\n                ease: \"power3.out\",\n                clearProps: \"all\"\n            });\n\n            // Scanner Toggle Interaction\n            const toggle = document.getElementById('scanner-toggle');\n            const popover = document.getElementById('scanner-popover');\n            const feedback = document.getElementById('scanner-feedback');\n            const icon = document.getElementById('scanner-icon');\n            let isOpen = false;\n\n            toggle.addEventListener('click', () => {\n                isOpen = !isOpen;\n                if(isOpen) {\n                    popover.classList.remove('hidden');\n                    gsap.to(popover, {\n                        opacity: 1,\n                        y: 0,\n                        duration: 0.5,\n                        ease: \"back.out(1.7)\"\n                    });\n                    feedback.classList.remove('hidden');\n                    icon.classList.replace('ti-barcode', 'ti-x');\n                    gsap.to(toggle, { backgroundColor: '#E5AA70', duration: 0.3 });\n                } else {\n                    gsap.to(popover, {\n                        opacity: 0,\n                        y: 20,\n                        duration: 0.3,\n                        ease: \"power2.in\",\n                        onComplete: () => popover.classList.add('hidden')\n                    });\n                    feedback.classList.add('hidden');\n                    icon.classList.replace('ti-x', 'ti-barcode');\n                    gsap.to(toggle, { backgroundColor: '#000000', duration: 0.3 });\n                }\n            });\n\n        });\n    </script>\n\n</div>\n",
