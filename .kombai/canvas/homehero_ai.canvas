      "themeId": null,
      "rect": {
        "x": 18480,
        "y": 0,
        "w": 1440,
        "h": 800
      },
      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n  @import url('https://unpkg.com/lenis@1/dist/lenis.css');\n\n  :root {\n    --vault-bg: #020C0E;\n    --vault-teal: #14B8A6;\n    --vault-glass: rgba(255, 255, 255, 0.03);\n    --vault-border: rgba(20, 184, 166, 0.15);\n  }\n\n  body {\n    background-color: var(--vault-bg);\n    color: #ffffff;\n    font-family: 'DM Sans', sans-serif;\n    margin: 0;\n    overflow-x: clip;\n  }\n\n  .font-inter { font-family: 'Inter', sans-serif; }\n\n  .glass-card {\n    background: var(--vault-glass);\n    backdrop-filter: blur(20px);\n    border: 1px solid var(--vault-border);\n    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);\n  }\n\n  .glow-teal {\n    box-shadow: 0 0 20px rgba(20, 184, 166, 0.2);\n  }\n\n  .lock-indicator {\n    background: radial-gradient(circle, rgba(20, 184, 166, 0.1) 0%, transparent 70%);\n  }\n\n  .ocr-badge {\n    background: rgba(20, 184, 166, 0.1);\n    border: 1px solid rgba(20, 184, 166, 0.3);\n    color: var(--vault-teal);\n  }\n\n  .folder-hover:hover {\n    background: rgba(20, 184, 166, 0.08);\n    border-color: rgba(20, 184, 166, 0.4);\n  }\n\n  /* Custom Switch */\n  .switch-input:checked ~ .switch-dot {\n    transform: translateX(100%);\n    background-color: var(--vault-teal);\n  }\n  \n  .switch-input:checked ~ .switch-bg {\n    background-color: rgba(20, 184, 166, 0.2);\n  }\n\n  /* Scrollbar */\n  ::-webkit-scrollbar {\n    width: 6px;\n  }\n  ::-webkit-scrollbar-track {\n    background: transparent;\n  }\n  ::-webkit-scrollbar-thumb {\n    background: rgba(255, 255, 255, 0.1);\n    border-radius: 10px;\n  }\n</style>\n\n<div class=\"min-h-screen flex flex-col lg:flex-row relative\" data-kid=\"1\">\n  \n  <aside class=\"w-full lg:w-20 lg:h-screen lg:sticky lg:top-0 border-b lg:border-b-0 lg:border-r border-white/5 flex lg:flex-col items-center py-6 px-4 gap-8 z-50 bg-[#020C0E]/80 backdrop-blur-xl\" data-kid=\"2\">\n    <div class=\"w-10 h-10 bg-teal-500 rounded-xl flex items-center justify-center shadow-[0_0_20px_rgba(20,184,166,0.5)]\" data-kid=\"3\">\n      <i class=\"ti ti-shield-lock text-black text-xl\" data-kid=\"4\"></i>\n    </div>\n    <nav class=\"flex lg:flex-col gap-6 items-center flex-1 lg:justify-center\" data-kid=\"5\">\n      <button class=\"w-12 h-12 rounded-xl bg-teal-500/10 text-teal-400 flex items-center justify-center transition-all hover:bg-teal-500/20\" data-kid=\"6\">\n        <i class=\"ti ti-layout-dashboard text-2xl\" data-kid=\"7\"></i>\n      </button>\n      <button class=\"w-12 h-12 rounded-xl text-white/40 flex items-center justify-center transition-all hover:text-white hover:bg-white/5\" data-kid=\"8\">\n        <i class=\"ti ti-files text-2xl\" data-kid=\"9\"></i>\n      </button>\n      <button class=\"w-12 h-12 rounded-xl text-white/40 flex items-center justify-center transition-all hover:text-white hover:bg-white/5\" data-kid=\"10\">\n        <i class=\"ti ti-users text-2xl\" data-kid=\"11\"></i>\n      </button>\n      <button class=\"w-12 h-12 rounded-xl text-white/40 flex items-center justify-center transition-all hover:text-white hover:bg-white/5\" data-kid=\"12\">\n        <i class=\"ti ti-settings text-2xl\" data-kid=\"13\"></i>\n      </button>\n    </nav>\n    <div class=\"hidden lg:block\" data-kid=\"14\">\n      <img src=\"https://i.pravatar.cc/100?u=anjali\" class=\"w-10 h-10 rounded-full border border-white/10\" alt=\"Avatar\" data-kid=\"15\">\n    </div>\n  </aside>\n\n  \n  <main class=\"flex-1 p-6 lg:p-10 space-y-10 overflow-x-clip\" data-kid=\"16\">\n    \n    \n    <header class=\"flex flex-col md:flex-row md:items-center justify-between gap-6\" data-kid=\"17\">\n      <div data-kid=\"18\">\n        <h1 class=\"text-3xl lg:text-4xl font-black font-inter tracking-tight\" data-kid=\"19\">Document Vault</h1>\n        <p class=\"text-white/40 text-sm mt-1 font-medium\" data-kid=\"20\">Last synced: 2 minutes ago • <span class=\"text-teal-400\" data-kid=\"21\">Secure</span></p>\n      </div>\n      <div class=\"flex items-center gap-4\" data-kid=\"22\">\n        <div class=\"bg-white/5 p-1 rounded-xl border border-white/10 flex\" data-kid=\"23\">\n          <button class=\"px-4 py-2 rounded-lg text-xs font-bold bg-white/10 shadow-sm uppercase tracking-widest\" data-kid=\"24\">All Files</button>\n          <button class=\"px-4 py-2 rounded-lg text-xs font-bold text-white/40 hover:text-white transition-all uppercase tracking-widest\" data-kid=\"25\">Recent</button>\n        </div>\n        <button class=\"bg-teal-500 hover:bg-teal-400 text-black px-6 py-3 rounded-xl font-bold flex items-center gap-2 transition-all shadow-[0_10px_30px_-5px_rgba(20,184,166,0.3)] active:scale-95\" data-kid=\"26\">\n          <i class=\"ti ti-upload\" data-kid=\"27\"></i>\n          <span data-kid=\"28\">Upload Asset</span>\n        </button>\n      </div>\n    </header>\n\n    \n    <section class=\"glass-card rounded-[2.5rem] p-8 lg:p-12 relative overflow-hidden group\" data-kid=\"29\">\n      \n      <div class=\"absolute inset-0 z-0 opacity-20 pointer-events-none\" data-kid=\"30\">\n        <div class=\"absolute top-0 right-0 w-96 h-96 bg-teal-500/20 rounded-full blur-[100px]\" data-kid=\"31\"></div>\n        <div class=\"absolute bottom-0 left-0 w-64 h-64 bg-teal-500/10 rounded-full blur-[80px]\" data-kid=\"32\"></div>\n      </div>\n\n      <div class=\"relative z-10 flex flex-col lg:flex-row items-center gap-12\" data-kid=\"33\">\n        <div class=\"relative flex-shrink-0\" data-kid=\"34\">\n          <div class=\"w-48 h-48 lg:w-56 lg:h-56 rounded-full border border-teal-500/20 bg-teal-500/5 flex items-center justify-center relative lock-indicator\" data-kid=\"35\">\n            \n            <div class=\"absolute inset-0 rounded-full border-t-2 border-teal-500/40 animate-[spin_8s_linear_infinite]\" data-kid=\"36\"></div>\n            <div class=\"absolute inset-4 rounded-full border-b-2 border-teal-500/20 animate-[spin_12s_linear_infinite_reverse]\" data-kid=\"37\"></div>\n            \n            <div class=\"vault-lock-main flex flex-col items-center\" data-kid=\"38\">\n              <i class=\"ti ti-lock-access text-6xl text-teal-400 drop-shadow-[0_0_15px_rgba(20,184,166,0.6)]\" data-kid=\"39\"></i>\n              <span class=\"text-[10px] font-black uppercase tracking-[0.3em] text-teal-400/60 mt-2\" data-kid=\"40\">Encrypted</span>\n            </div>\n          </div>\n          \n          <div class=\"absolute top-0 left-1/2 -translate-x-1/2 w-full h-[1px] bg-gradient-to-r from-transparent via-teal-400 to-transparent animate-[pan-y_4s_linear_infinite]\" data-kid=\"41\"></div>\n        </div>\n\n        <div class=\"text-center lg:text-left space-y-6\" data-kid=\"42\">\n          <div class=\"space-y-2\" data-kid=\"43\">\n            <h2 class=\"text-3xl lg:text-4xl font-black font-inter leading-none\" data-kid=\"44\">Your vault is fully secured</h2>\n            <p class=\"text-white/60 font-medium max-w-xl\" data-kid=\"45\">HomeHero AI is protecting 128 sensitive assets. All documents are scanned for malware and indexed via private OCR for instant searching.</p>\n          </div>\n          \n          <div class=\"grid grid-cols-2 md:grid-cols-4 gap-4\" data-kid=\"46\">\n            <div class=\"bg-white/5 border border-white/10 p-4 rounded-2xl\" data-kid=\"47\">\n              <p class=\"text-[10px] font-black text-white/30 uppercase tracking-widest mb-1\" data-kid=\"48\">Capacity</p>\n              <div class=\"flex items-end gap-2\" data-kid=\"49\">\n                <p class=\"text-xl font-black\" data-kid=\"50\">2.4<span class=\"text-sm font-bold opacity-40 ml-1 uppercase\" data-kid=\"51\">GB</span></p>\n              </div>\n            </div>\n            <div class=\"bg-white/5 border border-white/10 p-4 rounded-2xl\" data-kid=\"52\">\n              <p class=\"text-[10px] font-black text-white/30 uppercase tracking-widest mb-1\" data-kid=\"53\">Security</p>\n              <p class=\"text-xl font-black text-teal-400\" data-kid=\"54\">Military</p>\n            </div>\n            <div class=\"bg-white/5 border border-white/10 p-4 rounded-2xl\" data-kid=\"55\">\n              <p class=\"text-[10px] font-black text-white/30 uppercase tracking-widest mb-1\" data-kid=\"56\">OCR Indexed</p>\n              <p class=\"text-xl font-black\" data-kid=\"57\">94%</p>\n            </div>\n            <div class=\"bg-white/5 border border-white/10 p-4 rounded-2xl\" data-kid=\"58\">\n              <p class=\"text-[10px] font-black text-white/30 uppercase tracking-widest mb-1\" data-kid=\"59\">Sharing</p>\n              <p class=\"text-xl font-black\" data-kid=\"60\">Active</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <div class=\"grid grid-cols-1 xl:grid-cols-12 gap-10\" data-kid=\"61\">\n      \n      \n      <div class=\"xl:col-span-8 space-y-12\" data-kid=\"62\">\n        \n        \n        <section class=\"space-y-6\" data-kid=\"63\">\n          <div class=\"flex items-center justify-between\" data-kid=\"64\">\n            <h3 class=\"text-lg font-black uppercase tracking-widest text-white/40 font-inter\" data-kid=\"65\">Vault Categories</h3>\n            <button class=\"text-teal-400 text-xs font-bold hover:underline\" data-kid=\"66\">Manage Folders</button>\n          </div>\n          <div class=\"grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4\" data-kid=\"67\">\n            <div class=\"glass-card p-6 rounded-3xl flex flex-col items-center text-center cursor-pointer folder-hover transition-all group category-item\" data-kid=\"68\">\n              <div class=\"w-12 h-12 bg-teal-500/10 text-teal-400 rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform\" data-kid=\"69\">\n                <i class=\"ti ti-id-badge text-2xl\" data-kid=\"70\"></i>\n              </div>\n              <span class=\"font-bold text-sm\" data-kid=\"71\">Identity</span>\n              <span class=\"text-[10px] text-white/40 mt-1 uppercase tracking-tighter\" data-kid=\"72\">12 Docs</span>\n            </div>\n            <div class=\"glass-card p-6 rounded-3xl flex flex-col items-center text-center cursor-pointer folder-hover transition-all group category-item\" data-kid=\"73\">\n              <div class=\"w-12 h-12 bg-blue-500/10 text-blue-400 rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform\" data-kid=\"74\">\n                <i class=\"ti ti-building-estate text-2xl\" data-kid=\"75\"></i>\n              </div>\n              <span class=\"font-bold text-sm\" data-kid=\"76\">Property</span>\n              <span class=\"text-[10px] text-white/40 mt-1 uppercase tracking-tighter\" data-kid=\"77\">45 Docs</span>\n            </div>\n            <div class=\"glass-card p-6 rounded-3xl flex flex-col items-center text-center cursor-pointer folder-hover transition-all group category-item\" data-kid=\"78\">\n              <div class=\"w-12 h-12 bg-rose-500/10 text-rose-400 rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform\" data-kid=\"79\">\n                <i class=\"ti ti-heart-rate-monitor text-2xl\" data-kid=\"80\"></i>\n              </div>\n              <span class=\"font-bold text-sm\" data-kid=\"81\">Health</span>\n              <span class=\"text-[10px] text-white/40 mt-1 uppercase tracking-tighter\" data-kid=\"82\">28 Docs</span>\n            </div>\n            <div class=\"glass-card p-6 rounded-3xl flex flex-col items-center text-center cursor-pointer folder-hover transition-all group category-item\" data-kid=\"83\">\n              <div class=\"w-12 h-12 bg-emerald-500/10 text-emerald-400 rounded-2xl flex items-c