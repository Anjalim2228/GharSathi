      "html": "\n<div class=\"min-h-screen bg-[#F8F9FA] font-['DM_Sans'] text-[#011F5B] overflow-x-clip selection:bg-red-500/30 relative pb-20\" data-kid=\"0\">\n    \n    \n    <div class=\"fixed top-[-10%] left-[-10%] w-[40%] h-[40%] bg-blue-500/[0.03] rounded-full blur-[120px] pointer-events-none\" data-kid=\"1\"></div>\n    <div class=\"fixed bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-red-500/[0.03] rounded-full blur-[150px] pointer-events-none\" data-kid=\"2\"></div>\n\n    <style data-kid=\"3\">\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=DM+Sans:wght@400;500;700&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n        .glass {\n            background: rgba(255, 255, 255, 0.45);\n            backdrop-filter: blur(40px);\n            -webkit-backdrop-filter: blur(40px);\n            border: 1px solid rgba(255, 255, 255, 0.6);\n            box-shadow: 0 10px 40px -10px rgba(1, 31, 91, 0.04);\n        }\n        .glass-red {\n            background: rgba(239, 68, 68, 0.03);\n            backdrop-filter: blur(12px);\n            border: 1px solid rgba(239, 68, 68, 0.1);\n        }\n        .card-hover:hover {\n            transform: translateY(-6px);\n            box-shadow: 0 30px 60px -15px rgba(1, 31, 91, 0.12);\n        }\n        .sos-ripple {\n            animation: sos-ripple 2s infinite;\n        }\n        @keyframes sos-ripple {\n            0% { transform: scale(0.9); opacity: 1; }\n            100% { transform: scale(1.6); opacity: 0; }\n        }\n        .sos-pulse {\n            animation: sos-pulse 2s infinite cubic-bezier(0.4, 0, 0.6, 1);\n        }\n        @keyframes sos-pulse {\n            0%, 100% { transform: scale(1); }\n            50% { transform: scale(1.05); }\n        }\n        .custom-scrollbar::-webkit-scrollbar { width: 5px; }\n        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }\n        .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(1, 31, 91, 0.1); border-radius: 10px; }\n    </style>\n\n    \n    <nav class=\"sticky top-0 z-50 px-8 py-5 flex items-center justify-between glass mb-8 border-b border-white/50\" data-kid=\"4\">\n        <div class=\"flex items-center gap-3\" data-kid=\"5\">\n            <div class=\"w-10 h-10 bg-[#011F5B] rounded-xl flex items-center justify-center text-white shadow-lg shadow-[#011F5B]/20\" data-kid=\"6\">\n                <i class=\"ti ti-heart-pulse text-xl\" data-kid=\"7\"></i>\n            </div>\n            <h1 class=\"text-2xl font-bold font-['Inter'] tracking-tight\" data-kid=\"8\">HomeHero <span class=\"text-red-500\" data-kid=\"9\">Health</span></h1>\n        </div>\n        \n        <div class=\"hidden lg:flex items-center gap-10\" data-kid=\"10\">\n            <a href=\"#\" class=\"text-sm font-bold opacity-100 text-red-500 flex items-center gap-2\" data-kid=\"11\">\n                <span class=\"w-1.5 h-1.5 rounded-full bg-red-500\" data-kid=\"12\"></span> Dashboard\n            </a>\n            <a href=\"#\" class=\"text-sm font-bold opacity-50 hover:opacity-100 transition-opacity\" data-kid=\"13\">Family Profiles</a>\n            <a href=\"#\" class=\"text-sm font-bold opacity-50 hover:opacity-100 transition-opacity\" data-kid=\"14\">Vitals History</a>\n            <a href=\"#\" class=\"text-sm font-bold opacity-50 hover:opacity-100 transition-opacity\" data-kid=\"15\">Medications</a>\n            <a href=\"#\" class=\"text-sm font-bold opacity-50 hover:opacity-100 transition-opacity\" data-kid=\"16\">Nearby Care</a>\n        </div>\n\n        <div class=\"flex items-center gap-6\" data-kid=\"17\">\n            <div class=\"flex items-center gap-3 pl-6 border-l border-black/5\" data-kid=\"18\">\n                <div class=\"text-right hidden sm:block\" data-kid=\"19\">\n                    <p class=\"text-xs font-bold opacity-40 uppercase tracking-widest\" data-kid=\"20\">Wellness 