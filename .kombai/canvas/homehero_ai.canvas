      "html": "\n<div class=\"min-h-screen bg-[#ECEFF3] font-['DM_Sans'] text-[#011F5B] overflow-x-clip selection:bg-[#E5AA70]/30 relative pb-32\" data-kid=\"0\">\n    \n    \n    <div class=\"fixed top-[-15%] left-[-15%] w-[45%] h-[45%] bg-[#E5AA70]/10 rounded-full blur-[140px] pointer-events-none\" data-kid=\"1\"></div>\n    <div class=\"fixed bottom-[-10%] right-[-10%] w-[55%] h-[55%] bg-[#011F5B]/8 rounded-full blur-[160px] pointer-events-none\" data-kid=\"2\"></div>\n\n    <style data-kid=\"3\">\n        @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700&family=DM+Sans:wght@400;500;700&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n        .glass {\n            background: rgba(255, 255, 255, 0.65);\n            backdrop-filter: blur(40px);\n            -webkit-backdrop-filter: blur(40px);\n            border: 1px solid rgba(255, 255, 255, 0.8);\n            box-shadow: \n                0 4px 6px -1px rgba(0, 0, 0, 0.02),\n                0 20px 60px -15px rgba(1, 31, 91, 0.08);\n        }\n        .glass-dark {\n            background: rgba(1, 31, 91, 0.05);\n            backdrop-filter: blur(12px);\n            border: 1px solid rgba(1, 31, 91, 0.08);\n        }\n        .card-hover:hover {\n            transform: translateY(-8px);\n            box-shadow: 0 40px 100px -20px rgba(1, 31, 91, 0.18);\n        }\n        .shimmer {\n            position: relative;\n            overflow: hidden;\n        }\n        .shimmer::after {\n            content: '';\n            position: absolute;\n            top: -50%;\n            left: -50%;\n            width: 200%;\n            height: 200%;\n            background: linear-gradient(\n                45deg,\n                transparent,\n                rgba(255, 255, 255, 0.1),\n                transparent\n            );\n            transform: rotate(45deg);\n            transition: 0.5s;\n        }\n        .shimmer:hover::after {\n            left: 100%;\n        }\n        \n        .orb-pulse {\n            animation: orb-pulse 4s infinite cubic-bezier(0.4, 0, 0.6, 1);\n        }\n        @keyframes orb-pulse {\n            0%, 100% { transform: scale(1); box-shadow: 0 0 20px rgba(1, 31, 91, 0.2); }\n            50% { transform: scale(1.1); box-shadow: 0 0 40px rgba(1, 31, 91, 0.4); }\n        }\n\n        .wave-ring {\n            position: absolute;\n            border-radius: 50%;\n            border: 1px solid rgba(229, 170, 112, 0.4);\n            animation: ring-ripple 4s infinite ease-out;\n        }\n        @keyframes ring-ripple {\n            0% { transform: scale(0.8); opacity: 0.8; }\n            100% { transform: scale(3); opacity: 0; }\n        }\n\n        .custom-scrollbar::-webkit-scrollbar { width: 6px; }\n        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }\n        .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(1, 31, 91, 0.1); border-radius: 10px; }\n\n        .voice-orb-active {\n            background: radial-gradient(circle at center, #E5AA70 0%, #d4955b 100%);\n            box-shadow: 0 0 50px rgba(229, 170, 112, 0.4);\n        }\n    </style>\n\n    \n    <nav class=\"sticky top-0 z-50 px-8 py-6 flex items-center justify-between glass mb-8 border-b border-white/40\" data-kid=\"4\">\n        <div class=\"flex items-center gap-3\" data-kid=\"5\">\n            <div class=\"w-10 h-10 bg-[#011F5B] rounded-xl flex items-center justify-center text-white shadow-lg shadow-[#011F5B]/20\" data-kid=\"6\">\n                <i class=\"ti ti-home-heart text-xl\" data-kid=\"7\"></i>\n            </div>\n            <h1 class=\"text-2xl font-bold font-['Inter'] tracking-tight\" data-kid=\"8\">HomeHero <span class=\"text-[#E5AA70]\" data-kid=\"9\">AI</span></h1>\n        </div>\n        \n        <div class=\"hidden md:flex items-center gap-10\" data-kid=\"10\">\n            <a href=\"#\" class=\"text-sm font-bold opacity-50