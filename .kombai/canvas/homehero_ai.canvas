236\">14</span>\n                        </div>\n                        <div class=\"space-y-4 opacity-50 grayscale hover:opacity-80 hover:grayscale-0 transition-all cursor-pointer\" data-kid=\"237\">\n                            <div class=\"bg-white/50 p-5 rounded-2xl border border-[var(--terracotta)]/5\" data-kid=\"238\">\n                                <div class=\"flex justify-between items-start mb-3\" data-kid=\"239\">\n                                    <span class=\"bg-gray-100 text-gray-500 px-2 py-0.5 rounded text-[8px] font-bold uppercase\" data-kid=\"240\">Shopping</span>\n                                    <i class=\"ti ti-circle-check-filled text-green-500\" data-kid=\"241\"></i>\n                                </div>\n                                <p class=\"text-sm font-bold text-gray-400 line-through leading-snug\" data-kid=\"242\">Buy birthday decoration supplies</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </main>\n\n    \n    <button class=\"fixed bottom-8 right-8 w-16 h-16 bg-[var(--terracotta)] text-white rounded-full shadow-2xl flex items-center justify-center group hover:scale-110 transition-transform cursor-pointer z-50 ring-4 ring-white\" data-kid=\"243\">\n        <i class=\"ti ti-sparkles text-2xl group-hover:rotate-12 transition-transform\" data-kid=\"244\"></i>\n        <div class=\"absolute -top-14 right-0 bg-white p-3 rounded-2xl border-2 border-[var(--terracotta)]/20 shadow-2xl opacity-0 group-hover:opacity-100 transition-all transform translate-y-2 group-hover:translate-y-0 pointer-events-none w-56\" data-kid=\"245\">\n            <p class=\"text-[11px] text-[var(--terracotta)] font-bold mb-1\" data-kid=\"246\">AI Assistant Online</p>\n            <p class=\"text-[10px] text-[var(--terracotta)]/60 font-medium leading-tight italic\" data-kid=\"247\">\"Your AC service is due in 3 days. Shall I book the technician?\"</p>\n        </div>\n    </button>\n</div>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"248\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"249\"></script>\n<script type=\"module\" data-kid=\"250\">\n    import Lenis from \"https://esm.sh/lenis@1\"\n    \n    // Initialize Lenis for smooth scrolling\n    const lenis = new Lenis()\n    function raf(time) {\n      lenis.raf(time)\n      requestAnimationFrame(raf)\n    }\n    requestAnimationFrame(raf)\n\n    // GSAP Entrance Animations\n    gsap.registerPlugin(ScrollTrigger);\n\n    window.addEventListener('load', () => {\n        // Initial entrance\n        gsap.from(\".gs-fade-up\", {\n            duration: 0.8,\n            y: 40,\n            opacity: 0,\n            stagger: 0.1,\n            ease: \"power3.out\",\n            clearProps: \"all\"\n        });\n\n        // Sidebar entrance\n        gsap.from(\"aside\", {\n            duration: 1,\n            x: -100,\n            opacity: 0,\n            ease: \"power4.out\"\n        });\n\n        // Navbar entrance\n        gsap.from(\".nav-item\", {\n            duration: 0.6,\n            x: -20,\n            opacity: 0,\n            stagger: 0.05,\n            delay: 0.5,\n            ease: \"power2.out\"\n        });\n    });\n\n    // Custom interactivity for expense bars\n    const bars = document.querySelectorAll('.proportional-block');\n    bars.forEach(bar => {\n        bar.addEventListener('mouseenter', () => {\n            gsap.to(bar, { \n                y: -10, \n                duration: 0.4, \n                ease: \"power2.out\" \n            });\n        });\n        bar.addEventListener('mouseleave', () => {\n            gsap.to(bar, { \n                y: 0, \n                duration: 0.4, \n                ease: \"power2.out\" \n            });\n        });\n    });\n</script>\n",
