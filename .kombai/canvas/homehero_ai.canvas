      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&family=DM+Sans:ital,wght@0,400;0,700;1,500&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --color-sage: #A3B8A8;\n    --color-sage-light: #D4E5DB;\n    --color-cream: #FDFBF7;\n    --color-accent: #E5AA70;\n    --color-deep-navy: #011F5B;\n    --color-navy-light: #1A3A7A;\n    --color-glass-bg: rgba(255, 255, 255, 0.45);\n    --color-glass-border: rgba(255, 255, 255, 0.5);\n    --shadow-premium: 0 12px 48px -10px rgba(1, 31, 91, 0.1);\n    --radius-premium: 2.5rem;\n    --radius-card: 1.5rem;\n  }\n\n  .font-inter { font-family: 'Inter', sans-serif; }\n  .font-dm-sans { font-family: 'DM Sans', sans-serif; }\n\n  .glass-card {\n    background: var(--color-glass-bg);\n    backdrop-filter: blur(24px);\n    -webkit-backdrop-filter: blur(24px);\n    border: 1px solid var(--color-glass-border);\n    box-shadow: var(--shadow-premium);\n  }\n\n  .orb-pulse {\n    animation: orb-pulse 4s infinite cubic-bezier(0.4, 0, 0.6, 1);\n  }\n\n  @keyframes orb-pulse {\n    0%, 100% { transform: scale(1); opacity: 0.8; box-shadow: 0 0 10px rgba(163, 184, 168, 0.4); }\n    50% { transform: scale(1.2); opacity: 1; box-shadow: 0 0 20px rgba(163, 184, 168, 0.6); }\n  }\n\n  .hide-scrollbar::-webkit-scrollbar {\n    display: none;\n  }\n  .hide-scrollbar {\n    -ms-overflow-style: none;\n    scrollbar-width: none;\n  }\n</style>\n\n<div class=\"min-h-screen bg-[#F5F5F5] font-dm-sans text-[var(--color-deep-navy)] p-10 pb-24\" data-kid=\"1\">\n  \n  <header class=\"glass-card rounded-[var(--radius-premium)] p-10 flex flex-col md:flex-row justify-between items-center gap-8 mb-10 relative overflow-hidden group\" data-kid=\"2\">\n    <div class=\"absolute -top-24 -right-24 w-96 h-96 bg-[var(--color-sage)]/10 rounded-full blur-[100px] group-hover:bg-[var(--color-sage)]/20 transition-all duration-700\" data-kid=\"3\"></div>\n    \n    <div class=\"relative z-10 flex flex-col gap-2\" data-kid=\"4\">\n      <div class=\"flex items-center gap-3 px-4 py-2 bg-[var(--color-sage)]/10 border border-[var(--color-sage)]/20 rounded-full w-fit\" data-kid=\"5\">\n        <span class=\"w-2.5 h-2.5 rounded-full bg-[var(--color-sage)] orb-pulse\" data-kid=\"6\"></span>\n        <span class=\"font-inter text-[10px] font-black uppercase tracking-[0.2em] text-[var(--color-sage)]\" data-kid=\"7\">Pantry Synchronized • Live</span>\n      </div>\n      <h1 class=\"font-inter text-6xl font-black leading-[1.1] tracking-tight mt-2\" data-kid=\"8\">\n        AI Recipe Chef <br data-kid=\"9\">\n        <span class=\"text-[var(--color-sage)] italic font-medium\" data-kid=\"10\">Culinary Intelligence.</span>\n      </h1>\n      <p class=\"text-xl text-[var(--color-deep-navy)]/60 max-w-lg mt-4 leading-relaxed\" data-kid=\"11\">\n        Your smart fridge reports 94% ingredient availability. I've curated a high-protein menu for your family today.\n      </p>\n    </div>\n\n    <div class=\"relative z-10 flex flex-col items-center md:items-end gap-6\" data-kid=\"12\">\n      <div class=\"flex -space-x-4\" data-kid=\"13\">\n        <img src=\"https://i.pravatar.cc/100?u=Anjali\" class=\"w-16 h-16 rounded-full border-4 border-white shadow-sm\" alt=\"Anjali\" data-kid=\"14\">\n        <img src=\"https://i.pravatar.cc/100?u=Rahul\" class=\"w-16 h-16 rounded-full border-4 border-white shadow-sm\" alt=\"Rahul\" data-kid=\"15\">\n        <div class=\"w-16 h-16 rounded-full bg-[var(--color-sage-light)] border-4 border-white flex items-center justify-center font-black text-[var(--color-sage)] text-sm\" data-kid=\"16\">+3</div>\n      </div>\n      <button class=\"bg-[var(--color-deep-navy)] text-white px-10 py-5 rounded-2xl font-inter font-black text-sm uppercase tracking-widest shadow-2xl shadow-deep-navy/20 hover:scale-[1.02] active:scale-95 transition-all flex items-center gap-3\" data-kid=\"17\">\n        <i class=\"ti ti-chef-hat text-xl\" data-kid=\"18\"></i>\n        Generate Today's Menu\n      </button>\n    </div>\n  </header>\n\n  \n  <section class=\"mb-12\" data-kid=\"19\">\n    <div class=\"flex justify-between items-end mb-8 px-4\" data-kid=\"20\">\n      <div data-kid=\"21\">\n        <h2 class=\"font-inter text-3xl font-black tracking-tight\" data-kid=\"22\">Today's Curated Menu</h2>\n        <p class=\"text-[var(--color-deep-navy)]/40 font-bold uppercase tracking-widest text-[10px] mt-1\" data-kid=\"23\">Based on health goals & available stock</p>\n      </div>\n      <div class=\"flex gap-4\" data-kid=\"24\">\n        <button class=\"w-12 h-12 rounded-full border border-[var(--color-deep-navy)]/10 flex items-center justify-center hover:bg-white transition-all\" data-kid=\"25\"><i class=\"ti ti-chevron-left\" data-kid=\"26\"></i></button>\n        <button class=\"w-12 h-12 rounded-full border border-[var(--color-deep-navy)]/10 flex items-center justify-center hover:bg-white transition-all\" data-kid=\"27\"><i class=\"ti ti-chevron-right\" data-kid=\"28\"></i></button>\n      </div>\n    </div>\n\n    <div class=\"flex gap-8 overflow-x-auto pb-8 px-4 hide-scrollbar\" data-kid=\"29\">\n      \n      <div class=\"glass-card min-w-[400px] rounded-[var(--radius-premium)] p-8 flex flex-col group cursor-pointer hover:border-[var(--color-sage)]/40 transition-all\" data-kid=\"30\">\n        <div class=\"flex justify-between items-start mb-6\" data-kid=\"31\">\n          <span class=\"px-4 py-2 bg-[var(--color-sage)]/10 text-[var(--color-sage)] rounded-xl font-black text-[10px] uppercase tracking-widest\" data-kid=\"32\">Breakfast</span>\n          <div class=\"flex items-center gap-1.5 text-green-500 font-black text-[10px] uppercase\" data-kid=\"33\">\n            <i class=\"ti ti-check\" data-kid=\"34\"></i> 95% Match\n          </div>\n        </div>\n        <div class=\"relative w-full h-64 mb-8\" data-kid=\"35\">\n          <img src=\"https://images.unsplash.com/photo-1633204339691-9d3645430e14?auto=format&w=800&q=80&fit=crop\" class=\"w-full h-full object-cover rounded-[var(--radius-card)] shadow-xl group-hover:scale-[1.02] transition-transform duration-500\" alt=\"Avocado Toast by Bakd&Raw\" loading=\"lazy\" decoding=\"async\" data-kid=\"36\">\n          <div class=\"absolute -bottom-4 -right-4 w-16 h-16 bg-white rounded-2xl flex items-center justify-center shadow-lg text-[var(--color-accent)]\" data-kid=\"37\">\n            <i class=\"ti ti-flame text-3xl\" data-kid=\"38\"></i>\n          </div>\n        </div>\n        <h3 class=\"font-inter text-2xl font-black mb-4\" data-kid=\"39\">Avocado & Microgreen Sourdough</h3>\n        <div class=\"flex flex-wrap gap-2 mb-8\" data-kid=\"40\">\n          <span class=\"glass-card px-3 py-1.5 rounded-lg text-[10px] font-bold flex items-center gap-1.5\" data-kid=\"41\"><i class=\"ti ti-flame text-orange-500\" data-kid=\"42\"></i> 320 kcal</span>\n          <span class=\"glass-card px-3 py-1.5 rounded-lg text-[10px] font-bold flex items-center gap-1.5\" data-kid=\"43\"><i class=\"ti ti-leaf text-green-500\" data-kid=\"44\"></i> High Fiber</span>\n          <span class=\"glass-card px-3 py-1.5 rounded-lg text-[10px] font-bold flex items-center gap-1.5\" data-kid=\"45\"><i class=\"ti ti-clock\" data-kid=\"46\"></i> 15 mins</span>\n        </div>\n        <button class=\"w-full py-4 rounded-2xl border-2 border-[var(--color-deep-navy)]/5 font-black text-[10px] uppercase tracking-widest hover:bg-[var(--color-deep-navy)] hover:text-white transition-all\" data-kid=\"47\">View Full Recipe</button>\n      </div>\n\n      \n      <div class=\"glass-card min-w-[400px] rounded-[var(--radius-premium)] p-8 flex flex-col group cursor-pointer hover:border-[var(--color-sage)]/40 transition-all\" data-kid=\"48\">\n        <div class=\"flex justify-between items-start mb-6\" data-kid=\"49\">\n          <span class=\"px-4 py-2 bg-[var(--color-accent)]/10 text-[var(--color-accent)] rounded-xl font-black text-[10px] uppercase tracking-widest\" data-kid=\"50\">Lunch</span>\n          <div class=\"flex items-center gap-1.5 text-orange-500 font-black text-[10px] uppercase\" data-kid=\"51\">\n            <i class=\"ti ti-alert-circle\" data-kid=\"52\"></i> 82% Match\n          </div>\n        </div>\n        <div class=\"relative w-full h-64 mb-8\" data-kid=\"53\">\n          <img src=\"https://images.pexels.com/photos/17302314/pexels-photo-17302314.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" class=\"w-full h-full object-cover rounded-[var(--radius-card)] shadow-xl group-hover:scale-[1.02] transition-transform duration-500\" alt=\"Tomato Basil Soup by Sacha Moreau\" loading=\"lazy\" decoding=\"async\" data-kid=\"54\">\n          <div class=\"absolute -bottom-4 -right-4 w-16 h-16 bg-white rounded-2xl flex items-center justify-center shadow-lg text-[var(--color-sage)]\" data-kid=\"55\">\n            <i class=\"ti ti-tools-kitchen-2 text-3xl\" data-kid=\"56\"></i>\n          </div>\n        </div>\n        <h3 class=\"font-inter text-2xl font-black mb-4\" data-kid=\"57\">Rustic Creamy Tomato & Basil</h3>\n        <div class=\"flex flex-wrap gap-2 mb-8\" data-kid=\"58\">\n          <span class=\"glass-card px-3 py-1.5 rounded-lg text-[10px] font-bold flex items-center gap-1.5\" data-kid=\"59\"><i class=\"ti ti-flame text-orange-500\" data-kid=\"60\"></i> 410 kcal</span>\n          <span class=\"glass-card px-3 py-1.5 rounded-lg text-[10px] font-bold flex items-center gap-1.5\" data-kid=\"61\"><i class=\"ti ti-leaf text-green-500\" data-kid=\"62\"></i> Keto Friendly</span>\n          <span class=\"glass-card px-3 py-1.5 rounded-lg text-[10px] font-bold flex items-center gap-1.5\" data-kid=\"63\"><i class=\"ti ti-clock\" data-kid=\"64\"></i> 30 mins</span>\n        </div>\n        <button class=\"w-full py-4 rounded-2xl border-2 border-[var(--color-deep-navy)]/5 font-black text-[10px] uppercase tracking-widest hover:bg-[var(--color-deep-navy)] hover:text-white transition-all\" data-kid=\"65\">View Full Recipe</button>\n      </div>\n\n      \n      <div class=\"glass-card min-w-[400px] rounded-[var(--radius-premium)] p-8 flex flex-col group cursor-pointer hover:border-[var(--color-sage)]/40 transition-all\" data-kid=\"66\">\n        <div class=\"flex justify-between items-start mb-6\" data-kid=\"67\">\n          <span class=\"px-4 py-2 bg-[var(--color-deep-navy)]/10 text-[var(--color-deep-navy)] rounded-xl font-black text-[10px] uppercase tracking-widest\" data-kid=\"68\">Dinner</span>\n          <div class=\"flex items-center gap-1.5 text-green-500 font-black text-[10px] uppercase\" data-kid=\"69\">\n            <i class=\"ti ti-check\" data-kid=\"70\"></i> 100% Match\n          </div>\n        </div>\n        <div class=\"relative w-full h-64 mb-8\" data-kid=\"71\">\n          <img src=\"https://images.pexels.com/photos/33706289/pexels-photo-33706289.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" class=\"w-full h-full object-cover rounded-[var(--radius-card)] shadow-xl group-hover:scale-[1.02] transition-transform duration-500\" alt=\"Grilled Salmon by Valeria Boltneva\" loading=\"lazy\" decoding=\"async\" data-kid=\"72\">\n          <div class=\"absolute -bottom-4 -right-4 w-16 h-16 bg-white rounded-2xl flex items-center justify-center shadow-lg text-[var(--color-deep-navy)]\" data-kid=\"73\">\n            <i class=\"ti ti-fish text-3xl\" data-kid=\"74\"></i>\n          </div>\n        </div>\n        <h3 class=\"font-inter text-2xl font-black mb-4\" data-kid=\"75\">Miso Glazed Salmon & Asparagus</h3>\n        <div class=\"flex flex-wrap gap-2 mb-8\" data-kid=\"76\">\n          <span class=\"glass-card px-3 py-1.5 rounded-lg text-[10px] font-bold flex items-center gap-1.5\" data-kid=\"77\"><i class=\"ti ti-flame text-orange-500\" data-kid=\"78\"></i> 540 kcal</span>\n          <span class=\"glass-card px-3 py-1.5 rounded-lg text-[10px] font-bold flex items-center gap-1.5\" data-kid=\"79\"><i class=\"ti ti-leaf text-green-500\" data-kid=\"80\"></i> High Protein</span>\n          <span class=\"glass-card px-3 py-1.5 rounded-lg text-[10px] font-bold flex items-center gap-1.5\" data-kid=\"81\"><i class=\"ti ti-clock\" data-kid=\"82\"></i> 25 mins</span>\n        </div>\n        <button class=\"w-full py-4 rounded-2xl border-2 border-[var(--color-deep-navy)]/5 font-black text-[10px] uppercase tracking-widest hover:bg-[var(--color-deep-navy)] hover:text-white transition-all\" data-kid=\"83\">View Full Recipe</button>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-start\" data-kid=\"84\">\n    \n    <div class=\"lg:col-span-4 space-y-8\" data-kid=\"85\">\n      <div class=\"glass-card rounded-[var(--radius-premium)] p-8\" data-kid=\"86\">\n        <h4 class=\"font-inter text-xl font-black mb-6 flex items-center justify-between\" data-kid=\"87\">\n          Pantry & Shopping\n          <i class=\"ti ti-list-check text-[var(--color-sage)]\" data-kid=\"88\"></i>\n        </h4>\n        \n        <div class=\"space-y-6\" data-kid=\"89\">\n          <div data-kid=\"90\">\n            <span class=\"text-[10px] font-black uppercase tracking-widest text-green-600 mb-3 block\" data-kid=\"91\">In Stock (Owned)</span>\n            <div class=\"space-y-3\" data-kid=\"92\">\n              <div class=\"flex items-center gap-3 p-3 bg-white/40 rounded-2xl border border-transparent\" data-kid=\"93\">\n                <i class=\"ti ti-circle-check-filled text-green-500\" data-kid=\"94\"></i>\n                <span class=\"text-sm font-bold\" data-kid=\"95\">Salmon Fillets (2x)</span>\n              </div>\n              <div class=\"flex items-center gap-3 p-3 bg-white/40 rounded-2xl border border-transparent\" data-kid=\"96\">\n                <i class=\"ti ti-circle-check-filled text-green-500\" data-kid=\"97\"></i>\n                <span class=\"text-sm font-bold\" data-kid=\"98\">Asparagus Bundle</span>\n              </div>\n              <div class=\"flex items-center gap-3 p-3 bg-white/40 rounded-2xl border border-transparent\" data-kid=\"99\">\n                <i class=\"ti ti-circle-check-filled text-green-500\" data-kid=\"100\"></i>\n                <span class=\"text-sm font-bold\" data-kid=\"101\">Miso Paste (Pantry)</span>\n              </div>\n            </div>\n          </div>\n\n          <div data-kid=\"102\">\n            <span class=\"text-[10px] font-black uppercase tracking-widest text-[var(--color-accent)] mb-3 block\" data-kid=\"103\">Missing (Need to Buy)</span>\n            <div class=\"space-y-3\" data-kid=\"104\">\n              <div class=\"flex items-center justify-between p-3 bg-white/60 rounded-2xl border border-[var(--color-accent)]/20 shadow-sm\" data-kid=\"105\">\n                <div class=\"flex items-center gap-3\" data-kid=\"106\">\n                  <i class=\"ti ti-circle-dashed text-[var(--color-accent)]\" data-kid=\"107\"></i>\n                  <span class=\"text-sm font-bold italic\" data-kid=\"108\">Sourdough Bread</span>\n                </div>\n                <button class=\"text-[10px] font-black text-[var(--color-accent)] uppercase hover:underline\" data-kid=\"109\">Add +</button>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"glass-card rounded-[var(--radius-premium)] p-8 bg-gradient-to-br from-[var(--color-sage)]/10 to-transparent border-[var(--color-sage)]/20\" data-kid=\"110\">\n        <h4 class=\"font-inter text-sm font-black mb-2 text-[var(--color-sage)]\" data-kid=\"111\">AI Chef Tip</h4>\n        <p class=\"text-sm italic opacity-70\" data-kid=\"112\">\"Marinating the salmon for just 10 minutes enhances the umami flavor without breaking down the proteins.\"</p>\n      </div>\n    </div>\n\n    \n    <div class=\"lg:col-span-8\" data-kid=\"113\">\n      <div class=\"glass-card rounded-[var(--radius-premium)] p-10\" data-kid=\"114\">\n        <div class=\"flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-10 pb-10 border-b border-[var(--color-deep-navy)]/5\" data-kid=\"115\">\n          <div data-kid=\"116\">\n            <h3 class=\"font-inter text-3xl font-black\" data-kid=\"117\">Step-by-Step Preparation</h3>\n            <p class=\"text-[var(--color-deep-navy)]/40 text-sm font-bold mt-1 uppercase tracking-widest\" data-kid=\"118\">Active Recipe: Miso Glazed Salmon</p>\n          </div>\n          \n          \n          <div class=\"flex items-center gap-6 p-4 bg-[var(--color-deep-navy)]/5 rounded-3xl border border-[var(--color-deep-navy)]/10\" data-kid=\"119\">\n            <div class=\"text-right\" data-kid=\"120\">\n              <span class=\"text-[10px] font-black uppercase block leading-none\" data-kid=\"121\">Voice Mode</span>\n              <span class=\"text-xs opacity-60\" data-kid=\"122\">Hands-free guide</span>\n            </div>\n            <div class=\"relative w-16 h-8 bg-white/80 rounded-full cursor-pointer p-1\" data-kid=\"123\">\n              <div class=\"absolute left-1 top-1 w-6 h-6 bg-[var(--color-sage)] rounded-full transition-all\" data-kid=\"124\"></div>\n              <i class=\"ti ti-microphone-2 absolute right-2 top-1/2 -translate-y-1/2 text-[var(--color-deep-navy)]/20 text-sm\" data-kid=\"125\"></i>\n            </div>\n            <div class=\"w-10 h-10 rounded-full bg-[var(--color-sage)]/10 flex items-center justify-center text-[var(--color-sage)] orb-pulse\" data-kid=\"126\">\n              <i class=\"ti ti-microphone-2 text-xl\" data-kid=\"127\"></i>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"space-y-12\" data-kid=\"128\">\n          \n          <div class=\"flex gap-8 relative group\" data-kid=\"129\">\n            <div class=\"absolute left-6 top-12 bottom-[-48px] w-0.5 bg-[var(--color-sage)]/20\" data-kid=\"130\"></div>\n            <div class=\"w-12 h-12 shrink-0 rounded-2xl bg-[var(--color-sage)] text-white flex items-center justify-center font-inter font-black text-lg shadow-xl shadow-[var(--color-sage)]/30 z-10\" data-kid=\"131\">1</div>\n            <div class=\"flex-1 glass-card p-8 rounded-[var(--radius-card)] bg-white shadow-2xl shadow-[var(--color-deep-navy)]/5 -mt-2 border-l-4 border-l-[var(--color-sage)]\" data-kid=\"132\">\n              <h5 class=\"text-lg font-black mb-3\" data-kid=\"133\">Prepare the Miso Glaze</h5>\n              <p class=\"text-[var(--color-deep-navy)]/70 leading-relaxed\" data-kid=\"134\">In a small bowl, whisk together the miso paste, mirin, soy sauce, and a touch of honey until perfectly smooth. Ensure there are no miso clumps remaining.</p>\n              <div class=\"mt-6 flex gap-4\" data-kid=\"135\">\n                <button class=\"px-6 py-2.5 bg-[var(--color-sage)]/10 text-[var(--color-sage)] rounded-xl text-[10px] font-black uppercase tracking-widest\" data-kid=\"136\">Completed</button>\n              </div>\n            </div>\n          </div>\n\n          \n          <div class=\"flex gap-8 relative opacity-40 hover:opacity-100 transition-opacity\" data-kid=\"137\">\n            <div class=\"absolute left-6 top-12 bottom-[-48px] w-0.5 bg-[var(--color-sage)]/20\" data-kid=\"138\"></div>\n            <div class=\"w-12 h-12 shrink-0 rounded-2xl bg-[var(--color-deep-navy)]/5 text-[var(--color-deep-navy)]/40 flex items-center justify-center font-inter font-black text-lg z-10\" data-kid=\"139\">2</div>\n            <div class=\"flex-1 py-2\" data-kid=\"140\">\n              <h5 class=\"text-lg font-black mb-3\" data-kid=\"141\">Sear the Salmon</h5>\n              <p class=\"text-[var(--color-deep-navy)]/70 leading-relaxed\" data-kid=\"142\">Heat a non-stick skillet over medium-high heat. Place salmon skin-side down and sear for 4 minutes until the skin is crispy and golden.</p>\n            </div>\n          </div>\n\n          \n          <div class=\"flex gap-8\" data-kid=\"143\">\n            <div class=\"w-12 h-12 shrink-0 rounded-2xl bg-[var(--color-deep-navy)]/5 text-[var(--color-deep-navy)]/40 flex items-center justify-center font-inter font-black text-lg z-10\" data-kid=\"144\">3</div>\n            <div class=\"flex-1 py-2\" data-kid=\"145\">\n              <h5 class=\"text-lg font-black mb-3\" data-kid=\"146\">Glaze and Finish</h5>\n              <p class=\"text-[var(--color-deep-navy)]/70 leading-relaxed\" data-kid=\"147\">Brush the miso glaze generously over the salmon. Flip and cook for another 2 minutes until the glaze carmelizes and the salmon is cooked through.</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n</div>",
