      "html": "\n<section class=\"min-h-screen bg-[#040608] text-[#d1d5db] font-sans selection:bg-[#10b981]/30\" data-kid=\"0\">\n    \n    <div class=\"relative z-10 max-w-7xl mx-auto px-8 py-16\" data-kid=\"1\">\n        \n        \n        <header class=\"mb-20 flex flex-col md:flex-row md:items-end justify-between gap-8 border-b border-[#ffffff0a] pb-12\" data-kid=\"2\">\n            <div class=\"space-y-4\" data-kid=\"3\">\n                <div class=\"flex items-center gap-3\" data-kid=\"4\">\n                    <span class=\"px-3 py-1 rounded-md bg-[#ffffff0a] border border-[#ffffff10] text-[#10b981] text-[11px] font-bold tracking-widest uppercase\" data-kid=\"5\">Vault.04</span>\n                    <div class=\"h-1 w-1 rounded-full bg-slate-600\" data-kid=\"6\"></div>\n                    <span class=\"text-slate-500 text-xs font-medium tracking-wide\" data-kid=\"7\">Family Financial Hub</span>\n                </div>\n                <h1 class=\"text-6xl font-black tracking-tighter text-white font-display uppercase italic italic-none\" data-kid=\"8\">Reminders</h1>\n                <p class=\"text-slate-500 text-lg max-w-2xl font-medium leading-relaxed\" data-kid=\"9\">Systematic oversight for your household utility cycles. AI-monitored, human-controlled.</p>\n            </div>\n            <div class=\"flex items-center gap-4\" data-kid=\"10\">\n                <div class=\"flex flex-col items-end\" data-kid=\"11\">\n                    <span class=\"text-[10px] font-bold text-slate-600 uppercase tracking-widest\" data-kid=\"12\">System Date</span>\n                    <span class=\"text-white font-mono text-lg font-semibold tracking-tighter\" data-kid=\"13\">JULY 24, 2026</span>\n                </div>\n                <button class=\"px-8 py-4 rounded-lg bg-white text-black text-xs font-black tracking-widest uppercase hover:bg-[#10b981] hover:text-white transition-colors duration-300 active:scale-95\" data-kid=\"14\">Add Cycle</button>\n            </div>\n        </header>\n\n        \n        <div class=\"variant-section mb-40\" id=\"variant-1\" data-kid=\"15\">\n            <div class=\"flex items-center gap-4 mb-10\" data-kid=\"16\">\n                <div class=\"w-1.5 h-6 bg-[#10b981]\" data-kid=\"17\"></div>\n                <div data-kid=\"18\">\n                    <h2 class=\"text-xl font-black text-white uppercase tracking-tighter\" data-kid=\"19\">Queue: Critical Actions</h2>\n                    <p class=\"text-slate-500 text-xs font-bold uppercase tracking-widest mt-1\" data-kid=\"20\">Real-time status of recurring liabilities</p>\n                </div>\n            </div>\n\n            <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-10\" data-kid=\"21\">\n                \n                <div class=\"lg:col-span-8 space-y-4\" data-kid=\"22\">\n                    \n                    <div class=\"group flex items-center justify-between p-6 bg-[#ffffff05] border border-[#ffffff0a] hover:border-[#10b98140] transition-colors duration-200\" data-kid=\"23\">\n                        <div class=\"flex items-center gap-8\" data-kid=\"24\">\n                            <div class=\"text-[#10b981]\" data-kid=\"25\">\n                                <i class=\"fa-solid fa-bolt-lightning text-2xl\" data-kid=\"26\"></i>\n                            </div>\n                            <div data-kid=\"27\">\n                                <div class=\"flex items-center gap-3 mb-1\" data-kid=\"28\">\n                                    <h4 class=\"text-white font-bold text-lg tracking-tight\" data-kid=\"29\">ELECTRICITY</h4>\n                                    <span class=\"text-[11px] font-black text-rose-500 px-2 py-0.5 bg-rose-500/10 border border-rose-500/20\" data-kid=\"30\">DUE IN 2D</span>\n                                </div>\n                                <p class=\"text-slate-500 text-xs font-bold tracking-widest\" data-kid=\"31\">METER #8821 • ESTIMATED LOAD: +4%</p>\n                      