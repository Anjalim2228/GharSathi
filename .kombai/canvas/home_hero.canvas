" stroke=\"currentColor\" stroke-width=\"12\" fill=\"transparent\" stroke-dasharray=\"628\" stroke-dashoffset=\"113\" class=\"text-emerald-500 transition-all duration-1000\" data-kid=\"239\"></circle>\n              </svg>\n              <div class=\"absolute inset-0 flex flex-col items-center justify-center\" data-kid=\"240\">\n                <span class=\"text-6xl font-black\" data-kid=\"241\">82</span>\n                <span class=\"text-[10px] font-bold text-slate-500 uppercase tracking-[0.2em] mt-2\" data-kid=\"242\">Score</span>\n              </div>\n            </div>\n            <p class=\"text-slate-400 text-sm leading-relaxed mb-8\" data-kid=\"243\">\n              Your home is operating at <span class=\"text-white font-bold italic\" data-kid=\"244\">High Efficiency</span>. AI detects potential issues with water pressure in guest bathroom.\n            </p>\n            <button class=\"w-full py-4 bg-white text-slate-900 rounded-2xl font-black hover:bg-emerald-400 transition-colors\" data-kid=\"245\">\n              Run Full Diagnostic\n            </button>\n          </div>\n\n          <div class=\"bg-blue-600 rounded-[2rem] p-8 text-white\" data-kid=\"246\">\n            <div class=\"flex items-center gap-4 mb-6\" data-kid=\"247\">\n              <div class=\"w-12 h-12 bg-white/20 rounded-2xl flex items-center justify-center\" data-kid=\"248\">\n                <i class=\"lucide-zap w-6 h-6\" data-kid=\"249\"></i>\n              </div>\n              <h4 class=\"font-bold text-xl leading-tight\" data-kid=\"250\">Proactive Energy Savings</h4>\n            </div>\n            <p class=\"text-blue-100 text-sm mb-6 leading-relaxed\" data-kid=\"251\">\n              Based on compressor wear, your Hall AC is consuming 15% more power. Cleaning filters today could save you <span class=\"font-black text-white\" data-kid=\"252\">$12/mo</span>.\n            </p>\n            <button class=\"text-sm font-bold underline underline-offset-4 hover:text-white transition-colors\" data-kid=\"253\">Learn How AI Predicted This</button>\n          </div>\n        </div>\n\n        \n        <div class=\"lg:col-span-8 space-y-10\" data-kid=\"254\">\n          <div class=\"bg-white rounded-[2.5rem] p-10 border border-slate-200/60 shadow-sm\" data-kid=\"255\">\n            <div class=\"flex items-center justify-between mb-10\" data-kid=\"256\">\n              <h3 class=\"text-2xl font-black\" data-kid=\"257\">Maintenance Forecast</h3>\n              <div class=\"flex gap-2\" data-kid=\"258\">\n                <button class=\"px-4 py-1.5 bg-slate-900 text-white text-xs font-bold rounded-full\" data-kid=\"259\">Monthly</button>\n                <button class=\"px-4 py-1.5 bg-slate-100 text-slate-500 text-xs font-bold rounded-full\" data-kid=\"260\">Quarterly</button>\n              </div>\n            </div>\n\n            <div class=\"relative space-y-12 before:absolute before:left-3 before:top-2 before:bottom-2 before:w-[2px] before:bg-slate-100\" data-kid=\"261\">\n              \n              <div class=\"relative pl-12\" data-kid=\"262\">\n                <div class=\"absolute left-0 top-1.5 w-6 h-6 rounded-full bg-white border-4 border-amber-500 shadow-sm z-10\" data-kid=\"263\"></div>\n                <div class=\"flex flex-col md:flex-row md:items-center justify-between gap-4\" data-kid=\"264\">\n                  <div data-kid=\"265\">\n                    <p class=\"text-[10px] font-black text-amber-600 uppercase tracking-widest mb-1\" data-kid=\"266\">Feb 24, 2024 • High Probability</p>\n                    <h4 class=\"text-xl font-black text-slate-900\" data-kid=\"267\">Tesla Model 3: Motor Inverter Fluid</h4>\n                    <p class=\"text-sm text-slate-500 font-medium mt-1\" data-kid=\"268\">AI usage tracking suggests fluid level is reaching 10% threshold based on high-speed highway usage.</p>\n                  </div>\n                  <button class=\"shrink-0 px-6 py-2.5 border border-slate-200 rounded-xl text-sm font-bold hover:bg-slate-900 hover:text-white transition-all\" data-kid=\"269\">Pre-Book</button>\n                </div>\n              </div>\n\n              \n              <div class=\"relative pl-12\" data-kid=\"270\">\n                <div class=\"absolute left-0 top-1.5 w-6 h-6 rounded-full bg-white border-4 border-blue-500 shadow-sm z-10\" data-kid=\"271\"></div>\n                <div class=\"flex flex-col md:flex-row md:items-center justify-between gap-4\" data-kid=\"272\">\n                  <div data-kid=\"273\">\n                    <p class=\"text-[10px] font-black text-blue-600 uppercase tracking-widest mb-1\" data-kid=\"274\">Mar 12, 2024 • Pattern Match</p>\n                    <h4 class=\"text-xl font-black text-slate-900\" data-kid=\"275\">Living Room AC: Deep Sanitization</h4>\n                    <p class=\"text-sm text-slate-500 font-medium mt-1\" data-kid=\"276\">Historically, humidity levels in March lead to mold buildup. Preventive cleaning recommended.</p>\n                  </div>\n                  <button class=\"shrink-0 px-6 py-2.5 border border-slate-200 rounded-xl text-sm font-bold hover:bg-slate-900 hover:text-white transition-all\" data-kid=\"277\">Set Alert</button>\n                </div>\n              </div>\n\n              \n              <div class=\"relative pl-12 opacity-50\" data-kid=\"278\">\n                <div class=\"absolute left-0 top-1.5 w-6 h-6 rounded-full bg-white border-4 border-slate-200 shadow-sm z-10\" data-kid=\"279\"></div>\n                <div data-kid=\"280\">\n                  <p class=\"text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1\" data-kid=\"281\">Apr 05, 2024 • Scheduled</p>\n                  <h4 class=\"text-xl font-black text-slate-900\" data-kid=\"282\">Kitchen Chimney: Auto-Clean Cycle</h4>\n                  <p class=\"text-sm text-slate-500 font-medium mt-1\" data-kid=\"283\">Standard 60-day interval for deep degreasing.</p>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\" data-kid=\"284\">\n            <div class=\"bg-emerald-50 border border-emerald-100 p-8 rounded-[2rem]\" data-kid=\"285\">\n              <div class=\"w-12 h-12 bg-white rounded-2xl flex items-center justify-center text-emerald-600 mb-6 shadow-sm\" data-kid=\"286\">\n                <i class=\"lucide-sparkles w-6 h-6\" data-kid=\"287\"></i>\n              </div>\n              <h4 class=\"font-bold text-emerald-900 text-lg mb-2\" data-kid=\"288\">Technician Matchmaking</h4>\n              <p class=\"text-emerald-700/80 text-sm leading-relaxed mb-6\" data-kid=\"289\">\n                AI found 3 highly-rated split AC specialists available this Saturday who offer a 20% discount for HomeHero members.\n              </p>\n              <button class=\"text-emerald-600 font-black text-xs uppercase tracking-widest flex items-center gap-2\" data-kid=\"290\">View Candidates <i class=\"lucide-arrow-right w-3 h-3\" data-kid=\"291\"></i></button>\n            </div>\n            <div class=\"bg-white border border-slate-200 p-8 rounded-[2rem]\" data-kid=\"292\">\n              <div class=\"w-12 h-12 bg-slate-50 rounded-2xl flex items-center justify-center text-slate-400 mb-6 shadow-sm\" data-kid=\"293\">\n                <i class=\"lucide-wallet w-6 h-6\" data-kid=\"294\"></i>\n              </div>\n              <h4 class=\"font-bold text-slate-900 text-lg mb-2\" data-kid=\"295\">Budgeting Insight</h4>\n              <p class=\"text-slate-500 text-sm leading-relaxed mb-6\" data-kid=\"296\">\n                Maintenance costs are expected to spike in Q3 due to painting. We recommend setting aside $150 extra per month.\n              </p>\n              <button class=\"text-slate-900 font-black text-xs uppercase tracking-widest flex items-center gap-2\" data-kid=\"297\">Update Budget <i class=\"lucide-arrow-right w-3 h-3\" data-kid=\"298\"></i></button>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n  </main>\n</div>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"299\"></script>\n<script src=\"https://unpkg.com/lucide@latest\" data-kid=\"300\"></script>\n<script data-kid=\"301\">\n  // Initialize Lucide\n  lucide.createIcons();\n\n  // Entrance Animations\n  window.addEventListener('load', () => {\n    gsap.from(\".stat-card\", {\n      y: 20,\n      opacity: 0,\n      duration: 0.6,\n      stagger: 0.1,\n      ease: \"power2.out\"\n    });\n    \n    gsap.from(\".asset-card\", {\n      y: 40,\n      opacity: 0,\n      duration: 0.8,\n      stagger: 0.15,\n      delay: 0.2,\n      ease: \"power4.out\"\n    });\n\n    gsap.from(\".minor-task\", {\n      x: -20,\n      opacity: 0,\n      duration: 0.5,\n      stagger: 0.1,\n      delay: 0.6,\n      ease: \"power2.out\"\n    });\n  });\n\n  // Tab Switcher Logic\n  const tabs = document.querySelectorAll('#viewSwitcher button');\n  const views = {\n    dashboard: document.getElementById('view-dashboard'),\n    logs: document.getElementById('view-logs'),\n    'ai-hub': document.getElementById('view-ai-hub')\n  };\n\n  tabs.forEach(tab => {\n    tab.addEventListener('click', () => {\n      const targetView = tab.getAttribute('data-view');\n      \n      // Update UI\n      tabs.forEach(t => {\n        t.classList.remove('variant-tab-active', 'bg-white', 'shadow-sm', 'text-slate-900');\n        t.classList.add('text-slate-500');\n      });\n      tab.classList.add('variant-tab-active', 'bg-white', 'shadow-sm', 'text-slate-900');\n      tab.classList.remove('text-slate-500');\n\n      // Switch Views\n      Object.keys(views).forEach(v => {\n        views[v].classList.remove('visible-view');\n        views[v].classList.add('hidden-view');\n      });\n      views[targetView].classList.remove('hidden-view');\n      views[targetView].classList.add('visible-view');\n\n      // Re-trigger animations if any\n      if (targetView === 'ai-hub') {\n        const ring = document.getElementById('health-ring');\n        ring.style.strokeDashoffset = '628';\n        setTimeout(() => {\n          ring.style.strokeDashoffset = '113';\n        }, 100);\n      }\n    });\n  });\n</script>\n",
