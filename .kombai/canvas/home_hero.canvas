ll bg-indigo-400 w-[80%] rounded-full shadow-[0_0_15px_rgba(129,140,248,0.5)]\" data-kid=\"243\"></div>\n                                </div>\n                            </div>\n                            <button class=\"w-full mt-8 bg-white text-indigo-900 font-extrabold py-3.5 rounded-2xl hover:bg-indigo-50 transition-all\" data-kid=\"244\">Log Intake</button>\n                        </div>\n                    </div>\n                </section>\n\n                \n                <section id=\"inventory\" class=\"view-section space-y-8\" data-kid=\"245\">\n                    <div class=\"glass-card p-10 rounded-3xl\" data-kid=\"246\">\n                        <h2 class=\"text-2xl font-black text-slate-900 mb-8 tracking-tight\" data-kid=\"247\">Household Stock Evolution</h2>\n                        <div class=\"chart-container h-[400px]\" data-kid=\"248\">\n                            <canvas id=\"inventoryChart\" data-kid=\"249\"></canvas>\n                        </div>\n                    </div>\n                    <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\" data-kid=\"250\">\n                        <div class=\"glass-card p-8 rounded-[2.5rem] border-amber-200 bg-amber-50/20\" data-kid=\"251\">\n                            <h3 class=\"text-lg font-extrabold text-amber-900 mb-4\" data-kid=\"252\">Low Stock Alerts</h3>\n                            <div class=\"space-y-4\" data-kid=\"253\">\n                                <div class=\"flex items-center justify-between text-sm\" data-kid=\"254\">\n                                    <span class=\"font-bold text-amber-800\" data-kid=\"255\">Brown Rice (Kg)</span>\n                                    <span class=\"px-2 py-0.5 bg-amber-200 text-amber-900 rounded-md font-black\" data-kid=\"256\">0.5</span>\n                                </div>\n                                <div class=\"flex items-center justify-between text-sm\" data-kid=\"257\">\n                                    <span class=\"font-bold text-amber-800\" data-kid=\"258\">Laundry Pods</span>\n                                    <span class=\"px-2 py-0.5 bg-amber-200 text-amber-900 rounded-md font-black\" data-kid=\"259\">3</span>\n                                </div>\n                            </div>\n                            <button class=\"w-full mt-6 bg-amber-600 text-white font-extrabold py-2.5 rounded-xl text-sm\" data-kid=\"260\">Restock List</button>\n                        </div>\n                        <div class=\"glass-card p-8 rounded-[2.5rem] md:col-span-2\" data-kid=\"261\">\n                             <h3 class=\"text-lg font-extrabold text-slate-900 mb-4\" data-kid=\"262\">Predictive Analysis</h3>\n                             <p class=\"text-slate-600 text-sm mb-6\" data-kid=\"263\">Our AI predicts you will run out of the following items within the next 48 hours based on past consumption patterns:</p>\n                             <div class=\"grid grid-cols-2 gap-4\" data-kid=\"264\">\n                                 <div class=\"p-4 bg-slate-100 rounded-2xl border border-slate-200\" data-kid=\"265\">\n                                     <p class=\"text-xs font-bold text-slate-400 mb-1\" data-kid=\"266\">STAPLE</p>\n                                     <p class=\"font-extrabold text-slate-800\" data-kid=\"267\">Cooking Oil</p>\n                                 </div>\n                                 <div class=\"p-4 bg-slate-100 rounded-2xl border border-slate-200\" data-kid=\"268\">\n                                     <p class=\"text-xs font-bold text-slate-400 mb-1\" data-kid=\"269\">DAIRY</p>\n                                     <p class=\"font-extrabold text-slate-800\" data-kid=\"270\">Fresh Milk</p>\n                                 </div>\n                             </div>\n                        </div>\n                    </div>\n                </section>\n\n            </div>\n        </main>\n    </div>\n\n    \n    <script src=\"https://cdn.jsdelivr.net/npm/chart.js\" data-kid=\"271\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"272\"></script>\n    <script src=\"https://unpkg.com/lucide@latest\" data-kid=\"273\"></script>\n    <script data-kid=\"274\">\n        lucide.createIcons();\n\n        // View Switching Logic\n        const navButtons = document.querySelectorAll('.view-trigger');\n        const sections = document.querySelectorAll('.view-section');\n\n        navButtons.forEach(btn => {\n            btn.addEventListener('click', () => {\n                const target = btn.getAttribute('data-view');\n                \n                // Update nav classes\n                navButtons.forEach(b => {\n                    b.classList.remove('nav-item-active');\n                    b.classList.add('text-slate-500');\n                    b.classList.remove('bg-white');\n                });\n                btn.classList.add('nav-item-active');\n                btn.classList.remove('text-slate-500');\n\n                // Animate transition\n                gsap.to(sections, { \n                    opacity: 0, \n                    y: 10, \n                    duration: 0.3, \n                    display: 'none', \n                    onComplete: () => {\n                        const targetEl = document.getElementById(target);\n                        targetEl.style.display = 'block';\n                        gsap.fromTo(targetEl, { opacity: 0, y: 10 }, { opacity: 1, y: 0, duration: 0.5 });\n                    }\n                });\n            });\n        });\n\n        // Chart 1: Financial Performance\n        const ctxFinancial = document.getElementById('financialChart').getContext('2d');\n        new Chart(ctxFinancial, {\n            type: 'line',\n            data: {\n                labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],\n                datasets: [\n                    {\n                        label: 'Gross Income',\n                        data: [6500, 6800, 6400, 7200, 7500, 8000],\n                        borderColor: '#6366f1',\n                        borderWidth: 5,\n                        tension: 0.4,\n                        fill: true,\n                        backgroundColor: 'rgba(99, 102, 241, 0.04)',\n                        pointRadius: 0,\n                        pointHoverRadius: 6,\n                        pointHoverBackgroundColor: '#6366f1',\n                        pointHoverBorderColor: '#fff',\n                        pointHoverBorderWidth: 3\n                    },\n                    {\n                        label: 'Net Expenses',\n                        data: [3500, 4200, 3100, 3800, 4400, 3900],\n                        borderColor: '#f43f5e',\n                        borderWidth: 5,\n                        tension: 0.4,\n                        fill: false,\n                        pointRadius: 0,\n                        pointHoverRadius: 6,\n                        pointHoverBackgroundColor: '#f43f5e',\n                        pointHoverBorderColor: '#fff',\n                        pointHoverBorderWidth: 3\n                    }\n                ]\n            },\n            options: {\n                responsive: true,\n                maintainAspectRatio: false,\n                plugins: { legend: { display: false } },\n                scales: {\n                    y: { grid: { display: false }, ticks: { font: { weight: 'bold' } } },\n                    x: { grid: { display: false }, ticks: { font: { weight: 'bold' } } }\n                }\n            }\n        });\n\n        // Chart 2: Shopping Radar\n        const ctxRadar = document.getElementById('shoppingRadar').getContext('2d');\n        new Chart(ctxRadar, {\n            type: 'radar',\n            data: {\n                labels: ['Food', 'Health', 'Tech', 'Home', 'Leisure'],\n                datasets: [{\n                    label: 'Spend Share',\n                    data: [80, 50, 40, 60, 30],\n                    backgroundColor: 'rgba(99, 102, 241, 0.2)',\n                    borderColor: '#6366f1',\n                    borderWidth: 2,\n                    pointBackgroundColor: '#6366f1'\n                }]\n            },\n            options: {\n                responsive: true,\n                maintainAspectRatio: false,\n                plugins: { legend: { display: false } },\n                scales: {\n                    r: { ticks: { display: false }, grid: { color: 'rgba(0,0,0,0.05)' } }\n                }\n            }\n        });\n\n        // Heatmap Simulation\n        const heatmapGrid = document.getElementById('heatmapGrid');\n        for (let i = 0; i < 49; i++) {\n            const opacity = Math.random() * 0.9 + 0.1;\n            const div = document.createElement('div');\n            div.className = 'aspect-square rounded-lg transition-all hover:scale-110 cursor-pointer shadow-sm';\n            div.style.backgroundColor = `rgba(99, 102, 241, ${opacity})`;\n            heatmapGrid.appendChild(div);\n        }\n\n        // Chart 3: Refill Bar\n        const ctxRefill = document.getElementById('refillChart').getContext('2d');\n        new Chart(ctxRefill, {\n            type: 'bar',\n            data: {\n                labels: ['Aspirin', 'Vitamin D', 'Calcium', 'Omega 3'],\n                datasets: [{\n                    label: 'Stock %',\n                    data: [12, 85, 45, 95],\n                    backgroundColor: ['#f43f5e', '#6366f1', '#f59e0b', '#10b981'],\n                    borderRadius: 12\n                }]\n            },\n            options: {\n                responsive: true,\n                maintainAspectRatio: false,\n                plugins: { legend: { display: false } },\n                scales: {\n                    y: { beginAtZero: true, max: 100, grid: { display: false } },\n                    x: { grid: { display: false } }\n                }\n            }\n        });\n\n        // Chart 4: Activity Circular\n        const ctxActivity = document.getElementById('activityCircular').getContext('2d');\n        new Chart(ctxActivity, {\n            type: 'doughnut',\n            data: {\n                labels: ['Sarah', 'James', 'Leo', 'Mia'],\n                datasets: [{\n                    data: [35, 25, 20, 20],\n                    backgroundColor: ['#6366f1', '#ec4899', '#f59e0b', '#10b981'],\n                    borderWidth: 0,\n                    hoverOffset: 20\n                }]\n            },\n            options: {\n                responsive: true,\n                maintainAspectRatio: false,\n                cutout: '80%',\n                plugins: { legend: { position: 'bottom', labels: { usePointStyle: true, padding: 20, font: { weight: 'bold' } } } }\n            }\n        });\n\n        // Chart 5: Task Velocity\n        const ctxTask = document.getElementById('taskChart').getContext('2d');\n        new Chart(ctxTask, {\n            type: 'line',\n            data: {\n                labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],\n                datasets: [{\n                    label: 'Completed',\n                    data: [5, 8, 12, 7, 15, 22, 18],\n                    borderColor: '#10b981',\n                    borderWidth: 4,\n                    tension: 0.5,\n                    fill: true,\n                    backgroundColor: 'rgba(16, 185, 129, 0.1)',\n                    pointRadius: 6,\n                    pointBackgroundColor: '#fff',\n                    pointBorderWidth: 3\n                }]\n            },\n            options: {\n                responsive: true,\n                maintainAspectRatio: false,\n                plugins: { legend: { display: false } },\n                scales: {\n                    y: { grid: { display: false } },\n                    x: { grid: { display: false } }\n                }\n            }\n        });\n\n        // Chart 6: Inventory Trends\n        const ctxInventory = document.getElementById('inventoryChart').getContext('2d');\n        new Chart(ctxInventory, {\n            type: 'bar',\n            data: {\n                labels: ['Rice', 'Oil', 'Sugar', 'Flour', 'Milk', 'Eggs', 'Detergent'],\n                datasets: [{\n                    label: 'Usage rate',\n                    data: [65, 45, 80, 30, 95, 85, 20],\n                    backgroundColor: 'rgba(99, 102, 241, 0.6)',\n                    hoverBackgroundColor: '#6366f1',\n                    borderRadius: 15\n                }]\n            },\n            options: {\n                responsive: true,\n                maintainAspectRatio: false,\n                scales: { y: { grid: { borderDash: [5, 5] } }, x: { grid: { display: false } } }\n            }\n        });\n\n        // GSAP Initialization for cards - Removed direct transition conflicts\n        gsap.from('.glass-card', {\n            opacity: 0,\n            y: 20,\n            stagger: 0.08,\n            duration: 0.6,\n            ease: 'power2.out'\n        });\n\n    </script>\n</div>\n",
