0\" data-kid=\"240\">4.2 GB</td>\n                    <td class=\"px-8 py-5\" data-kid=\"241\">\n                      <span class=\"inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-emerald-100 text-emerald-800\" data-kid=\"242\">EXCELLENT</span>\n                    </td>\n                 </tr>\n               </tbody>\n            </table>\n         </div>\n      </div>\n\n      \n      <div id=\"variant-3\" class=\"variant-content space-y-12\" data-kid=\"243\">\n        <div class=\"flex items-center justify-between\" data-kid=\"244\">\n           <div class=\"max-w-2xl\" data-kid=\"245\">\n             <h2 class=\"text-6xl font-black text-slate-900 tracking-tighter leading-none mb-4\" data-kid=\"246\">USER <span class=\"text-indigo-600 italic\" data-kid=\"247\">INTELLIGENCE</span></h2>\n             <p class=\"text-xl text-slate-600 font-medium\" data-kid=\"248\">Aggregated data stream from HomeHero's neural engine.</p>\n           </div>\n           <div class=\"hidden lg:block\" data-kid=\"249\">\n              <div class=\"w-48 h-48 bg-yellow-400 border-4 border-slate-900 neo-shadow flex items-center justify-center -rotate-3 hover:rotate-0 transition-transform cursor-pointer\" data-kid=\"250\">\n                 <div class=\"text-center\" data-kid=\"251\">\n                    <div class=\"text-5xl font-black\" data-kid=\"252\">98%</div>\n                    <div class=\"text-xs font-bold uppercase tracking-widest\" data-kid=\"253\">Uptime</div>\n                 </div>\n              </div>\n           </div>\n        </div>\n\n        <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8\" data-kid=\"254\">\n           <div class=\"p-8 border-4 border-slate-900 bg-white neo-shadow flex flex-col justify-between aspect-square group\" data-kid=\"255\">\n              <div class=\"text-4xl font-black\" data-kid=\"256\">2.4M</div>\n              <div data-kid=\"257\">\n                <div class=\"text-xs font-black uppercase tracking-widest mb-2\" data-kid=\"258\">Total Packets</div>\n                <p class=\"text-sm font-medium text-slate-500 group-hover:text-slate-900 transition-colors\" data-kid=\"259\">Daily secure synchronization cycles processed via AES-256.</p>\n              </div>\n           </div>\n           <div class=\"p-8 border-4 border-slate-900 bg-indigo-600 text-white neo-shadow flex flex-col justify-between aspect-square\" data-kid=\"260\">\n            <div class=\"text-4xl font-black\" data-kid=\"261\">12.1k</div>\n            <div data-kid=\"262\">\n              <div class=\"text-xs font-black uppercase tracking-widest mb-2\" data-kid=\"263\">Active Sessions</div>\n              <p class=\"text-sm font-bold opacity-70\" data-kid=\"264\">Concurrent family members utilizing AI Assistant features.</p>\n            </div>\n          </div>\n          <div class=\"p-8 border-4 border-slate-900 bg-rose-400 neo-shadow flex flex-col justify-between aspect-square\" data-kid=\"265\">\n            <div class=\"text-4xl font-black\" data-kid=\"266\">0.04%</div>\n            <div data-kid=\"267\">\n              <div class=\"text-xs font-black uppercase tracking-widest mb-2\" data-kid=\"268\">Churn Risk</div>\n              <p class=\"text-sm font-bold text-slate-800\" data-kid=\"269\">Subscription retention predicted by health engine.</p>\n            </div>\n          </div>\n          <div class=\"p-8 border-4 border-slate-900 bg-emerald-400 neo-shadow flex flex-col justify-between aspect-square\" data-kid=\"270\">\n            <div class=\"text-4xl font-black\" data-kid=\"271\">$42.8k</div>\n            <div data-kid=\"272\">\n              <div class=\"text-xs font-black uppercase tracking-widest mb-2\" data-kid=\"273\">Net Growth</div>\n              <p class=\"text-sm font-bold text-slate-800\" data-kid=\"274\">New revenue generated in the last 24 hours.</p>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-12\" data-kid=\"275\">\n          <div class=\"space-y-6\" data-kid=\"276\">\n            <h3 class=\"text-3xl font-black border-b-4 border-slate-900 pb-2 inline-block\" data-kid=\"277\">FEEDBACK STREAM</h3>\n            <div class=\"space-y-4\" data-kid=\"278\">\n               <div class=\"p-6 border-4 border-slate-900 bg-white neo-shadow\" data-kid=\"279\">\n                  <div class=\"flex justify-between items-start mb-4\" data-kid=\"280\">\n                     <span class=\"text-2xl font-black\" data-kid=\"281\">\"STUNNING\"</span>\n                     <span class=\"px-3 py-1 bg-yellow-400 border-2 border-slate-900 text-xs font-bold\" data-kid=\"282\">5 STARS</span>\n                  </div>\n                  <p class=\"font-bold text-slate-600 italic\" data-kid=\"283\">\"The family leaderboard has turned chores into a game for my kids. Life changer.\"</p>\n                  <div class=\"mt-4 flex items-center gap-2\" data-kid=\"284\">\n                    <div class=\"w-8 h-8 bg-slate-200 border-2 border-slate-900\" data-kid=\"285\"></div>\n                    <span class=\"text-xs font-black\" data-kid=\"286\">CARLA M. • DENVER, CO</span>\n                  </div>\n               </div>\n               <div class=\"p-6 border-4 border-slate-900 bg-white neo-shadow\" data-kid=\"287\">\n                <div class=\"flex justify-between items-start mb-4\" data-kid=\"288\">\n                   <span class=\"text-2xl font-black\" data-kid=\"289\">\"NEEDS SYNC\"</span>\n                   <span class=\"px-3 py-1 bg-slate-100 border-2 border-slate-900 text-xs font-bold\" data-kid=\"290\">3 STARS</span>\n                </div>\n                <p class=\"font-bold text-slate-600 italic\" data-kid=\"291\">\"Integration with Samsung refrigerators is slightly buggy on the inventory sync.\"</p>\n                <div class=\"mt-4 flex items-center gap-2\" data-kid=\"292\">\n                  <div class=\"w-8 h-8 bg-slate-200 border-2 border-slate-900\" data-kid=\"293\"></div>\n                  <span class=\"text-xs font-black\" data-kid=\"294\">DAVID R. • BERLIN, DE</span>\n                </div>\n             </div>\n            </div>\n          </div>\n\n          <div class=\"bg-slate-900 p-8 border-4 border-slate-900 text-white\" data-kid=\"295\">\n            <h3 class=\"text-3xl font-black mb-8 italic\" data-kid=\"296\">ANALYTIC_CORE_V4</h3>\n            <div class=\"space-y-8\" data-kid=\"297\">\n               <div class=\"space-y-2\" data-kid=\"298\">\n                  <div class=\"flex justify-between text-xs font-black tracking-widest\" data-kid=\"299\">\n                    <span data-kid=\"300\">AI PROCESSING LOAD</span>\n                    <span data-kid=\"301\">94%</span>\n                  </div>\n                  <div class=\"h-4 border-2 border-white bg-white/10 p-0.5\" data-kid=\"302\">\n                    <div class=\"h-full bg-white w-[94%]\" data-kid=\"303\"></div>\n                  </div>\n               </div>\n               <div class=\"space-y-2\" data-kid=\"304\">\n                <div class=\"flex justify-between text-xs font-black tracking-widest\" data-kid=\"305\">\n                  <span data-kid=\"306\">STORAGE AVAILABILITY</span>\n                  <span data-kid=\"307\">42%</span>\n                </div>\n                <div class=\"h-4 border-2 border-white bg-white/10 p-0.5\" data-kid=\"308\">\n                  <div class=\"h-full bg-indigo-500 w-[42%]\" data-kid=\"309\"></div>\n                </div>\n              </div>\n              <div class=\"space-y-2\" data-kid=\"310\">\n                <div class=\"flex justify-between text-xs font-black tracking-widest\" data-kid=\"311\">\n                  <span data-kid=\"312\">USER CONVERSION</span>\n                  <span data-kid=\"313\">12%</span>\n                </div>\n                <div class=\"h-4 border-2 border-white bg-white/10 p-0.5\" data-kid=\"314\">\n                  <div class=\"h-full bg-emerald-400 w-[12%]\" data-kid=\"315\"></div>\n                </div>\n              </div>\n            </div>\n            <div class=\"mt-12 p-4 bg-white/10 border-2 border-white/20 italic text-sm\" data-kid=\"316\">\n              <span class=\"text-indigo-400 font-black\" data-kid=\"317\">WARNING:</span> Heat spike detected in Frankfurt DC-12. Rerouting traffic to Paris DC-03...\n            </div>\n          </div>\n        </div>\n      </div>\n\n    </div>\n  </main>\n</div>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"318\"></script>\n<script data-kid=\"319\">\n  document.addEventListener('DOMContentLoaded', () => {\n    const buttons = document.querySelectorAll('#variant-switcher button');\n    const contents = document.querySelectorAll('.variant-content');\n    const mainContent = document.getElementById('main-content');\n    const sidebar = document.getElementById('sidebar');\n\n    const themes = {\n      1: { bg: '#0f172a', text: '#f8fafc', sidebar: '#0f172a', sidebarText: '#94a3b8' },\n      2: { bg: '#f8fafc', text: '#0f172a', sidebar: '#ffffff', sidebarText: '#64748b' },\n      3: { bg: '#ffffff', text: '#0f172a', sidebar: '#0f172a', sidebarText: '#94a3b8' }\n    };\n\n    buttons.forEach(btn => {\n      btn.addEventListener('click', () => {\n        const variant = btn.getAttribute('data-variant');\n\n        // Update Button Styles\n        buttons.forEach(b => {\n          b.classList.remove('bg-indigo-600', 'text-white');\n          b.classList.add('text-slate-400');\n        });\n        btn.classList.add('bg-indigo-600', 'text-white');\n        btn.classList.remove('text-slate-400');\n\n        // Switch Content with GSAP\n        const activeContent = document.querySelector('.variant-content.active');\n        const nextContent = document.getElementById(`variant-${variant}`);\n\n        if(activeContent === nextContent) return;\n\n        gsap.to(activeContent, {\n          opacity: 0,\n          y: 10,\n          duration: 0.2,\n          ease: \"power2.in\",\n          onComplete: () => {\n            activeContent.classList.remove('active');\n            nextContent.classList.add('active');\n\n            // Change Page Theme with smooth GSAP transition\n            const theme = themes[variant];\n            gsap.to(mainContent, { \n              backgroundColor: theme.bg, \n              color: theme.text, \n              duration: 0.5,\n              ease: \"sine.inOut\" \n            });\n\n            gsap.fromTo(nextContent, { opacity: 0, y: -10 }, { opacity: 1, y: 0, duration: 0.4, ease: \"power2.out\" });\n          }\n        });\n      });\n    });\n\n    // Initial Entrance\n    gsap.from(\".surface-obsidian\", {\n      opacity: 0,\n      y: 30,\n      stagger: 0.08,\n      duration: 1.2,\n      ease: \"expo.out\"\n    });\n  });\n</script>\n",
