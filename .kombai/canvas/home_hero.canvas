      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap');\n\n  :root {\n    --color-accent: #E5AA70;\n    --color-accent-hover: #D49960;\n    --color-deep-navy: #011F5B;\n    --color-navy-light: #1A3A7A;\n    --color-glass-deep: rgba(255, 255, 255, 0.03);\n    --color-glass-light: rgba(255, 255, 255, 0.07);\n    --color-glass-border: rgba(255, 255, 255, 0.12);\n    --color-surface: #020617;\n    --font-inter: \"Inter\", sans-serif;\n    --font-dm-sans: \"DM Sans\", sans-serif;\n  }\n\n  .smart-manager-root {\n    background-color: var(--color-surface);\n    color: white;\n    font-family: var(--font-dm-sans);\n    min-height: 100vh;\n    overflow-x: clip;\n  }\n\n  /* Varied Glassmorphism */\n  .glass-panel {\n    background: var(--color-glass-deep);\n    backdrop-filter: blur(40px);\n    border: 1px solid rgba(255, 255, 255, 0.08);\n    border-radius: 2rem;\n  }\n\n  .glass-item {\n    background: var(--color-glass-light);\n    backdrop-filter: blur(20px);\n    border: 1px solid var(--color-glass-border);\n    border-radius: 1.25rem;\n    box-shadow: 0 4px 20px -5px rgba(0, 0, 0, 0.3);\n  }\n\n  .accent-button {\n    background: var(--color-accent);\n    color: var(--color-deep-navy);\n    padding: 0.75rem 1.75rem;\n    border-radius: 1rem;\n    font-weight: 800;\n    display: inline-flex;\n    align-items: center;\n    gap: 0.75rem;\n    cursor: pointer;\n    border: none;\n    transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.2s ease;\n  }\n\n  .accent-button:hover {\n    transform: translateY(-2px);\n    box-shadow: 0 12px 24px rgba(229, 170, 112, 0.3);\n  }\n\n  .voice-wave-container {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 6px;\n    height: 48px;\n  }\n\n  .wave-bar-v2 {\n    width: 5px;\n    background: linear-gradient(to top, var(--color-accent), #fff);\n    border-radius: 100px;\n    animation: wave-v2 1.5s ease-in-out infinite;\n  }\n\n  @keyframes wave-v2 {\n    0%, 100% { height: 12px; opacity: 0.3; }\n    50% { height: 48px; opacity: 1; }\n  }\n\n  .scroll-container {\n    scroll-snap-type: y mandatory;\n    height: 100vh;\n    overflow-y: scroll;\n    scrollbar-width: none;\n    -ms-overflow-style: none;\n  }\n\n  .scroll-container::-webkit-scrollbar { display: none; }\n\n  .snap-section {\n    scroll-snap-align: start;\n    height: 100vh;\n    width: 100%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding: 4rem;\n    position: relative;\n    overflow: hidden;\n  }\n\n  .nav-dot {\n    width: 8px;\n    height: 8px;\n    border-radius: 50%;\n    background: rgba(255, 255, 255, 0.15);\n    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n\n  .nav-dot.active {\n    background: var(--color-accent);\n    height: 32px;\n    border-radius: 10px;\n    box-shadow: 0 0 15px var(--color-accent);\n  }\n\n  /* Fixed AI Insight Typography */\n  .insight-quote {\n    font-family: var(--font-dm-sans);\n    font-weight: 500;\n    line-height: 1.6;\n    letter-spacing: -0.01em;\n  }\n\n  .font-inter { font-family: var(--font-inter); }\n\n  /* Utility for Hover and Active states without breaking GSAP */\n  .hover-scale:hover { transform: scale(1.02); }\n  .hover-glow:hover { border-color: var(--color-accent); }\n</style>\n\n<div class=\"smart-manager-root\" data-kid=\"1\">\n  <div class=\"scroll-container\" data-kid=\"2\">\n    \n    \n    <section id=\"variant-1\" class=\"snap-section bg-[#020617]\" data-kid=\"3\">\n      <div class=\"absolute inset-0 pointer-events-none\" data-kid=\"4\">\n        <div class=\"absolute top-0 left-0 w-full h-full bg-gradient-to-tr from-[#0a1128] via-transparent to-[#020617]\" data-kid=\"5\"></div>\n        <div class=\"absolute bottom-[-10%] left-[-5%] w-[600px] h-[600px] bg-[var(--color-navy-light)] opacity-10 blur-[150px] rounded-full\" data-kid=\"6\"></div>\n      </div>\n\n      <div class=\"max-w-7xl w-full h-full max-h-[850px] glass-panel p-2 flex gap-2 relative z-10 border-white/5 shadow-[0_0_100px_rgba(0,0,0,0.8)]\" data-kid=\"7\">\n        \n        \n        <aside class=\"w-72 bg-white/[0.02] border-r border-white/5 p-8 flex flex-col gsap-reveal-item-1\" data-kid=\"8\">\n          <div class=\"flex items-center gap-4 mb-12\" data-kid=\"9\">\n            <div class=\"w-12 h-12 bg-[var(--color-accent)] rounded-2xl flex items-center justify-center text-[var(--color-deep-navy)] shadow-inner\" data-kid=\"10\">\n              <i data-lucide=\"shopping-basket\" class=\"w-7 h-7\" data-kid=\"11\"></i>\n            </div>\n            <h1 class=\"font-inter font-black text-2xl tracking-tighter\" data-kid=\"12\">PantryPro</h1>\n          </div>\n          \n          <nav class=\"space-y-2 grow\" data-kid=\"13\">\n            <a href=\"#\" class=\"flex items-center gap-3 p-4 bg-white/5 rounded-2xl text-[var(--color-accent)] font-bold\" data-kid=\"14\">\n              <i data-lucide=\"layout-grid\" class=\"w-5 h-5\" data-kid=\"15\"></i> Dashboard\n            </a>\n            <a href=\"#\" class=\"flex items-center gap-3 p-4 text-white/40 hover:text-white hover:bg-white/[0.03] rounded-2xl transition-colors group\" data-kid=\"16\">\n              <i data-lucide=\"list-check\" class=\"w-5 h-5 group-hover:text-[var(--color-accent)] transition-colors\" data-kid=\"17\"></i> Shopping Lists\n            </a>\n            <a href=\"#\" class=\"flex items-center gap-3 p-4 text-white/40 hover:text-white hover:bg-white/[0.03] rounded-2xl transition-colors group\" data-kid=\"18\">\n              <i data-lucide=\"trending-up\" class=\"w-5 h-5 group-hover:text-[var(--color-accent)] transition-colors\" data-kid=\"19\"></i> Price Insights\n            </a>\n            <a href=\"#\" class=\"flex items-center gap-3 p-4 text-white/40 hover:text-white hover:bg-white/[0.03] rounded-2xl transition-colors group\" data-kid=\"20\">\n              <i data-lucide=\"brain-circuit\" class=\"w-5 h-5 group-hover:text-[var(--color-accent)] transition-colors\" data-kid=\"21\"></i> AI Forecasting\n            </a>\n          </nav>\n\n          <div class=\"mt-auto pt-8 border-t border-white/5\" data-kid=\"22\">\n            <div class=\"flex items-center gap-3 p-2 bg-white/5 rounded-2xl\" data-kid=\"23\">\n              <img src=\"https://i.pravatar.cc/100?u=sarah\" alt=\"User\" class=\"w-10 h-10 rounded-xl\" decoding=\"async\" loading=\"lazy\" data-kid=\"24\">\n              <div class=\"overflow-hidden\" data-kid=\"25\">\n                <p class=\"text-xs font-bold truncate\" data-kid=\"26\">Sarah Mitchell</p>\n                <p class=\"text-[10px] text-white/30 truncate\" data-kid=\"27\">Premium Family Plan</p>\n              </div>\n            </div>\n          </div>\n        </aside>\n\n        \n        <main class=\"grow p-10 flex flex-col gap-10\" data-kid=\"28\">\n          <header class=\"flex items-center justify-between gsap-reveal-item-1\" data-kid=\"29\">\n            <div data-kid=\"30\">\n              <h2 class=\"text-4xl font-black font-inter tracking-tight\" data-kid=\"31\">Active Groceries</h2>\n              <p class=\"text-sm text-white/40 mt-1 font-medium\" data-kid=\"32\">Monitoring 42 items in your smart pantry.</p>\n            </div>\n            <div class=\"flex gap-4\" data-kid=\"33\">\n              <button class=\"bg-white/5 hover:bg-white/10 px-6 py-3 rounded-xl border border-white/10 font-bold transition-colors\" data-kid=\"34\">History</button>\n              <button class=\"accent-button shadow-2xl\" data-kid=\"35\">\n                <i data-lucide=\"wand-2\" class=\"w-5 h-5\" data-kid=\"36\"></i>\n                Auto-Generate List\n              </button>\n            </div>\n          </header>\n\n          <div class=\"grid grid-cols-2 gap-6 gsap-reveal-item-1\" data-kid=\"37\">\n            \n            <div class=\"glass-item p-6 border-white/5 hover:border-white/10 transition-colors\" data-kid=\"38\">\n              <div class=\"flex justify-between items-center mb-6\" data-kid=\"39\">\n                <div class=\"flex items-center gap-3\" data-kid=\"40\">\n                  <div class=\"w-10 h-10 bg-green-500/10 rounded-xl flex items-center justify-center text-green-400\" data-kid=\"41\">\n                    <i data-lucide=\"leaf\" class=\"w-5 h-5\" data-kid=\"42\"></i>\n                  </div>\n                  <h4 class=\"font-bold text-lg\" data-kid=\"43\">Fresh Produce</h4>\n                </div>\n                <span class=\"text-xs text-white/30 font-bold\" data-kid=\"44\">12 Items</span>\n              </div>\n              <div class=\"space-y-3\" data-kid=\"45\">\n                <div class=\"flex items-center justify-between p-3 rounded-xl bg-white/5 border border-white/5\" data-kid=\"46\">\n                  <div class=\"flex items-center gap-3\" data-kid=\"47\">\n                    <div class=\"w-2 h-2 rounded-full bg-green-500 shadow-[0_0_8px_rgba(34,197,94,0.5)]\" data-kid=\"48\"></div>\n                    <span class=\"text-sm font-medium\" data-kid=\"49\">Granny Smith Apples</span>\n                  </div>\n                  <span class=\"text-xs font-bold text-white/60\" data-kid=\"50\">$4.50</span>\n                </div>\n                <div class=\"flex items-center justify-between p-3 rounded-xl bg-[var(--color-accent)]/10 border border-[var(--color-accent)]/20\" data-kid=\"51\">\n                  <div class=\"flex items-center gap-3\" data-kid=\"52\">\n                    <div class=\"w-2 h-2 rounded-full bg-red-500 animate-pulse\" data-kid=\"53\"></div>\n                    <span class=\"text-sm font-bold\" data-kid=\"54\">Hass Avocados</span>\n                  </div>\n                  <span class=\"text-[10px] font-black uppercase text-[var(--color-accent)]\" data-kid=\"55\">Low Stock</span>\n                </div>\n              </div>\n            </div>\n\n            \n            <div class=\"glass-item p-6 border-white/5 hover:border-white/10 transition-colors\" data-kid=\"56\">\n              <div class=\"flex justify-between items-center mb-6\" data-kid=\"57\">\n                <div class=\"flex items-center gap-3\" data-kid=\"58\">\n                  <div class=\"w-10 h-10 bg-blue-500/10 rounded-xl flex items-center justify-center text-blue-400\" data-kid=\"59\">\n                    <i data-lucide=\"milk\" class=\"w-5 h-5\" data-kid=\"60\"></i>\n                  </div>\n                  <h4 class=\"font-bold text-lg\" data-kid=\"61\">Dairy & Eggs</h4>\n                </div>\n                <span class=\"text-xs text-white/30 font-bold\" data-kid=\"62\">4 Items</span>\n              </div>\n              <div class=\"space-y-3\" data-kid=\"63\">\n                <div class=\"flex items-center justify-between p-3 rounded-xl bg-white/[0.08] border border-white/10\" data-kid=\"64\">\n                  <div class=\"flex items-center gap-3\" data-kid=\"65\">\n                    <div class=\"w-2 h-2 rounded-full bg-[var(--color-accent)]\" data-kid=\"66\"></div>\n                    <span class=\"text-sm font-bold\" data-kid=\"67\">Organic Whole Milk</span>\n                  </div>\n                  <span class=\"text-xs font-bold text-[var(--color-accent)]\" data-kid=\"68\">Finishes in 2d</span>\n                </div>\n                <div class=\"flex items-center justify-between p-3 rounded-xl bg-white/5 border border-white/5 opacity-50\" data-kid=\"69\">\n                  <div class=\"flex items-center gap-3\" data-kid=\"70\">\n                    <div class=\"w-2 h-2 rounded-full bg-white/20\" data-kid=\"71\"></div>\n                    <span class=\"text-sm font-medium line-through\" data-kid=\"72\">Unsalted Butter</span>\n                  </div>\n                  <span class=\"text-xs font-bold text-white/20\" data-kid=\"73\">$2.40</span>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          \n          <div class=\"mt-auto bg-white/5 border border-white/5 rounded-[1.5rem] p-8 gsap-reveal-item-1\" data-kid=\"74\">\n             <div class=\"grid grid-cols-3 gap-12\" data-kid=\"75\">\n               <div class=\"space-y-3\" data-kid=\"76\">\n                 <p class=\"text-[10px] font-black uppercase tracking-widest text-white/30\" data-kid=\"77\">Weekly Prediction</p>\n                 <p class=\"insight-quote text-sm italic opacity-80\" data-kid=\"78\">\"Your pantry will likely run out of coffee by Tuesday morning. Added to draft list.\"</p>\n               </div>\n               <div class=\"space-y-3 border-l border-white/5 pl-12\" data-kid=\"79\">\n                 <p class=\"text-[10px] font-black uppercase tracking-widest text-white/30\" data-kid=\"80\">Smart Savings</p>\n                 <p class=\"font-bold text-2xl font-inter text-green-400\" data-kid=\"81\">$18.40 <span class=\"text-xs font-medium text-white/30 ml-1\" data-kid=\"82\">saved this month</span></p>\n                 <div class=\"h-1 w-full bg-white/5 rounded-full overflow-hidden\" data-kid=\"83\">\n                   <div class=\"h-full w-2/3 bg-green-500 rounded-full\" data-kid=\"84\"></div>\n                 </div>\n               </div>\n               <div class=\"space-y-3 border-l border-white/5 pl-12\" data-kid=\"85\">\n                 <p class=\"text-[10px] font-black uppercase tracking-widest text-white/30\" data-kid=\"86\">Budget Pulse</p>\n                 <p class=\"font-bold text-2xl font-inter\" data-kid=\"87\">$142.60 <span class=\"text-xs font-medium text-white/30 ml-1\" data-kid=\"88\">/ $200.00</span></p>\n                 <div class=\"h-1 w-full bg-white/5 rounded-full overflow-hidden\" data-kid=\"89\">\n                   <div class=\"h-full w-3/4 bg-[var(--color-accent)] rounded-full\" data-kid=\"90\"></div>\n                 </div>\n               </div>\n             </div>\n          </div>\n        </main>\n\n        \n        <aside class=\"w-80 bg-white/[0.04] border-l border-white/5 p-8 flex flex-col gap-8 gsap-reveal-item-1\" data-kid=\"91\">\n          <div class=\"glass-item p-8 flex flex-col items-center text-center gap-6 bg-white/[0.04] border-white/10 shadow-inner\" data-kid=\"92\">\n            <div class=\"relative\" data-kid=\"93\">\n              <div class=\"absolute inset-0 bg-[var(--color-accent)]/30 blur-[40px] rounded-full animate-pulse scale-150\" data-kid=\"94\"></div>\n              <div class=\"w-20 h-20 bg-[var(--color-accent)] rounded-full flex items-center justify-center text-[var(--color-deep-navy)] shadow-[0_20px_40px_rgba(229,170,112,0.4)] relative z-10\" data-kid=\"95\">\n                <i data-lucide=\"mic\" class=\"w-10 h-10\" data-kid=\"96\"></i>\n              </div>\n            </div>\n            <div class=\"space-y-1\" data-kid=\"97\">\n              <h4 class=\"font-inter font-black text-2xl tracking-tighter\" data-kid=\"98\">Voice Assistant</h4>\n              <p class=\"text-[10px] text-white/40 uppercase font-black tracking-widest\" data-kid=\"99\">\"ADD BABY SPINACH\"</p>\n            </div>\n            <div class=\"voice-wave-container mb-2\" data-kid=\"100\">\n              <div class=\"wave-bar-v2\" style=\"animation-delay: 0.1s\" data-kid=\"101\"></div>\n              <div class=\"wave-bar-v2\" style=\"animation-delay: 0.3s\" data-kid=\"102\"></div>\n              <div class=\"wave-bar-v2\" style=\"animation-delay: 0.2s\" data-kid=\"103\"></div>\n              <div class=\"wave-bar-v2\" style=\"animation-delay: 0.5s\" data-kid=\"104\"></div>\n              <div class=\"wave-bar-v2\" style=\"animation-delay: 0.4s\" data-kid=\"105\"></div>\n            </div>\n          </div>\n\n          <div class=\"space-y-4\" data-kid=\"106\">\n            <h4 class=\"text-[10px] font-black uppercase tracking-widest text-white/30\" data-kid=\"107\">Quick Price Alerts</h4>\n            <div class=\"space-y-3\" data-kid=\"108\">\n              <div class=\"glass-item p-5 bg-red-500/[0.03] border-red-500/20 flex items-center gap-4 hover:bg-red-500/[0.05] transition-colors cursor-pointer border-l-4 border-l-red-500/40\" data-kid=\"109\">\n                <div class=\"w-10 h-10 rounded-xl bg-red-500/10 flex items-center justify-center shrink-0\" data-kid=\"110\">\n                  <i data-lucide=\"trending-up\" class=\"w-5 h-5 text-red-400\" data-kid=\"111\"></i>\n                </div>\n                <div class=\"overflow-hidden text-left\" data-kid=\"112\">\n                  <p class=\"text-sm font-black truncate\" data-kid=\"113\">Butter Spike</p>\n                  <p class=\"text-[11px] text-white/30 font-bold\" data-kid=\"114\">+12% vs week</p>\n                </div>\n              </div>\n              <div class=\"glass-item p-5 bg-green-500/[0.03] border-green-500/20 flex items-center gap-4 hover:bg-green-500/[0.05] transition-colors cursor-pointer border-l-4 border-l-green-500/40\" data-kid=\"115\">\n                <div class=\"w-10 h-10 rounded-xl bg-green-500/10 flex items-center justify-center shrink-0\" data-kid=\"116\">\n                  <i data-lucide=\"trending-down\" class=\"w-5 h-5 text-green-400\" data-kid=\"117\"></i>\n                </div>\n                <div class=\"overflow-hidden text-left\" data-kid=\"118\">\n                  <p class=\"text-sm font-black truncate\" data-kid=\"119\">Avocado Promo</p>\n                  <p class=\"text-[11px] text-white/30 font-bold\" data-kid=\"120\">-15% local avg.</p>\n                </div>\n              </div>\n            </div>\n          </div>\n        </aside>\n      </div>\n    </section>\n\n    \n    <section id=\"variant-2\" class=\"snap-section bg-[#020617]\" data-kid=\"121\">\n      <div class=\"absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--color-navy-light)_0%,_transparent_70%)] opacity-30 pointer-events-none\" data-kid=\"122\"></div>\n      \n      <div class=\"max-w-4xl w-full text-center space-y-20 relative z-10\" data-kid=\"123\">\n        <div class=\"gsap-reveal-item-2\" data-kid=\"124\">\n          <span class=\"px-4 py-1.5 bg-white/10 rounded-full text-[10px] font-black uppercase tracking-[0.2em] border border-white/5 mb-8 inline-block\" data-kid=\"125\">Ambient Mode</span>\n          <h2 class=\"text-[7rem] font-black font-inter tracking-tighter leading-[0.9] text-transparent bg-clip-text bg-gradient-to-b from-white to-white/20\" data-kid=\"126\">\n            \"Milk finishes <br data-kid=\"127\"> in 2 days.\"\n          </h2>\n          <p class=\"text-xl text-white/40 font-medium max-w-2xl mx-auto mt-8\" data-kid=\"128\">Smart inventory management designed for hands-free kitchen interaction.</p>\n        </div>\n\n        <div class=\"flex justify-center gsap-reveal-item-2\" data-kid=\"129\">\n          <div class=\"w-64 h-64 rounded-full glass-panel flex items-center justify-center cursor-pointer relative group\" data-kid=\"130\">\n             <div class=\"absolute inset-[-20px] rounded-full border border-[var(--color-accent)]/10 animate-[ping_3s_linear_infinite] opacity-30\" data-kid=\"131\"></div>\n             <div class=\"absolute inset-[-40px] rounded-full border border-[var(--color-accent)]/5 animate-[ping_4s_linear_infinite] opacity-20\" data-kid=\"132\"></div>\n             <i data-lucide=\"mic\" class=\"w-24 h-24 text-[var(--color-accent)] group-hover:scale-110 transition-transform duration-500\" data-kid=\"133\"></i>\n          </div>\n        </div>\n\n        <div class=\"grid grid-cols-3 gap-6 gsap-reveal-item-2\" data-kid=\"134\">\n          <div class=\"glass-item p-8 bg-white/[0.03] border-white/5 hover:border-white/20 cursor-pointer\" data-kid=\"135\">\n            <h4 class=\"font-inter font-black text-xl mb-3\" data-kid=\"136\">Auto-Generate</h4>\n            <p class=\"text-xs text-white/40 leading-relaxed\" data-kid=\"137\">Synthesizing a weekly grocery list from your consumption trends.</p>\n          </div>\n          <div class=\"glass-item p-8 bg-white/[0.03] border-white/5 hover:border-white/20 cursor-pointer\" data-kid=\"138\">\n            <h4 class=\"font-inter font-black text-xl mb-3\" data-kid=\"139\">Refill Alert</h4>\n            <p class=\"text-xs text-white/40 leading-relaxed\" data-kid=\"140\">Predictive replenishment suggestions for high-velocity items.</p>\n          </div>\n          <div class=\"glass-item p-8 bg-white/[0.03] border-white/5 hover:border-white/20 cursor-pointer\" data-kid=\"141\">\n            <h4 class=\"font-inter font-black text-xl mb-3\" data-kid=\"142\">Price Shield</h4>\n            <p class=\"text-xs text-white/40 leading-relaxed\" data-kid=\"143\">Real-time alerts when tracked essentials go on promotion.</p>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section id=\"variant-3\" class=\"snap-section bg-[#020617]\" data-kid=\"144\">\n      <div class=\"max-w-7xl w-full grid grid-cols-12 gap-12 relative z-10\" data-kid=\"145\">\n        <header class=\"col-span-12 gsap-reveal-item-3\" data-kid=\"146\">\n          <h2 class=\"text-6xl font-black font-inter tracking-tight mb-4\" data-kid=\"147\">Master Inventory</h2>\n          <div class=\"h-1 w-24 bg-[var(--color-accent)] rounded-full\" data-kid=\"148\"></div>\n        </header>\n\n        <aside class=\"col-span-4 space-y-4 gsap-reveal-item-3\" data-kid=\"149\">\n          <div class=\"p-6 bg-[var(--color-accent)] text-[var(--color-deep-navy)] rounded-3xl flex items-center justify-between font-black shadow-[0_20px_50px_rgba(229,170,112,0.2)]\" data-kid=\"150\">\n            <div class=\"flex items-center gap-4\" data-kid=\"151\">\n              <i data-lucide=\"leaf\" class=\"w-7 h-7\" data-kid=\"152\"></i>\n              <span class=\"text-lg\" data-kid=\"153\">Produce</span>\n            </div>\n            <span class=\"bg-black/10 px-4 py-1.5 rounded-xl text-sm\" data-kid=\"154\">12</span>\n          </div>\n          <div class=\"p-6 glass-item bg-white/[0.02] border-white/5 flex items-center justify-between text-white/40 hover:text-white hover:bg-white/5 transition-colors cursor-pointer\" data-kid=\"155\">\n            <div class=\"flex items-center gap-4\" data-kid=\"156\">\n              <i data-lucide=\"milk\" class=\"w-7 h-7\" data-kid=\"157\"></i>\n              <span class=\"text-lg\" data-kid=\"158\">Dairy & Eggs</span>\n            </div>\n            <span class=\"text-sm\" data-kid=\"159\">4</span>\n          </div>\n          <div class=\"p-6 glass-item bg-white/[0.02] border-white/5 flex items-center justify-between text-white/40 hover:text-white hover:bg-white/5 transition-colors cursor-pointer\" data-kid=\"160\">\n            <div class=\"flex items-center gap-4\" data-kid=\"161\">\n              <i data-lucide=\"beef\" class=\"w-7 h-7\" data-kid=\"162\"></i>\n              <span class=\"text-lg\" data-kid=\"163\">Meat & Seafood</span>\n            </div>\n            <span class=\"text-sm\" data-kid=\"164\">6</span>\n          </div>\n          <div class=\"p-6 glass-item bg-white/[0.02] border-white/5 flex items-center justify-between text-white/40 hover:text-white hover:bg-white/5 transition-colors cursor-pointer\" data-kid=\"165\">\n            <div class=\"flex items-center gap-4\" data-kid=\"166\">\n              <i data-lucide=\"coffee\" class=\"w-7 h-7\" data-kid=\"167\"></i>\n              <span class=\"text-lg\" data-kid=\"168\">Pantry Staples</span>\n            </div>\n            <span class=\"text-sm\" data-kid=\"169\">18</span>\n          </div>\n        </aside>\n\n        <main class=\"col-span-8 glass-panel p-12 flex flex-col min-h-[600px] border-white/5 gsap-reveal-item-3\" data-kid=\"170\">\n          <div class=\"flex items-center justify-between mb-12\" data-kid=\"171\">\n             <h3 class=\"text-4xl font-black font-inter tracking-tighter\" data-kid=\"172\">Produce Essentials</h3>\n             <div class=\"flex gap-4\" data-kid=\"173\">\n               <button class=\"w-14 h-14 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-white/60 hover:text-white hover:bg-white/10 transition-colors\" data-kid=\"174\">\n                 <i data-lucide=\"search\" class=\"w-6 h-6\" data-kid=\"175\"></i>\n               </button>\n               <button class=\"w-14 h-14 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-white/60 hover:text-white hover:bg-white/10 transition-colors\" data-kid=\"176\">\n                 <i data-lucide=\"sliders-horizontal\" class=\"w-6 h-6\" data-kid=\"177\"></i>\n               </button>\n             </div>\n          </div>\n\n          <div class=\"space-y-4 mb-auto\" data-kid=\"178\">\n            <div class=\"glass-item p-6 flex items-center justify-between border-white/10 hover:border-white/20 transition-colors group cursor-pointer\" data-kid=\"179\">\n              <div class=\"flex items-center gap-6\" data-kid=\"180\">\n                <div class=\"w-8 h-8 rounded-xl border-2 border-white/10 flex items-center justify-center group-hover:border-[var(--color-accent)]/50 transition-colors\" data-kid=\"181\"></div>\n                <div data-kid=\"182\">\n                  <h4 class=\"text-xl font-bold\" data-kid=\"183\">Organic Bananas</h4>\n                  <p class=\"text-sm text-white/40 font-medium\" data-kid=\"184\">Whole Foods Market • $1.99 / bundle</p>\n                </div>\n              </div>\n              <div class=\"flex items-center gap-4\" data-kid=\"185\">\n                 <span class=\"px-3 py-1 bg-green-500/10 text-green-400 text-[10px] font-black uppercase rounded-lg border border-green-500/20\" data-kid=\"186\">Optimal Price</span>\n                 <i data-lucide=\"more-horizontal\" class=\"w-6 h-6 text-white/20\" data-kid=\"187\"></i>\n              </div>\n            </div>\n\n            <div class=\"glass-item p-6 flex items-center justify-between border-[var(--color-accent)]/30 bg-white/[0.08] group cursor-pointer\" data-kid=\"188\">\n              <div class=\"flex items-center gap-6\" data-kid=\"189\">\n                <div class=\"w-8 h-8 rounded-xl border-2 border-[var(--color-accent)] flex items-center justify-center bg-[var(--color-accent)]/10\" data-kid=\"190\">\n                  <i data-lucide=\"check\" class=\"w-5 h-5 text-[var(--color-accent)]\" data-kid=\"191\"></i>\n                </div>\n                <div data-kid=\"192\">\n                  <h4 class=\"text-xl font-bold\" data-kid=\"193\">Hass Avocados</h4>\n                  <p class=\"text-sm text-red-400 font-bold\" data-kid=\"194\">Predicted stockout: Tomorrow Morning</p>\n                </div>\n              </div>\n              <div class=\"flex items-center gap-4\" data-kid=\"195\">\n                 <span class=\"px-3 py-1 bg-red-500/10 text-red-400 text-[10px] font-black uppercase rounded-lg border border-red-500/20\" data-kid=\"196\">Critical Stock</span>\n                 <i data-lucide=\"more-horizontal\" class=\"w-6 h-6 text-white/20\" data-kid=\"197\"></i>\n              </div>\n            </div>\n          </div>\n\n          <footer class=\"mt-12 pt-12 border-t border-white/10 flex items-center justify-between\" data-kid=\"198\">\n            <div data-kid=\"199\">\n              <p class=\"text-[10px] font-black uppercase tracking-[0.2em] text-white/30 mb-1\" data-kid=\"200\">Estimated Cart Total</p>\n              <h4 class=\"text-6xl font-black font-inter text-[var(--color-accent)]\" data-kid=\"201\">$64.20</h4>\n            </div>\n            <button class=\"accent-button px-12 py-6 rounded-3xl text-xl shadow-[0_25px_60px_rgba(229,170,112,0.3)]\" data-kid=\"202\">\n              Proceed to Order\n              <i data-lucide=\"arrow-right\" class=\"w-6 h-6\" data-kid=\"203\"></i>\n            </button>\n          </footer>\n        </main>\n      </div>\n    </section>\n\n  </div>\n\n  \n  <nav class=\"fixed right-12 top-1/2 -translate-y-1/2 z-50 flex flex-col gap-6\" data-kid=\"204\">\n    <a href=\"#variant-1\" class=\"nav-dot active\" title=\"Variant 1\" data-kid=\"205\"></a>\n    <a href=\"#variant-2\" class=\"nav-dot\" title=\"Variant 2\" data-kid=\"206\"></a>\n    <a href=\"#variant-3\" class=\"nav-dot\" title=\"Variant 3\" data-kid=\"207\"></a>\n  </nav>\n</div>\n\n<script src=\"https://unpkg.com/lucide@latest\" data-kid=\"208\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"209\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"210\"></script>\n\n<script data-kid=\"211\">\n  gsap.registerPlugin(ScrollTrigger);\n  lucide.createIcons();\n\n  // Entrance animations - using single classes to avoid > combinators\n  gsap.from(\".gsap-reveal-item-1\", {\n    y: 60,\n    opacity: 0,\n    duration: 1.2,\n    stagger: 0.1,\n    ease: \"power4.out\",\n    scrollTrigger: {\n      trigger: \"#variant-1\",\n      start: \"top 30%\",\n    }\n  });\n\n  gsap.from(\".gsap-reveal-item-2\", {\n    y: 80,\n    opacity: 0,\n    duration: 1.5,\n    stagger: 0.2,\n    ease: \"expo.out\",\n    scrollTrigger: {\n      trigger: \"#variant-2\",\n      start: \"top 30%\",\n    }\n  });\n\n  gsap.from(\".gsap-reveal-item-3\", {\n    x: -100,\n    opacity: 0,\n    duration: 1.2,\n    stagger: 0.2,\n    ease: \"power3.out\",\n    scrollTrigger: {\n      trigger: \"#variant-3\",\n      start: \"top 30%\",\n    }\n  });\n\n  // Intersection Observer for Nav Dots\n  const sections = document.querySelectorAll('section');\n  const dots = document.querySelectorAll('.nav-dot');\n\n  const observer = new IntersectionObserver((entries) => {\n    entries.forEach(entry => {\n      if (entry.isIntersecting) {\n        dots.forEach(dot => dot.classList.remove('active'));\n        const activeDot = document.querySelector(`.nav-dot[href=\"#${entry.target.id}\"]`);\n        if (activeDot) activeDot.classList.add('active');\n      }\n    });\n  }, { threshold: 0.5 });\n\n  sections.forEach(s => observer.observe(s));\n\n  // Smooth click\n  dots.forEach(dot => {\n    dot.addEventListener('click', (e) => {\n      e.preventDefault();\n      document.querySelector(dot.getAttribute('href')).scrollIntoView({ behavior: 'smooth' });\n    });\n  });\n</script>\n",
