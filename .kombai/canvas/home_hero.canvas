ition-all\" data-kid=\"150\"><i class=\"fa-solid fa-eye\" data-kid=\"151\"></i></button>\n                                        <button class=\"p-2 hover:bg-white hover:shadow-sm rounded-lg text-slate-400 hover:text-indigo-600 transition-all\" data-kid=\"152\"><i class=\"fa-solid fa-download\" data-kid=\"153\"></i></button>\n                                    </div>\n                                </td>\n                            </tr>\n                            \n                            <tr class=\"hover:bg-indigo-50/30 transition-colors group\" data-kid=\"154\">\n                                <td class=\"px-8 py-5\" data-kid=\"155\">\n                                    <div class=\"flex items-center gap-4\" data-kid=\"156\">\n                                        <div class=\"w-10 h-10 bg-rose-100 text-rose-600 rounded-xl flex items-center justify-center text-sm\" data-kid=\"157\">\n                                            <i class=\"fa-solid fa-car-burst\" data-kid=\"158\"></i>\n                                        </div>\n                                        <div data-kid=\"159\">\n                                            <div class=\"text-sm font-bold text-slate-900\" data-kid=\"160\">Car Insurance - Honda City</div>\n                                            <div class=\"text-xs text-slate-400\" data-kid=\"161\">#POL-88219</div>\n                                        </div>\n                                    </div>\n                                </td>\n                                <td class=\"px-8 py-5\" data-kid=\"162\">\n                                    <span class=\"px-3 py-1 bg-slate-100 text-slate-600 text-[10px] font-bold uppercase rounded-full tracking-wider\" data-kid=\"163\">Insurance</span>\n                                </td>\n                                <td class=\"px-8 py-5\" data-kid=\"164\">\n                                    <div class=\"text-sm text-slate-600\" data-kid=\"165\">Sep 05, 2023</div>\n                                </td>\n                                <td class=\"px-8 py-5\" data-kid=\"166\">\n                                    <div class=\"flex items-center gap-2\" data-kid=\"167\">\n                                        <span class=\"w-2 h-2 rounded-full bg-amber-500\" data-kid=\"168\"></span>\n                                        <span class=\"text-xs font-semibold text-slate-700\" data-kid=\"169\">Expiring Soon</span>\n                                    </div>\n                                </td>\n                                <td class=\"px-8 py-5 text-right\" data-kid=\"170\">\n                                    <div class=\"flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"171\">\n                                        <button class=\"p-2 hover:bg-white hover:shadow-sm rounded-lg text-slate-400 hover:text-indigo-600 transition-all\" data-kid=\"172\"><i class=\"fa-solid fa-eye\" data-kid=\"173\"></i></button>\n                                        <button class=\"p-2 hover:bg-white hover:shadow-sm rounded-lg text-slate-400 hover:text-indigo-600 transition-all\" data-kid=\"174\"><i class=\"fa-solid fa-download\" data-kid=\"175\"></i></button>\n                                    </div>\n                                </td>\n                            </tr>\n                        </tbody>\n                    </table>\n                </div>\n            </div>\n        </div>\n\n        \n        <div id=\"categories-view\" class=\"view-content\" data-kid=\"176\">\n            <div class=\"grid grid-cols-12 gap-8\" data-kid=\"177\">\n                \n                <div class=\"col-span-12 lg:col-span-3\" data-kid=\"178\">\n                    <div class=\"bg-white p-4 rounded-3xl border border-slate-200 flex flex-col gap-1.5 shadow-sm\" data-kid=\"179\">\n                        <button class=\"flex items-center justify-between px-4 py-3 bg-indigo-600 text-white rounded-2xl font-bold text-sm transition-all shadow-md shadow-indigo-100\" data-kid=\"180\">\n                            <span class=\"flex items-center gap-3\" data-kid=\"181\">\n                                <i class=\"fa-solid fa-grid-4\" data-kid=\"182\"></i> All Categories\n                            </span>\n                            <span class=\"text-[10px] bg-indigo-100 px-1.5 py-0.5 rounded-md\" data-kid=\"183\">12</span>\n                        </button>\n                        <button class=\"flex items-center justify-between px-4 py-3 text-slate-600 hover:bg-slate-50 hover:translate-x-1 rounded-2xl font-semibold text-sm transition-all\" data-kid=\"184\">\n                            <span class=\"flex items-center gap-3\" data-kid=\"185\">\n                                <i class=\"fa-solid fa-id-card-clip text-indigo-400\" data-kid=\"186\"></i> Identity Cards\n                            </span>\n                            <span class=\"text-[10px] bg-slate-100 px-1.5 py-0.5 rounded-md text-slate-400\" data-kid=\"187\">4</span>\n                        </button>\n                        <button class=\"flex items-center justify-between px-4 py-3 text-slate-600 hover:bg-slate-50 hover:translate-x-1 rounded-2xl font-semibold text-sm transition-all\" data-kid=\"188\">\n                            <span class=\"flex items-center gap-3\" data-kid=\"189\">\n                                <i class=\"fa-solid fa-umbrella text-emerald-400\" data-kid=\"190\"></i> Insurance\n                            </span>\n                            <span class=\"text-[10px] bg-slate-100 px-1.5 py-0.5 rounded-md text-slate-400\" data-kid=\"191\">3</span>\n                        </button>\n                        <button class=\"flex items-center justify-between px-4 py-3 text-slate-600 hover:bg-slate-50 hover:translate-x-1 rounded-2xl font-semibold text-sm transition-all\" data-kid=\"192\">\n                            <span class=\"flex items-center gap-3\" data-kid=\"193\">\n                                <i class=\"fa-solid fa-award text-amber-400\" data-kid=\"194\"></i> Warranties\n                            </span>\n                            <span class=\"text-[10px] bg-slate-100 px-1.5 py-0.5 rounded-md text-slate-400\" data-kid=\"195\">5</span>\n                        </button>\n                        <hr class=\"my-2 border-slate-100\" data-kid=\"196\">\n                        <button class=\"flex items-center justify-between px-4 py-3 text-slate-400 hover:text-slate-600 hover:bg-slate-50 rounded-2xl font-semibold text-sm transition-all\" data-kid=\"197\">\n                            <span class=\"flex items-center gap-3\" data-kid=\"198\">\n                                <i class=\"fa-solid fa-trash-can\" data-kid=\"199\"></i> Trash\n                            </span>\n                        </button>\n                    </div>\n\n                    <div class=\"mt-6 bg-gradient-to-br from-indigo-600 to-purple-700 p-6 rounded-3xl text-white relative overflow-hidden shadow-xl shadow-indigo-200\" data-kid=\"200\">\n                        <div class=\"relative z-10\" data-kid=\"201\">\n                            <h4 class=\"text-sm font-bold mb-1\" data-kid=\"202\">Vault Storage</h4>\n                            <p class=\"text-[10px] opacity-70 mb-4 uppercase tracking-widest\" data-kid=\"203\">2.4 GB of 5 GB used</p>\n                            <div class=\"w-full h-1.5 bg-white/20 rounded-full mb-4 overflow-hidden\" data-kid=\"204\">\n                                <div class=\"w-[48%] h-full bg-white rounded-full\" data-kid=\"205\"></div>\n                            </div>\n                            <button class=\"w-full py-2 bg-white/10 hover:bg-white/20 text-xs font-bold rounded-xl transition-all border border-white/10\" data-kid=\"206\">Upgrade Plan</button>\n                        </div>\n                        <i class=\"fa-solid fa-cloud absolute -right-4 -bottom-4 text-8xl opacity-10\" data-kid=\"207\"></i>\n                    </div>\n                </div>\n\n                \n                <div class=\"col-span-12 lg:col-span-9\" data-kid=\"208\">\n                    <div class=\"grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6\" data-kid=\"209\">\n                        \n                        <div class=\"bg-white p-5 rounded-3xl border border-slate-200 hover:shadow-xl hover:shadow-slate-200/50 transition-all group\" data-kid=\"210\">\n                            <div class=\"flex items-start justify-between mb-4\" data-kid=\"211\">\n                                <div class=\"w-12 h-12 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center text-xl group-hover:scale-110 transition-transform\" data-kid=\"212\">\n                                    <i class=\"fa-solid fa-file-invoice\" data-kid=\"213\"></i>\n                                </div>\n                                <div class=\"text-right\" data-kid=\"214\">\n                                    <span class=\"text-[10px] text-slate-400 font-bold uppercase tracking-tighter\" data-kid=\"215\">Identity</span>\n                                </div>\n                            </div>\n                            <h5 class=\"text-sm font-bold text-slate-900 mb-1\" data-kid=\"216\">PAN Card</h5>\n                            <p class=\"text-xs text-slate-500 mb-4\" data-kid=\"217\">Last updated 2 days ago</p>\n                            <div class=\"flex items-center justify-between pt-4 border-t border-slate-50\" data-kid=\"218\">\n                                <span class=\"text-[10px] font-bold text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded uppercase\" data-kid=\"219\">Verified</span>\n                                <button class=\"text-slate-300 hover:text-indigo-600\" data-kid=\"220\"><i class=\"fa-solid fa-share-nodes text-xs\" data-kid=\"221\"></i></button>\n                            </div>\n                        </div>\n\n                        \n                        <div class=\"bg-white p-5 rounded-3xl border border-slate-200 hover:shadow-xl hover:shadow-slate-200/50 transition-all group\" data-kid=\"222\">\n                            <div class=\"flex items-start justify-between mb-4\" data-kid=\"223\">\n                                <div class=\"w-12 h-12 bg-amber-50 text-amber-600 rounded-2xl flex items-center justify-center text-xl group-hover:scale-110 transition-transform\" data-kid=\"224\">\n                                    <i class=\"fa-solid fa-file-shield\" data-kid=\"225\"></i>\n                                </div>\n                                <div class=\"text-right\" data-kid=\"226\">\n                                    <span class=\"text-[10px] text-slate-400 font-bold uppercase tracking-tighter\" data-kid=\"227\">Warranty</span>\n                                </div>\n                            </div>\n                            <h5 class=\"text-sm font-bold text-slate-900 mb-1\" data-kid=\"228\">Samsung OLED TV</h5>\n                            <p class=\"text-xs text-slate-500 mb-4\" data-kid=\"229\">Valid until Mar 2026</p>\n                            <div class=\"flex items-center justify-between pt-4 border-t border-slate-50\" data-kid=\"230\">\n                                <span class=\"text-[10px] font-bold text-amber-600 bg-amber-50 px-2 py-0.5 rounded uppercase\" data-kid=\"231\">In Protection</span>\n                                <button class=\"text-slate-300 hover:text-indigo-600\" data-kid=\"232\"><i class=\"fa-solid fa-share-nodes text-xs\" data-kid=\"233\"></i></button>\n                            </div>\n                        </div>\n\n                        \n                        <button class=\"bg-slate-50 border-2 border-dashed border-slate-200 rounded-3xl p-5 flex flex-col items-center justify-center gap-3 text-slate-400 hover:border-indigo-300 hover:bg-indigo-50/30 hover:text-indigo-500 transition-all group\" data-kid=\"234\">\n                            <div class=\"w-12 h-12 rounded-full border border-slate-200 flex items-center justify-center text-xl group-hover:border-indigo-200 group-hover:scale-110 transition-all\" data-kid=\"235\">\n                                <i class=\"fa-solid fa-plus\" data-kid=\"236\"></i>\n                            </div>\n                            <span class=\"text-xs font-bold uppercase tracking-widest\" data-kid=\"237\">Add Document</span>\n                        </button>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </main>\n\n    \n    <script type=\"module\" data-kid=\"238\">\n        import { animate } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n\n        const btns = document.querySelectorAll('.view-btn');\n        const contents = document.querySelectorAll('.view-content');\n\n        btns.forEach(btn => {\n            btn.addEventListener('click', () => {\n                const targetView = btn.getAttribute('data-view');\n\n                // Update Button Styles\n                btns.forEach(b => {\n                    b.classList.remove('active', 'bg-white', 'shadow-sm', 'text-indigo-600');\n                    b.classList.add('text-slate-600');\n                });\n                btn.classList.add('active', 'bg-white', 'shadow-sm', 'text-indigo-600');\n                btn.classList.remove('text-slate-600');\n\n                // Switch Content with animation\n                contents.forEach(content => {\n                    if (content.classList.contains('active')) {\n                        animate(content, { opacity: 0, y: 10 }, { duration: 0.2 }).finished.then(() => {\n                            content.classList.remove('active');\n                            \n                            const newActive = document.getElementById(`${targetView}-view`);\n                            newActive.classList.add('active');\n                            animate(newActive, { opacity: [0, 1], y: [10, 0] }, { duration: 0.4, easing: \"ease-out\" });\n                        });\n                    }\n                });\n            });\n        });\n\n        // Initialize view\n        animate(\".view-content.active\", { opacity: [0, 1], y: [20, 0] }, { duration: 0.6, easing: \"ease-out\" });\n        \n        // Stagger grid items\n        animate(\"#grid-view > div > div\", { opacity: [0, 1], scale: [0.95, 1] }, { \n            delay: (i) => i * 0.1,\n            duration: 0.5\n        });\n    </script>\n</div>\n",
