      "html": "<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"0\">\n<style data-kid=\"1\">\n  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap');\n\n  :root {\n    --color-accent: #E5AA70;\n    --color-deep-navy: #011F5B;\n    --color-navy-light: #1A3A7A;\n    --color-glass-bg: rgba(255, 255, 255, 0.45);\n    --color-glass-border: rgba(255, 255, 255, 0.5);\n    --color-surface: #F5F5F5;\n  }\n\n  body {\n    background-color: var(--color-surface);\n    color: var(--color-deep-navy);\n    font-family: 'DM Sans', sans-serif;\n    margin: 0;\n    overflow-x: hidden;\n  }\n\n  h1, h2, h3, h4, h5, h6 {\n    font-family: 'Inter', sans-serif;\n  }\n\n  .glass-card {\n    background: var(--color-glass-bg);\n    backdrop-filter: blur(24px);\n    -webkit-backdrop-filter: blur(24px);\n    border: 1px solid var(--color-glass-border);\n    box-shadow: 0 12px 48px -10px rgba(1, 31, 91, 0.08);\n  }\n\n  .sidebar-blur {\n    background: rgba(255, 255, 255, 0.6);\n    backdrop-filter: blur(20px);\n    border-right: 1px solid rgba(1, 31, 91, 0.05);\n  }\n\n  .orb-glow {\n    background: radial-gradient(circle at center, var(--color-accent) 0%, transparent 70%);\n    filter: blur(40px);\n    opacity: 0.2;\n  }\n\n  .scrollbar-hidden::-webkit-scrollbar {\n    display: none;\n  }\n</style>\n\n<div class=\"flex min-h-screen relative overflow-hidden\" data-kid=\"2\">\n  \n  <div class=\"absolute top-[-10%] right-[-5%] w-[600px] h-[600px] orb-glow pointer-events-none\" data-kid=\"3\"></div>\n  <div class=\"absolute bottom-[-10%] left-[-5%] w-[400px] h-[400px] orb-glow pointer-events-none\" style=\"background: radial-gradient(circle at center, #1A3A7A 0%, transparent 70%);\" data-kid=\"4\"></div>\n\n  \n  <aside class=\"w-72 sidebar-blur h-screen sticky top-0 z-50 p-8 flex flex-col justify-between shrink-0\" data-kid=\"5\">\n    <div class=\"space-y-12\" data-kid=\"6\">\n      <div class=\"flex items-center gap-3\" data-kid=\"7\">\n        <div class=\"w-12 h-12 bg-deep-navy rounded-2xl flex items-center justify-center text-white shadow-xl shadow-deep-navy/20\" data-kid=\"8\">\n          <i class=\"ti ti-home-hero text-2xl\" data-kid=\"9\"></i>\n        </div>\n        <div data-kid=\"10\">\n          <h1 class=\"text-xl font-black tracking-tight leading-none text-deep-navy\" data-kid=\"11\">HomeHero<span class=\"text-accent\" data-kid=\"12\">AI</span></h1>\n          <span class=\"text-[10px] font-bold uppercase tracking-widest opacity-40\" data-kid=\"13\">Family OS 2026</span>\n        </div>\n      </div>\n\n      <nav class=\"space-y-2\" data-kid=\"14\">\n        <a href=\"#\" class=\"flex items-center gap-4 px-4 py-4 rounded-[1.5rem] bg-deep-navy text-white shadow-xl shadow-deep-navy/15 transition-all\" data-kid=\"15\">\n          <i class=\"ti ti-layout-dashboard text-2xl text-accent\" data-kid=\"16\"></i>\n          <span class=\"font-bold\" data-kid=\"17\">Dashboard</span>\n        </a>\n        <a href=\"#\" class=\"flex items-center gap-4 px-4 py-4 rounded-[1.5rem] text-deep-navy/50 hover:bg-deep-navy/5 hover:text-deep-navy transition-all group\" data-kid=\"18\">\n          <i class=\"ti ti-shopping-cart text-2xl group-hover:scale-110 transition-transform\" data-kid=\"19\"></i>\n          <span class=\"font-bold\" data-kid=\"20\">Grocery Hub</span>\n        </a>\n        <a href=\"#\" class=\"flex items-center gap-4 px-4 py-4 rounded-[1.5rem] text-deep-navy/50 hover:bg-deep-navy/5 hover:text-deep-navy transition-all group\" data-kid=\"21\">\n          <i class=\"ti ti-receipt-dollar text-2xl group-hover:scale-110 transition-transform\" data-kid=\"22\"></i>\n          <span class=\"font-bold\" data-kid=\"23\">Expenses</span>\n        </a>\n        <a href=\"#\" class=\"flex items-center gap-4 px-4 py-4 rounded-[1.5rem] text-deep-navy/5