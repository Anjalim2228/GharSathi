=\"104\"></i>\n                                <div class=\"px-2 py-0.5 bg-white/10 rounded-md text-[8px] font-bold uppercase tracking-widest border border-white/20\" data-kid=\"105\">Standard</div>\n                            </div>\n                            <div class=\"space-y-4\" data-kid=\"106\">\n                                <h3 class=\"text-base font-bold font-geist tracking-tight\" data-kid=\"107\">MacBook Pro 16\"</h3>\n                                <div class=\"flex justify-between items-end border-t border-white/10 pt-2\" data-kid=\"108\">\n                                    <p class=\"text-[10px] opacity-70\" data-kid=\"109\">S/N: C02DR1X8MD6M</p>\n                                    <i class=\"fa-solid fa-barcode text-2xl opacity-30\" data-kid=\"110\"></i>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"mt-4 flex items-center justify-between px-1\" data-kid=\"111\">\n                        <div data-kid=\"112\">\n                            <h4 class=\"font-bold text-slate-800 text-sm\" data-kid=\"113\">Apple Warranty</h4>\n                            <p class=\"text-[10px] text-amber-600 uppercase tracking-wider font-bold\" data-kid=\"114\">184 Days Left</p>\n                        </div>\n                        <div class=\"flex gap-1.5\" data-kid=\"115\">\n                            <button class=\"w-8 h-8 flex items-center justify-center text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-colors\" data-kid=\"116\"><i class=\"fa-solid fa-expand text-[11px]\" data-kid=\"117\"></i></button>\n                            <button class=\"w-8 h-8 flex items-center justify-center text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-colors\" data-kid=\"118\"><i class=\"fa-solid fa-ellipsis-v text-[11px]\" data-kid=\"119\"></i></button>\n                        </div>\n      