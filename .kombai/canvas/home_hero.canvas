      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=DM+Sans:wght@400;500;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  @layer base {\n    body {\n      font-family: 'DM Sans', sans-serif;\n      background-color: #011F5B;\n      color: #FFFFFF;\n      margin: 0;\n      padding: 0;\n      overflow-x: hidden;\n    }\n  }\n\n  @layer components {\n    .emergency-glow {\n      box-shadow: 0 0 50px rgba(239, 68, 68, 0.2);\n    }\n    .pulsate-red {\n      animation: pulsate-red 2s infinite;\n    }\n    @keyframes pulsate-red {\n      0% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7); }\n      70% { box-shadow: 0 0 0 20px rgba(239, 68, 68, 0); }\n      100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }\n    }\n    .glass-alert {\n      background: rgba(239, 68, 68, 0.1);\n      backdrop-filter: blur(20px);\n      border: 1px solid rgba(239, 68, 68, 0.3);\n    }\n    .glass-navy {\n      background: rgba(255, 255, 255, 0.05);\n      backdrop-filter: blur(20px);\n      border: 1px solid rgba(255, 255, 255, 0.1);\n    }\n  }\n</style>\n\n<div class=\"min-h-screen p-8 flex flex-col gap-8 bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-from)_0%,_transparent_50%)] from-red-900/20\" data-kid=\"1\">\n  \n  <header class=\"flex items-center justify-between\" data-kid=\"2\">\n    <div class=\"flex items-center gap-4\" data-kid=\"3\">\n      <div class=\"w-12 h-12 bg-red-600 rounded-2xl flex items-center justify-center pulsate-red\" data-kid=\"4\">\n        <i class=\"ti ti-ambulance text-2xl\" data-kid=\"5\"></i>\n      </div>\n      <div data-kid=\"6\">\n        <h1 class=\"text-2xl font-bold font-inter tracking-tight uppercase\" data-kid=\"7\">Emergency Control</h1>\n        <p class=\"text-sm text-red-400 font-bold flex items-center gap-2\" data-kid=\"8\">\n          <span class=\"w-2 h-2 rounded-full bg-red-500 animate-ping\" data-kid=\"9\"></span>\n          SOS MODE ACTIVE • LIVE UPDATES\n        </p>\n      </div>\n    </div>\n    \n    <div class=\"flex items-center gap-6\" data-kid=\"10\">\n      <div class=\"flex -space-x-3\" data-kid=\"11\">\n        <img src=\"https://images.unsplash.com/photo-1606143688554-bc6fc40629ca?auto=format&w=80&q=80&fit=crop\" class=\"w-12 h-12 rounded-full border-2 border-deep-navy shadow-xl\" alt=\"Anjali\" data-kid=\"12\">\n        <img src=\"https://images.unsplash.com/photo-1773339707692-6460b73ff938?auto=format&w=80&q=80&fit=crop\" class=\"w-12 h-12 rounded-full border-2 border-deep-navy shadow-xl\" alt=\"Brother\" data-kid=\"13\">\n        <div class=\"w-12 h-12 rounded-full bg-red-600 flex items-center justify-center border-2 border-deep-navy text-xs font-bold\" data-kid=\"14\">+2</div>\n      </div>\n      <button class=\"px-6 py-3 rounded-2xl bg-white/10 border border-white/20 font-bold hover:bg-white/20 transition-all\" data-kid=\"15\">\n        Exit SOS Mode\n      </button>\n    </div>\n  </header>\n\n  \n  <main class=\"flex-1 grid grid-cols-12 gap-8\" data-kid=\"16\">\n    \n    \n    <div class=\"col-span-12 lg:col-span-3 flex flex-col gap-6\" data-kid=\"17\">\n      <div class=\"glass-alert p-10 rounded-[2.5rem] flex flex-col items-center justify-center text-center gap-6 border-red-500/50\" data-kid=\"18\">\n        <div class=\"relative\" data-kid=\"19\">\n          <div class=\"absolute inset-0 bg-red-600 rounded-full animate-ping opacity-20\" data-kid=\"20\"></div>\n          <button class=\"w-48 h-48 rounded-full bg-red-600 border-[10px] border-red-500/30 flex items-center justify-center text-white relative z-10 shadow-[0_0_60px_rgba(220,38,38,0.5)] active:scale-95 transition-transform\" data-kid=\"21\">\n            <span class=\"text-4xl font-black uppercase tracking-widest\" data-kid=\"22\">SOS</span>\n          </button>\n        </div>\n        <div data-kid=\"23\">\n          <h2 class=\"text-2xl font-bold mb-2\" data-kid=\"24\">Help is on the way</h2>\n          <p class=\"text-sm text-white/60\" data-kid=\"25\">Family notified • Location Shared • Emergency services alerted</p>\n        </div>\n        <div class=\"w-full h-1 bg-white/10 rounded-full overflow-hidden\" data-kid=\"26\">\n          <div class=\"w-2/3 h-full bg-red-500 shadow-[0_0_10px_rgba(239,68,68,0.8)]\" data-kid=\"27\"></div>\n        </div>\n      </div>\n\n      <div class=\"glass-navy p-6 rounded-3xl space-y-4\" data-kid=\"28\">\n        <h3 class=\"font-bold flex items-center gap-2\" data-kid=\"29\">\n          <i class=\"ti ti-history text-red-500\" data-kid=\"30\"></i> Timeline\n        </h3>\n        <div class=\"space-y-4 relative before:absolute before:left-2 before:top-2 before:bottom-2 before:w-0.5 before:bg-white/10\" data-kid=\"31\">\n          <div class=\"flex gap-4 relative pl-8\" data-kid=\"32\">\n            <div class=\"absolute left-0.5 top-2 w-3 h-3 rounded-full bg-red-500 shadow-[0_0_10px_rgba(239,68,68,0.5)]\" data-kid=\"33\"></div>\n            <div data-kid=\"34\">\n              <p class=\"text-xs font-bold\" data-kid=\"35\">12:42 PM</p>\n              <p class=\"text-sm text-white/80\" data-kid=\"36\">SOS Button Pressed by Anjali</p>\n            </div>\n          </div>\n          <div class=\"flex gap-4 relative pl-8\" data-kid=\"37\">\n            <div class=\"absolute left-0.5 top-2 w-3 h-3 rounded-full bg-green-500\" data-kid=\"38\"></div>\n            <div data-kid=\"39\">\n              <p class=\"text-xs font-bold\" data-kid=\"40\">12:43 PM</p>\n              <p class=\"text-sm text-white/80\" data-kid=\"41\">Family Members Notified</p>\n            </div>\n          </div>\n          <div class=\"flex gap-4 relative pl-8 opacity-40\" data-kid=\"42\">\n            <div class=\"absolute left-0.5 top-2 w-3 h-3 rounded-full bg-white/20\" data-kid=\"43\"></div>\n            <div data-kid=\"44\">\n              <p class=\"text-xs font-bold\" data-kid=\"45\">Pending</p>\n              <p class=\"text-sm text-white/80\" data-kid=\"46\">Emergency Services Arrival</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"col-span-12 lg:col-span-6 rounded-[2.5rem] overflow-hidden relative border border-white/10 shadow-2xl\" data-kid=\"47\">\n      <img src=\"https://images.pexels.com/photos/27141314/pexels-photo-27141314.jpeg?auto=compress&cs=tinysrgb&w=1200&q=80\" alt=\"Live Map\" class=\"w-full h-full object-cover grayscale brightness-50 opacity-80\" decoding=\"async\" loading=\"lazy\" data-kid=\"48\">\n      \n      \n      <div class=\"absolute inset-0 p-8 flex flex-col justify-between pointer-events-none\" data-kid=\"49\">\n        <div class=\"flex justify-between items-start\" data-kid=\"50\">\n          <div class=\"glass-navy p-4 rounded-2xl pointer-events-auto flex items-center gap-4\" data-kid=\"51\">\n            <div class=\"w-10 h-10 rounded-full border-2 border-red-500 p-0.5\" data-kid=\"52\">\n              <img src=\"https://images.unsplash.com/photo-1606143688554-bc6fc40629ca?auto=format&w=80&q=80&fit=crop\" class=\"w-full h-full rounded-full object-cover\" alt=\"Anjali\" data-kid=\"53\">\n            </div>\n            <div data-kid=\"54\">\n              <p class=\"text-xs font-bold uppercase tracking-wider text-red-400\" data-kid=\"55\">Distress Signal</p>\n              <p class=\"text-sm font-bold\" data-kid=\"56\">Anjali • Near Central Park</p>\n            </div>\n          </div>\n          <div class=\"flex flex-col gap-2 pointer-events-auto\" data-kid=\"57\">\n            <button class=\"w-10 h-10 rounded-xl glass-navy flex items-center justify-center text-white hover:bg-white/20\" data-kid=\"58\">\n              <i class=\"ti ti-plus\" data-kid=\"59\"></i>\n            </button>\n            <button class=\"w-10 h-10 rounded-xl glass-navy flex items-center justify-center text-white hover:bg-white/20\" data-kid=\"60\">\n              <i class=\"ti ti-minus\" data-kid=\"61\"></i>\n            </button>\n            <button class=\"w-10 h-10 rounded-xl glass-navy flex items-center justify-center text-white hover:bg-white/20\" data-kid=\"62\">\n              <i class=\"ti ti-focus-2\" data-kid=\"63\"></i>\n            </button>\n          </div>\n        </div>\n\n        <div class=\"glass-navy p-6 rounded-3xl pointer-events-auto w-fit max-w-xs space-y-2 border-l-4 border-red-500\" data-kid=\"64\">\n          <p class=\"text-xs font-bold text-white/50\" data-kid=\"65\">ESTIMATED RESPONSE</p>\n          <p class=\"text-2xl font-bold font-inter\" data-kid=\"66\">4m 12s</p>\n          <p class=\"text-xs text-green-400 flex items-center gap-1\" data-kid=\"67\">\n            <i class=\"ti ti-circle-check\" data-kid=\"68\"></i> Ambulance #402 dispatched\n          </p>\n        </div>\n      </div>\n\n      \n      <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2\" data-kid=\"69\">\n        <div class=\"w-8 h-8 bg-red-600 rounded-full pulsate-red flex items-center justify-center border-4 border-white/20\" data-kid=\"70\">\n          <i class=\"ti ti-current-location text-xs\" data-kid=\"71\"></i>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"col-span-12 lg:col-span-3 flex flex-col gap-8\" data-kid=\"72\">\n      <div class=\"space-y-4\" data-kid=\"73\">\n        <h3 class=\"text-lg font-bold flex items-center justify-between\" data-kid=\"74\">\n          Family Status \n          <span class=\"text-xs font-normal text-white/40\" data-kid=\"75\">4 Connected</span>\n        </h3>\n        \n        \n        <div class=\"glass-navy p-4 rounded-[2rem] flex items-center justify-between group hover:bg-red-500/10 transition-colors border-red-500/20\" data-kid=\"76\">\n          <div class=\"flex items-center gap-3\" data-kid=\"77\">\n            <div class=\"w-12 h-12 rounded-full border-2 border-red-500 p-0.5 relative\" data-kid=\"78\">\n              <img src=\"https://images.unsplash.com/photo-1606143688554-bc6fc40629ca?auto=format&w=80&q=80&fit=crop\" class=\"w-full h-full rounded-full object-cover\" alt=\"Anjali\" data-kid=\"79\">\n              <div class=\"absolute -bottom-1 -right-1 w-4 h-4 bg-red-600 rounded-full border-2 border-deep-navy\" data-kid=\"80\"></div>\n            </div>\n            <div data-kid=\"81\">\n              <p class=\"font-bold\" data-kid=\"82\">Anjali</p>\n              <p class=\"text-[10px] text-red-400 font-bold uppercase tracking-wider\" data-kid=\"83\">Emergency</p>\n            </div>\n          </div>\n          <button class=\"w-8 h-8 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20\" data-kid=\"84\">\n            <i class=\"ti ti-phone\" data-kid=\"85\"></i>\n          </button>\n        </div>\n\n        <div class=\"glass-navy p-4 rounded-[2rem] flex items-center justify-between opacity-80\" data-kid=\"86\">\n          <div class=\"flex items-center gap-3\" data-kid=\"87\">\n            <div class=\"w-12 h-12 rounded-full border-2 border-green-500 p-0.5 relative\" data-kid=\"88\">\n              <img src=\"https://images.unsplash.com/photo-1773339707692-6460b73ff938?auto=format&w=80&q=80&fit=crop\" class=\"w-full h-full rounded-full object-cover\" alt=\"Rahul\" data-kid=\"89\">\n              <div class=\"absolute -bottom-1 -right-1 w-4 h-4 bg-green-500 rounded-full border-2 border-deep-navy\" data-kid=\"90\"></div>\n            </div>\n            <div data-kid=\"91\">\n              <p class=\"font-bold\" data-kid=\"92\">Rahul</p>\n              <p class=\"text-[10px] text-green-400 font-bold uppercase tracking-wider\" data-kid=\"93\">Safe • Home</p>\n            </div>\n          </div>\n          <button class=\"w-8 h-8 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20\" data-kid=\"94\">\n            <i class=\"ti ti-message\" data-kid=\"95\"></i>\n          </button>\n        </div>\n\n        <div class=\"glass-navy p-4 rounded-[2rem] flex items-center justify-between opacity-80\" data-kid=\"96\">\n          <div class=\"flex items-center gap-3\" data-kid=\"97\">\n            <div class=\"w-12 h-12 rounded-full border-2 border-yellow-500 p-0.5 relative\" data-kid=\"98\">\n              <img src=\"https://images.unsplash.com/photo-1626362337699-9b020ec8e716?auto=format&w=80&q=80&fit=crop\" class=\"w-full h-full rounded-full object-cover\" alt=\"Mom\" data-kid=\"99\">\n              <div class=\"absolute -bottom-1 -right-1 w-4 h-4 bg-yellow-500 rounded-full border-2 border-deep-navy\" data-kid=\"100\"></div>\n            </div>\n            <div data-kid=\"101\">\n              <p class=\"font-bold\" data-kid=\"102\">Mom</p>\n              <p class=\"text-[10px] text-yellow-400 font-bold uppercase tracking-wider\" data-kid=\"103\">Away • Market</p>\n            </div>\n          </div>\n          <button class=\"w-8 h-8 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20\" data-kid=\"104\">\n            <i class=\"ti ti-phone\" data-kid=\"105\"></i>\n          </button>\n        </div>\n      </div>\n\n      <div class=\"glass-alert p-6 rounded-3xl border-red-500/30\" data-kid=\"106\">\n        <h3 class=\"font-bold mb-4 flex items-center gap-2\" data-kid=\"107\">\n          <i class=\"ti ti-medical-cross text-red-500\" data-kid=\"108\"></i> Anjali's Profile\n        </h3>\n        <div class=\"grid grid-cols-2 gap-4\" data-kid=\"109\">\n          <div class=\"bg-white/5 p-3 rounded-2xl\" data-kid=\"110\">\n            <p class=\"text-[10px] text-white/50 uppercase\" data-kid=\"111\">Blood Group</p>\n            <p class=\"text-xl font-black text-red-500\" data-kid=\"112\">O+</p>\n          </div>\n          <div class=\"bg-white/5 p-3 rounded-2xl\" data-kid=\"113\">\n            <p class=\"text-[10px] text-white/50 uppercase\" data-kid=\"114\">Allergies</p>\n            <p class=\"text-sm font-bold\" data-kid=\"115\">Peanuts, Penicillin</p>\n          </div>\n          <div class=\"bg-white/5 p-3 rounded-2xl col-span-2\" data-kid=\"116\">\n            <p class=\"text-[10px] text-white/50 uppercase\" data-kid=\"117\">Medical Conditions</p>\n            <p class=\"text-sm font-bold\" data-kid=\"118\">Asthma (Carries Inhaler)</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </main>\n\n  \n  <footer class=\"grid grid-cols-1 md:grid-cols-4 gap-6\" data-kid=\"119\">\n    <div class=\"glass-navy p-6 rounded-3xl flex items-center gap-4 hover:bg-white/10 cursor-pointer group transition-all\" data-kid=\"120\">\n      <div class=\"w-12 h-12 rounded-2xl bg-red-600/20 text-red-600 flex items-center justify-center group-hover:scale-110 transition-transform\" data-kid=\"121\">\n        <i class=\"ti ti-ambulance text-2xl\" data-kid=\"122\"></i>\n      </div>\n      <div data-kid=\"123\">\n        <p class=\"font-bold\" data-kid=\"124\">Call Ambulance</p>\n        <p class=\"text-xs text-white/40\" data-kid=\"125\">Direct line to EMS</p>\n      </div>\n    </div>\n    <div class=\"glass-navy p-6 rounded-3xl flex items-center gap-4 hover:bg-white/10 cursor-pointer group transition-all\" data-kid=\"126\">\n      <div class=\"w-12 h-12 rounded-2xl bg-blue-600/20 text-blue-600 flex items-center justify-center group-hover:scale-110 transition-transform\" data-kid=\"127\">\n        <i class=\"ti ti-badge-vo text-2xl\" data-kid=\"128\"></i>\n      </div>\n      <div data-kid=\"129\">\n        <p class=\"font-bold\" data-kid=\"130\">Call Police</p>\n        <p class=\"text-xs text-white/40\" data-kid=\"131\">Nearby precinct notified</p>\n      </div>\n    </div>\n    <div class=\"glass-navy p-6 rounded-3xl flex items-center gap-4 hover:bg-white/10 cursor-pointer group transition-all\" data-kid=\"132\">\n      <div class=\"w-12 h-12 rounded-2xl bg-orange-600/20 text-orange-600 flex items-center justify-center group-hover:scale-110 transition-transform\" data-kid=\"133\">\n        <i class=\"ti ti-firetruck text-2xl\" data-kid=\"134\"></i>\n      </div>\n      <div data-kid=\"135\">\n        <p class=\"font-bold\" data-kid=\"136\">Fire Department</p>\n        <p class=\"text-xs text-white/40\" data-kid=\"137\">Emergency fire line</p>\n      </div>\n    </div>\n    <div class=\"glass-navy p-6 rounded-3xl flex items-center gap-4 hover:bg-white/10 cursor-pointer group transition-all\" data-kid=\"138\">\n      <div class=\"w-12 h-12 rounded-2xl bg-accent/20 text-accent flex items-center justify-center group-hover:scale-110 transition-transform\" data-kid=\"139\">\n        <i class=\"ti ti-stethoscope text-2xl\" data-kid=\"140\"></i>\n      </div>\n      <div data-kid=\"141\">\n        <p class=\"font-bold\" data-kid=\"142\">Family Doctor</p>\n        <p class=\"text-xs text-white/40\" data-kid=\"143\">Dr. Verma • On Call</p>\n      </div>\n    </div>\n  </footer>\n</div>",
