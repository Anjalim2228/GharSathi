      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Inter:wght@400;500;600;700&display=swap');\n\n  :root {\n    --color-accent: #E5AA70;\n    --color-deep-navy: #011F5B;\n    --color-surface: #F5F5F5;\n    --shadow-premium: 0 12px 48px -10px rgba(1, 31, 91, 0.1);\n    --shadow-glass: 0 8px 32px 0 rgba(31, 38, 135, 0.08);\n  }\n\n  body {\n    font-family: 'DM Sans', sans-serif;\n    background-color: var(--color-surface);\n    color: var(--color-deep-navy);\n  }\n\n  .font-inter { font-family: 'Inter', sans-serif; }\n  \n  .glass-card {\n    background: rgba(255, 255, 255, 0.45);\n    backdrop-filter: blur(24px);\n    -webkit-backdrop-filter: blur(24px);\n    border: 1px solid rgba(255, 255, 255, 0.5);\n    box-shadow: var(--shadow-premium);\n  }\n\n  .orb-pulse {\n    animation: orb-pulse 4s infinite cubic-bezier(0.4, 0, 0.6, 1);\n  }\n\n  @keyframes orb-pulse {\n    0%, 100% { transform: scale(1); box-shadow: 0 0 20px rgba(1, 31, 91, 0.2); }\n    50% { transform: scale(1.1); box-shadow: 0 0 40px rgba(1, 31, 91, 0.4); }\n  }\n\n  .custom-scrollbar::-webkit-scrollbar {\n    width: 6px;\n  }\n  .custom-scrollbar::-webkit-scrollbar-track {\n    background: transparent;\n  }\n  .custom-scrollbar::-webkit-scrollbar-thumb {\n    background: rgba(1, 31, 91, 0.1);\n    border-radius: 10px;\n  }\n</style>\n\n<div class=\"flex min-h-screen\" data-kid=\"1\">\n  \n  <aside class=\"w-20 md:w-64 bg-white/60 backdrop-blur-xl border-r border-white/20 flex flex-col py-8 px-4 sticky top-0 h-screen\" data-kid=\"2\">\n    <div class=\"flex items-center gap-3 mb-12 px-2\" data-kid=\"3\">\n      <div class=\"w-10 h-10 bg-[var(--color-deep-navy)] rounded-xl flex items-center justify-center text-white shadow-lg\" data-kid=\"4\">\n        <i data-lucide=\"home\" class=\"w-6 h-6\" data-kid=\"5\"></i>\n      </div>\n      <h1 class=\"text-xl font-bold font-inter tracking-tight hidden md:block\" data-kid=\"6\">\n        HomeHero <span class=\"text-[var(--color-accent)]\" data-kid=\"7\">AI</span>\n      </h1>\n    </div>\n\n    <nav class=\"flex-1 space-y-2\" data-kid=\"8\">\n      <a href=\"#\" class=\"flex items-center gap-4 px-3 py-3 rounded-2xl bg-[var(--color-deep-navy)] text-white shadow-lg shadow-navy-900/10\" data-kid=\"9\">\n        <i data-lucide=\"layout-dashboard\" class=\"w-6 h-6 text-[var(--color-accent)]\" data-kid=\"10\"></i>\n        <span class=\"font-bold hidden md:block\" data-kid=\"11\">Dashboard</span>\n      </a>\n      <a href=\"#\" class=\"flex items-center gap-4 px-3 py-3 rounded-2xl text-[var(--color-deep-navy)]/50 hover:bg-[var(--color-deep-navy)]/5 hover:text-[var(--color-deep-navy)] transition-all\" data-kid=\"12\">\n        <i data-lucide=\"shopping-cart\" class=\"w-6 h-6\" data-kid=\"13\"></i>\n        <span class=\"font-bold hidden md:block\" data-kid=\"14\">Grocery</span>\n      </a>\n      <a href=\"#\" class=\"flex items-center gap-4 px-3 py-3 rounded-2xl text-[var(--color-deep-navy)]/50 hover:bg-[var(--color-deep-navy)]/5 hover:text-[var(--color-deep-navy)] transition-all\" data-kid=\"15\">\n        <i data-lucide=\"receipt\" class=\"w-6 h-6\" data-kid=\"16\"></i>\n        <span class=\"font-bold hidden md:block\" data-kid=\"17\">Expenses</span>\n      </a>\n      <a href=\"#\" class=\"flex items-center gap-4 px-3 py-3 rounded-2xl text-[var(--color-deep-navy)]/50 hover:bg-[var(--color-deep-navy)]/5 hover:text-[var(--color-deep-navy)] transition-all\" data-kid=\"18\">\n        <i data-lucide=\"heart-pulse\" class=\"w-6 h-6\" data-kid=\"19\"></i>\n        <span class=\"font-bold hidden md:block\" data-kid=\"20\">Health</span>\n      </a>\n      <a href=\"#\" class=\"flex items-center gap-4 px-3 py-3 rounded-2xl text-[var(--color-deep-navy)]/50 hover:bg-[var(--color-deep-navy)]/5 hover:text-[var(--color-deep-navy)] transition-all\" data-kid=\"21\">\n        <i data-lucide=\"package\" class=\"w-6 h-6\" data-kid=\"22\"></i>\n        <span class=\"font-bold hidden md:block\" data-kid=\"23\">Inventory</span>\n      </a>\n    </nav>\n\n    <div class=\"pt-8 border-t border-navy-900/5 space-y-2\" data-kid=\"24\">\n      <a href=\"#\" class=\"flex items-center gap-4 px-3 py-3 rounded-2xl text-[var(--color-deep-navy)]/50 hover:bg-[var(--color-deep-navy)]/5 hover:text-[var(--color-deep-navy)] transition-all\" data-kid=\"25\">\n        <i data-lucide=\"settings\" class=\"w-6 h-6\" data-kid=\"26\"></i>\n        <span class=\"font-bold hidden md:block\" data-kid=\"27\">Settings</span>\n      </a>\n    </div>\n  </aside>\n\n  \n  <main class=\"flex-1 p-8 md:p-12 overflow-y-auto custom-scrollbar\" data-kid=\"28\">\n    \n    <header class=\"flex items-center justify-between mb-12\" data-kid=\"29\">\n      <div class=\"relative w-full max-w-md hidden sm:block\" data-kid=\"30\">\n        <i data-lucide=\"search\" class=\"absolute left-3 top-1/2 -translate-y-1/2 text-[var(--color-deep-navy)]/30 w-5 h-5\" data-kid=\"31\"></i>\n        <input type=\"text\" placeholder=\"Search anything or ask AI...\" class=\"w-full bg-white/50 border border-white/40 rounded-2xl py-3 pl-10 pr-4 focus:outline-none focus:border-[var(--color-accent)] transition-all text-sm font-medium shadow-sm\" data-kid=\"32\">\n      </div>\n\n      <div class=\"flex items-center gap-6\" data-kid=\"33\">\n        <div className=\"flex items-center gap-3\" data-kid=\"34\">\n          <button class=\"w-12 h-12 rounded-2xl bg-white/50 border border-white/40 flex items-center justify-center text-[var(--color-deep-navy)]/60 hover:text-[var(--color-accent)] transition-all hover:scale-105 active:scale-95 shadow-sm relative\" data-kid=\"35\">\n            <i data-lucide=\"bell\" class=\"w-6 h-6\" data-kid=\"36\"></i>\n            <span class=\"absolute top-3 right-3 w-2 h-2 bg-red-500 rounded-full border-2 border-white\" data-kid=\"37\"></span>\n          </button>\n        </div>\n\n        <div class=\"flex items-center gap-4 pl-6 border-l border-navy-900/5\" data-kid=\"38\">\n          <div class=\"text-right hidden md:block\" data-kid=\"39\">\n            <p class=\"text-[10px] uppercase tracking-wider font-black text-[var(--color-accent)]\" data-kid=\"40\">Premium</p>\n            <p class=\"font-bold text-[var(--color-deep-navy)]\" data-kid=\"41\">Anjali Sharma</p>\n          </div>\n          <div class=\"w-12 h-12 rounded-full border-2 border-[var(--color-accent)] p-0.5 shadow-lg shadow-accent/10 overflow-hidden\" data-kid=\"42\">\n            <img src=\"https://i.pravatar.cc/150?u=Anjali\" alt=\"Profile\" class=\"w-full h-full rounded-full object-cover\" data-kid=\"43\">\n          </div>\n        </div>\n      </div>\n    </header>\n\n    \n    <div class=\"space-y-10\" data-kid=\"44\">\n      \n      <section class=\"grid grid-cols-1 lg:grid-cols-12 gap-8\" data-kid=\"45\">\n        <div class=\"lg:col-span-8 glass-card rounded-[2.5rem] p-10 md:p-12 flex flex-col justify-between relative overflow-hidden group\" data-kid=\"46\">\n          \n          <div class=\"absolute top-0 right-0 p-12 opacity-[0.03] group-hover:opacity-[0.07] transition-opacity rotate-12 pointer-events-none\" data-kid=\"47\">\n            <i data-lucide=\"zap\" class=\"w-64 h-64 text-[var(--color-accent)]\" data-kid=\"48\"></i>\n          </div>\n\n          <div class=\"space-y-6 relative z-10\" data-kid=\"49\">\n            <div class=\"flex items-center gap-3\" data-kid=\"50\">\n              <div class=\"w-10 h-10 rounded-2xl bg-[var(--color-accent)]/10 flex items-center justify-center text-[var(--color-accent)]\" data-kid=\"51\">\n                <i data-lucide=\"sparkles\" class=\"w-5 h-5\" data-kid=\"52\"></i>\n              </div>\n              <p class=\"text-sm font-bold opacity-60\" data-kid=\"53\">Monday, July 14, 2026</p>\n            </div>\n            \n            <h2 class=\"text-5xl md:text-6xl font-inter font-black tracking-tight leading-tight\" data-kid=\"54\">\n              Good Morning,<br data-kid=\"55\">Anjali!\n            </h2>\n            \n            <p class=\"text-xl md:text-2xl opacity-70 max-w-xl font-medium\" data-kid=\"56\">\n              It's 28°C and mostly sunny. The household is running smoothly today.\n            </p>\n          </div>\n\n          <div class=\"mt-12 flex flex-col md:flex-row items-stretch md:items-center gap-6 relative z-10\" data-kid=\"57\">\n            <div class=\"flex-1 bg-white/40 backdrop-blur-md rounded-3xl p-6 border border-white/50 flex items-center gap-4\" data-kid=\"58\">\n              <div class=\"w-10 h-10 rounded-xl bg-red-500/10 flex items-center justify-center text-red-500 shadow-sm shadow-red-500/20\" data-kid=\"59\">\n                <i data-lucide=\"alert-circle\" class=\"w-5 h-5\" data-kid=\"60\"></i>\n              </div>\n              <div data-kid=\"61\">\n                <p class=\"text-xs font-black uppercase tracking-wider text-red-500/60\" data-kid=\"62\">Urgent Action</p>\n                <p class=\"font-bold text-sm\" data-kid=\"63\">Electricity bill due today ($142.50)</p>\n              </div>\n            </div>\n            <div class=\"flex-1 bg-white/40 backdrop-blur-md rounded-3xl p-6 border border-white/50 flex items-center gap-4\" data-kid=\"64\">\n              <div class=\"w-10 h-10 rounded-xl bg-[var(--color-accent)]/10 flex items-center justify-center text-[var(--color-accent)] shadow-sm shadow-accent/20\" data-kid=\"65\">\n                <i data-lucide=\"pill\" class=\"w-5 h-5\" data-kid=\"66\"></i>\n              </div>\n              <div data-kid=\"67\">\n                <p class=\"text-xs font-black uppercase tracking-wider text-[var(--color-accent)]/60\" data-kid=\"68\">Upcoming</p>\n                <p class=\"font-bold text-sm\" data-kid=\"69\">Mom's medicine at 9:00 AM</p>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"lg:col-span-4 flex flex-col gap-8\" data-kid=\"70\">\n          <div class=\"flex-1 glass-card rounded-[2.5rem] p-10 flex flex-col items-center justify-center text-center group transition-all\" data-kid=\"71\">\n            <div class=\"w-20 h-20 mb-6 bg-[var(--color-accent)]/5 rounded-3xl flex items-center justify-center text-[var(--color-accent)] group-hover:scale-110 transition-transform duration-500\" data-kid=\"72\">\n              <i data-lucide=\"sun\" class=\"w-12 h-12\" data-kid=\"73\"></i>\n            </div>\n            <h3 class=\"text-6xl font-inter font-black\" data-kid=\"74\">28°C</h3>\n            <p class=\"font-bold opacity-40 uppercase tracking-widest text-xs mt-2\" data-kid=\"75\">Sunny • Paris</p>\n          </div>\n\n          <div class=\"glass-card rounded-[2.5rem] p-8 flex items-center justify-between group cursor-pointer hover:bg-white/60 transition-all\" data-kid=\"76\">\n            <div class=\"space-y-1\" data-kid=\"77\">\n              <div class=\"flex items-center gap-2\" data-kid=\"78\">\n                <h4 class=\"font-bold text-lg\" data-kid=\"79\">Family Status</h4>\n                <span class=\"w-2 h-2 rounded-full bg-green-500 animate-pulse shadow-[0_0_8px_rgba(34,197,94,0.5)]\" data-kid=\"80\"></span>\n              </div>\n              <p class=\"text-xs opacity-50 font-bold\" data-kid=\"81\">4 members at home</p>\n            </div>\n            <div class=\"flex -space-x-4\" data-kid=\"82\">\n              <img src=\"https://i.pravatar.cc/150?u=Anjali\" class=\"w-12 h-12 rounded-full border-4 border-white shadow-xl hover:-translate-y-1 transition-transform z-30\" data-kid=\"83\">\n              <img src=\"https://i.pravatar.cc/150?u=Father\" class=\"w-12 h-12 rounded-full border-4 border-white shadow-xl hover:-translate-y-1 transition-transform z-20\" data-kid=\"84\">\n              <img src=\"https://i.pravatar.cc/150?u=Mother\" class=\"w-12 h-12 rounded-full border-4 border-white shadow-xl hover:-translate-y-1 transition-transform z-10\" data-kid=\"85\">\n              <div class=\"w-12 h-12 rounded-full bg-[var(--color-accent)] border-4 border-white shadow-xl flex items-center justify-center text-white text-xs font-bold z-0\" data-kid=\"86\">+1</div>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      \n      <section class=\"grid grid-cols-1 lg:grid-cols-12 gap-8\" data-kid=\"87\">\n        \n        <div class=\"lg:col-span-8 glass-card rounded-[2.5rem] p-10\" data-kid=\"88\">\n          <div class=\"flex items-center justify-between mb-10\" data-kid=\"89\">\n            <div data-kid=\"90\">\n              <h3 class=\"text-2xl font-inter font-bold\" data-kid=\"91\">Financial Health</h3>\n              <p class=\"text-sm font-medium opacity-50\" data-kid=\"92\">Spending is 8.2% lower than June</p>\n            </div>\n            <div class=\"text-right\" data-kid=\"93\">\n              <p class=\"text-3xl font-inter font-black text-[var(--color-accent)]\" data-kid=\"94\">$3,842.10</p>\n              <p class=\"text-xs font-bold text-green-500 flex items-center justify-end gap-1 mt-1\" data-kid=\"95\">\n                <i data-lucide=\"trending-up\" class=\"w-3 h-3\" data-kid=\"96\"></i> On Track\n              </p>\n            </div>\n          </div>\n\n          <div class=\"h-64 w-full mb-10\" data-kid=\"97\">\n            <canvas id=\"financialChart\" data-kid=\"98\"></canvas>\n          </div>\n\n          <div class=\"grid grid-cols-1 md:grid-cols-3 gap-6\" data-kid=\"99\">\n            <div class=\"bg-[var(--color-deep-navy)]/5 rounded-3xl p-6 border border-white/40\" data-kid=\"100\">\n              <p class=\"text-[10px] uppercase font-black tracking-widest opacity-40 mb-2\" data-kid=\"101\">Total Spent</p>\n              <h5 class=\"text-xl font-bold font-inter\" data-kid=\"102\">$3,842</h5>\n            </div>\n            <div class=\"bg-[var(--color-accent)]/5 rounded-3xl p-6 border border-white/40\" data-kid=\"103\">\n              <p class=\"text-[10px] uppercase font-black tracking-widest opacity-40 mb-2\" data-kid=\"104\">Savings</p>\n              <h5 class=\"text-xl font-bold font-inter text-[var(--color-accent)]\" data-kid=\"105\">$1,157</h5>\n            </div>\n            <div class=\"bg-green-500/5 rounded-3xl p-6 border border-white/40\" data-kid=\"106\">\n              <p class=\"text-[10px] uppercase font-black tracking-widest opacity-40 mb-2\" data-kid=\"107\">AI Forecast</p>\n              <h5 class=\"text-xl font-bold font-inter text-green-600\" data-kid=\"108\">Optimal</h5>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"lg:col-span-4 space-y-8\" data-kid=\"109\">\n          <div class=\"glass-card rounded-[2.5rem] p-8 border-l-8 border-l-[var(--color-accent)]\" data-kid=\"110\">\n            <div class=\"flex items-center justify-between mb-8\" data-kid=\"111\">\n              <h4 class=\"text-lg font-bold flex items-center gap-3\" data-kid=\"112\">\n                <i data-lucide=\"activity\" class=\"text-[var(--color-accent)] w-6 h-6\" data-kid=\"113\"></i> Health Pulse\n              </h4>\n              <button class=\"w-8 h-8 rounded-full bg-white/50 border border-white flex items-center justify-center text-[var(--color-deep-navy)]/40 hover:text-[var(--color-accent)] transition-all\" data-kid=\"114\">\n                <i data-lucide=\"more-horizontal\" class=\"w-4 h-4\" data-kid=\"115\"></i>\n              </button>\n            </div>\n\n            <div class=\"space-y-6\" data-kid=\"116\">\n              <div class=\"flex items-center justify-between\" data-kid=\"117\">\n                <div class=\"flex items-center gap-4\" data-kid=\"118\">\n                  <div class=\"w-12 h-12 rounded-2xl bg-blue-500/10 flex items-center justify-center text-blue-500\" data-kid=\"119\">\n                    <i data-lucide=\"droplets\" class=\"w-6 h-6\" data-kid=\"120\"></i>\n                  </div>\n                  <div data-kid=\"121\">\n                    <p class=\"text-sm font-bold\" data-kid=\"122\">Hydration</p>\n                    <p class=\"text-[10px] font-black opacity-40\" data-kid=\"123\">1.8 / 3.0 L</p>\n                  </div>\n                </div>\n                <div class=\"w-12 h-12 rounded-full border-4 border-blue-100 flex items-center justify-center relative\" data-kid=\"124\">\n                  <svg class=\"absolute inset-0 -rotate-90 w-full h-full\" data-kid=\"125\">\n                    <circle cx=\"24\" cy=\"24\" r=\"20\" fill=\"none\" stroke=\"#3b82f6\" stroke-width=\"4\" stroke-dasharray=\"125.6\" stroke-dashoffset=\"50.2\" stroke-linecap=\"round\" data-kid=\"126\"></circle>\n                  </svg>\n                  <span class=\"text-[10px] font-black text-blue-500\" data-kid=\"127\">60%</span>\n                </div>\n              </div>\n\n              <div class=\"flex items-center justify-between\" data-kid=\"128\">\n                <div class=\"flex items-center gap-4\" data-kid=\"129\">\n                  <div class=\"w-12 h-12 rounded-2xl bg-purple-500/10 flex items-center justify-center text-purple-500\" data-kid=\"130\">\n                    <i data-lucide=\"moon\" class=\"w-6 h-6\" data-kid=\"131\"></i>\n                  </div>\n                  <div data-kid=\"132\">\n                    <p class=\"text-sm font-bold\" data-kid=\"133\">Sleep</p>\n                    <p class=\"text-[10px] font-black opacity-40\" data-kid=\"134\">7h 12m Quality</p>\n                  </div>\n                </div>\n                <div class=\"w-12 h-12 rounded-full border-4 border-purple-100 flex items-center justify-center relative\" data-kid=\"135\">\n                  <svg class=\"absolute inset-0 -rotate-90 w-full h-full\" data-kid=\"136\">\n                    <circle cx=\"24\" cy=\"24\" r=\"20\" fill=\"none\" stroke=\"#a855f7\" stroke-width=\"4\" stroke-dasharray=\"125.6\" stroke-dashoffset=\"20.1\" stroke-linecap=\"round\" data-kid=\"137\"></circle>\n                  </svg>\n                  <span class=\"text-[10px] font-black text-purple-500\" data-kid=\"138\">84%</span>\n                </div>\n              </div>\n            </div>\n\n            <button class=\"w-full mt-8 py-4 rounded-2xl bg-[var(--color-deep-navy)] text-white font-bold text-sm flex items-center justify-center gap-2 group transition-all active:scale-[0.98]\" data-kid=\"139\">\n              Open Health Hub\n              <i data-lucide=\"arrow-right\" class=\"w-4 h-4 group-hover:translate-x-1 transition-transform\" data-kid=\"140\"></i>\n            </button>\n          </div>\n\n          <div class=\"glass-card rounded-[2.5rem] p-8\" data-kid=\"141\">\n            <h4 class=\"text-lg font-bold mb-6\" data-kid=\"142\">Today's Chores</h4>\n            <div class=\"space-y-4\" data-kid=\"143\">\n              <div class=\"flex items-center justify-between p-4 rounded-3xl bg-white/30 border border-white/50 group cursor-pointer hover:border-accent/40 transition-all\" data-kid=\"144\">\n                <div class=\"flex items-center gap-4\" data-kid=\"145\">\n                  <div class=\"w-5 h-5 rounded-lg border-2 border-[var(--color-deep-navy)]/10 flex items-center justify-center group-hover:border-accent transition-all\" data-kid=\"146\"></div>\n                  <p class=\"font-bold text-sm\" data-kid=\"147\">Fold Laundry</p>\n                </div>\n                <p class=\"text-[10px] font-black text-[var(--color-accent)] tracking-widest\" data-kid=\"148\">+50 PTS</p>\n              </div>\n              <div class=\"flex items-center justify-between p-4 rounded-3xl bg-white/30 border border-white/50 group cursor-pointer hover:border-accent/40 transition-all\" data-kid=\"149\">\n                <div class=\"flex items-center gap-4\" data-kid=\"150\">\n                  <div class=\"w-5 h-5 rounded-lg border-2 border-[var(--color-deep-navy)]/10 flex items-center justify-center group-hover:border-accent transition-all\" data-kid=\"151\"></div>\n                  <p class=\"font-bold text-sm\" data-kid=\"152\">Water Plants</p>\n                </div>\n                <p class=\"text-[10px] font-black text-[var(--color-accent)] tracking-widest\" data-kid=\"153\">+20 PTS</p>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n    </div>\n  </main>\n\n  \n  <div class=\"fixed bottom-10 right-10 z-50 group\" data-kid=\"154\">\n    \n    <div class=\"absolute bottom-full right-0 mb-6 w-72 glass-card rounded-3xl p-6 opacity-0 translate-y-4 pointer-events-none group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500 shadow-2xl\" data-kid=\"155\">\n      <div class=\"flex items-center gap-3 mb-3\" data-kid=\"156\">\n        <div class=\"w-8 h-8 rounded-full bg-[var(--color-deep-navy)] flex items-center justify-center text-white\" data-kid=\"157\">\n          <i data-lucide=\"sparkles\" class=\"w-4 h-4\" data-kid=\"158\"></i>\n        </div>\n        <p class=\"font-black text-[10px] uppercase tracking-widest text-[var(--color-accent)]\" data-kid=\"159\">HomeHero AI</p>\n      </div>\n      <p class=\"text-sm font-bold text-[var(--color-deep-navy)] leading-relaxed\" data-kid=\"160\">\n        \"Hi Anjali! Don't forget to pay the electricity bill today. It's due in 4 hours.\"\n      </p>\n      <div class=\"mt-4 flex gap-2\" data-kid=\"161\">\n        <button class=\"flex-1 py-2 rounded-xl bg-[var(--color-deep-navy)] text-white text-[10px] font-black tracking-widest uppercase\" data-kid=\"162\">Quick Pay</button>\n        <button class=\"w-10 h-8 rounded-xl bg-white/50 border border-white flex items-center justify-center text-[var(--color-deep-navy)]/60\" data-kid=\"163\"><i data-lucide=\"mic\" class=\"w-4 h-4\" data-kid=\"164\"></i></button>\n      </div>\n    </div>\n\n    \n    <button class=\"w-20 h-20 rounded-full bg-gradient-to-br from-[var(--color-deep-navy)] to-[#1A3A7A] flex items-center justify-center text-white shadow-2xl relative overflow-hidden orb-pulse active:scale-95 transition-transform\" data-kid=\"165\">\n      <div class=\"absolute inset-0 bg-[radial-gradient(circle_at_30%_30%,rgba(229,170,112,0.4),transparent)] animate-pulse\" data-kid=\"166\"></div>\n      <i data-lucide=\"bot\" class=\"w-10 h-10 relative z-10\" data-kid=\"167\"></i>\n    </button>\n  </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/lucide@0.419.0/dist/umd/lucide.min.js\" data-kid=\"168\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/chart.js\" data-kid=\"169\"></script>\n<script data-kid=\"170\">\n  // Initialize Lucide Icons\n  lucide.createIcons();\n\n  // Initialize Financial Chart\n  const ctx = document.getElementById('financialChart').getContext('2d');\n  const gradient = ctx.createLinearGradient(0, 0, 0, 300);\n  gradient.addColorStop(0, 'rgba(229, 170, 112, 0.3)');\n  gradient.addColorStop(1, 'rgba(229, 170, 112, 0)');\n\n  new Chart(ctx, {\n    type: 'line',\n    data: {\n      labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],\n      datasets: [{\n        label: 'Spending',\n        data: [400, 300, 600, 800, 500, 900, 700],\n        borderColor: '#E5AA70',\n        borderWidth: 5,\n        tension: 0.4,\n        fill: true,\n        backgroundColor: gradient,\n        pointRadius: 0,\n        pointHoverRadius: 8,\n        pointHoverBackgroundColor: '#E5AA70',\n        pointHoverBorderColor: '#fff',\n        pointHoverBorderWidth: 4\n      }]\n    },\n    options: {\n      responsive: true,\n      maintainAspectRatio: false,\n      plugins: {\n        legend: { display: false },\n        tooltip: {\n          backgroundColor: '#fff',\n          titleColor: '#011F5B',\n          bodyColor: '#011F5B',\n          bodyFont: { weight: 'bold' },\n          padding: 12,\n          cornerRadius: 16,\n          displayColors: false,\n          borderColor: 'rgba(1, 31, 91, 0.05)',\n          borderWidth: 1\n        }\n      },\n      scales: {\n        x: {\n          grid: { display: false },\n          ticks: { color: 'rgba(1, 31, 91, 0.4)', font: { weight: 'bold' } }\n        },\n        y: {\n          display: false,\n          grid: { display: false }\n        }\n      }\n    }\n  });\n</script>",
