te/5 border border-white/10 flex items-center justify-center hover:bg-purple-500 transition-colors\" data-kid=\"189\">\n                                    <i class=\"ri-more-2-line\" data-kid=\"190\"></i>\n                                </button>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        \n        <section id=\"variant-v3\" class=\"variant-content animate-in fade-in slide-in-from-bottom-4 duration-700\" data-kid=\"191\">\n            <div class=\"bg-white rounded-[2.5rem] p-10 shadow-[0_32px_64px_-16px_rgba(0,0,0,0.08)] border border-slate-100\" data-kid=\"192\">\n                <header class=\"flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-12\" data-kid=\"193\">\n                    <div data-kid=\"194\">\n                        <h2 class=\"text-3xl font-black tracking-tight text-slate-900 mb-2\" data-kid=\"195\">Household Gallery</h2>\n                        <div class=\"flex items-center gap-2\" data-kid=\"196\">\n                            <div class=\"flex -space-x-2\" data-kid=\"197\">\n                                <img src=\"https://i.pravatar.cc/100?u=1\" class=\"w-6 h-6 rounded-full border-2 border-white\" alt=\"Avatar\" decoding=\"async\" loading=\"lazy\" data-kid=\"198\">\n                                <img src=\"https://i.pravatar.cc/100?u=2\" class=\"w-6 h-6 rounded-full border-2 border-white\" alt=\"Avatar\" decoding=\"async\" loading=\"lazy\" data-kid=\"199\">\n                                <img src=\"https://i.pravatar.cc/100?u=3\" class=\"w-6 h-6 rounded-full border-2 border-white\" alt=\"Avatar\" decoding=\"async\" loading=\"lazy\" data-kid=\"200\">\n                            </div>\n                            <span class=\"text-xs font-semibold text-slate-500\" data-kid=\"201\">Shared with Family</span>\n                        </div>\n                    </div>\n                    <div class=\"flex gap-4 w-full md:w-auto\" data-kid=\"202\">\n                        <div class=\"flex-grow md:flex-none relative\" data-kid=\"203\">\n                            <input type=\"text\" placeholder=\"Find anything...\" class=\"w-full md:w-80 px-6 py-3 bg-slate-50 border border-slate-100 rounded-2xl text-sm focus:outline-hidden focus:ring-4 focus:ring-slate-100 transition-all\" data-kid=\"204\">\n                        </div>\n                        <button class=\"bg-indigo-600 text-white p-3 rounded-2xl shadow-xl shadow-indigo-100 hover:scale-110 active:scale-95 transition-transform\" data-kid=\"205\">\n                            <i class=\"ri-camera-lens-line text-xl\" data-kid=\"206\"></i>\n                        </button>\n                    </div>\n                </header>\n\n                <div class=\"grid grid-cols-2 md:grid-cols-4 gap-8\" data-kid=\"207\">\n                    \n                    <div class=\"group cursor-pointer\" data-kid=\"208\">\n                        <div class=\"aspect-square bg-slate-100 rounded-[2rem] mb-4 overflow-hidden relative group-hover:shadow-2xl group-hover:shadow-slate-200 transition-all duration-500\" data-kid=\"209\">\n                            <div class=\"absolute inset-0 flex items-center justify-center p-8\" data-kid=\"210\">\n                                <div class=\"w-full h-full bg-white rounded-3xl shadow-sm border border-slate-200/50 flex items-center justify-center group-hover:scale-105 transition-transform duration-500\" data-kid=\"211\">\n                                    <i class=\"ri-tv-line text-5xl text-slate-200\" data-kid=\"212\"></i>\n                                </div>\n                            </div>\n                            <div class=\"absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"213\">\n                                <button class=\"bg-white/90 backdrop-blur p-2 rounded-full shadow-lg\" data-kid=\"214\"><i class=\"ri-heart-line\" data-kid=\"215\"></i></button>\n                            </div>\n                            <div class=\"absolute bottom-4 left-4\" data-kid=\"216\">\n                                <span class=\"bg-blue-600 text-white text-[10px] font-black uppercase px-2 py-1 rounded-lg\" data-kid=\"217\">Electronics</span>\n                            </div>\n                        </div>\n                        <h4 class=\"font-bold text-slate-900 group-hover:text-indigo-600 transition-colors\" data-kid=\"218\">Study iMac 24\"</h4>\n                        <div class=\"flex justify-between items-center mt-1\" data-kid=\"219\">\n                            <span class=\"text-xs text-slate-400\" data-kid=\"220\">Home Office</span>\n                            <span class=\"text-xs font-bold text-slate-900\" data-kid=\"221\">Premium</span>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"group cursor-pointer\" data-kid=\"222\">\n                        <div class=\"aspect-square bg-slate-100 rounded-[2rem] mb-4 overflow-hidden relative group-hover:shadow-2xl group-hover:shadow-slate-200 transition-all duration-500\" data-kid=\"223\">\n                             <div class=\"absolute inset-0 flex items-center justify-center p-8\" data-kid=\"224\">\n                                <div class=\"w-full h-full bg-white rounded-3xl shadow-sm border border-slate-200/50 flex items-center justify-center group-hover:scale-105 transition-transform duration-500\" data-kid=\"225\">\n                                    <i class=\"ri-fridge-line text-5xl text-slate-200\" data-kid=\"226\"></i>\n                                </div>\n                            </div>\n                            <div class=\"absolute bottom-4 left-4\" data-kid=\"227\">\n                                <span class=\"bg-red-600 text-white text-[10px] font-black uppercase px-2 py-1 rounded-lg\" data-kid=\"228\">Low Stock</span>\n                            </div>\n                        </div>\n                        <h4 class=\"font-bold text-slate-900 group-hover:text-indigo-600 transition-colors\" data-kid=\"229\">Gas Cylinder</h4>\n                        <div class=\"flex justify-between items-center mt-1\" data-kid=\"230\">\n                            <span class=\"text-xs text-slate-400\" data-kid=\"231\">12% Remaining</span>\n                            <button class=\"text-xs font-black text-indigo-600 underline\" data-kid=\"232\">Refill</button>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"group cursor-pointer\" data-kid=\"233\">\n                        <div class=\"aspect-square bg-slate-100 rounded-[2rem] mb-4 overflow-hidden relative group-hover:shadow-2xl group-hover:shadow-slate-200 transition-all duration-500\" data-kid=\"234\">\n                            <div class=\"absolute inset-0 flex items-center justify-center p-8\" data-kid=\"235\">\n                                <div class=\"w-full h-full bg-white rounded-3xl shadow-sm border border-slate-200/50 flex items-center justify-center group-hover:scale-105 transition-transform duration-500\" data-kid=\"236\">\n                                    <i class=\"ri-drop-line text-5xl text-slate-200\" data-kid=\"237\"></i>\n                                </div>\n                            </div>\n                            <div class=\"absolute bottom-4 left-4\" data-kid=\"238\">\n                                <span class=\"bg-emerald-600 text-white text-[10px] font-black uppercase px-2 py-1 rounded-lg\" data-kid=\"239\">Staples</span>\n                            </div>\n                        </div>\n                        <h4 class=\"font-bold text-slate-900 group-hover:text-indigo-600 transition-colors\" data-kid=\"240\">Olive Oil (Extra)</h4>\n                        <div class=\"flex justify-between items-center mt-1\" data-kid=\"241\">\n                            <span class=\"text-xs text-slate-400\" data-kid=\"242\">Full Supply</span>\n                            <span class=\"text-xs font-bold text-slate-900\" data-kid=\"243\">Kitchen</span>\n                        </div>\n                    </div>\n\n                    \n                    <div class=\"group cursor-pointer\" data-kid=\"244\">\n                        <div class=\"aspect-square border-4 border-dashed border-slate-100 rounded-[2rem] mb-4 flex flex-col items-center justify-center text-slate-300 group-hover:border-indigo-200 group-hover:text-indigo-500 transition-all duration-500\" data-kid=\"245\">\n                            <i class=\"ri-add-line text-6xl mb-2 group-hover:rotate-90 transition-transform duration-500\" data-kid=\"246\"></i>\n                            <span class=\"text-sm font-black uppercase tracking-widest\" data-kid=\"247\">Add Item</span>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n    </main>\n\n    \n    <div id=\"scanner-ui\" class=\"fixed inset-0 z-100 bg-black/60 backdrop-blur-sm hidden items-center justify-center p-6 animate-in fade-in duration-300\" data-kid=\"248\">\n        <div class=\"bg-white w-full max-w-md rounded-[2.5rem] overflow-hidden shadow-2xl animate-in zoom-in-95 duration-300\" data-kid=\"249\">\n            <div class=\"p-8 pb-0 flex justify-between items-center\" data-kid=\"250\">\n                <h3 class=\"text-xl font-bold\" data-kid=\"251\">Scanning...</h3>\n                <button onclick=\"toggleScanner()\" class=\"w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center hover:bg-slate-200 transition-colors\" data-kid=\"252\">\n                    <i class=\"ri-close-line\" data-kid=\"253\"></i>\n                </button>\n            </div>\n            <div class=\"p-8\" data-kid=\"254\">\n                <div class=\"aspect-square bg-slate-950 rounded-3xl relative overflow-hidden group border border-slate-800\" data-kid=\"255\">\n                    <div class=\"absolute inset-0 flex items-center justify-center\" data-kid=\"256\">\n                        \n                        <div class=\"absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_0%,rgba(99,102,241,0.05)_100%)]\" data-kid=\"257\"></div>\n                        <div class=\"w-64 h-64 border border-white/5 rounded-full absolute animate-[ping_3s_infinite] opacity-20\" data-kid=\"258\"></div>\n                        \n                        <div class=\"w-56 h-56 border-2 border-indigo-500/30 rounded-3xl relative\" data-kid=\"259\">\n                            \n                            <div class=\"absolute left-0 right-0 h-[2px] bg-indigo-400 shadow-[0_0_20px_rgba(99,102,241,1)] animate-[scan_2.5s_infinite] z-20\" data-kid=\"260\"></div>\n                            \n                            \n                            <div class=\"absolute -top-1 -left-1 w-6 h-6 border-t-4 border-l-4 border-indigo-500 rounded-tl-xl\" data-kid=\"261\"></div>\n                            <div class=\"absolute -top-1 -right-1 w-6 h-6 border-t-4 border-r-4 border-indigo-500 rounded-tr-xl\" data-kid=\"262\"></div>\n                            <div class=\"absolute -bottom-1 -left-1 w-6 h-6 border-b-4 border-l-4 border-indigo-500 rounded-bl-xl\" data-kid=\"263\"></div>\n                            <div class=\"absolute -bottom-1 -right-1 w-6 h-6 border-b-4 border-r-4 border-indigo-500 rounded-br-xl\" data-kid=\"264\"></div>\n                        </div>\n                    </div>\n                    <div class=\"absolute bottom-6 left-0 right-0 text-center\" data-kid=\"265\">\n                        <p class=\"text-white/50 text-[10px] font-bold uppercase tracking-widest\" data-kid=\"266\">Align barcode within the frame</p>\n                    </div>\n                </div>\n                \n                <div class=\"mt-8 space-y-4\" data-kid=\"267\">\n                    <button class=\"w-full py-4 bg-indigo-600 text-white rounded-2xl font-bold hover:bg-indigo-700 transition-colors flex items-center justify-center gap-2\" data-kid=\"268\">\n                        <i class=\"ri-flashlight-line\" data-kid=\"269\"></i> Turn Flash On\n                    </button>\n                    <button class=\"w-full py-4 bg-slate-100 text-slate-900 rounded-2xl font-bold hover:bg-slate-200 transition-colors\" data-kid=\"270\">\n                        Enter Code Manually\n                    </button>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    \n    <button onclick=\"toggleScanner()\" class=\"fixed bottom-8 right-8 w-16 h-16 bg-slate-900 text-white rounded-full shadow-2xl flex items-center justify-center z-40 hover:scale-110 active:scale-95 transition-transform group\" data-kid=\"271\">\n        <div class=\"absolute -top-12 right-0 bg-slate-900 text-white text-[10px] font-black uppercase px-3 py-1.5 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap\" data-kid=\"272\">Quick Scan</div>\n        <i class=\"ri-qr-scan-2-line text-2xl\" data-kid=\"273\"></i>\n    </button>\n\n    <script data-kid=\"274\">\n        document.addEventListener('DOMContentLoaded', () => {\n            gsap.from(\".inventory-card\", {\n                duration: 0.6,\n                y: 20,\n                opacity: 0,\n                stagger: 0.1,\n                ease: \"power2.out\"\n            });\n        });\n\n        function switchVariant(v) {\n            // GSAP exit animation\n            gsap.to(\".variant-content.active\", {\n                duration: 0.3,\n                opacity: 0,\n                y: 10,\n                onComplete: () => {\n                    // Update buttons\n                    document.querySelectorAll('.variant-btn').forEach(btn => {\n                        btn.classList.remove('bg-white', 'shadow-sm', 'text-slate-900');\n                        btn.classList.add('text-slate-500');\n                    });\n                    document.getElementById('btn-' + v).classList.add('bg-white', 'shadow-sm', 'text-slate-900');\n                    document.getElementById('btn-' + v).classList.remove('text-slate-500');\n\n                    // Update content\n                    document.querySelectorAll('.variant-content').forEach(content => {\n                        content.classList.remove('active');\n                    });\n                    \n                    const newActive = document.getElementById('variant-' + v);\n                    newActive.classList.add('active');\n                    \n                    // GSAP entry animation\n                    gsap.fromTo(newActive, \n                        { opacity: 0, y: 10 },\n                        { opacity: 1, y: 0, duration: 0.4, ease: \"power2.out\" }\n                    );\n                }\n            });\n        }\n\n        function toggleScanner() {\n            const ui = document.getElementById('scanner-ui');\n            if(ui.classList.contains('hidden')) {\n                ui.classList.remove('hidden');\n                ui.classList.add('flex');\n                gsap.fromTo(ui.querySelector('.bg-white'), \n                    { scale: 0.9, opacity: 0 }, \n                    { scale: 1, opacity: 1, duration: 0.4, ease: \"back.out(1.7)\" }\n                );\n            } else {\n                gsap.to(ui.querySelector('.bg-white'), {\n                    scale: 0.9,\n                    opacity: 0,\n                    duration: 0.3,\n                    ease: \"power2.in\",\n                    onComplete: () => {\n                        ui.classList.add('hidden');\n                        ui.classList.remove('flex');\n                    }\n                });\n            }\n        }\n    </script>\n\n    <style data-kid=\"275\">\n        @keyframes scan {\n            0% { top: 0%; opacity: 0; }\n            10% { opacity: 1; }\n            90% { opacity: 1; }\n            100% { top: 100%; opacity: 0; }\n        }\n    </style>\n\n</div>\n",
