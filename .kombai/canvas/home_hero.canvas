      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css');\n\n  :root {\n    --pharma-blue: #3b82f6;\n    --pharma-teal: #14b8a6;\n    --pharma-slate: #f8fafc;\n  }\n\n  body {\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n    padding: 0;\n    background-color: #f1f5f9;\n    color: #1e293b;\n  }\n\n  .font-heading { font-family: 'Space Grotesk', sans-serif; }\n\n  .glass {\n    background: rgba(255, 255, 255, 0.8);\n    backdrop-filter: blur(16px);\n    -webkit-backdrop-filter: blur(16px);\n    border: 1px solid rgba(255, 255, 255, 0.4);\n  }\n\n  .variant-content { display: none; }\n  .variant-active { display: block; }\n\n  /* Custom Scrollbar */\n  ::-webkit-scrollbar { width: 5px; }\n  ::-webkit-scrollbar-track { background: transparent; }\n  ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }\n</style>\n\n<div class=\"min-h-screen pb-16 overflow-x-clip\" id=\"main-container\" data-kid=\"1\">\n  \n  <header class=\"sticky top-4 z-50 px-6 max-w-xl mx-auto\" data-kid=\"2\">\n    <div class=\"glass px-2 py-1.5 rounded-2xl flex items-center justify-between shadow-xl border border-white/50\" data-kid=\"3\">\n      <div class=\"flex items-center gap-2 ml-3\" data-kid=\"4\">\n        <div class=\"w-7 h-7 bg-blue-600 rounded-lg flex items-center justify-center\" data-kid=\"5\">\n          <i class=\"ti ti-heart-rate-monitor text-white text-sm\" data-kid=\"6\"></i>\n        </div>\n        <span class=\"font-heading font-bold text-slate-800 text-sm tracking-tight\" data-kid=\"7\">HomeHero <span class=\"text-blue-600\" data-kid=\"8\">Health</span></span>\n      </div>\n      <div class=\"flex bg-slate-100/60 p-1 rounded-xl gap-1\" data-kid=\"9\">\n        <button onclick=\"switchVariant(1)\" id=\"btn-1\" class=\"variant-btn px-3 py-1 rounded-lg text-xs font-bold transition-all bg-white text-blue-600 shadow-sm\" data-kid=\"10\">Dashboard</button>\n        <button onclick=\"switchVariant(2)\" id=\"btn-2\" class=\"variant-btn px-3 py-1 rounded-lg text-xs font-bold transition-all text-slate-500 hover:text-slate-700\" data-kid=\"11\">Essential</button>\n        <button onclick=\"switchVariant(3)\" id=\"btn-3\" class=\"variant-btn px-3 py-1 rounded-lg text-xs font-bold transition-all text-slate-500 hover:text-slate-700\" data-kid=\"12\">Dark</button>\n      </div>\n    </div>\n  </header>\n\n  \n  <main id=\"variant-1\" class=\"variant-content variant-active w-full max-w-[1440px] mx-auto px-8 lg:px-12 mt-8\" data-kid=\"13\">\n    <div class=\"flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4\" data-kid=\"14\">\n      <div class=\"fade-up-v1\" data-kid=\"15\">\n        <h1 class=\"text-3xl font-extrabold text-slate-900 tracking-tight\" data-kid=\"16\">Medical Command Center</h1>\n        <p class=\"text-slate-500 text-sm mt-0.5\" data-kid=\"17\">Automated tracking for 4 active family protocols.</p>\n      </div>\n      <div class=\"flex gap-2 fade-up-v1\" data-kid=\"18\">\n        <div class=\"flex items-center bg-white border border-blue-100 rounded-xl px-4 py-2 shadow-sm shadow-blue-50/50 group cursor-pointer hover:border-blue-300 transition-colors\" data-kid=\"19\">\n           <i class=\"ti ti-camera text-blue-500 mr-2 group-hover:scale-110 transition-transform\" data-kid=\"20\"></i>\n           <span class=\"text-xs font-bold text-slate-700\" data-kid=\"21\">Scan Rx</span>\n           <div class=\"ml-3 h-4 w-[1px] bg-slate-200\" data-kid=\"22\"></div>\n           <button class=\"ml-3 text-[10px] font-black uppercase text-blue-600 hover:text-blue-700\" data-kid=\"23\">Browse</button>\n        </div>\n        <button class=\"px-5 py-2.5 bg-blue-600 text-white text-sm font-bold rounded-xl shadow-lg shadow-blue-200 hover:bg-blue-700 transition-all flex items-center gap-2\" data-kid=\"24\">\n          <i class=\"ti ti-plus\" data-kid=\"25\"></i> New Protocol\n        </button>\n      </div>\n    </div>\n\n    <div class=\"grid grid-cols-12 gap-6 items-start\" data-kid=\"26\">\n      \n      <div class=\"col-span-12 lg:col-span-8 space-y-6\" data-kid=\"27\">\n        \n        <section class=\"bg-white rounded-2xl p-6 shadow-sm border border-slate-100 fade-up-v1\" data-kid=\"28\">\n          <div class=\"flex items-center justify-between mb-6\" data-kid=\"29\">\n            <h2 class=\"text-lg font-bold text-slate-800 flex items-center gap-2\" data-kid=\"30\">\n              <i class=\"ti ti-calendar-event text-blue-500\" data-kid=\"31\"></i> Daily Protocol\n            </h2>\n            <div class=\"flex items-center gap-4 text-[10px] font-black tracking-widest text-slate-400 uppercase\" data-kid=\"32\">\n              <span class=\"flex items-center gap-1.5\" data-kid=\"33\"><span class=\"w-1.5 h-1.5 rounded-full bg-green-500\" data-kid=\"34\"></span> Taken</span>\n              <span class=\"flex items-center gap-1.5\" data-kid=\"35\"><span class=\"w-1.5 h-1.5 rounded-full bg-amber-400\" data-kid=\"36\"></span> Pending</span>\n            </div>\n          </div>\n\n          <div class=\"space-y-3\" data-kid=\"37\">\n            \n            <div class=\"group flex items-center gap-5 p-4 rounded-xl bg-slate-50/50 border border-slate-100 hover:bg-white hover:border-blue-100 hover:shadow-md transition-all duration-300\" data-kid=\"38\">\n              <div class=\"flex flex-col items-center justify-center shrink-0 w-12 border-r border-slate-200 pr-5\" data-kid=\"39\">\n                <span class=\"text-[9px] font-black text-slate-400 uppercase\" data-kid=\"40\">AM</span>\n                <span class=\"text-sm font-bold text-slate-500 line-through\" data-kid=\"41\">08:30</span>\n              </div>\n              <div class=\"flex-1\" data-kid=\"42\">\n                <div class=\"flex items-center gap-2\" data-kid=\"43\">\n                  <h3 class=\"font-bold text-slate-800\" data-kid=\"44\">Metformin Hydrochloride</h3>\n                  <span class=\"px-2 py-0.5 bg-green-50 text-green-700 text-[8px] font-black rounded uppercase border border-green-200 tracking-wider\" data-kid=\"45\">Recorded</span>\n                </div>\n                <p class=\"text-[11px] text-slate-500 mt-0.5\" data-kid=\"46\">500mg • After Breakfast • Mom</p>\n                <div class=\"mt-2 text-[11px] text-blue-600/80 bg-blue-50/50 p-2.5 rounded-lg border border-blue-100/30 flex items-start gap-2\" data-kid=\"47\">\n                   <i class=\"ti ti-sparkles text-blue-400 shrink-0 mt-0.5\" data-kid=\"48\"></i>\n                   <p data-kid=\"49\">AI Insight: Consuming this with food significantly improves absorption and gut tolerance.</p>\n                </div>\n              </div>\n              <div class=\"w-7 h-7 rounded-full bg-green-500 text-white flex items-center justify-center shadow-lg shadow-green-100\" data-kid=\"50\">\n                <i class=\"ti ti-check text-xs\" data-kid=\"51\"></i>\n              </div>\n            </div>\n\n            \n            <div class=\"group flex items-center gap-5 p-4 rounded-xl bg-white border border-slate-100 hover:border-blue-200 hover:shadow-md transition-all duration-300\" data-kid=\"52\">\n              <div class=\"flex flex-col items-center justify-center shrink-0 w-12 border-r border-slate-200 pr-5\" data-kid=\"53\">\n                <span class=\"text-[9px] font-black text-blue-400 uppercase\" data-kid=\"54\">PM</span>\n                <span class=\"text-sm font-bold text-blue-600\" data-kid=\"55\">13:00</span>\n              </div>\n              <div class=\"flex-1\" data-kid=\"56\">\n                <h3 class=\"font-bold text-slate-800\" data-kid=\"57\">Vitamin D3</h3>\n                <p class=\"text-[11px] text-slate-500 mt-0.5\" data-kid=\"58\">2000 IU • With Lunch • Dad</p>\n              </div>\n              <div class=\"flex gap-1\" data-kid=\"59\">\n                 <button class=\"px-3 py-1.5 bg-blue-600 text-white rounded-lg text-[11px] font-bold hover:bg-blue-700 transition-colors\" data-kid=\"60\">Mark Taken</button>\n                 <button class=\"p-1.5 text-slate-300 hover:text-slate-500\" data-kid=\"61\"><i class=\"ti ti-bell-off\" data-kid=\"62\"></i></button>\n              </div>\n            </div>\n\n            \n            <div class=\"group flex items-center gap-5 p-4 rounded-xl bg-white border border-slate-100 hover:border-rose-200 hover:shadow-md transition-all duration-300\" data-kid=\"63\">\n              <div class=\"flex flex-col items-center justify-center shrink-0 w-12 border-r border-slate-200 pr-5\" data-kid=\"64\">\n                <span class=\"text-[9px] font-black text-slate-400 uppercase\" data-kid=\"65\">PM</span>\n                <span class=\"text-sm font-bold text-slate-800\" data-kid=\"66\">20:00</span>\n              </div>\n              <div class=\"flex-1\" data-kid=\"67\">\n                <div class=\"flex items-center gap-2\" data-kid=\"68\">\n                  <h3 class=\"font-bold text-slate-800\" data-kid=\"69\">Lisinopril</h3>\n                  <span class=\"px-2 py-0.5 bg-rose-50 text-rose-500 text-[9px] font-black rounded uppercase border border-rose-100\" data-kid=\"70\">Stock Alert: 2 left</span>\n                </div>\n                <p class=\"text-[11px] text-slate-500 mt-0.5\" data-kid=\"71\">10mg • Before Bed • Mom</p>\n              </div>\n              <button class=\"px-4 py-1.5 bg-slate-900 text-white rounded-lg text-[11px] font-bold hover:bg-slate-800 transition-colors\" data-kid=\"72\">Auto-Refill</button>\n            </div>\n          </div>\n        </section>\n\n        \n        <section class=\"grid grid-cols-1 md:grid-cols-2 gap-6\" data-kid=\"73\">\n          <div class=\"bg-slate-900 rounded-2xl p-6 text-white shadow-xl fade-up-v1 relative overflow-hidden group\" data-kid=\"74\">\n            <div class=\"absolute -right-6 -bottom-6 w-32 h-32 bg-blue-500/20 rounded-full blur-3xl group-hover:scale-125 transition-transform duration-1000\" data-kid=\"75\"></div>\n            <h3 class=\"font-bold text-sm mb-4 flex items-center gap-2 relative z-10 text-blue-400\" data-kid=\"76\">\n              <i class=\"ti ti-shield-check\" data-kid=\"77\"></i> Safety Scan Protocol\n            </h3>\n            <p class=\"text-[11px] leading-relaxed text-slate-300 mb-5 relative z-10 font-medium\" data-kid=\"78\">\n              No conflict detected for upcoming doses. Suggest monitoring serum potassium levels for <span class=\"text-blue-400\" data-kid=\"79\">John</span> next week due to ACE inhibitor interaction.\n            </p>\n            <div class=\"flex gap-2 relative z-10\" data-kid=\"80\">\n              <button class=\"flex-1 py-2 bg-white text-slate-900 text-[10px] font-black uppercase rounded-lg hover:bg-blue-50 transition-colors tracking-widest\" data-kid=\"81\">Full Analysis</button>\n              <button class=\"px-3 py-2 bg-white/5 border border-white/10 text-white rounded-lg hover:bg-white/10 transition-colors\" data-kid=\"82\"><i class=\"ti ti-brand-hipchat text-sm\" data-kid=\"83\"></i></button>\n            </div>\n          </div>\n          <div class=\"bg-white border border-slate-200 rounded-2xl p-6 shadow-sm fade-up-v1 flex flex-col\" data-kid=\"84\">\n            <h3 class=\"font-bold text-sm text-slate-800 mb-4 flex items-center gap-2\" data-kid=\"85\">\n              <i class=\"ti ti-history text-blue-500\" data-kid=\"86\"></i> Recent Activity\n            </h3>\n            <div class=\"space-y-3 flex-1\" data-kid=\"87\">\n               <div class=\"flex items-center gap-3\" data-kid=\"88\">\n                  <div class=\"w-1.5 h-1.5 rounded-full bg-slate-200\" data-kid=\"89\"></div>\n                  <p class=\"text-[10px] text-slate-500\" data-kid=\"90\"><span class=\"font-bold text-slate-700\" data-kid=\"91\">Dad</span> took Omega-3 at 12:45 PM</p>\n               </div>\n               <div class=\"flex items-center gap-3\" data-kid=\"92\">\n                  <div class=\"w-1.5 h-1.5 rounded-full bg-slate-200\" data-kid=\"93\"></div>\n                  <p class=\"text-[10px] text-slate-500\" data-kid=\"94\"><span class=\"font-bold text-slate-700\" data-kid=\"95\">System</span> auto-ordered Lipitor refill</p>\n               </div>\n            </div>\n            <button class=\"w-full mt-4 text-[10px] font-black uppercase text-blue-600 hover:text-blue-700\" data-kid=\"96\">View Full Logs</button>\n          </div>\n        </section>\n      </div>\n\n      \n      <aside class=\"col-span-12 lg:col-span-4 space-y-6\" data-kid=\"97\">\n        \n        <section class=\"bg-white rounded-2xl p-6 shadow-sm border border-slate-100 fade-up-v1\" data-kid=\"98\">\n          <div class=\"flex items-center justify-between mb-5\" data-kid=\"99\">\n             <h3 class=\"font-bold text-sm text-slate-800 uppercase tracking-widest\" data-kid=\"100\">Inventory</h3>\n             <i class=\"ti ti-settings text-slate-300 hover:text-slate-500 cursor-pointer\" data-kid=\"101\"></i>\n          </div>\n          <div class=\"space-y-5\" data-kid=\"102\">\n            <div data-kid=\"103\">\n              <div class=\"flex justify-between text-[11px] mb-2\" data-kid=\"104\">\n                <span class=\"font-bold text-slate-700\" data-kid=\"105\">Metformin</span>\n                <span class=\"text-rose-500 font-black\" data-kid=\"106\">2 Left</span>\n              </div>\n              <div class=\"h-1.5 bg-slate-100 rounded-full overflow-hidden\" data-kid=\"107\">\n                <div class=\"h-full bg-rose-500 w-[10%] rounded-full\" data-kid=\"108\"></div>\n              </div>\n            </div>\n            <div data-kid=\"109\">\n              <div class=\"flex justify-between text-[11px] mb-2\" data-kid=\"110\">\n                <span class=\"font-bold text-slate-700\" data-kid=\"111\">Atorvastatin</span>\n                <span class=\"text-slate-500 font-medium\" data-kid=\"112\">18 Left</span>\n              </div>\n              <div class=\"h-1.5 bg-slate-100 rounded-full overflow-hidden\" data-kid=\"113\">\n                <div class=\"h-full bg-blue-500 w-[60%] rounded-full\" data-kid=\"114\"></div>\n              </div>\n            </div>\n            <div data-kid=\"115\">\n              <div class=\"flex justify-between text-[11px] mb-2\" data-kid=\"116\">\n                <span class=\"font-bold text-slate-700\" data-kid=\"117\">Omega-3 Complex</span>\n                <span class=\"text-teal-500 font-bold\" data-kid=\"118\">Stable</span>\n              </div>\n              <div class=\"h-1.5 bg-slate-100 rounded-full overflow-hidden\" data-kid=\"119\">\n                <div class=\"h-full bg-teal-500 w-[90%] rounded-full\" data-kid=\"120\"></div>\n              </div>\n            </div>\n          </div>\n        </section>\n\n        \n        <section class=\"bg-slate-50 rounded-2xl p-6 border border-slate-200 fade-up-v1 shadow-inner\" data-kid=\"121\">\n          <h3 class=\"font-bold text-sm text-slate-800 mb-5 flex items-center gap-2\" data-kid=\"122\">\n            <i class=\"ti ti-heart text-blue-500\" data-kid=\"123\"></i> Family Health Index\n          </h3>\n          <div class=\"space-y-3\" data-kid=\"124\">\n            <div class=\"flex items-center gap-3 p-3 rounded-xl bg-white border border-slate-100 hover:border-blue-200 hover:shadow-sm transition-all cursor-pointer group\" data-kid=\"125\">\n              <div class=\"relative\" data-kid=\"126\">\n                <img src=\"https://i.pravatar.cc/100?u=mom\" class=\"w-10 h-10 rounded-full border border-slate-100\" alt=\"Sarah\" data-kid=\"127\">\n                <div class=\"absolute -bottom-0.5 -right-0.5 w-3 h-3 bg-green-500 border-2 border-white rounded-full\" data-kid=\"128\"></div>\n              </div>\n              <div class=\"flex-1\" data-kid=\"129\">\n                <h4 class=\"font-bold text-[11px] text-slate-800\" data-kid=\"130\">Sarah (Mom)</h4>\n                <div class=\"flex items-center gap-2 mt-0.5\" data-kid=\"131\">\n                   <span class=\"text-[10px] text-slate-400 font-bold\" data-kid=\"132\">Protocol 100%</span>\n                </div>\n              </div>\n              <i class=\"ti ti-chevron-right text-slate-300 group-hover:text-blue-500 transition-colors\" data-kid=\"133\"></i>\n            </div>\n\n            <div class=\"flex items-center gap-3 p-3 rounded-xl bg-white border border-slate-100 hover:border-blue-200 hover:shadow-sm transition-all cursor-pointer group\" data-kid=\"134\">\n              <div class=\"relative\" data-kid=\"135\">\n                <img src=\"https://i.pravatar.cc/100?u=dad\" class=\"w-10 h-10 rounded-full border border-slate-100\" alt=\"John\" data-kid=\"136\">\n                <div class=\"absolute -bottom-0.5 -right-0.5 w-3 h-3 bg-amber-500 border-2 border-white rounded-full\" data-kid=\"137\"></div>\n              </div>\n              <div class=\"flex-1\" data-kid=\"138\">\n                <h4 class=\"font-bold text-[11px] text-slate-800\" data-kid=\"139\">John (Dad)</h4>\n                <div class=\"flex items-center gap-2 mt-0.5\" data-kid=\"140\">\n                   <span class=\"text-[10px] text-amber-600 font-bold\" data-kid=\"141\">1 dose pending</span>\n                </div>\n              </div>\n              <i class=\"ti ti-chevron-right text-slate-300 group-hover:text-blue-500 transition-colors\" data-kid=\"142\"></i>\n            </div>\n          </div>\n        </section>\n      </aside>\n    </div>\n  </main>\n\n  \n  <main id=\"variant-2\" class=\"variant-content max-w-[1440px] mx-auto px-10 mt-16\" data-kid=\"143\">\n    <div class=\"text-center mb-10 fade-up-v2\" data-kid=\"144\">\n      <h2 class=\"text-4xl font-black text-slate-900 font-heading\" data-kid=\"145\">Health Core</h2>\n      <p class=\"text-slate-500 mt-2 text-sm max-w-sm mx-auto\" data-kid=\"146\">Essential pharmaceutical management with integrated AI vision technology.</p>\n    </div>\n\n    <div class=\"grid grid-cols-12 gap-8 items-start\" data-kid=\"147\">\n      \n      <div class=\"col-span-12 lg:col-span-8 grid grid-cols-1 md:grid-cols-2 gap-4\" data-kid=\"148\">\n        <div class=\"bg-white border border-slate-100 rounded-2xl p-6 hover:border-teal-500 hover:shadow-xl transition-all group fade-up-v2\" data-kid=\"149\">\n          <div class=\"flex justify-between items-start mb-6\" data-kid=\"150\">\n            <div class=\"w-12 h-12 bg-teal-50 rounded-xl flex items-center justify-center text-teal-500 text-2xl group-hover:scale-110 transition-transform duration-300\" data-kid=\"151\">\n              <i class=\"ti ti-pill\" data-kid=\"152\"></i>\n            </div>\n            <span class=\"px-3 py-1 bg-rose-50 text-rose-500 text-[9px] font-black uppercase tracking-widest rounded-full border border-rose-100\" data-kid=\"153\">Refill Urgent</span>\n          </div>\n          <h3 class=\"text-xl font-bold text-slate-800\" data-kid=\"154\">Atorvastatin</h3>\n          <p class=\"text-slate-500 text-xs mt-1 font-medium\" data-kid=\"155\">10mg • Once Daily • Night</p>\n          <div class=\"mt-6 pt-6 border-t border-slate-50 flex items-center justify-between\" data-kid=\"156\">\n            <span class=\"text-sm font-bold text-rose-600\" data-kid=\"157\">3 Tablets Left</span>\n            <button class=\"px-4 py-1.5 bg-teal-600 text-white rounded-lg text-xs font-bold shadow-lg shadow-teal-100\" data-kid=\"158\">Order</button>\n          </div>\n        </div>\n\n        <div class=\"bg-white border border-slate-100 rounded-2xl p-6 hover:border-blue-500 hover:shadow-xl transition-all group fade-up-v2\" data-kid=\"159\">\n          <div class=\"flex justify-between items-start mb-6\" data-kid=\"160\">\n            <div class=\"w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center text-blue-500 text-2xl group-hover:scale-110 transition-transform duration-300\" data-kid=\"161\">\n              <i class=\"ti ti-droplet\" data-kid=\"162\"></i>\n            </div>\n            <span class=\"px-3 py-1 bg-blue-50 text-blue-600 text-[9px] font-black uppercase tracking-widest rounded-full\" data-kid=\"163\">Standard</span>\n          </div>\n          <h3 class=\"text-xl font-bold text-slate-800\" data-kid=\"164\">Timolol Eye Drops</h3>\n          <p class=\"text-slate-500 text-xs mt-1 font-medium\" data-kid=\"165\">0.5% • 2 Drops • Daily</p>\n          <div class=\"mt-6 pt-6 border-t border-slate-50 flex items-center justify-between\" data-kid=\"166\">\n            <span class=\"text-sm font-bold text-slate-800 italic\" data-kid=\"167\">Exp: Oct 2026</span>\n            <button class=\"text-blue-600 text-xs font-bold hover:underline\" data-kid=\"168\">Update Protocol</button>\n          </div>\n        </div>\n      </div>\n\n      \n      <aside class=\"col-span-12 lg:col-span-4 space-y-4 fade-up-v2\" data-kid=\"169\">\n        <div class=\"bg-slate-900 rounded-2xl p-8 text-white shadow-2xl relative overflow-hidden\" data-kid=\"170\">\n           <div class=\"relative z-10\" data-kid=\"171\">\n              <h3 class=\"text-xs font-black uppercase tracking-[0.2em] text-teal-400 mb-4\" data-kid=\"172\">AI Biological Insight</h3>\n              <p class=\"text-sm text-slate-300 leading-relaxed italic font-light\" data-kid=\"173\">\n               \"Atorvastatin functions by inhibiting HMG-CoA reductase in the liver, effectively lowering LDL cholesterol production while you sleep.\"\n              </p>\n           </div>\n           <div class=\"absolute -right-10 -bottom-10 w-40 h-40 bg-teal-500/10 rounded-full blur-3xl\" data-kid=\"174\"></div>\n        </div>\n        <div class=\"bg-white border border-slate-200 rounded-2xl p-6 flex items-center gap-5 cursor-pointer hover:bg-slate-50 transition-all group shadow-sm\" data-kid=\"175\">\n           <div class=\"w-12 h-12 bg-slate-100 rounded-xl flex items-center justify-center text-slate-400 group-hover:text-blue-500 transition-colors\" data-kid=\"176\">\n              <i class=\"ti ti-scan text-xl\" data-kid=\"177\"></i>\n           </div>\n           <div data-kid=\"178\">\n              <h4 class=\"text-sm font-bold text-slate-800\" data-kid=\"179\">New Prescription</h4>\n              <p class=\"text-[10px] text-slate-400 font-bold uppercase tracking-tight mt-0.5\" data-kid=\"180\">Extract from photo</p>\n           </div>\n        </div>\n      </aside>\n    </div>\n  </main>\n\n  \n  <main id=\"variant-3\" class=\"variant-content min-h-screen bg-slate-950 text-white w-full max-w-[1440px] mx-auto overflow-hidden\" data-kid=\"181\">\n    <div class=\"px-10 pt-20\" data-kid=\"182\">\n      <div class=\"flex justify-between items-end mb-16\" data-kid=\"183\">\n        <div class=\"fade-up-v3\" data-kid=\"184\">\n          <span class=\"text-blue-500 font-mono text-xs tracking-[0.3em] uppercase\" data-kid=\"185\">Autonomous Protocol v2.0</span>\n          <h2 class=\"text-6xl font-black mt-3 font-heading tracking-tighter\" data-kid=\"186\">Health Matrix</h2>\n        </div>\n        <div class=\"bg-white/5 backdrop-blur-xl p-1.5 rounded-2xl border border-white/10 flex gap-1.5 fade-up-v3\" data-kid=\"187\">\n          <button class=\"px-8 py-2.5 bg-blue-600 rounded-xl font-bold text-xs tracking-widest shadow-[0_0_40px_rgba(37,99,235,0.3)]\" data-kid=\"188\">LIVE</button>\n          <button class=\"px-8 py-2.5 rounded-xl font-bold text-xs text-white/30 hover:text-white transition-colors\" data-kid=\"189\">HISTORY</button>\n        </div>\n      </div>\n\n      <div class=\"grid grid-cols-12 gap-10 items-start\" data-kid=\"190\">\n        <div class=\"col-span-12 lg:col-span-7 space-y-6 fade-up-v3\" data-kid=\"191\">\n           <div class=\"bg-white/[0.02] border border-white/10 rounded-2xl p-8 backdrop-blur-3xl shadow-2xl\" data-kid=\"192\">\n              <h3 class=\"text-xs font-black text-white/30 mb-10 uppercase tracking-[0.3em]\" data-kid=\"193\">Active Bio-Stack</h3>\n              <div class=\"space-y-12 relative before:content-[''] before:absolute before:left-[1rem] before:top-2 before:bottom-2 before:w-[1px] before:bg-gradient-to-b before:from-blue-500/40 before:to-transparent\" data-kid=\"194\">\n                 \n                 <div class=\"relative pl-12 group\" data-kid=\"195\">\n                    <div class=\"absolute left-0 top-1 w-8 h-8 rounded-full bg-blue-500/20 border border-blue-500/40 flex items-center justify-center transition-all group-hover:scale-125\" data-kid=\"196\">\n                       <div class=\"w-2.5 h-2.5 bg-blue-500 rounded-full shadow-[0_0_15px_rgba(59,130,246,1)]\" data-kid=\"197\"></div>\n                    </div>\n                    <div class=\"flex justify-between items-start\" data-kid=\"198\">\n                       <div data-kid=\"199\">\n                          <h4 class=\"font-bold text-2xl tracking-tight\" data-kid=\"200\">Morning Supplements</h4>\n                          <p class=\"text-sm text-blue-400 mt-1 font-mono\" data-kid=\"201\">COMPLETE • 08:30 AM</p>\n                       </div>\n                       <div class=\"px-4 py-1.5 bg-blue-500/10 border border-blue-500/20 rounded-full text-[10px] font-black text-blue-400 uppercase tracking-widest\" data-kid=\"202\">Logged</div>\n                    </div>\n                 </div>\n                 \n                 <div class=\"relative pl-12 opacity-50 group hover:opacity-100 transition-opacity\" data-kid=\"203\">\n                    <div class=\"absolute left-0 top-1 w-8 h-8 rounded-full bg-white/5 border border-white/10 group-hover:border-white/30 transition-colors\" data-kid=\"204\"></div>\n                    <div class=\"flex justify-between items-start\" data-kid=\"205\">\n                       <div data-kid=\"206\">\n                          <h4 class=\"font-bold text-2xl tracking-tight\" data-kid=\"207\">Lisinopril 10mg</h4>\n                          <p class=\"text-sm text-white/40 mt-1 font-mono\" data-kid=\"208\">PENDING • DUE IN 04:15:00</p>\n                       </div>\n                       <button class=\"px-6 py-2 bg-white text-black font-black text-[10px] uppercase rounded-lg\" data-kid=\"209\">Mark Now</button>\n                    </div>\n                 </div>\n              </div>\n           </div>\n           \n           \n           <div class=\"bg-gradient-to-br from-blue-700 to-indigo-900 rounded-2xl p-8 shadow-[0_40px_80px_-20px_rgba(37,99,235,0.4)] relative overflow-hidden group\" data-kid=\"210\">\n              <div class=\"relative z-10 flex items-center gap-6\" data-kid=\"211\">\n                 <div class=\"w-16 h-16 bg-white/20 backdrop-blur-xl rounded-2xl flex items-center justify-center border border-white/20 shadow-2xl\" data-kid=\"212\">\n                    <i class=\"ti ti-brain text-3xl\" data-kid=\"213\"></i>\n                 </div>\n                 <div data-kid=\"214\">\n                    <h4 class=\"text-xs font-black uppercase text-blue-200 tracking-[0.2em] mb-2\" data-kid=\"215\">Neural Prediction</h4>\n                    <p class=\"text-xl leading-relaxed font-bold italic tracking-tight\" data-kid=\"216\">\"Nightly dosage optimized. Interaction profile cleared for next cycle.\"</p>\n                 </div>\n              </div>\n              <div class=\"absolute -right-20 -top-20 w-60 h-60 bg-white/10 rounded-full blur-[100px] group-hover:scale-150 transition-transform duration-1000\" data-kid=\"217\"></div>\n           </div>\n        </div>\n\n        \n        <aside class=\"col-span-12 lg:col-span-5 space-y-6 fade-up-v3\" data-kid=\"218\">\n           <div class=\"bg-rose-500/10 border border-rose-500/20 rounded-2xl p-10 relative overflow-hidden\" data-kid=\"219\">\n              <p class=\"text-[10px] font-black uppercase text-rose-400 tracking-[0.3em] mb-6\" data-kid=\"220\">Inventory Depletion</p>\n              <h4 class=\"text-6xl font-black tracking-tighter\" data-kid=\"221\">02 Pills</h4>\n              <p class=\"text-sm text-white/60 mt-2 font-medium\" data-kid=\"222\">Lisinopril Protocol • Mom</p>\n              <button class=\"mt-10 w-full py-4 bg-rose-600 text-white rounded-xl text-xs font-black uppercase tracking-[0.2em] shadow-2xl shadow-rose-900/50 hover:bg-rose-700 transition-all hover:-translate-y-1\" data-kid=\"223\">Initialize Refill</button>\n              <div class=\"absolute -right-8 -top-8 w-32 h-32 bg-rose-500/20 rounded-full blur-3xl\" data-kid=\"224\"></div>\n           </div>\n           <div class=\"bg-white/5 border border-white/10 rounded-2xl p-8 flex items-center gap-6 cursor-pointer hover:bg-white/10 transition-all group\" data-kid=\"225\">\n              <div class=\"w-14 h-14 rounded-2xl bg-blue-500/20 text-blue-400 flex items-center justify-center border border-blue-500/30 group-hover:scale-110 transition-transform\" data-kid=\"226\">\n                 <i class=\"ti ti-scan text-2xl\" data-kid=\"227\"></i>\n              </div>\n              <div data-kid=\"228\">\n                 <h4 class=\"text-lg font-bold\" data-kid=\"229\">Bio-Vision Scan</h4>\n                 <p class=\"text-xs text-white/40 mt-1 font-mono uppercase tracking-widest\" data-kid=\"230\">Awaiting Input...</p>\n              </div>\n           </div>\n        </aside>\n      </div>\n    </div>\n  </main>\n</div>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"231\"></script>\n\n<script data-kid=\"232\">\n  let currentVariant = 1;\n\n  function switchVariant(v) {\n    if (v === currentVariant) return;\n\n    document.querySelectorAll('.variant-btn').forEach(btn => {\n      btn.classList.remove('bg-white', 'text-blue-600', 'shadow-sm', 'bg-blue-600', 'text-white');\n      btn.classList.add('text-slate-500');\n    });\n\n    const activeBtn = document.getElementById(`btn-${v}`);\n    if (v === 3) activeBtn.classList.add('bg-blue-600', 'text-white');\n    else activeBtn.classList.add('bg-white', 'text-blue-600', 'shadow-sm');\n    activeBtn.classList.remove('text-slate-500');\n\n    const oldVariant = document.getElementById(`variant-${currentVariant}`);\n    const newVariant = document.getElementById(`variant-${v}`);\n\n    gsap.to(oldVariant, {\n      opacity: 0,\n      duration: 0.2,\n      onComplete: () => {\n        oldVariant.classList.remove('variant-active');\n        newVariant.classList.add('variant-active');\n        \n        const bgColor = v === 3 ? '#020617' : (v === 2 ? '#ffffff' : '#f1f5f9');\n        gsap.to(['body', '#main-container'], { backgroundColor: bgColor, duration: 0.3 });\n\n        gsap.fromTo(newVariant, \n          { opacity: 0, y: 10 }, \n          { opacity: 1, y: 0, duration: 0.4, ease: \"power2.out\" }\n        );\n\n        gsap.fromTo(`.fade-up-v${v}`, \n          { opacity: 0, y: 15 }, \n          { opacity: 1, y: 0, duration: 0.6, stagger: 0.05, ease: \"power3.out\" }\n        );\n      }\n    });\n\n    currentVariant = v;\n  }\n\n  // Initial Entrance Animation\n  window.addEventListener('load', () => {\n    gsap.from('.fade-up-v1', {\n      opacity: 0,\n      y: 30,\n      duration: 0.8,\n      stagger: 0.12,\n      ease: \"power3.out\"\n    });\n  });\n</script>\n",
