/20 group\" data-kid=\"173\">\n              <div class=\"w-12 h-12 rounded-full relative\" data-kid=\"174\">\n                <img src=\"https://i.pravatar.cc/100?u=Mom\" class=\"w-full h-full rounded-full object-cover\" data-kid=\"175\">\n                <span class=\"absolute bottom-0 right-0 w-3.5 h-3.5 bg-green-500 border-2 border-white rounded-full\" data-kid=\"176\"></span>\n              </div>\n              <div class=\"flex-1\" data-kid=\"177\">\n                <p class=\"text-sm font-bold\" data-kid=\"178\">Mom</p>\n                <p class=\"text-[10px] opacity-60\" data-kid=\"179\">At Market • Safe</p>\n              </div>\n              <button class=\"w-8 h-8 rounded-full bg-deep-navy/5 flex items-center justify-center text-deep-navy/40 hover:text-accent\" data-kid=\"180\"><i class=\"ti ti-chevron-right\" data-kid=\"181\"></i></button>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"glass-card p-8 rounded-[2.5rem] bg-accent/10 border-accent/20 space-y-4\" data-kid=\"182\">\n          <div class=\"flex items-center gap-4\" data-kid=\"183\">\n            <div class=\"w-14 h-14 bg-accent rounded-2xl flex items-center justify-center text-white shadow-lg\" data-kid=\"184\">\n              <i class=\"ti ti-shopping-cart text-3xl\" data-kid=\"185\"></i>\n            </div>\n            <div data-kid=\"186\">\n              <h4 class=\"font-black text-lg\" data-kid=\"187\">Smart Grocery</h4>\n              <p class=\"text-xs opacity-60\" data-kid=\"188\">8 items low in stock</p>\n            </div>\n          </div>\n          <div class=\"space-y-2\" data-kid=\"189\">\n            <div class=\"w-full h-2 bg-deep-navy/5 rounded-full overflow-hidden\" data-kid=\"190\">\n              <div class=\"h-full bg-accent w-[35%]\" data-kid=\"191\"></div>\n            </div>\n            <p class=\"text-[10px] font-bold opacity-40 text-right uppercase\" data-kid=\"192\">Stock Health: Critical</p>\n          </div>\n          <button class=\"w-full py-3 bg-white/60 border border-white/60 rounded-xl font-bold text-sm hover:bg-white transition-all\" data-kid=\"193\">Generate Shopping List</button>\n        </div>\n      </div>\n    </section>\n  </main>\n</div>\n\n\n<button class=\"fixed bottom-10 right-10 w-20 h-20 bg-deep-navy rounded-full shadow-2xl flex items-center justify-center text-accent hover:scale-110 active:scale-95 transition-all z-[100] group\" data-kid=\"194\">\n  <div class=\"absolute inset-0 rounded-full border-4 border-accent/20 animate-ping group-hover:hidden\" data-kid=\"195\"></div>\n  <i class=\"ti ti-brand-openai text-4xl\" data-kid=\"196\"></i>\n  <div class=\"absolute -top-16 right-0 bg-white glass-card px-4 py-2 rounded-2xl opacity-0 group-hover:opacity-100 transition-all translate-y-2 group-hover:translate-y-0 whitespace-nowrap shadow-xl\" data-kid=\"197\">\n    <p class=\"text-xs font-bold text-deep-navy\" data-kid=\"198\">\"I've updated your grocery list!\"</p>\n  </div>\n</button>",
