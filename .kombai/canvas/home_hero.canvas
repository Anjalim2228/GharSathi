      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 13540,
        "y": 0,
        "w": 1280,
        "h": 800
      },
      "html": "\n<style data-kid=\"0\">\n    .no-scrollbar::-webkit-scrollbar {\n        display: none;\n    }\n    .no-scrollbar {\n        -ms-overflow-style: none;\n        scrollbar-width: none;\n    }\n    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap');\n\n    :root {\n        --primary: #6366f1;\n        --primary-glow: rgba(99, 102, 241, 0.4);\n        --accent: #a855f7;\n    }\n\n    body {\n        font-family: 'Plus Jakarta Sans', sans-serif;\n        background-color: #050810;\n        color: #f8fafc;\n        overflow-x: clip;\n    }\n\n    .glass {\n        background: rgba(255, 255, 255, 0.08);\n        backdrop-filter: blur(24px);\n        -webkit-backdrop-filter: blur(24px);\n        border: 1px solid rgba(255, 255, 255, 0.15);\n    }\n\n    .orb-glow {\n        filter: blur(40px);\n        background: radial-gradient(circle, #818cf8, #c084fc, #fb7185);\n        opacity: 0.5;\n        animation: orb-pulse 4s ease-in-out infinite alternate;\n    }\n\n    @keyframes orb-pulse {\n        0% { transform: scale(1) rotate(0deg); opacity: 0.4; border-radius: 50%; }\n        50% { transform: scale(1.2) rotate(180deg); opacity: 0.6; border-radius: 45%; }\n        100% { transform: scale(1.4) rotate(360deg); opacity: 0.5; border-radius: 50%; }\n    }\n\n    .ai-bubble {\n        border-bottom-left-radius: 4px;\n    }\n\n    .user-bubble {\n        border-bottom-right-radius: 4px;\n        background: linear-gradient(135deg, var(--primary), var(--accent));\n    }\n\n    .tab-active {\n        background: rgba(255, 255, 255, 0.1);\n        border-color: rgba(255, 255, 255, 0.2);\n    }\n\n    /* Scrollbar */\n    .custom-scrollbar::-webkit-scrollbar {\n        width: 4px;\n    }\n    .custom-scrollbar::-webkit-scrollbar-track {\n        background: transparent;\n    }\n    .custom-scrollbar::-webkit-scrollbar-thumb {\n        background: rgba(255, 255, 255, 0.1);\n        border-radius: 10px;\n    }\n\n    .voice-wave-bar {\n        animation: wave-animation 1s ease-in-out infinite;\n    }\n\n    @keyframes wave-animation {\n        0%, 100% { height: 6px; transform: scaleY(1); opacity: 0.5; }\n        50% { height: 36px; transform: scaleY(1.2); opacity: 1; }\n    }\n</style>\n\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css\" data-kid=\"1\">\n\n<div id=\"main-container\" class=\"relative min-h-screen w-full flex flex-col items-center justify-start pt-8 pb-4 px-4\" data-kid=\"2\">\n    \n    <div class=\"fixed top-6 z-50 glass rounded-full p-1.5 flex gap-2\" data-kid=\"3\">\n        <button onclick=\"switchVariant(1)\" id=\"tab-1\" class=\"variant-tab px-6 py-2 rounded-full text-sm font-semibold transition-all tab-active\" data-kid=\"4\">Immersive</button>\n        <button onclick=\"switchVariant(2)\" id=\"tab-2\" class=\"variant-tab px-6 py-2 rounded-full text-sm font-semibold transition-all text-white/50 hover:text-white\" data-kid=\"5\">Sidebar</button>\n        <button onclick=\"switchVariant(3)\" id=\"tab-3\" class=\"variant-tab px-6 py-2 rounded-full text-sm font-semibold transition-all text-white/50 hover:text-white\" data-kid=\"6\">Minimal</button>\n    </div>\n\n    \n    <div class=\"fixed inset-0 overflow-hidden pointer-events-none\" data-kid=\"7\">\n        <div class=\"absolute top-[-5%] left-[-5%] w-[30%] h-[30%] bg-indigo-500/5 rounded-full blur-[100px]\" data-kid=\"8\"></div>\n        <div class=\"absolute bottom-[-5%] right-[-5%] w-[30%] h-[30%] bg-purple-500/5 rounded-full blur-[100px]\" data-kid=\"9\"></div>\n    </div>\n\n    \n    <div id=\"variant-1\" class=\"variant-container w-full max-w-4xl mt-12 flex flex-col h-[88vh]\" data-kid=\"10\">\n        \n        <div class=\"flex items-center justify-between v1-animate mb-10\" data-kid=\"11\">\n            <div class=\"flex items-center gap-4\" data-kid=\"12\">\n                <div class=\"w-12 h-12 rounded-2xl glass flex items-center justify-center border border-white/20 shadow-lg\" data-kid=\"13\">\n                    <i class=\"fa-solid fa-sparkles text-indigo-400 text-xl\" data-kid=\"14\"></i>\n                </div>\n                <div data-kid=\"15\">\n                    <h1 class=\"text-xl font-bold tracking-tight text-white\" data-kid=\"16\">HomeHero AI</h1>\n                    <p class=\"text-xs text-white/40 font-semibold uppercase tracking-widest\" data-kid=\"17\">Personal Assistant</p>\n                </div>\n            </div>\n            <div class=\"flex gap-2\" data-kid=\"18\">\n                <button class=\"w-10 h-10 rounded-full glass flex items-center justify-center hover:bg-white/10 transition-all border border-white/10\" data-kid=\"19\"><i class=\"fa-solid fa-cog text-white/50 text-sm\" data-kid=\"20\"></i></button>\n                <button class=\"w-10 h-10 rounded-full glass flex items-center justify-center hover:bg-white/10 transition-all border border-white/10\" data-kid=\"21\"><i class=\"fa-solid fa-history text-white/50 text-sm\" data-kid=\"22\"></i></button>\n            </div>\n        </div>\n\n        \n        <div id=\"chat-scroller\" class=\"flex-1 overflow-y-auto custom-scrollbar space-y-10 pr-4 pb-32 v1-animate\" data-kid=\"23\">\n            \n            <div class=\"flex gap-4\" data-kid=\"24\">\n                <div class=\"w-10 h-10 rounded-xl bg-gradient-to-tr from-indigo-500 to-purple-600 flex items-center justify-center shrink-0 mt-1 shadow-xl ring-1 ring-white/20\" data-kid=\"25\">\n                    <i class=\"fa-solid fa-robot text-xs text-white\" data-kid=\"26\"></i>\n                </div>\n                <div class=\"max-w-[85%] glass p-6 rounded-3xl ai-bubble space-y-6 shadow-2xl\" data-kid=\"27\">\n                    <p class=\"text-white text-base font-medium leading-relaxed\" data-kid=\"28\">Good morning, Anjali! I've analyzed your household data for today. Here's what's happening:</p>\n                    <div class=\"grid grid-cols-1 md:grid-cols-2 gap-4\" data-kid=\"29\">\n                        <div class=\"p-4 rounded-2xl bg-white/5 border border-white/10 flex items-center gap-4 hover:bg-white/10 transition-colors cursor-pointer\" data-kid=\"30\">\n                            <div class=\"w-10 h-10 rounded-xl bg-amber-500/20 flex items-center justify-center text-amber-500 text-lg\" data-kid=\"31\"><i class=\"fa-solid fa-lightbulb\" data-kid=\"32\"></i></div>\n                            <div data-kid=\"33\">\n                                <p class=\"text-[10px] text-white/50 font-bold uppercase tracking-widest mb-0.5\" data-kid=\"34\">Energy</p>\n                                <p class=\"text-sm font-bold text-white\" data-kid=\"35\">Usage up by 15%</p>\n                            </div>\n                        </div>\n                        <div class=\"p-4 rounded-2xl bg-white/5 border border-white/10 flex items-center gap-4 hover:bg-white/10 transition-colors cursor-pointer\" data-kid=\"36\">\n                            <div class=\"w-10 h-10 rounded-xl bg-emerald-500/20 flex items-center justify-center text-emerald-500 text-lg\" data-kid=\"37\"><i class=\"fa-solid fa-utensils\" data-kid=\"38\"></i></div>\n                            <div data-kid=\"39\">\n                                <p class=\"text-[10px] text-white/50 font-bold uppercase tracking-widest mb-0.5\" data-kid=\"40\">Cooking</p>\n                                <p class=\"text-sm font-bold text-white\" data-kid=\"41\">Recipe ready</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"flex flex-row-reverse gap-4\" data-kid=\"42\">\n                <div class=\"w-10 h-10 rounded-full border border-white/20 p-0.5 shrink-0 mt-1\" data-kid=\"43\">\n                    <img src=\"https://i.pravatar.cc/100?u=anjali\" alt=\"User\" class=\"w-full h-full rounded-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"44\">\n                </div>\n                <div class=\"max-w-[85%] user-bubble p-5 rounded-3xl shadow-xl\" data-kid=\"45\">\n                    <p class=\"text-base text-white font-medium\" data-kid=\"46\">What's our grocery situation? Are we running low on anything?</p>\n                </div>\n            </div>\n\n            \n            <div class=\"flex gap-4\" data-kid=\"47\">\n                <div class=\"w-10 h-10 rounded-xl bg-gradient-to-tr from-indigo-500 to-purple-600 flex items-center justify-center shrink-0 mt-1 shadow-xl ring-1 ring-white/20\" data-kid=\"48\">\n                    <i class=\"fa-solid fa-robot text-xs text-white\" data-kid=\"49\"></i>\n                </div>\n                <div class=\"max-w-[85%] glass p-6 rounded-3xl ai-bubble space-y-6 shadow-2xl\" data-kid=\"50\">\n                    <p class=\"text-white text-base font-medium leading-relaxed\" data-kid=\"51\">Based on your usage patterns, you're running low on these essentials. I've added them to your draft shopping list:</p>\n                    \n                    <div class=\"space-y-3\" data-kid=\"52\">\n                        <div class=\"flex items-center justify-between p-4 bg-white/5 rounded-2xl border border-white/10 group hover:border-white/20 transition-all hover:bg-white/10\" data-kid=\"53\">\n                            <div class=\"flex items-center gap-4\" data-kid=\"54\">\n                                <div class=\"w-10 h-10 rounded-xl bg-indigo-500/20 flex items-center justify-center text-indigo-400\" data-kid=\"55\">\n                                    <i class=\"fa-solid fa-droplet\" data-kid=\"56\"></i>\n                                </div>\n                                <div data-kid=\"57\">\n                                    <h4 class=\"text-sm font-bold text-white\" data-kid=\"58\">Cooking Oil</h4>\n                                    <p class=\"text-xs text-white/40 font-medium\" data-kid=\"59\">~2 days left</p>\n                                </div>\n                            </div>\n                            <button class=\"px-3 py-1.5 bg-indigo-500/10 text-[10px] font-bold text-indigo-400 rounded-lg group-hover:bg-indigo-500 group-hover:text-white transition-all uppercase tracking-widest\" data-kid=\"60\">DETAILS</button>\n                        </div>\n                        <div class=\"flex items-center justify-between p-4 bg-white/5 rounded-2xl border border-white/10 group hover:border-white/20 transition-all hover:bg-white/10\" data-kid=\"61\">\n                            <div class=\"flex items-center gap-4\" data-kid=\"62\">\n                                <div class=\"w-10 h-10 rounded-xl bg-purple-500/20 flex items-center justify-center text-purple-400\" data-kid=\"63\">\n                                    <i class=\"fa-solid fa-cubes-stacked\" data-kid=\"64\"></i>\n                                </div>\n                                <div data-kid=\"65\">\n                                    <h4 class=\"text-sm font-bold text-white\" data-kid=\"66\">White Rice</h4>\n                                    <p class=\"text-xs text-rose-400 font-bold tracking-tighter\" data-kid=\"67\">Critical: 1kg</p>\n                                </div>\n                            </div>\n                            <button class=\"px-3 py-1.5 bg-purple-500/10 text-[10px] font-bold text-purple-400 rounded-lg group-hover:bg-purple-500 group-hover:text-white transition-all uppercase tracking-widest\" data-kid=\"68\">DETAILS</button>\n                        </div>\n                    </div>\n\n                    <div class=\"flex gap-2 pt-1\" data-kid=\"69\">\n                        <button class=\"flex-1 py-3.5 bg-indigo-600 text-white rounded-2xl text-xs font-bold hover:bg-indigo-500 transition-all uppercase tracking-widest\" data-kid=\"70\">Order Now</button>\n                        <button class=\"flex-1 py-3.5 glass rounded-2xl text-xs font-bold hover:bg-white/10 transition-all border border-white/10 uppercase tracking-widest\" data-kid=\"71\">Edit List</button>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        \n        <div class=\"relative v1-animate\" data-kid=\"72\">\n            \n            <div class=\"flex gap-3 mb-4 overflow-x-auto custom-scrollbar pb-2 no-scrollbar\" data-kid=\"73\">\n                <button class=\"whitespace-nowrap px-5 py-2 glass rounded-full text-[10px] font-bold text-white/70 hover:text-white hover:bg-white/20 transition-all flex items-center gap-2 border border-white/10\" data-kid=\"74\">\n                    <i class=\"fa-solid fa-chart-line text-indigo-400\" data-kid=\"75\"></i> ANALYZE SAVINGS\n                </button>\n                <button class=\"whitespace-nowrap px-5 py-2 glass rounded-full text-[10px] font-bold text-white/70 hover:text-white hover:bg-white/20 transition-all flex items-center gap-2 border border-white/10\" data-kid=\"76\">\n                    <i class=\"fa-solid fa-clock-rotate-left text-purple-400\" data-kid=\"77\"></i> PENDING BILLS\n                </button>\n                <button class=\"whitespace-nowrap px-5 py-2 glass rounded-full text-[10px] font-bold text-white/70 hover:text-white hover:bg-white/20 transition-all flex items-center gap-2 border border-white/10\" data-kid=\"78\">\n                    <i class=\"fa-solid fa-house-medical text-rose-400\" data-kid=\"79\"></i> EMERGENCY MODE\n                </button>\n            </div>\n\n            \n            <div class=\"glass p-2 rounded-3xl flex items-center gap-2 border-white/20 focus-within:border-indigo-500/50 transition-all mb-4\" data-kid=\"80\">\n                <button class=\"w-10 h-10 rounded-full flex items-center justify-center text-white/30 hover:text-white transition-colors\" data-kid=\"81\">\n                    <i class=\"fa-solid fa-plus text-lg\" data-kid=\"82\"></i>\n                </button>\n                <input type=\"text\" placeholder=\"Ask HomeHero anything...\" class=\"flex-1 bg-transparent border-none focus:ring-0 text-white placeholder-white/20 text-sm py-4\" data-kid=\"83\">\n                \n                <button class=\"group relative w-12 h-12 flex items-center justify-center\" data-kid=\"84\">\n                    <div class=\"orb-glow absolute inset-0 rounded-full scale-75 group-hover:scale-100 transition-transform duration-500\" data-kid=\"85\"></div>\n                    <div class=\"relative w-10 h-10 rounded-xl bg-gradient-to-tr from-indigo-500 to-purple-600 flex items-center justify-center shadow-lg group-hover:shadow-indigo-500/40 transition-all\" data-kid=\"86\">\n                        <i class=\"fa-solid fa-microphone text-white group-hover:scale-110 transition-transform\" data-kid=\"87\"></i>\n                    </div>\n                </button>\n            </div>\n        </div>\n    </div>\n\n    \n    <div id=\"variant-2\" class=\"variant-container hidden w-full h-[90vh] flex gap-6 p-4\" data-kid=\"88\">\n        \n        <div class=\"flex-1 glass rounded-[2.5rem] p-10 space-y-10 overflow-y-auto custom-scrollbar\" data-kid=\"89\">\n            <header class=\"flex justify-between items-end\" data-kid=\"90\">\n                <div class=\"space-y-1\" data-kid=\"91\">\n                    <p class=\"text-sm font-semibold text-indigo-400 uppercase tracking-widest\" data-kid=\"92\">Dashboard Overview</p>\n                    <h2 class=\"text-4xl font-extrabold text-white\" data-kid=\"93\">Welcome, Anjali</h2>\n                </div>\n                <div class=\"flex items-center gap-2 bg-white/5 p-2 rounded-2xl border border-white/10\" data-kid=\"94\">\n                    <div class=\"w-10 h-10 rounded-xl bg-blue-500/20 flex items-center justify-center text-blue-400\" data-kid=\"95\"><i class=\"fa-solid fa-cloud-sun\" data-kid=\"96\"></i></div>\n                    <div class=\"pr-2\" data-kid=\"97\">\n                        <p class=\"text-xs font-bold leading-none\" data-kid=\"98\">24°C</p>\n                        <p class=\"text-[10px] text-white/40 font-medium\" data-kid=\"99\">Partly Cloudy</p>\n                    </div>\n                </div>\n            </header>\n\n            <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-6\" data-kid=\"100\">\n                \n                <div class=\"p-8 rounded-[2rem] bg-gradient-to-br from-indigo-500/10 to-transparent border border-white/10 space-y-6\" data-kid=\"101\">\n                    <div class=\"flex justify-between items-center\" data-kid=\"102\">\n                        <h3 class=\"text-lg font-bold\" data-kid=\"103\">Family Health</h3>\n                        <i class=\"fa-solid fa-heart-pulse text-rose-500\" data-kid=\"104\"></i>\n                    </div>\n                    <div class=\"flex items-end justify-between gap-2 h-20 pt-2\" data-kid=\"105\">\n                        <div class=\"flex-1 h-full bg-white/5 rounded-lg relative overflow-hidden\" data-kid=\"106\"><div class=\"absolute bottom-0 w-full bg-indigo-500 h-[40%] rounded-t-sm\" data-kid=\"107\"></div></div>\n                        <div class=\"flex-1 h-full bg-white/5 rounded-lg relative overflow-hidden\" data-kid=\"108\"><div class=\"absolute bottom-0 w-full bg-indigo-500 h-[70%] rounded-t-sm\" data-kid=\"109\"></div></div>\n                        <div class=\"flex-1 h-full bg-white/5 rounded-lg relative overflow-hidden\" data-kid=\"110\"><div class=\"absolute bottom-0 w-full bg-indigo-500 h-[55%] rounded-t-sm\" data-kid=\"111\"></div></div>\n                        <div class=\"flex-1 h-full bg-white/5 rounded-lg relative overflow-hidden\" data-kid=\"112\"><div class=\"absolute bottom-0 w-full bg-indigo-500 h-[90%] rounded-t-sm\" data-kid=\"113\"></div></div>\n                        <div class=\"flex-1 h-full bg-white/5 rounded-lg relative overflow-hidden\" data-kid=\"114\"><div class=\"absolute bottom-0 w-full bg-indigo-500 h-[65%] rounded-t-sm\" data-kid=\"115\"></div></div>\n                    </div>\n                    <p class=\"text-xs text-white/50 leading-relaxed italic\" data-kid=\"116\">\"Sleep levels for the family are up 12% this week. Keep it up!\"</p>\n                </div>\n\n                \n                <div class=\"p-8 rounded-[2rem] glass space-y-6\" data-kid=\"117\">\n                    <div class=\"flex justify-between items-center\" data-kid=\"118\">\n                        <h3 class=\"text-lg font-bold\" data-kid=\"119\">Expense Forecast</h3>\n                        <i class=\"fa-solid fa-chart-pie text-indigo-400\" data-kid=\"120\"></i>\n                    </div>\n                    <div class=\"flex items-center gap-6\" data-kid=\"121\">\n                        <div class=\"relative w-24 h-24 flex items-center justify-center\" data-kid=\"122\">\n                            <svg class=\"w-full h-full transform -rotate-90\" data-kid=\"123\">\n                                <circle cx=\"48\" cy=\"48\" r=\"40\" stroke=\"currentColor\" stroke-width=\"8\" fill=\"transparent\" class=\"text-white/5\" data-kid=\"124\"></circle>\n                                <circle cx=\"48\" cy=\"48\" r=\"40\" stroke=\"currentColor\" stroke-width=\"8\" fill=\"transparent\" stroke-dasharray=\"251\" stroke-dashoffset=\"60\" class=\"text-indigo-500\" data-kid=\"125\"></circle>\n                            </svg>\n                            <span class=\"absolute text-sm font-bold\" data-kid=\"126\">75%</span>\n                        </div>\n                        <div class=\"flex-1 space-y-2\" data-kid=\"127\">\n                            <p class=\"text-xs text-white/50 uppercase font-bold tracking-tighter\" data-kid=\"128\">Budget Status</p>\n                            <p class=\"text-lg font-bold\" data-kid=\"129\">On Track</p>\n                            <p class=\"text-[10px] text-emerald-400\" data-kid=\"130\">Estimated savings: ₹4,200</p>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        \n        <div class=\"w-96 glass rounded-[2.5rem] flex flex-col p-6 space-y-6 overflow-hidden border-indigo-500/20 shadow-2xl shadow-indigo-500/10\" data-kid=\"131\">\n            <div class=\"flex items-center gap-3\" data-kid=\"132\">\n                <div class=\"w-10 h-10 rounded-xl bg-gradient-to-br from-indigo-500 to-purple-500 flex items-center justify-center shadow-lg\" data-kid=\"133\"><i class=\"fa-solid fa-sparkles text-white text-sm\" data-kid=\"134\"></i></div>\n                <h3 class=\"font-bold\" data-kid=\"135\">HomeHero Sidekick</h3>\n            </div>\n\n            <div class=\"flex-1 overflow-y-auto custom-scrollbar space-y-4 pr-2\" data-kid=\"136\">\n                <div class=\"bg-white/5 rounded-2xl p-4 border border-white/10 v2-animate\" data-kid=\"137\">\n                    <p class=\"text-[10px] text-indigo-400 font-black tracking-widest mb-1 uppercase\" data-kid=\"138\">Proactive Insight</p>\n                    <p class=\"text-xs leading-relaxed text-white/90 font-medium\" data-kid=\"139\">Rain expected at 4 PM. Reminders sent to family members to carry umbrellas.</p>\n                </div>\n\n                <div class=\"flex justify-start\" data-kid=\"140\">\n                    <div class=\"max-w-[90%] glass p-4 rounded-2xl rounded-tl-none border-white/5 text-xs leading-relaxed text-white/70\" data-kid=\"141\">\n                        Ask me about today's bills or recipe ideas for dinner.\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"pt-4 space-y-4\" data-kid=\"142\">\n                <div class=\"flex items-center gap-2 p-1.5 glass rounded-2xl border-white/10\" data-kid=\"143\">\n                    <input type=\"text\" placeholder=\"Talk to AI...\" class=\"flex-1 bg-transparent border-none focus:ring-0 text-white placeholder-white/20 text-xs py-2 pl-3\" data-kid=\"144\">\n                    <button class=\"w-8 h-8 rounded-xl bg-indigo-500 flex items-center justify-center hover:bg-indigo-400 transition-colors\" data-kid=\"145\"><i class=\"fa-solid fa-paper-plane text-[10px] text-white\" data-kid=\"146\"></i></button>\n                </div>\n                <div class=\"flex justify-center\" data-kid=\"147\">\n                    <div class=\"flex items-end gap-1.5 h-6\" data-kid=\"148\">\n                        <div class=\"w-1 bg-indigo-400 rounded-full voice-wave-bar\" style=\"animation-delay: 0.1s\" data-kid=\"149\"></div>\n                        <div class=\"w-1 bg-purple-400 rounded-full voice-wave-bar\" style=\"animation-delay: 0.3s\" data-kid=\"150\"></div>\n                        <div class=\"w-1 bg-indigo-400 rounded-full voice-wave-bar\" style=\"animation-delay: 0.2s\" data-kid=\"151\"></div>\n                        <div class=\"w-1 bg-purple-400 rounded-full voice-wave-bar\" style=\"animation-delay: 0.5s\" data-kid=\"152\"></div>\n                        <div class=\"w-1 bg-indigo-400 rounded-full voice-wave-bar\" style=\"animation-delay: 0.4s\" data-kid=\"153\"></div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    \n    <div id=\"variant-3\" class=\"variant-container hidden flex flex-col items-center justify-center w-full h-[80vh] space-y-12\" data-kid=\"154\">\n        <div class=\"relative w-72 h-72 flex items-center justify-center\" data-kid=\"155\">\n            \n            <div class=\"absolute inset-0 rounded-full bg-indigo-500/5 border border-indigo-500/10 animate-ping\" style=\"animation-duration: 4s\" data-kid=\"156\"></div>\n            <div class=\"absolute inset-8 rounded-full bg-purple-500/5 border border-purple-500/10 animate-ping\" style=\"animation-duration: 3s; animation-delay: 1s\" data-kid=\"157\"></div>\n            \n            \n            <div class=\"relative w-36 h-36 rounded-full bg-gradient-to-tr from-indigo-600 via-purple-500 to-rose-400 shadow-[0_0_100px_rgba(129,140,248,0.4)] flex items-center justify-center overflow-hidden border border-white/30\" data-kid=\"158\">\n                <div class=\"orb-glow absolute inset-0 rounded-full opacity-60\" data-kid=\"159\"></div>\n                <div class=\"absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(255,255,255,0.3),transparent_60%)]\" data-kid=\"160\"></div>\n                <div class=\"inner-wave absolute bottom-0 left-0 w-full h-1/2 bg-white/10 blur-2xl\" data-kid=\"161\"></div>\n                <i class=\"fa-solid fa-microphone text-white text-5xl z-10 drop-shadow-lg\" data-kid=\"162\"></i>\n            </div>\n        </div>\n\n        <div class=\"text-center space-y-4 max-w-lg\" data-kid=\"163\">\n            <h2 class=\"text-4xl font-black tracking-tight text-white\" data-kid=\"164\">How can I help you?</h2>\n            <p class=\"text-lg text-white/40 font-medium\" data-kid=\"165\">\"Add tomatoes to grocery list\", \"What is my credit card bill?\", or \"Is it raining outside?\"</p>\n        </div>\n\n        <div class=\"flex gap-4\" data-kid=\"166\">\n            <button class=\"px-8 py-3 glass rounded-2xl text-sm font-bold hover:bg-white/10 transition-all\" data-kid=\"167\">Type a command</button>\n            <button class=\"px-8 py-3 bg-white text-black rounded-2xl text-sm font-bold hover:bg-slate-200 transition-all\" data-kid=\"168\">Enable Voice Always</button>\n        </div>\n    </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"169\"></script>\n<script data-kid=\"170\">\n    function switchVariant(v) {\n        // Update Tabs\n        document.querySelectorAll('.variant-tab').forEach(tab => {\n            tab.classList.remove('tab-active', 'text-white');\n            tab.classList.add('text-white/50');\n        });\n        document.getElementById('tab-' + v).classList.add('tab-active', 'text-white');\n        document.getElementById('tab-' + v).classList.remove('text-white/50');\n\n        // Animation for transition\n        const containers = document.querySelectorAll('.variant-container');\n        gsap.to(containers, {\n            opacity: 0,\n            y: 20,\n            duration: 0.3,\n            onComplete: () => {\n                containers.forEach(c => c.classList.add('hidden'));\n                const activeContainer = document.getElementById('variant-' + v);\n                activeContainer.classList.remove('hidden');\n                gsap.fromTo(activeContainer, \n                    { opacity: 0, y: 20 },\n                    { opacity: 1, y: 0, duration: 0.5, ease: \"power2.out\" }\n                );\n            }\n        });\n    }\n\n    // Initial entrance\n    window.onload = () => {\n        gsap.from(\".v1-animate\", {\n            opacity: 0,\n            y: 20,\n            stagger: 0.1,\n            duration: 0.8,\n            ease: \"power3.out\"\n        });\n        \n        // Floating animation for the orb\n        gsap.to(\".orb-glow\", {\n            y: -10,\n            duration: 2,\n            repeat: -1,\n            yoyo: true,\n            ease: \"sine.inOut\"\n        });\n    };\n</script>\n",
      "comments": [],
      "created": "2026-07-04T08:37:22.508471+00:00",
      "modified": "2026-07-04T08:37:22.508471+00:00",
      "id": "var_2b05db1d1cba"
    },
    "var_3ef56bd1ca9b": {
      "type": "variant",
      "label": "Family Task Manager",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 14920,
        "y": 0,
        "w": 1440,
        "h": 800
      },
      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap');\n  @import url('https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css');\n\n  :root {\n    --glass-bg-light: rgba(255, 255, 255, 0.4);\n    --glass-border-light: rgba(255, 255, 255, 0.5);\n    --glass-bg-dark: rgba(15, 23, 42, 0.3);\n    --glass-border-dark: rgba(255, 255, 255, 0.1);\n  }\n\n  body {\n    font-family: 'Plus Jakarta Sans', sans-serif;\n    background: #fdfdff;\n    color: #1e293b;\n    scroll-behavior: smooth;\n  }\n\n  .font-outfit { font-family: 'Outfit', sans-serif; }\n\n  /* Glassmorphism Classes */\n  .glass-card {\n    background: var(--glass-bg-light);\n    backdrop-filter: blur(16px);\n    -webkit-backdrop-filter: blur(16px);\n    border: 1px solid var(--glass-border-light);\n    box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.05);\n  }\n\n  .glass-card-dark {\n    background: var(--glass-bg-dark);\n    backdrop-filter: blur(20px);\n    -webkit-backdrop-filter: blur(20px);\n    border: 1px solid var(--glass-border-dark);\n    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.2);\n  }\n\n  /* Custom Animations */\n  .float { animation: float 6s ease-in-out infinite; }\n  @keyframes float {\n    0% { transform: translateY(0px); }\n    50% { transform: translateY(-15px); }\n    100% { transform: translateY(0px); }\n  }\n\n  /* Custom Scrollbar */\n  ::-webkit-scrollbar { width: 8px; }\n  ::-webkit-scrollbar-track { background: #f1f5f9; }\n  ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }\n  ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }\n</style>\n\n<div class=\"relative min-h-screen overflow-x-clip bg-slate-50/50\" data-kid=\"1\">\n  \n  <nav class=\"fixed top-6 left-1/2 -translate-x-1/2 z-50 glass-card rounded-full px-6 py-2 flex gap-2 text-sm font-bold shadow-xl border-white/60\" data-kid=\"2\">\n    <a href=\"#v1\" class=\"px-5 py-2 rounded-full hover:bg-indigo-600 hover:text-white transition-all text-slate-600\" data-kid=\"3\">01 Playful</a>\n    <a href=\"#v2\" class=\"px-5 py-2 rounded-full hover:bg-indigo-600 hover:text-white transition-all text-slate-600\" data-kid=\"4\">02 Minimal</a>\n    <a href=\"#v3\" class=\"px-5 py-2 rounded-full hover:bg-indigo-600 hover:text-white transition-all text-slate-600\" data-kid=\"5\">03 Dashboard</a>\n  </nav>\n\n  \n  \n  \n  <section id=\"v1\" class=\"min-h-screen py-32 px-6 max-w-7xl mx-auto border-b border-slate-100\" data-kid=\"6\">\n    <div class=\"mb-20 flex flex-col md:flex-row items-end justify-between gap-8\" data-kid=\"7\">\n      <div class=\"max-w-xl\" data-kid=\"8\">\n        <h2 class=\"font-outfit text-6xl font-black text-slate-900 mb-6 leading-[0.9] tracking-tight\" data-kid=\"9\">Level Up <br data-kid=\"10\"><span class=\"text-indigo-600\" data-kid=\"11\">Together.</span></h2>\n        <p class=\"text-slate-500 text-xl font-medium\" data-kid=\"12\">Earn epic rewards by crushing household chores. Who will lead the family this week?</p>\n      </div>\n      <button class=\"bg-indigo-600 hover:bg-indigo-700 text-white px-8 py-4 rounded-3xl font-extrabold flex items-center gap-3 transition-all hover:-rotate-2 hover:scale-105 shadow-xl shadow-indigo-100\" data-kid=\"13\">\n        <i class=\"fa-solid fa-sparkles\" data-kid=\"14\"></i> START NEW ADVENTURE\n      </button>\n    </div>\n\n    <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-10 items-stretch\" data-kid=\"15\">\n      \n      <div class=\"lg:col-span-8 grid grid-cols-1 md:grid-cols-2 gap-6\" data-kid=\"16\">\n          \n          <div class=\"v1-task-card glass-card rounded-[3rem] p-10 relative group hover:bg-white border-white hover:transition-colors\" data-kid=\"17\">\n            <div class=\"flex items-start justify-between mb-8\" data-kid=\"18\">\n              <div class=\"w-20 h-20 bg-blue-500/10 rounded-[2rem] flex items-center justify-center text-blue-600 group-hover:bg-blue-500 group-hover:text-white transition-all duration-500\" data-kid=\"19\">\n                <i class=\"fa-solid fa-broom text-4xl\" data-kid=\"20\"></i>\n              </div>\n              <div class=\"flex flex-col items-end\" data-kid=\"21\">\n                <span class=\"bg-amber-400 text-slate-900 text-sm font-black px-4 py-1.5 rounded-full shadow-lg rotate-6\" data-kid=\"22\">+50 PTS</span>\n                <span class=\"text-[10px] font-bold text-slate-400 mt-2 uppercase tracking-widest\" data-kid=\"23\">Priority: High</span>\n              </div>\n            </div>\n            <h4 class=\"font-outfit text-3xl font-bold text-slate-900 mb-3\" data-kid=\"24\">Living Room Polish</h4>\n            <p class=\"text-slate-500 mb-8 font-medium\" data-kid=\"25\">Make it sparkle before the guests arrive this evening!</p>\n            <div class=\"pt-8 border-t border-slate-100 flex items-center justify-between\" data-kid=\"26\">\n              <div class=\"flex items-center gap-4\" data-kid=\"27\">\n                <img src=\"https://i.pravatar.cc/100?u=rohan\" class=\"w-12 h-12 rounded-full border-4 border-white shadow-lg\" alt data-kid=\"28\">\n                <div data-kid=\"29\">\n                  <p class=\"text-[10px] font-bold text-slate-400 uppercase\" data-kid=\"30\">Assigned</p>\n                  <p class=\"font-extrabold text-slate-800\" data-kid=\"31\">Rohan K.</p>\n                </div>\n              </div>\n              <button class=\"w-14 h-14 rounded-2xl bg-slate-900 text-white flex items-center justify-center hover:bg-blue-600 transition-colors shadow-lg\" data-kid=\"32\">\n                <i class=\"fa-solid fa-check text-xl\" data-kid=\"33\"></i>\n              </button>\n            </div>\n          </div>\n\n          \n          <div class=\"v1-task-card glass-card rounded-[3rem] p-10 relative group hover:bg-white border-white hover:transition-colors\" data-kid=\"34\">\n            <div class=\"flex items-start justify-between mb-8\" data-kid=\"35\">\n              <div class=\"w-20 h-20 bg-purple-500/10 rounded-[2rem] flex items-center justify-center text-purple-600 group-hover:bg-purple-500 group-hover:text-white transition-all duration-500\" data-kid=\"36\">\n                <i class=\"fa-solid fa-shirt text-4xl\" data-kid=\"37\"></i>\n              </div>\n              <div class=\"flex flex-col items-end\" data-kid=\"38\">\n                <span class=\"bg-indigo-500 text-white text-sm font-black px-4 py-1.5 rounded-full shadow-lg -rotate-3\" data-kid=\"39\">+30 PTS</span>\n                <span class=\"text-[10px] font-bold text-slate-400 mt-2 uppercase tracking-widest\" data-kid=\"40\">Priority: Mid</span>\n              </div>\n            </div>\n            <h4 class=\"font-outfit text-3xl font-bold text-slate-900 mb-3\" data-kid=\"41\">Laundry Mountain</h4>\n            <p class=\"text-slate-500 mb-8 font-medium\" data-kid=\"42\">Wash, dry, and fold. Let's conquer the peak together!</p>\n            <div class=\"pt-8 border-t border-slate-100 flex items-center justify-between\" data-kid=\"43\">\n              <div class=\"flex items-center gap-4\" data-kid=\"44\">\n                <img src=\"https://i.pravatar.cc/100?u=mom\" class=\"w-12 h-12 rounded-full border-4 border-white shadow-lg\" alt data-kid=\"45\">\n                <div data-kid=\"46\">\n                  <p class=\"text-[10px] font-bold text-slate-400 uppercase\" data-kid=\"47\">Assigned</p>\n                  <p class=\"font-extrabold text-slate-800\" data-kid=\"48\">Mom</p>\n                </div>\n              </div>\n              <button class=\"w-14 h-14 rounded-2xl bg-slate-900 text-white flex items-center justify-center hover:bg-purple-600 transition-colors shadow-lg\" data-kid=\"49\">\n                <i class=\"fa-solid fa-check text-xl\" data-kid=\"50\"></i>\n              </button>\n            </div>\n          </div>\n      </div>\n\n      \n      <div class=\"lg:col-span-4\" data-kid=\"51\">\n        <div class=\"glass-card rounded-[3.5rem] p-10 border-white shadow-2xl h-full flex flex-col\" data-kid=\"52\">\n          <div class=\"absolute top-0 right-0 opacity-10 -mr-12 -mt-12 text-[10rem] rotate-12 text-slate-400\" data-kid=\"53\">\n            <i class=\"fa-solid fa-trophy\" data-kid=\"54\"></i>\n          </div>\n          <h3 class=\"font-outfit text-3xl font-extrabold text-slate-800 mb-8 flex items-center gap-3\" data-kid=\"55\">\n            <i class=\"fa-solid fa-crown text-amber-500\" data-kid=\"56\"></i> Leaderboard\n          </h3>\n          <div class=\"space-y-6 relative z-10\" data-kid=\"57\">\n            \n            <div class=\"flex items-center gap-5 p-4 bg-indigo-50/50 rounded-3xl border border-indigo-100/50\" data-kid=\"58\">\n              <div class=\"relative\" data-kid=\"59\">\n                <img src=\"https://i.pravatar.cc/100?u=anjali\" class=\"w-16 h-16 rounded-2xl border-4 border-white shadow-md\" alt=\"Anjali\" data-kid=\"60\">\n                <div class=\"absolute -bottom-2 -right-2 w-8 h-8 bg-amber-400 text-white rounded-full flex items-center justify-center font-bold text-sm border-2 border-white\" data-kid=\"61\">1</div>\n              </div>\n              <div data-kid=\"62\">\n                <h4 class=\"font-bold text-slate-800\" data-kid=\"63\">Anjali</h4>\n                <p class=\"text-xs font-bold text-indigo-600 uppercase\" data-kid=\"64\">1,240 Points</p>\n              </div>\n              <div class=\"ml-auto flex items-center gap-1 text-emerald-500 font-bold\" data-kid=\"65\">\n                <i class=\"fa-solid fa-arrow-up text-[10px]\" data-kid=\"66\"></i>\n                <span data-kid=\"67\">+4</span>\n              </div>\n            </div>\n            \n            <div class=\"flex items-center gap-5 p-4 rounded-3xl border border-white/40\" data-kid=\"68\">\n              <div class=\"relative\" data-kid=\"69\">\n                <img src=\"https://i.pravatar.cc/100?u=dad\" class=\"w-16 h-16 rounded-2xl border-4 border-white shadow-sm\" alt=\"Dad\" data-kid=\"70\">\n                <div class=\"absolute -bottom-2 -right-2 w-8 h-8 bg-slate-200 text-slate-500 rounded-full flex items-center justify-center font-bold text-sm border-2 border-white\" data-kid=\"71\">2</div>\n              </div>\n              <div data-kid=\"72\">\n                <h4 class=\"font-bold text-slate-800\" data-kid=\"73\">Dad</h4>\n                <p class=\"text-xs font-bold text-slate-400 uppercase\" data-kid=\"74\">980 Points</p>\n              </div>\n            </div>\n             \n             <div class=\"flex items-center gap-5 p-4 rounded-3xl border border-white/40\" data-kid=\"75\">\n              <div class=\"relative\" data-kid=\"76\">\n                <img src=\"https://i.pravatar.cc/100?u=rohan\" class=\"w-16 h-16 rounded-2xl border-4 border-white shadow-sm\" alt=\"Rohan\" data-kid=\"77\">\n                <div class=\"absolute -bottom-2 -right-2 w-8 h-8 bg-orange-200 text-orange-600 rounded-full flex items-center justify-center font-bold text-sm border-2 border-white\" data-kid=\"78\">3</div>\n              </div>\n              <div data-kid=\"79\">\n                <h4 class=\"font-bold text-slate-800\" data-kid=\"80\">Rohan</h4>\n                <p class=\"text-xs font-bold text-slate-400 uppercase\" data-kid=\"81\">845 Points</p>\n              </div>\n            </div>\n          </div>\n          <button class=\"w-full mt-10 bg-slate-900 text-white py-4 rounded-2xl font-bold hover:bg-slate-800 transition-all\" data-kid=\"82\">View All Standings</button>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  \n  \n  <section id=\"v2\" class=\"min-h-screen py-24 px-6 bg-white/30 backdrop-blur-3xl border-y border-white/40\" data-kid=\"83\">\n    <div class=\"max-w-7xl mx-auto\" data-kid=\"84\">\n      <div class=\"mb-16 flex flex-col md:flex-row items-center justify-between gap-6\" data-kid=\"85\">\n        <div data-kid=\"86\">\n          <span class=\"inline-block px-3 py-1 rounded-md bg-slate-900 text-white font-bold text-[10px] uppercase tracking-widest mb-4\" data-kid=\"87\">Variant 02</span>\n          <h2 class=\"font-outfit text-4xl font-light text-slate-900 mb-2\" data-kid=\"88\">Crystal <span class=\"font-bold\" data-kid=\"89\">Minimalism</span></h2>\n          <p class=\"text-slate-400 text-lg\" data-kid=\"90\">Sophisticated glass effects with a focus on essential information.</p>\n        </div>\n        <div class=\"flex gap-4\" data-kid=\"91\">\n           <button class=\"px-6 py-2 rounded-lg border border-slate-200 font-bold text-slate-600 hover:bg-slate-50 transition-colors\" data-kid=\"92\">Family Stats</button>\n           <button class=\"px-6 py-2 rounded-lg bg-slate-900 text-white font-bold shadow-lg hover:bg-slate-800 transition-all\" data-kid=\"93\">Assign Tasks</button>\n        </div>\n      </div>\n\n      <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8\" data-kid=\"94\">\n        \n        <div class=\"glass-card rounded-2xl p-1 bg-white/50 border-white shadow-sm overflow-hidden group hover:shadow-md transition-shadow\" data-kid=\"95\">\n           <div class=\"p-6 bg-gradient-to-br from-indigo-50/50 to-transparent rounded-t-2xl border-b border-white/60\" data-kid=\"96\">\n             <div class=\"flex justify-between items-center mb-6\" data-kid=\"97\">\n                <div class=\"p-3 bg-indigo-600 text-white rounded-xl shadow-lg shadow-indigo-200\" data-kid=\"98\">\n                  <i class=\"fa-solid fa-kitchen-set\" data-kid=\"99\"></i>\n                </div>\n                <div class=\"flex flex-col items-end\" data-kid=\"100\">\n                  <span class=\"text-[10px] font-extrabold text-indigo-400 uppercase tracking-tighter\" data-kid=\"101\">Kitchen Duties</span>\n                  <span class=\"text-[9px] text-slate-400\" data-kid=\"102\">4 tasks today</span>\n                </div>\n             </div>\n             <h4 class=\"font-outfit text-xl font-bold text-slate-800 mb-1\" data-kid=\"103\">Morning Prep</h4>\n             <p class=\"text-xs text-slate-400 mb-4\" data-kid=\"104\">Clean up after breakfast and prep lunch items.</p>\n             <div class=\"w-full bg-slate-200/50 h-2 rounded-full overflow-hidden backdrop-blur-sm\" data-kid=\"105\">\n               <div class=\"bg-gradient-to-r from-indigo-400 to-indigo-600 h-full w-2/3 rounded-full\" data-kid=\"106\"></div>\n             </div>\n             <div class=\"flex justify-between items-center mt-2\" data-kid=\"107\">\n                <p class=\"text-[10px] font-bold text-indigo-600\" data-kid=\"108\">66% COMPLETED</p>\n                <div class=\"flex -space-x-2\" data-kid=\"109\">\n                  <img src=\"https://i.pravatar.cc/100?u=rohan\" class=\"w-4 h-4 rounded-full border border-white\" alt data-kid=\"110\">\n                  <img src=\"https://i.pravatar.cc/100?u=anjali\" class=\"w-4 h-4 rounded-full border border-white\" alt data-kid=\"111\">\n                </div>\n             </div>\n           </div>\n           <div class=\"p-4 space-y-2\" data-kid=\"112\">\n             <div class=\"flex items-center justify-between p-3 rounded-xl bg-white/40 border border-white/80 hover:bg-white/80 transition-colors cursor-pointer group/item\" data-kid=\"113\">\n               <div class=\"flex items-center gap-3\" data-kid=\"114\">\n                 <div class=\"w-2 h-2 rounded-full bg-emerald-400\" data-kid=\"115\"></div>\n                 <span class=\"text-sm font-medium text-slate-700\" data-kid=\"116\">Dishwashing</span>\n               </div>\n               <img src=\"https://i.pravatar.cc/100?u=rohan\" class=\"w-6 h-6 rounded-full grayscale group-hover/item:grayscale-0 transition-all\" alt data-kid=\"117\">\n             </div>\n             <div class=\"flex items-center justify-between p-3 rounded-xl bg-indigo-600/5 border border-indigo-100 hover:bg-indigo-100/20 transition-colors cursor-pointer group/item\" data-kid=\"118\">\n               <div class=\"flex items-center gap-3\" data-kid=\"119\">\n                 <div class=\"w-2 h-2 rounded-full bg-slate-300\" data-kid=\"120\"></div>\n                 <span class=\"text-sm font-medium text-slate-700\" data-kid=\"121\">Prep Veggies</span>\n               </div>\n               <img src=\"https://i.pravatar.cc/100?u=anjali\" class=\"w-6 h-6 rounded-full\" alt data-kid=\"122\">\n             </div>\n           </div>\n        </div>\n\n        \n        <div class=\"glass-card rounded-2xl p-1 bg-white/50 border-white shadow-sm overflow-hidden group hover:shadow-md transition-shadow\" data-kid=\"123\">\n          <div class=\"p-6 bg-gradient-to-br from-rose-50/50 to-transparent rounded-t-2xl border-b border-white/60\" data-kid=\"124\">\n            <div class=\"flex justify-between items-center mb-6\" data-kid=\"125\">\n               <div class=\"p-3 bg-rose-500 text-white rounded-xl shadow-lg shadow-rose-200\" data-kid=\"126\">\n                 <i class=\"fa-solid fa-cart-shopping\" data-kid=\"127\"></i>\n               </div>\n               <div class=\"flex flex-col items-end\" data-kid=\"128\">\n                <span class=\"text-[10px] font-extrabold text-rose-400 uppercase tracking-tighter\" data-kid=\"129\">Grocery Runs</span>\n                <span class=\"text-[9px] text-slate-400\" data-kid=\"130\">2 active list</span>\n              </div>\n            </div>\n            <h4 class=\"font-outfit text-xl font-bold text-slate-800 mb-1\" data-kid=\"131\">Weekly Stock</h4>\n            <p class=\"text-xs text-slate-400 mb-4\" data-kid=\"132\">Check pantry and head to the local supermarket.</p>\n            <div class=\"w-full bg-slate-200/50 h-2 rounded-full overflow-hidden backdrop-blur-sm\" data-kid=\"133\">\n              <div class=\"bg-gradient-to-r from-rose-400 to-rose-600 h-full w-1/4 rounded-full\" data-kid=\"134\"></div>\n            </div>\n            <div class=\"flex justify-between item