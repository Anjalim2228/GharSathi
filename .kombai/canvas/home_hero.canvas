      "html": "\n<div class=\"min-h-screen bg-[#F8FAFC] font-sans text-slate-900 selection:bg-indigo-100\" data-kid=\"0\">\n    \n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css\" data-kid=\"1\">\n    \n    \n    <style data-kid=\"2\">\n        @import url('https://fonts.googleapis.com/css2?family=Geist:wght@100..900&family=Inter:wght@300;400;500;600;700&display=swap');\n        \n        body {\n            font-family: 'Inter', sans-serif;\n        }\n        \n        .font-geist {\n            font-family: 'Geist', sans-serif;\n        }\n\n        .glass-panel {\n            background: rgba(255, 255, 255, 0.7);\n            backdrop-filter: blur(12px);\n            border: 1px solid rgba(255, 255, 255, 0.3);\n        }\n\n        .id-card-shadow {\n            box-shadow: 0 20px 35px -8px rgba(0, 0, 0, 0.12), 0 10px 20px -8px rgba(0, 0, 0, 0.05);\n        }\n\n        .id-card-texture {\n            background-image: radial-gradient(circle at 2px 2px, rgba(255,255,255,0.05) 1px, transparent 0);\n            background-size: 16px 16px;\n        }\n\n        .watermark-svg {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%) scale(2);\n            opacity: 0.03;\n            pointer-events: none;\n        }\n\n        .card-sheen {\n            background: linear-gradient(135deg, rgba(255,255,255,0.15) 0%, rgba(255,255,255,0) 50%, rgba(255,255,255,0.05) 100%);\n        }\n\n        .chip-icon {\n            background: linear-gradient(135deg, #fcd34d 0%, #d97706 100%);\n            width: 38px;\n            height: 28px;\n            border-radius: 4px;\n            position: relative;\n        }\n\n        .chip-icon::after {\n            content: '';\n            position: absolute;\n            inset: 4px;\n            border: 1px solid rgba(0,0,0,0.1);\n            border-radius: 2px;\n        }\n\n        /* Hide scrollbar but keep functionality */\n        .no-scrollbar::-webkit-scrollbar {\n            display: none;\n        }\n        .no-scrollbar {\n            -ms-overflow-style: none;\n            scrollbar-width: none;\n        }\n\n        .view-content {\n            display: none;\n        }\n        .view-content.active {\n            display: block;\n        }\n    </style>\n\n    \n    <header class=\"sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-200/60\" data-kid=\"3\">\n        <div class=\"max-w-7xl mx-auto px-6 h-20 flex items-center justify-between\" data-kid=\"4\">\n            <div class=\"flex items-center gap-4\" data-kid=\"5\">\n                <div class=\"w-10 h-10 bg-indigo-600 rounded-xl flex items-center justify-center text-white shadow-lg shadow-indigo-200\" data-kid=\"6\">\n                    <i class=\"fa-solid fa-vault text-lg\" data-kid=\"7\"></i>\n                </div>\n                <div data-kid=\"8\">\n                    <h1 class=\"text-xl font-bold tracking-tight text-slate-900\" data-kid=\"9\">Document Vault</h1>\n                    <p class=\"text-xs text-slate-500 font-medium flex items-center gap-1.5\" data-kid=\"10\">\n                        <span class=\"w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse\" data-kid=\"11\"></span>\n                        Securely Synced\n                    </p>\n                </div>\n            </div>\n\n            \n            <div class=\"flex-1 max-w-md mx-8 hidden md:block\" data-kid=\"12\">\n                <div class=\"relative group\" data-kid=\"13\">\n                    <i class=\"fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-indigo-600 transition-colors\" data-kid=\"14\"></i>\n                    <input type=\"text\" placeholder=\"Ask AI to find a document...\" class=\"w-full bg-slate-50 border border-slate-200/60 rounded-2xl py-2.5 pl-11 pr-4 text-sm focus:ring-4 focus:ring-indigo-500/5 focus:border-indigo-500/50 transition-all outline-none\" data-kid=\"15\">\n                    <div class=\"absolute right-3 top-1/2 -translate-y-1/2 flex items-center gap-1 opacity-0 group-focus-within:opacity-100 transition-opacity\" data-kid=\"16\">\n                        <span class=\"text-[10px] font-bold text-indigo-500 bg-indigo-50 px-1.5 py-0.5 rounded\" data-kid=\"17\">AI Assist</span>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"flex items-center gap-4\" data-kid=\"18\">\n                <div class=\"hidden lg:flex items-center gap-2 px-3 py-1.5 bg-white rounded-full border border-slate-200 shadow-xs\" data-kid=\"19\">\n                    <i class=\"fa-solid fa-shield-check text-emerald-500 text-[10px]\" data-kid=\"20\"></i>\n                    <span class=\"text-[10px] font-bold text-slate-500 uppercase tracking-wider\" data-kid=\"21\">256-Bit Encrypted</span>\n                </div>\n                <button class=\"bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2.5 rounded-xl text-sm font-bold transition-all shadow-md shadow-indigo-200 flex items-center gap-2 active:scale-95\" data-kid=\"22\">\n                    <i class=\"fa-solid fa-plus text-xs\" data-kid=\"23\"></i>\n                    <span data-kid=\"24\">Add Document</span>\n                </button>\n                <div class=\"w-10 h-10 rounded-full bg-slate-200 overflow-hidden cursor-pointer hover:ring-2 ring-indigo-500/50 transition-all\" data-kid=\"25\">\n                    <img src=\"https://i.pravatar.cc/100?u=docvault\" alt=\"Avatar\" class=\"w-full h-full object-cover\" data-kid=\"26\">\n                </div>\n            </div>\n        </div>\n    </header>\n\n    <main class=\"max-w-7xl mx-auto px-6 py-8\" data-kid=\"27\">\n        \n        <div class=\"flex flex-col md:flex-row md:items-center justify-between gap-6 mb-10\" data-kid=\"28\">\n            <div class=\"flex p-1 bg-slate-200/60 rounded-xl w-fit\" id=\"view-switcher\" data-kid=\"29\">\n                <button data-view=\"grid\" class=\"view-btn active px-4 py-2 rounded-lg text-sm font-medium transition-all flex items-center gap-2 bg-white shadow-sm text-indigo-600\" data-kid=\"30\">\n                    <i class=\"fa-solid fa-grid-2\" data-kid=\"31\"></i> Grid\n                </button>\n                <button data-view=\"list\" class=\"view-btn px-4 py-2 rounded-lg text-sm font-medium transition-all flex items-center gap-2 text-slate-600 hover:text-slate-900\" data-kid=\"32\">\n                    <i class=\"fa-solid fa-list-ul\" data-kid=\"33\"></i> List\n                </button>\n                <button data-view=\"categories\" class=\"view-btn px-4 py-2 rounded-lg text-sm font-medium transition-all flex items-center gap-2 text-slate-600 hover:text-slate-900\" data-kid=\"34\">\n                    <i class=\"fa-solid fa-folders\" data-kid=\"35\"></i> Folders\n                </button>\n            </div>\n\n            <div class=\"flex items-center gap-3 overflow-x-auto no-scrollbar pb-2 md:pb-0\" data-kid=\"36\">\n                <button class=\"px-4 py-1.5 bg-indigo-600 text-white rounded-full text-xs font-semibold whitespace-nowrap\" data-kid=\"37\">All Files</button>\n                <button class=\"px-4 py-1.5 bg-white border border-slate-200 text-slate-600 hover:border-slate-300 rounded-full text-xs font-semibold whitespace-nowrap transition-colors\" data-kid=\"38\">Identity</button>\n                <button class=\"px-4 py-1.5 bg-white border border-slate-200 text-slate-600 hover:border-slate-300 rounded-full text-xs font-semibold whitespace-nowrap transition-colors\" data-kid=\"39\">Insurance</button>\n                <button class=\"px-4 py-1.5 bg-white border border-slate-200 text-slate-600 hover:border-slate-300 rounded-full text-xs font-semibold whitespace-nowrap transition-colors\" data-kid=\"40\">Warranties</button>\n                <div class=\"h-6 w-px bg-slate-200 mx-1\" data-kid=\"41\"></div>\n                <button class=\"flex items-center gap-2 px-3 py-1.5 text-slate-500 hover:text-slate-900 transition-colors\" data-kid=\"42\">\n                    <i class=\"fa-solid fa-sliders text-xs\" data-kid=\"43\"></i>\n                    <span class=\"text-xs font-bold uppercase tracking-wider\" data-kid=\"44\">Filters</span>\n                </button>\n            </div>\n        </div>\n\n        \n        <div id=\"grid-view\" class=\"view-content active\" data-kid=\"45\">\n            <div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-12\" data-kid=\"46\">\n                \n                <div class=\"doc-card group cursor-pointer\" data-kid=\"47\">\n                    <div class=\"aspect-[1.6/1] bg-[#2563eb] rounded-[1.5rem] p-6 text-white relative overflow-hidden id-card-shadow hover:scale-[1.02] transition-transform duration-300\" data-kid=\"48\">\n                        <div class=\"absolute inset-0 card-sheen\" data-kid=\"49\"></div>\n                        <div class=\"absolute inset-0 id-card-texture\" data-kid=\"50\"></div>\n                        <i class=\"fa-solid fa-clover watermark-svg\" data-kid=\"51\"></i>\n                        <div class=\"relative z-10 flex flex-col h-full justify-between\" data-kid=\"52\">\n                            <div class=\"flex justify-between items-start\" data-kid=\"53\">\n                                <div class=\"space-y-0.5\" data-kid=\"54\">\n                                    <p class=\"text-[8px] uppercase tracking-[0.3em] font-bold opacity-60\" data-kid=\"55\">Govt of India</p>\n                                    <h3 class=\"text-lg font-bold font-geist tracking-tight\" data-kid=\"56\">AADHAAR</h3>\n                                </div>\n                                <div class=\"chip-icon shadow-md ring-1 ring-white/10\" data-kid=\"57\"></div>\n                            </div>\n                            <div data-kid=\"58\">\n                                <p class=\"text-xl font-geist font-bold tracking-[0.2em] mb-1\" data-kid=\"59\">8821 4409 1209</p>\n                                <div class=\"flex justify-between items-end border-t border-white/10 pt-2\" data-kid=\"60\">\n                                    <p class=\"text-[10px] font-medium opacity-80 uppercase tracking-widest\" data-kid=\"61\">Aditya Sharma</p>\n                                    <i class=\"fa-solid fa-fingerprint text-2xl opacity-30\" data-kid=\"62\"></i>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"mt-4 flex items-center justify-between px-1\" data-kid=\"63\">\n                        <div data-kid=\"64\">\n                            <h4 class=\"font-bold text-slate-800 text-sm\" data-kid=\"65\">Identity Card</h4>\n                            <p class=\"text-[10px] text-slate-400 uppercase tracking-wider font-bold\" data-kid=\"66\">Primary ID</p>\n                        </div>\n                        <div class=\"flex gap-1.5\" data-kid=\"67\">\n                            <button class=\"w-8 h-8 flex items-center justify-center text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-colors\" data-kid=\"68\"><i class=\"fa-solid fa-share-nodes text-[11px]\" data-kid=\"69\"></i></button>\n                            <button class=\"w-8 h-8 flex items-center justify-center text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-colors\" data-kid=\"70\"><i class=\"fa-solid fa-ellipsis-v text-[11px]\" data-kid=\"71\"></i></button>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"doc-card group cursor-pointer lg:translate-y-6\" data-kid=\"72\">\n                    <div class=\"aspect-[1.6/1] bg-[#059669] rounded-[1.5rem] p-6 text-white relative overflow-hidden id-card-shadow hover:scale-[1.02] transition-transform duration-300\" data-kid=\"73\">\n                        <div class=\"absolute inset-0 card-sheen\" data-kid=\"74\"></div>\n                        <div class=\"absolute inset-0 id-card-texture opacity-40\" data-kid=\"75\"></div>\n                        <div class=\"relative z-10 flex flex-col h-full justify-between\" data-kid=\"76\">\n                            <div class=\"flex justify-between items-start\" data-kid=\"77\">\n                                <div class=\"space-y-0.5\" data-kid=\"78\">\n                                    <p class=\"text-[8px] uppercase tracking-[0.3em] font-bold opacity-60\" data-kid=\"79\">Premium Care</p>\n                                    <h3 class=\"text-lg font-bold font-geist tracking-tight\" data-kid=\"80\">HEALTH+</h3>\n                                </div>\n                                <i class=\"fa-solid fa-shield-heart text-2xl opacity-40\" data-kid=\"81\"></i>\n                            </div>\n                            <div class=\"space-y-3\" data-kid=\"82\">\n                                <div class=\"flex items-center gap-3\" data-kid=\"83\">\n                                    <div class=\"w-10 h-6 rounded bg-white/10 border border-white/20 flex items-center justify-center text-[8px] font-bold uppercase tracking-tighter\" data-kid=\"84\">Gold</div>\n                                    <div class=\"text-[10px] font-geist opacity-80\" data-kid=\"85\">SH-9920-X88</div>\n                                </div>\n                                <div class=\"flex justify-between items-end border-t border-white/10 pt-2\" data-kid=\"86\">\n                                    <p class=\"text-[10px] font-medium opacity-80 uppercase tracking-widest italic\" data-kid=\"87\">Exp: Dec 2026</p>\n                                    <i class=\"fa-solid fa-heart-pulse text-2xl opacity-20\" data-kid=\"88\"></i>\n                                </div>\n                            </div>\n                  