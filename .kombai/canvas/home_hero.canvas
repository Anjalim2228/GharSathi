rd p-6 rounded-3xl group\" data-kid=\"75\">\n                        <div class=\"size-10 bg-emerald-50 rounded-xl flex items-center justify-center mb-6\" data-kid=\"76\">\n                            <i data-lucide=\"shield-check\" class=\"size-5 text-emerald-600\" data-kid=\"77\"></i>\n                        </div>\n                        <p class=\"text-slate-500 text-xs font-bold uppercase tracking-widest mb-1\" data-kid=\"78\">Home Safety</p>\n                        <h3 class=\"text-2xl font-black text-emerald-600 tracking-tight\" data-kid=\"79\">MAX</h3>\n                        <p class=\"text-[10px] text-slate-400 font-black mt-2\" data-kid=\"80\">ALL SYSTEMS NOMINAL</p>\n                    </div>\n                </div>\n\n                \n                <section id=\"financial\" class=\"view-section active space-y-8\" data-kid=\"81\">\n                    <div class=\"grid grid-cols-12 gap-8\" data-kid=\"82\">\n                        <div class=\"col-span-12 lg:col-span-8 glass-card p-10 rounded-3xl\" data-kid=\"83\">\n                            <div class=\"flex flex-col md:flex-row md:items-center justify-between mb-10 gap-4\" data-kid=\"84\">\n                                <div data-kid=\"85\">\n                                    <h2 class=\"text-2xl font-black text-slate-900 tracking-tight\" data-kid=\"86\">Cash Flow Dynamics</h2>\n                                    <p class=\"text-slate-500 text-sm font-medium\" data-kid=\"87\">Real-time analysis of household liquidity</p>\n                                </div>\n                                <div class=\"flex bg-slate-100/80 p-1 rounded-xl self-start\" data-kid=\"88\">\n                                    <button class=\"px-4 py-2 text-[10px] font-black uppercase tracking-widest bg-white rounded-lg shadow-sm cursor-pointer\" data-kid=\"89\">Monthly</button>\n                                    <button class=\"px-4 py-2 text-[10px] font-black uppercase tracking-widest text-slate-400 hove