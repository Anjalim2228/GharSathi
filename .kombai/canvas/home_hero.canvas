text-[10px] font-bold text-white/20 uppercase tracking-widest mb-2\" data-kid=\"269\">Travelers</p>\n                      <div class=\"flex -space-x-2\" data-kid=\"270\">\n                        <img src=\"https://i.pravatar.cc/100?u=1\" class=\"w-8 h-8 rounded-full border-2 border-slate-900 shadow-xl\" alt=\"member\" data-kid=\"271\">\n                        <img src=\"https://i.pravatar.cc/100?u=2\" class=\"w-8 h-8 rounded-full border-2 border-slate-900 shadow-xl\" alt=\"member\" data-kid=\"272\">\n                        <img src=\"https://i.pravatar.cc/100?u=3\" class=\"w-8 h-8 rounded-full border-2 border-slate-900 shadow-xl\" alt=\"member\" data-kid=\"273\">\n                        <div class=\"w-8 h-8 rounded-full border-2 border-slate-900 bg-white/5 flex items-center justify-center text-[10px] font-bold text-white/40\" data-kid=\"274\">+1</div>\n                      </div>\n                    </div>\n                    <div class=\"w-px h-10 bg-white/10 my-auto\" data-kid=\"275\"></div>\n                    <div data-kid=\"276\">\n                      <p class=\"text-[10px] font-bold text-white/20 uppercase tracking-widest mb-2\" data-kid=\"277\">Weather Forecast</p>\n                      <div class=\"flex items-center gap-2 text-white/80 font-bold text-sm\" data-kid=\"278\">\n                        <i class=\"ri-sun-cloudy-line text-amber-400 text-lg\" data-kid=\"279\"></i> 29°C\n                      </div>\n                    </div>\n                    <div class=\"w-px h-10 bg-white/10 my-auto\" data-kid=\"280\"></div>\n                    <div data-kid=\"281\">\n                      <p class=\"text-[10px] font-bold text-white/20 uppercase tracking-widest mb-2\" data-kid=\"282\">Budget Status</p>\n                      <p class=\"text-sm font-bold text-emerald-400/80\" data-kid=\"283\">$4,200 <span class=\"text-white/20 font-normal\" data-kid=\"284\">/ $5k</span></p>\n                    </div>\n                  </div>\n                </div>\n\n                <div class=\"mt-8 space-y-2\" data-kid=\"285\">\n                   <div class=\"flex justify-between text-[10px] font-bold uppercase tracking-widest text-white/40\" data-kid=\"286\">\n                     <span data-kid=\"287\">Packing Progress</span>\n                     <span data-kid=\"288\">60%</span>\n                   </div>\n                   <div class=\"h-1.5 w-full bg-white/5 rounded-full overflow-hidden\" data-kid=\"289\">\n                     <div class=\"h-full bg-gradient-to-r from-indigo-500 to-teal-400 w-[60%] rounded-full\" data-kid=\"290\"></div>\n                   </div>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          \n          <div class=\"glass-card rounded-[2.5rem] p-1 border-white/10 group hover:border-white/20 transition-all duration-500 shadow-2xl overflow-hidden opacity-80 hover:opacity-100\" data-kid=\"291\">\n            <div class=\"flex flex-col md:flex-row gap-6 p-6\" data-kid=\"292\">\n              <div class=\"w-full md:w-56 h-48 rounded-3xl overflow-hidden relative border border-white/10 shrink-0 grayscale hover:grayscale-0 transition-all\" data-kid=\"293\">\n                <img src=\"https://images.unsplash.com/photo-1470770841072-f978cf4d019e?auto=compress&cs=tinysrgb&w=600&q=80\" alt=\"Destination\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-700\" data-kid=\"294\">\n                <div class=\"absolute inset-0 bg-gradient-to-t from-black/60 to-transparent\" data-kid=\"295\"></div>\n                <div class=\"absolute bottom-4 left-4\" data-kid=\"296\">\n                  <span class=\"bg-amber-600 text-white text-[10px] font-bold px-2 py-1 rounded uppercase tracking-widest\" data-kid=\"297\">SUMMER 2027</span>\n                </div>\n              </div>\n\n              <div class=\"flex-1 flex flex-col justify-between py-2\" data-kid=\"298\">\n                <div data-kid=\"299\">\n                  <div class=\"flex justify-between items-start\" data-kid=\"300\">\n                    <h4 class=\"text-2xl font-bold font-jakarta text-white/80\" data-kid=\"301\">Swiss Alps Hiking</h4>\n                    <span class=\"text-white/40 flex items-center gap-1 text-xs font-bold uppercase bg-white/5 px-3 py-1 rounded-full\" data-kid=\"302\">\n                      Drafting\n                    </span>\n                  </div>\n                  <p class=\"text-white/40 text-sm mt-1\" data-kid=\"303\">July 10 - July 20 • 10 Days • Zermatt</p>\n                </div>\n\n                <div class=\"mt-8 flex gap-3\" data-kid=\"304\">\n                  <button class=\"flex-1 py-3 px-4 rounded-2xl bg-white/5 border border-white/10 text-white/70 text-xs font-bold hover:bg-white/10 transition-all\" data-kid=\"305\">View Itinerary</button>\n                  <button class=\"p-3 rounded-2xl bg-white/5 border border-white/10 text-white/70 hover:bg-white/10 transition-all\" data-kid=\"306\"><i class=\"ri-share-line\" data-kid=\"307\"></i></button>\n                </div>\n              </div>\n            </div>\n          </div>\n\n        </div>\n      </div>\n    </section>\n\n  </main>\n\n  \n  <button class=\"fixed bottom-8 right-8 w-16 h-16 rounded-full bg-indigo-600 text-white shadow-2xl shadow-indigo-600/40 flex items-center justify-center text-3xl hover:scale-110 active:scale-95 transition-all lg:hidden z-40\" data-kid=\"308\">\n    <i class=\"ri-add-line\" data-kid=\"309\"></i>\n  </button>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"310\"></script>\n<script data-kid=\"311\">\n  function switchVariant(variantId, btn) {\n    // Nav UI updates\n    document.querySelectorAll('.nav-btn').forEach(b => {\n      b.classList.remove('bg-white/10', 'text-white', 'shadow-lg');\n      b.classList.add('text-white/50', 'hover:text-white', 'hover:bg-white/5');\n    });\n    btn.classList.add('bg-white/10', 'text-white', 'shadow-lg');\n    btn.classList.remove('text-white/50', 'hover:text-white', 'hover:bg-white/5');\n\n    // Content Switch\n    const containers = document.querySelectorAll('.variant-container');\n    const target = document.getElementById(variantId);\n    \n    // Animate out current\n    gsap.to('.variant-container.variant-active', {\n      opacity: 0,\n      y: 20,\n      duration: 0.3,\n      onComplete: () => {\n        containers.forEach(c => c.classList.remove('variant-active'));\n        \n        // Animate in new\n        target.classList.add('variant-active');\n        gsap.fromTo(target, {\n          opacity: 0,\n          y: 20\n        }, {\n          opacity: 1,\n          y: 0,\n          duration: 0.5,\n          ease: \"power2.out\"\n        });\n      }\n    });\n  }\n\n  // Initial Entrance\n  window.addEventListener('load', () => {\n    gsap.from('.variant-active', {\n      opacity: 0,\n      y: 30,\n      duration: 0.8,\n      ease: \"power3.out\",\n      delay: 0.2\n    });\n\n    gsap.from('nav', {\n      y: -50,\n      opacity: 0,\n      duration: 0.8,\n      ease: \"power4.out\"\n    });\n  });\n</script>\n",
