      "html": "\n<style data-kid=\"0\">\n@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700&display=swap');\n\n:root {\n  --color-aura-primary: #10B981;\n  --color-matrix-neon: #39FF14;\n  --color-eco-primary: #059669;\n}\n\nbody {\n  margin: 0;\n  padding: 0;\n  overflow-x: clip;\n}\n\n.font-aura { font-family: 'Plus Jakarta Sans', sans-serif; }\n.font-matrix { font-family: 'Space Grotesk', sans-serif; }\n.font-eco { font-family: 'Outfit', sans-serif; }\n\n/* Custom Animations */\n.glass-glow {\n  box-shadow: 0 0 20px rgba(16, 185, 129, 0.1), inset 0 0 20px rgba(255, 255, 255, 0.5);\n}\n\n.matrix-grid {\n  background-image: linear-gradient(rgba(57, 255, 20, 0.05) 1px, transparent 1px),\n                    linear-gradient(90deg, rgba(57, 255, 20, 0.05) 1px, transparent 1px);\n  background-size: 32px 32px;\n}\n\n.noise-overlay {\n  pointer-events: none;\n  position: absolute;\n  inset: 0;\n  z-index: 50;\n  opacity: 0.03;\n  background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E\");\n}\n</style>\n\n<div class=\"relative min-h-screen bg-slate-950 text-white overflow-hidden selection:bg-emerald-500/30\" data-kid=\"1\">\n  <div class=\"noise-overlay\" data-kid=\"2\"></div>\n\n  \n  <nav class=\"fixed top-8 left-1/2 -translate-x-1/2 z-[100] bg-slate-900/90 backdrop-blur-2xl border border-white/10 rounded-full p-1.5 flex gap-1 shadow-2xl\" data-kid=\"3\">\n    <a href=\"#variant-aura\" class=\"nav-link px-6 py-2 rounded-full text-[10px] uppercase tracking-widest font-black transition-all font-aura text-white/40 hover:text-white\" data-target=\"aura\" data-kid=\"4\">Aura Glass</a>\n    <a href=\"#variant-matrix\" class=\"nav-link px-6 py-2 rounded-full text-[10px] uppercase tracking-widest font-black transition-all font-matrix text-white/40 hover:text-white\" data-target=\"matrix\" data-kid=\"5\">Matrix Core</a>\n    <a href=\"#variant-eco\" class=\"nav-link px-6 py-2 rounded-full text-[10px] uppercase tracking-widest font-black transition-all font-eco text-white/40 hover:text-white\" data-target=\"eco\" data-kid=\"6\">Eco Leaf</a>\n    <div id=\"nav-pill\" class=\"absolute h-[calc(100%-12px)] bg-white/20 border border-white/10 rounded-full transition-all duration-500 ease-out -z-10\" data-kid=\"7\"></div>\n  </nav>\n\n  \n  <main class=\"w-full\" data-kid=\"8\">\n\n    \n    <section id=\"variant-aura\" class=\"min-h-screen flex items-center justify-center bg-[#F8FAFC] relative p-6 sm:p-12 font-aura section-block\" data-kid=\"9\">\n      <div class=\"absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(16,185,129,0.06),transparent_50%)]\" data-kid=\"10\"></div>\n      \n      <div class=\"max-w-6xl w-full bg-white/60 backdrop-blur-3xl border border-white/40 rounded-[3rem] shadow-2xl overflow-hidden aura-container\" data-kid=\"11\">\n        <div class=\"p-10 lg:p-20\" data-kid=\"12\">\n          <header class=\"flex flex-col md:flex-row md:items-end justify-between gap-8 mb-20\" data-kid=\"13\">\n            <div data-kid=\"14\">\n              <div class=\"flex items-center gap-3 mb-6\" data-kid=\"15\">\n                <span class=\"w-2 h-2 bg-emerald-500 rounded-full animate-pulse shadow-[0_0_8px_#10b981]\" data-kid=\"16\"></span>\n                <span class=\"text-[10px] font-black text-slate-400 uppercase tracking-[0.3em]\" data-kid=\"17\">AI Prediction Mode</span>\n              </div>\n              <h1 class=\"text-6xl font-black text-slate-900 tracking-tighter leading-none mb-6\" data-kid=\"18\">Energy <span class=\"text-emerald-500\" data-kid=\"19\">Hub.</span></h1>\n              <p class=\"text-slate-500 text-lg max-w-md font-medium leading-relaxed\" data-kid=\"20\">Predictive consumption analytics and real-time household efficiency optimization.</p>\n            </div>\n            <div class=\"flex items-center gap-3 p-1.5 bg-slate-100 rounded-2xl border border-slate-200 shadow-inner\" data-kid=\"21\">\n              <button class=\"px-6 py-3 rounded-xl bg-white shadow-sm text-slate-900 font-bold text-xs uppercase tracking-widest\" data-kid=\"22\">Real-Time</button>\n              <button class=\"px-6 py-3 rounded-xl text-slate-400 font-bold text-xs uppercase tracking-widest hover:text-slate-900 transition-colors\" data-kid=\"23\">Historical</button>\n            </div>\n          </header>\n\n          <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-8 mb-16\" data-kid=\"24\">\n            \n            <div class=\"lg:col-span-8 group bg-white p-10 rounded-[3rem] border border-white shadow-[0_8px_40px_rgba(0,0,0,0.04)] hover:shadow-[0_30px_60px_rgba(0,0,0,0.1)] transition-shadow aura-card relative overflow-hidden\" data-kid=\"25\">\n              <div class=\"absolute top-0 right-0 p-12 opacity-[0.03] group-hover:opacity-[0.07] transition-opacity\" data-kid=\"26\">\n                <i class=\"lucide-zap w-48 h-48 text-amber-500\" data-kid=\"27\"></i>\n              </div>\n              <div class=\"relative z-10 flex flex-col md:flex-row md:items-end justify-between gap-8 h-full\" data-kid=\"28\">\n                <div data-kid=\"29\">\n                  <div class=\"w-16 h-16 bg-amber-50 rounded-2xl flex items-center justify-center mb-10 text-amber-500\" data-kid=\"30\">\n                    <i class=\"lucide-zap w-8 h-8\" data-kid=\"31\"></i>\n                  </div>\n                  <h3 class=\"text-sm font-black text-slate-400 uppercase tracking-[0.2em] mb-3\" data-kid=\"32\">Core Electricity Draw</h3>\n                  <div class=\"flex items-baseline gap-3\" data-kid=\"33\">\n                    <span class=\"text-7xl font-black text-slate-900 tracking-tighter\" data-kid=\"34\">342.5</span>\n                    <span class=\"text-xl font-bold text-slate-300\" data-kid=\"35\">kWh</span>\n                  </div>\n                </div>\n                <div class=\"flex flex-col gap-4\" data-kid=\"36\">\n                  <div class=\"bg-emerald-50 px-6 py-4 rounded-3xl border border-emerald-100\" data-kid=\"37\">\n                    <p class=\"text-[10px] font-black text-emerald-600 uppercase tracking-widest mb-1\" data-kid=\"38\">MoM Efficiency</p>\n                    <p class=\"text-2xl font-black text-emerald-700 leading-none\" data-kid=\"39\">-4.2%</p>\n                  </div>\n                  <div class=\"bg-slate-50 px-6 py-4 rounded-3xl border border-slate-100\" data-kid=\"40\">\n                    <p class=\"text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1\" data-kid=\"41\">Peak Time Today</p>\n                    <p class=\"text-lg font-black text-slate-900 leading-none\" data-kid=\"42\">19:42 PM</p>\n                  </div>\n                </div>\n              </div>\n            </div>\n\n            \n            <div class=\"lg:col-span-4 flex flex-col gap-8\" data-kid=\"43\">\n               <div class=\"flex-1 bg-white p-8 rounded-[2.5rem] border border-white shadow-sm hover:shadow-xl transition-shadow aura-card\" data-kid=\"44\">\n                 <div class=\"flex items-center gap-6 mb-8\" data-kid=\"45\">\n                    <div class=\"w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center text-blue-500\" data-kid=\"46\">\n                      <i class=\"lucide-droplets w-6 h-6\" data-kid=\"47\"></i>\n                    </div>\n                    <div data-kid=\"48\">\n                      <p class=\"text-[10px] font-black text-slate-400 uppercase tracking-widest mb-0.5\" data-kid=\"49\">Water Usage</p>\n                      <p class=\"text-2xl font-black text-slate-900\" data-kid=\"50\">12.8 <span class=\"text-sm text-slate-300\" data-kid=\"51\">kL</