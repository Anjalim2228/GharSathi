      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css');\n\n  :root {\n    --bg-main: #0a0c10;\n    --glass-bg: rgba(255, 255, 255, 0.03);\n    --glass-border: rgba(255, 255, 255, 0.08);\n    --accent-primary: #6366f1;\n  }\n\n  body {\n    font-family: 'Inter', sans-serif;\n    background-color: var(--bg-main);\n    color: white;\n    margin: 0;\n    overflow-x: clip;\n  }\n\n  .font-jakarta { font-family: 'Plus Jakarta Sans', sans-serif; }\n\n  .glass-card {\n    background: var(--glass-bg);\n    backdrop-filter: blur(20px);\n    -webkit-backdrop-filter: blur(20px);\n    border: 1px solid var(--glass-border);\n  }\n\n  .glass-card-hover:hover {\n    background: rgba(255, 255, 255, 0.06);\n    border-color: rgba(255, 255, 255, 0.15);\n  }\n\n  .no-scrollbar::-webkit-scrollbar { display: none; }\n  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n\n  .calendar-grid {\n    display: grid;\n    grid-template-columns: repeat(7, 1fr);\n  }\n\n  .variant-container {\n    display: none;\n  }\n\n  .variant-active {\n    display: block;\n  }\n  \n  .active-tab-indicator {\n    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n\n  /* Custom Glows */\n  .glow-pink { box-shadow: 0 0 20px rgba(236, 72, 153, 0.15); }\n  .glow-emerald { box-shadow: 0 0 20px rgba(16, 185, 129, 0.15); }\n  .glow-indigo { box-shadow: 0 0 20px rgba(99, 102, 241, 0.15); }\n</style>\n\n<div class=\"min-h-screen relative overflow-hidden bg-[var(--bg-main)]\" data-kid=\"1\">\n  \n  <div class=\"fixed top-0 left-0 w-full h-full pointer-events-none overflow-hidden -z-10\" data-kid=\"2\">\n    <div class=\"absolute -top-[10%] -left-[5%] w-[40%] h-[40%] bg-indigo-500/10 blur-[120px] rounded-full\" data-kid=\"3\"></div>\n    <div class=\"absolute top-[40%] -right-[10%] w-[35%] h-[35%] bg-pink-500/5 blur-[120px] rounded-full\" data-kid=\"4\"></div>\n    <div class=\"absolute -bottom-[10%] left-[20%] w-[45%] h-[45%] bg-teal-500/5 blur-[120px] rounded-full\" data-kid=\"5\"></div>\n  </div>\n\n  \n  <nav class=\"fixed top-6 left-1/2 -translate-x-1/2 z-50\" data-kid=\"6\">\n    <div class=\"glass-card p-1.5 rounded-2xl flex items-center gap-1 shadow-2xl border-white/10\" data-kid=\"7\">\n      <button onclick=\"switchVariant('v1', this)\" class=\"nav-btn px-5 py-2.5 rounded-xl text-sm font-semibold transition-all duration-300 flex items-center gap-2 bg-white/10 text-white shadow-lg\" data-kid=\"8\">\n        <i class=\"ri-calendar-line\" data-kid=\"9\"></i> <span data-kid=\"10\">Grid View</span>\n      </button>\n      <button onclick=\"switchVariant('v2', this)\" class=\"nav-btn px-5 py-2.5 rounded-xl text-sm font-semibold transition-all duration-300 flex items-center gap-2 text-white/50 hover:text-white hover:bg-white/5\" data-kid=\"11\">\n        <i class=\"ri-list-check-2\" data-kid=\"12\"></i> <span data-kid=\"13\">Family Agenda</span>\n      </button>\n      <button onclick=\"switchVariant('v3', this)\" class=\"nav-btn px-5 py-2.5 rounded-xl text-sm font-semibold transition-all duration-300 flex items-center gap-2 text-white/50 hover:text-white hover:bg-white/5\" data-kid=\"14\">\n        <i class=\"ri-plane-line\" data-kid=\"15\"></i> <span data-kid=\"16\">Holiday Planner</span>\n      </button>\n    </div>\n  </nav>\n\n  \n  <main class=\"max-w-[1440px] mx-auto pt-24 px-8 pb-12\" data-kid=\"17\">\n    \n    \n    <section id=\"v1\" class=\"variant-container variant-active\" data-kid=\"18\">\n      <div class=\"flex flex-col lg:flex-row gap-8\" data-kid=\"19\">\n        \n        <aside class=\"w-full lg:w-80 space-y-6\" data-kid=\"20\">\n          <div class=\"glass-card rounded-3xl p-6 border-white/10\" data-kid=\"21\">\n            <h3 class=\"text-xs font-bold uppercase tracking-widest text-white/40 mb-4\" data-kid=\"22\">Family Calendars</h3>\n            <div class=\"space-y-4\" data-kid=\"23\">\n              <label class=\"flex items-center gap-3 cursor-pointer group\" data-kid=\"24\">\n                <div class=\"w-5 h-5 rounded-md bg-indigo-500 flex items-center justify-center transition-transform group-hover:scale-110\" data-kid=\"25\">\n                  <i class=\"ri-check-line text-white text-xs\" data-kid=\"26\"></i>\n                </div>\n                <span class=\"text-sm font-medium text-white/80\" data-kid=\"27\">Family Events</span>\n              </label>\n              <label class=\"flex items-center gap-3 cursor-pointer group\" data-kid=\"28\">\n                <div class=\"w-5 h-5 rounded-md bg-pink-500 flex items-center justify-center transition-transform group-hover:scale-110\" data-kid=\"29\">\n                  <i class=\"ri-check-line text-white text-xs\" data-kid=\"30\"></i>\n                </div>\n                <span class=\"text-sm font-medium text-white/80\" data-kid=\"31\">Birthdays</span>\n              </label>\n              <label class=\"flex items-center gap-3 cursor-pointer group\" data-kid=\"32\">\n                <div class=\"w-5 h-5 rounded-md bg-emerald-500 flex items-center justify-center transition-transform group-hover:scale-110\" data-kid=\"33\">\n                  <i class=\"ri-check-line text-white text-xs\" data-kid=\"34\"></i>\n                </div>\n                <span class=\"text-sm font-medium text-white/80\" data-kid=\"35\">Medical</span>\n              </label>\n              <label class=\"flex items-center gap-3 cursor-pointer group\" data-kid=\"36\">\n                <div class=\"w-5 h-5 rounded-md bg-amber-500 flex items-center justify-center transition-transform group-hover:scale-110\" data-kid=\"37\">\n                  <i class=\"ri-check-line text-white text-xs\" data-kid=\"38\"></i>\n                </div>\n                <span class=\"text-sm font-medium text-white/80\" data-kid=\"39\">School / Work</span>\n              </label>\n            </div>\n          </div>\n\n          \n          <div class=\"glass-card rounded-3xl p-6 border-white/10 relative overflow-hidden group\" data-kid=\"40\">\n            <div class=\"absolute -right-4 -top-4 w-12 h-12 bg-white/5 blur-xl group-hover:bg-white/10 transition-all\" data-kid=\"41\"></div>\n            <h3 class=\"text-xs font-bold uppercase tracking-widest text-white/40 mb-4 flex justify-between items-center\" data-kid=\"42\">\n              <span data-kid=\"43\">Upcoming</span>\n              <i class=\"ri-arrow-right-up-line text-white/20\" data-kid=\"44\"></i>\n            </h3>\n            <div class=\"space-y-4\" data-kid=\"45\">\n              <div class=\"flex gap-4 group/item cursor-pointer\" data-kid=\"46\">\n                <div class=\"shrink-0 w-11 h-11 rounded-xl bg-pink-500/10 flex flex-col items-center justify-center border border-pink-500/20 group-hover/item:bg-pink-500/20 transition-all\" data-kid=\"47\">\n                  <span class=\"text-[9px] font-bold text-pink-400/60 uppercase\" data-kid=\"48\">Sep</span>\n                  <span class=\"text-lg font-black text-white leading-none\" data-kid=\"49\">02</span>\n                </div>\n                <div class=\"flex-1 border-b border-white/5 pb-3 group-hover/item:border-white/10 transition-all\" data-kid=\"50\">\n                  <p class=\"text-sm font-bold text-white group-hover/item:text-pink-300 transition-colors\" data-kid=\"51\">Sarah's Birthday</p>\n                  <p class=\"text-[10px] text-white/40 font-medium\" data-kid=\"52\">10th Anniversary Party</p>\n                </div>\n              </div>\n              <div class=\"flex gap-4 group/item cursor-pointer\" data-kid=\"53\">\n                <div class=\"shrink-0 w-11 h-11 rounded-xl bg-emerald-500/10 flex flex-col items-center justify-center border border-emerald-500/20 group-hover/item:bg-emerald-500/20 transition-all\" data-kid=\"54\">\n                  <span class=\