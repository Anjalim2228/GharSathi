        "x": 0,
        "y": 0,
        "w": 1280,
        "h": 800
      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap');\n\n  :root {\n    --color-accent: #E5AA70;\n    --color-accent-hover: #D49960;\n    --color-deep-navy: #011F5B;\n    --color-navy-light: #1A3A7A;\n    --color-glass-bg: rgba(255, 255, 255, 0.45);\n    --color-glass-border: rgba(255, 255, 255, 0.5);\n    --color-surface: #F5F5F5;\n    \n    --font-inter: \"Inter\", sans-serif;\n    --font-dm-sans: \"DM Sans\", sans-serif;\n\n    --shadow-premium: 0 12px 48px -10px rgba(1, 31, 91, 0.1);\n    --shadow-glass: 0 8px 32px 0 rgba(31, 38, 135, 0.08);\n    \n    --radius-premium: 2.5rem;\n    --radius-card: 1.5rem;\n  }\n\n  body {\n    background-color: var(--color-surface);\n    color: var(--color-deep-navy);\n    font-family: var(--font-dm-sans);\n    margin: 0;\n  }\n\n  .font-inter { font-family: var(--font-inter); }\n  .font-dm-sans { font-family: var(--font-dm-sans); }\n\n  .glass-card {\n    background: var(--color-glass-bg);\n    backdrop-filter: blur(24px);\n    border: 1px solid var(--color-glass-border);\n    box-shadow: var(--shadow-premium);\n    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;\n    border-radius: var(--radius-card);\n  }\n\n  .glass-card:hover {\n    transform: translateY(-4px);\n    box-shadow: 0 20px 60px -15px rgba(1, 31, 91, 0.15);\n  }\n\n  .premium-button {\n    background: var(--color-deep-navy);\n    color: white;\n    padding: 0.75rem 1.5rem;\n    border-radius: 0.75rem;\n    font-weight: 700;\n    transition: all 0.3s ease;\n    display: inline-flex;\n    align-items: center;\n    gap: 0.5rem;\n    cursor: pointer;\n    border: none;\n  }\n\n  .premium-button:hover {\n    transform: scale(1.05);\n    box-shadow: 0 10px 20px rgba(1, 31, 91, 0.2);\n  }\n\n  .accent-button {\n    background: var(--color-accent);\n    color: white;\n    padding: 0.75rem 1.5rem;\n    border-radius: 0.75rem;\n    font-weight: 700;\n    transition: all 0.3s ease;\n    display: inline-flex;\n    align-items: center;\n    gap: 0.5rem;\n    cursor: pointer;\n    border: none;\n  }\n\n  .accent-button:hover {\n    background: var(--color-accent-hover);\n    transform: scale(1.05);\n  }\n</style>\n\n<div class=\"min-h-screen p-12 space-y-20\" data-kid=\"1\">\n  \n  <header class=\"space-y-4\" data-kid=\"2\">\n    <div class=\"flex items-center gap-4\" data-kid=\"3\">\n      <div class=\"w-12 h-12 bg-(--color-deep-navy) rounded-xl flex items-center justify-center text-white shadow-lg\" data-kid=\"4\">\n        <i data-lucide=\"layout-dashboard\" class=\"w-7 h-7\" data-kid=\"5\"></i>\n      </div>\n      <h1 class=\"text-4xl font-black font-inter tracking-tight\" data-kid=\"6\">\n        HomeHero <span class=\"text-(--color-accent)\" data-kid=\"7\">AI</span>\n      </h1>\n    </div>\n    <p class=\"text-xl text-(--color-deep-navy)/60 max-w-2xl\" data-kid=\"8\">\n      A premium Design System for smart family management. Inspired by Apple, Notion, and Airbnb.\n    </p>\n  </header>\n\n  \n  <section class=\"space-y-8\" data-kid=\"9\">\n    <h2 class=\"text-2xl font-bold font-inter border-b border-(--color-deep-navy)/10 pb-4 flex items-center gap-3\" data-kid=\"10\">\n      <i data-lucide=\"palette\" class=\"w-6 h-6 text-(--color-accent)\" data-kid=\"11\"></i>\n      Color Palette\n    </h2>\n    <div class=\"grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-6\" data-kid=\"12\">\n      <div class=\"space-y-3\" data-kid=\"13\">\n        <div class=\"h-32 w-full rounded-2xl bg-(--color-deep-navy) shadow-lg\" data-kid=\"14\"></div>\n        <p class=\"font-bold text-sm\" data-kid=\"15\">Deep Navy</p>\n        <p class=\"text-xs opacity-50\" data-kid=\"16\">#011F5B</p>\n      </div>\n      <div class=\"space-y-3\" data-kid=\"17\">\n        <div class=\"h-32 w-full rounded-2xl bg-(--color-accent) shadow-lg\" data-kid=\"18\"></div>\n        <p class=\"font-bold text-sm\" data-kid=\"19\">Accent Gold</p>\n        <p class=\"text-xs opacity-50\" data-kid=\"20\">#E5AA70</p>\n      </div>\n      <div class=\"space-y-3\" data-kid=\"21\">\n        <div class=\"h-32 w-full rounded-2xl bg-(--color-navy-light) shadow-lg\" data-kid=\"22\"></div>\n        <p class=\"font-bold text-sm\" data-kid=\"23\">Navy Light</p>\n        <p class=\"text-xs opacity-50\" data-kid=\"24\">#1A3A7A</p>\n      </div>\n      <div class=\"space-y-3\" data-kid=\"25\">\n        <div class=\"h-32 w-full rounded-2xl bg-white border border-(--color-deep-navy)/5 shadow-lg\" data-kid=\"26\"></div>\n        <p class=\"font-bold text-sm\" data-kid=\"27\">Surface White</p>\n        <p class=\"text-xs opacity-50\" data-kid=\"28\">#FFFFFF</p>\n      </div>\n      <div class=\"space-y-3\" data-kid=\"29\">\n        <div class=\"h-32 w-full rounded-2xl bg-(--color-surface) border border-(--color-deep-navy)/5 shadow-lg\" data-kid=\"30\"></div>\n        <p class=\"font-bold text-sm\" data-kid=\"31\">BG Surface</p>\n        <p class=\"text-xs opacity-50\" data-kid=\"32\">#F5F5F5</p>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"space-y-8\" data-kid=\"33\">\n    <h2 class=\"text-2xl font-bold font-inter border-b border-(--color-deep-navy)/10 pb-4 flex items-center gap-3\" data-kid=\"34\">\n      <i data-lucide=\"type\" class=\"w-6 h-6 text-(--color-accent)\" data-kid=\"35\"></i>\n      Typography\n    </h2>\n    <div class=\"grid grid-cols-1 md:grid-cols-2 gap-12\" data-kid=\"36\">\n      <div class=\"space-y-6\" data-kid=\"37\">\n        <p class=\"text-xs font-bold uppercase tracking-widest opacity-40\" data-kid=\"38\">Headings (Inter)</p>\n        <div class=\"space-y-4\" data-kid=\"39\">\n          <h1 class=\"text-5xl font-black font-inter\" data-kid=\"40\">H1: The Future of Home</h1>\n          <h2 class=\"text-3xl font-bold font-inter\" data-kid=\"41\">H2: Family First Hub</h2>\n          <h3 class=\"text-2xl font-bold font-inter\" data-kid=\"42\">H3: Smart AI Insights</h3>\n          <h4 class=\"text-xl font-bold font-inter\" data-kid=\"43\">H4: Daily Briefing</h4>\n        </div>\n      </div>\n      <div class=\"space-y-6\" data-kid=\"44\">\n        <p class=\"text-xs font-bold uppercase tracking-widest opacity-40\" data-kid=\"45\">Body (DM Sans)</p>\n        <div class=\"space-y-4\" data-kid=\"46\">\n          <p class=\"text-lg leading-relaxed\" data-kid=\"47\">\n            HomeHero AI is designed to simplify your life. From grocery management to emergency safety, every feature is crafted with precision and care.\n          </p>\n          <p class=\"text-base opacity-70\" data-kid=\"48\">\n            \"The design should feel like Apple + Notion + Google + Airbnb. Use smooth animations, glassmorphism, rounded cards, and gradients.\"\n          </p>\n          <p class=\"text-sm font-bold text-(--color-accent)\" data-kid=\"49\">Caption Label & Small Text</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"space-y-8\" data-kid=\"50\">\n    <h2 class=\"text-2xl font-bold font-inter border-b border-(--color-deep-navy)/10 pb-4 flex items-center gap-3\" data-kid=\"51\">\n      <i data-lucide=\"component\" class=\"w-6 h-6 text-(--color-accent)\" data-kid=\"52\"></i>\n      UI Components\n    </h2>\n    \n    <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-12\" data-kid=\"53\">\n      \n      <div class=\"space-y-6\" data-kid=\"54\">\n        <p class=\"text-xs font-bold uppercase tracking-widest opacity-40\" data-kid=\"55\">Buttons</p>\n        <div class=\"flex flex-wrap gap-4\" data-kid=\"56\">\n          <button class=\"premium-button\" data-kid=\"57\">\n            Premium Action\n            <i data-lucide=\"sparkles\" class=\"w-4 h-4\" data-kid=\"58\"></i>\n          </button>\n          <button class=\"accent-button\" data-kid=\"59\">\n            Accent Action\n            <i data-lucide=\"plus\" class=\"w-4 h-4\" data-kid=\"60\"></i>\n          </button>\n          <button class=\"px-6 py-3 rounded-xl border-2 border-(--color-deep-navy)/10 font-bold hover:bg-(--color-deep-navy)/5 transition-all\" data-kid=\"61\">\n            Secondary\n          </button>\n          <button class=\"px-6 py-3 rounded-xl font-bold text-red-500 hover:bg-red-50 transition-all\" data-kid=\"62\">\n            Danger\n          </button>\n        </div>\n      </div>\n\n      \n      <div class=\"space-y-6\" data-kid=\"63\">\n        <p class=\"text-xs font-bold uppercase tracking-widest opacity-40\" data-kid=\"64\">Glassmorphism Cards</p>\n        <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-6\" data-kid=\"65\">\n          <div class=\"glass-card p-6 space-y-4\" data-kid=\"66\">\n            <div class=\"w-10 h-10 rounded-lg bg-(--color-accent)/10 flex items-center justify-center text-(--color-accent)\" data-kid=\"67\">\n              <i data-lucide=\"zap\" class=\"w-5 h-5\" data-kid=\"68\"></i>\n            </div>\n            <h4 class=\"font-bold\" data-kid=\"69\">Smart Insights</h4>\n            <p class=\"text-xs opacity-60\" data-kid=\"70\">Real-time analysis of your household patterns.</p>\n          </div>\n          <div class=\"glass-card p-6 bg-white/60 border-accent/20\" data-kid=\"71\">\n            <div class=\"flex items-center justify-between mb-4\" data-kid=\"72\">\n              <span class=\"text-xs font-bold text-(--color-accent)\" data-kid=\"73\">Premium</span>\n              <div class=\"w-2 h-2 rounded-full bg-green-500 animate-pulse\" data-kid=\"74\"></div>\n            </div>\n            <div class=\"h-2 w-full bg-(--color-deep-navy)/5 rounded-full overflow-hidden\" data-kid=\"75\">\n              <div class=\"h-full w-2/3 bg-(--color-accent) rounded-full\" data-kid=\"76\"></div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"space-y-8\" data-kid=\"77\">\n    <h2 class=\"text-2xl font-bold font-inter border-b border-(--color-deep-navy)/10 pb-4 flex items-center gap-3\" data-kid=\"78\">\n      <i data-lucide=\"image\" class=\"w-6 h-6 text-(--color-accent)\" data-kid=\"79\"></i>\n      Visual Language\n    </h2>\n    <div class=\"grid grid-cols-2 md:grid-cols-4 lg:grid-cols-8 gap-8\" data-kid=\"80\">\n      <div class=\"flex flex-col items-center gap-2 p-4 rounded-2xl bg-white shadow-sm border border-(--color-deep-navy)/5\" data-kid=\"81\">\n        <i data-lucide=\"home\" class=\"w-8 h-8 text-(--color-deep-navy)\" data-kid=\"82\"></i>\n        <span class=\"text-[10px] font-bold\" data-kid=\"83\">Home</span>\n      </div>\n      <div class=\"flex flex-col items-center gap-2 p-4 rounded-2xl bg-white shadow-sm border border-(--color-deep-navy)/5\" data-kid=\"84\">\n        <i data-lucide=\"shopping-cart\" class=\"w-8 h-8 text-(--color-deep-navy)\" data-kid=\"85\"></i>\n        <span class=\"text-[10px] font-bold\" data-kid=\"86\">Grocery</span>\n      </div>\n      <div class=\"flex flex-col items-center gap-2 p-4 rounded-2xl bg-white shadow-sm border border-(--color-deep-navy)/5\" data-kid=\"87\">\n        <i data-lucide=\"heart-pulse\" class=\"w-8 h-8 text-(--color-deep-navy)\" data-kid=\"88\"></i>\n        <span class=\"text-[10px] font-bold\" data-kid=\"89\">Health</span>\n      </div>\n      <div class=\"flex flex-col items-center gap-2 p-4 rounded-2xl bg-white shadow-sm border border-(--color-deep-navy)/5\" data-kid=\"90\">\n        <i data-lucide=\"alert-triangle\" class=\"w-8 h-8 text-red-500\" data-kid=\"91\"></i>\n        <span class=\"text-[10px] font-bold\" data-kid=\"92\">SOS</span>\n      </div>\n      <div class=\"flex flex-col items-center gap-2 p-4 rounded-2xl bg-white shadow-sm border border-(--color-deep-navy)/5\" data-kid=\"93\">\n        <i data-lucide=\"brain-circuit\" class=\"w-8 h-8 text-(--color-accent)\" data-kid=\"94\"></i>\n        <span class=\"text-[10px] font-bold\" data-kid=\"95\">AI Brain</span>\n      </div>\n    </div>\n  </section>\n</div>\n\n<script src=\"https://unpkg.com/lucide@latest\" data-kid=\"96\"></script>\n<script data-kid=\"97\">\n  lucide.createIcons();\n</script>",
