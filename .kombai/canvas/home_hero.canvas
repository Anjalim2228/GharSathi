data-kid=\"202\"></i>\n                            <span class=\"px-3 py-1 bg-[#10b98110] text-[#10b981] text-[10px] font-black uppercase tracking-widest border border-[#10b98120]\" data-kid=\"203\">System Recommended</span>\n                        </div>\n                        <h4 class=\"text-xl font-black text-white uppercase tracking-tighter mb-4\" data-kid=\"204\">AUTONOMOUS SETTLEMENT</h4>\n                        <p class=\"text-slate-500 text-xs font-medium leading-relaxed mb-8 uppercase tracking-wide\" data-kid=\"205\">Permit AI-driven automated payment for recurring fixed cycles under $100.00. End-to-end encryption verified.</p>\n                        <button class=\"w-full py-5 border border-white/20 text-white font-black text-xs tracking-widest uppercase hover:bg-white hover:text-black transition-colors\" data-kid=\"206\">AUTHORIZE MODULE</button>\n                    </div>\n\n                    <div class=\"p-10 bg-[#ffffff02] border border-[#ffffff10] hover:border-amber-500/40 transition-colors group\" data-kid=\"207\">\n                        <div class=\"flex items-center gap-6 mb-4\" data-kid=\"208\">\n                            <i class=\"fa-solid fa-bell-slash text-2xl text-amber-500\" data-kid=\"209\"></i>\n                            <div data-kid=\"210\">\n                                <h4 class=\"text-xl font-black text-white uppercase tracking-tighter\" data-kid=\"211\">ANOMALY THRESHOLD</h4>\n                                <p class=\"text-slate-500 text-[11px] font-bold uppercase tracking-widest\" data-kid=\"212\">Intercept transactions exceeding +15% avg</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n    </div>\n\n    \n    <div class=\"fixed bottom-8 right-8 z-50\" data-kid=\"213\">\n        <a href=\"#\" class=\"w-14 h-14 rounded-full bg-white/5 backdrop-blur-xl border border-white/20 flex items-center justify-center text-white hover:bg-white/10 transition-all shadow-2xl\" data-kid=\"214\">\n            <i class=\"fa-solid fa-chevron-up\" data-kid=\"215\"></i>\n        </a>\n    </div>\n</section>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"216\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"217\"></script>\n<script data-kid=\"218\">\n    gsap.registerPlugin(ScrollTrigger);\n\n    document.addEventListener('DOMContentLoaded', () => {\n        // Subtle Entrance\n        gsap.from('header', {\n            y: 40,\n            opacity: 0,\n            duration: 1.5,\n            ease: 'expo.out'\n        });\n\n        gsap.utils.toArray('.variant-section').forEach((section, index) => {\n            gsap.from(section, {\n                scrollTrigger: {\n                    trigger: section,\n                    start: 'top 90%',\n                },\n                y: 60,\n                opacity: 0,\n                duration: 1.2,\n                ease: 'power4.out'\n            });\n        });\n\n        // Refined Hover Logic (Removing CSS conflicts)\n        const hoverCards = document.querySelectorAll('.group');\n        hoverCards.forEach(card => {\n            card.addEventListener('mouseenter', () => {\n                gsap.to(card, {\n                    y: -4,\n                    borderColor: '#10b98150',\n                    backgroundColor: '#ffffff08',\n                    duration: 0.4,\n                    ease: 'power2.out'\n                });\n            });\n            card.addEventListener('mouseleave', () => {\n                gsap.to(card, {\n                    y: 0,\n                    borderColor: '#ffffff0a',\n                    backgroundColor: '#ffffff05',\n                    duration: 0.4,\n                    ease: 'power2.out'\n                });\n            });\n        });\n    });\n</script>\n\n\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css\" data-kid=\"219\">\n<style data-kid=\"220\">\n    @import url('https://fonts.googleapis.com/css2?family=Geist:wght@100..900&family=Sora:wght@100..800&display=swap');\n    \n    .font-sans { font-family: 'Geist', sans-serif; }\n    .font-display { font-family: 'Sora', sans-serif; }\n\n    ::-webkit-scrollbar { width: 4px; }\n    ::-webkit-scrollbar-track { background: #040608; }\n    ::-webkit-scrollbar-thumb { background: #1a1e23; }\n    ::-webkit-scrollbar-thumb:hover { background: #10b981; }\n\n    .variant-section { position: relative; }\n</style>\n",
